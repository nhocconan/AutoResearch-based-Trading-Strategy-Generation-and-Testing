# Primary setup: official Ollama Cloud
OLLAMA_API_KEY=ollama_...
OLLAMA_BASE_URL=https://ollama.com/api/chat
OLLAMA_MODEL=nemotron-3-super
OLLAMA_ANALYSIS_MODEL=glm-5

# Optional cloud fallbacks to try manually
# OLLAMA_MODEL=qwen3-coder-next
# OLLAMA_MODEL=gemma3:27b
# OLLAMA_CONVERT_MODEL=qwen3-coder-next

# Optional local Ollama override
# OLLAMA_BASE_URL=http://127.0.0.1:11434/api/chat
# OLLAMA_MODEL=gemma4:e2b

# Optional secondary providers
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4.1-mini
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=AI...
