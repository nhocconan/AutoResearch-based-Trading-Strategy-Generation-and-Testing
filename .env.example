# LLM API Keys (set at least one)
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AI...

# Custom endpoint for OpenAI-compatible APIs (e.g. Alibaba DashScope, vLLM, OpenRouter)
# OPENAI_BASE_URL=https://coding-intl.dashscope.aliyuncs.com/v1
# OPENAI_MODEL=qwen3-235b-a22b   # Override model name (any OpenAI-compatible model)

# Example: Alibaba DashScope (Qwen models)
# OPENAI_API_KEY=<your-dashscope-key>
# OPENAI_BASE_URL=https://coding-intl.dashscope.aliyuncs.com/v1
# OPENAI_MODEL=qwen3-235b-a22b

# Example: Anthropic-compatible proxy
# ANTHROPIC_BASE_URL=https://your-proxy.com
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
