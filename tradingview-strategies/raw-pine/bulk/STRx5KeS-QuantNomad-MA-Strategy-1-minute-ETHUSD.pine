//@version=3
strategy("Kozlod - MA Strategy - 1 minute - ETHUSD", overlay = true, default_qty_type = strategy.percent_of_equity, default_qty_value = 100)

// Inputs
length     = input(15)
price      = input(close)

// RSI
ma = sma(price, length)

plot(ma)

if (crossover(close, ma))
    strategy.entry("MaLong", strategy.long, comment="MaLong")
if (crossunder(close, ma))
    strategy.entry("MaShort", strategy.short, comment="MaLong")
