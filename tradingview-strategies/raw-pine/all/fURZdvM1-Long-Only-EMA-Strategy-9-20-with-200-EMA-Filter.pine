//@version=6
strategy('Long Only EMA Strategy (9/20 with 200 EMA Filter)', overlay = true, initial_capital = 100000, default_qty_type = strategy.percent_of_equity, default_qty_value = 10)

// EMA lengths
shortEmaLen = 9
longEmaLen = 20
trendEmaLen = 200

// Calculate EMAs
emaShort = ta.ema(close, shortEmaLen) // 9 EMA
emaLong = ta.ema(close, longEmaLen) // 20 EMA
emaTrend = ta.ema(close, trendEmaLen) // 200 EMA

// Plot EMAs
plot(emaShort, color = color.blue, title = '9 EMA')
plot(emaLong, color = color.orange, title = '20 EMA')
plot(emaTrend, color = color.purple, title = '200 EMA')

// Entry: 9 crosses above 20 AND close above 200 EMA
longCondition = ta.crossover(emaShort, emaLong) and close > emaTrend

// Exit: close crosses below 20 EMA
exitCondition = ta.crossunder(close, emaLong)

// Long only
if longCondition
    strategy.entry('Long', strategy.long)

if exitCondition and strategy.position_size > 0
    strategy.close('Long')

// Debug label to see trade count
var label tradesLabel = na
if barstate.islast
    label.delete(tradesLabel)
    tradesLabel := label.new(bar_index, high, 'Closed trades: ' + str.tostring(strategy.closedtrades))
    tradesLabel

