//@version=6
strategy(title="Momentum Scalp Pro: Best for Crypto Scalping", overlay=true, margin_long=100, margin_short=100)

// Inputs: Основные
atrPeriod = input.int(7, "ATR Period")  // Для скорости
src = input.source(hl2, "Source")
atrMult = input.float(2.0, "SuperTrend ATR Multiplier", step=0.1)
macdFast = input.int(12, "MACD Fast")
macdSlow = input.int(26, "MACD Slow")
macdSignal = input.int(9, "MACD Signal")
rsiPeriod = input.int(14, "RSI Period")
bbPeriod = input.int(20, "Bollinger Period")
bbDev = input.float(2.0, "Bollinger Deviation")
volPeriod = input.int(20, "Volume SMA Period")
volMult = input.float(1.5, "Volume Spike Multiplier")

// Inputs: TP/SL/Risk
useSL = input.bool(true, "Use Stop Loss")
slMult = input.float(1.0, "SL Multiplier (ATR)", step=0.1)  // Тесный для скальпа
useTP = input.bool(true, "Use Take Profits")
tp1Mult = input.float(1.0, "TP1 Multiplier (ATR)")
tp2Mult = input.float(2.0, "TP2 Multiplier (ATR)")
tp3Mult = input.float(3.0, "TP3 Multiplier (ATR)")
tp1Qty = input.float(33.0, "TP1 % Position")
tp2Qty = input.float(33.0, "TP2 % Position")
useBreakeven = input.bool(true, "Breakeven after TP1")
useTrailing = input.bool(true, "Trailing SL on BB Midline")
minAtrFilter = input.float(0.005, "Min ATR Filter (as % of price)")  // Для волатильности

// Calculations
atr = ta.rma(ta.tr, atrPeriod)

// SuperTrend
up = src - (atrMult * atr)
up1 = nz(up[1], up)
up := close[1] > up1 ? math.max(up, up1) : up
dn = src + (atrMult * atr)
dn1 = nz(dn[1], dn)
dn := close[1] < dn1 ? math.min(dn, dn1) : dn
var int trend = 1
trend := nz(trend[1], trend)
trend := (trend == -1 and close > dn1) ? 1 : (trend == 1 and close < up1) ? -1 : trend
buySignal = trend == 1 and trend[1] == -1
sellSignal = trend == -1 and trend[1] == 1

// MACD
[macdLine, signalLine, _] = ta.macd(close, macdFast, macdSlow, macdSignal)
macdCrossUp = ta.crossover(macdLine, signalLine)
macdCrossDown = ta.crossunder(macdLine, signalLine)

// RSI
rsi = ta.rsi(close, rsiPeriod)

// Bollinger Bands
bbBasis = ta.sma(close, bbPeriod)
bbUpper = bbBasis + bbDev * ta.stdev(close, bbPeriod)
bbLower = bbBasis - bbDev * ta.stdev(close, bbPeriod)
bbBreakUp = ta.crossover(close, bbUpper)
bbBreakDown = ta.crossunder(close, bbLower)

// Volume
volSma = ta.sma(volume, volPeriod)
volumeSpike = volume > volSma * volMult

// Volatility Filter
atrPct = atr / close
volFilter = atrPct > minAtrFilter

// Conditions
longCondition = buySignal and macdCrossUp and rsi > 50 and bbBreakUp and volumeSpike and volFilter
shortCondition = sellSignal and macdCrossDown and rsi < 50 and bbBreakDown and volumeSpike and volFilter

// Variables
var float entryPrice = na
var float currentAtr = na
var float tp1Level = na
var bool tp1TriggeredLong = false
var bool tp1TriggeredShort = false
var float prevPositionSize = 0.0

// Entries
if (longCondition)
    strategy.entry("Long", strategy.long)
    entryPrice := strategy.position_avg_price
    currentAtr := atr
    tp1Level := entryPrice + tp1Mult * currentAtr
    prevPositionSize := strategy.position_size
    tp1TriggeredLong := false
    if (useSL)
        slLevel = entryPrice - slMult * currentAtr
        strategy.exit("SL Long", "Long", stop=slLevel, trail_price=useTrailing ? bbBasis : na, trail_offset=useTrailing ? math.round((entryPrice - bbBasis) / syminfo.mintick) : na)
    if (useTP)
        strategy.exit("TP1 Long", "Long", qty_percent=tp1Qty, limit=entryPrice + tp1Mult * currentAtr)
        strategy.exit("TP2 Long", "Long", qty_percent=tp2Qty, limit=entryPrice + tp2Mult * currentAtr)
        strategy.exit("TP3 Long", "Long", limit=entryPrice + tp3Mult * currentAtr)

if (shortCondition)
    strategy.entry("Short", strategy.short)
    entryPrice := strategy.position_avg_price
    currentAtr := atr
    tp1Level := entryPrice - tp1Mult * currentAtr
    prevPositionSize := strategy.position_size
    tp1TriggeredShort := false
    if (useSL)
        slLevel = entryPrice + slMult * currentAtr
        strategy.exit("SL Short", "Short", stop=slLevel, trail_price=useTrailing ? bbBasis : na, trail_offset=useTrailing ? math.round((bbBasis - entryPrice) / syminfo.mintick) : na)
    if (useTP)
        strategy.exit("TP1 Short", "Short", qty_percent=tp1Qty, limit=entryPrice - tp1Mult * currentAtr)
        strategy.exit("TP2 Short", "Short", qty_percent=tp2Qty, limit=entryPrice - tp2Mult * currentAtr)
        strategy.exit("TP3 Short", "Short", limit=entryPrice - tp3Mult * currentAtr)

// Breakeven
if (useBreakeven and useTP and not na(entryPrice))
    currSize = strategy.position_size
    if (currSize != prevPositionSize and ((strategy.position_size > 0 and close >= tp1Level) or (strategy.position_size < 0 and close <= tp1Level)))
        if (strategy.position_size > 0)
            tp1TriggeredLong := true
        else
            tp1TriggeredShort := true
    if (tp1TriggeredLong and strategy.position_size > 0)
        strategy.exit("BE Long", "Long", stop=entryPrice)
        tp1TriggeredLong := false
    if (tp1TriggeredShort and strategy.position_size < 0)
        strategy.exit("BE Short", "Short", stop=entryPrice)
        tp1TriggeredShort := false
    prevPositionSize := currSize

// Reset
if (strategy.position_size == 0)
    entryPrice := na
    tp1Level := na
    tp1TriggeredLong := false
    tp1TriggeredShort := false
    prevPositionSize := 0.0

// Plots (для визуализации)
plot(trend == 1 ? up : na, "SuperTrend Up", color.green, 2)
plot(trend == -1 ? dn : na, "SuperTrend Dn", color.red, 2)
plot(bbBasis, "BB Mid", color.blue)
plot(bbUpper, "BB Upper", color.orange)
plot(bbLower, "BB Lower", color.orange)

