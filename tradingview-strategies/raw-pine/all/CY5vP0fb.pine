//@version=6
strategy("Mean-Reversion with Cooldown", overlay=true, initial_capital=10000, default_qty_type=strategy.percent_of_equity, default_qty_value=90, pyramiding=1)

// === PARAMETER ===
sl_percent = input.float(0.2, "Stop Loss (%)") / 100
tp_percent = input.float(2.5, "Take Profit (%)") / 100

enum cd_mode
    fib  = "FIBONACCI"
    pow = "POWER OF TWO"

cooldown_mode = input.enum(cd_mode.fib, "Cooldwon pause calculation")
max_cooldown = input.int(16, "Max Cooldown Candles")

// === VARIABLEN ===
var float tp_price = na
var float sl_price = na

var int loss_count = 0
var int cooldown_bars = 0    // How many bars do we wait until opening the next long position?
var int cooldown_timer = 0   // current Countdown

var bool had_position_prev_bar = false

f_fib(n) =>
    if n <= 1
        n
    else
        a = 0 
        b = 1
        for i = 2 to n
            c = a + b
            a := b
            b := c
        b

f_cooldown(n) =>
    switch cooldown_mode
        cd_mode.fib => f_fib(n)
        cd_mode.pow => math.round(math.pow(2, n))

// === STATUS ===
has_open_trade = strategy.position_size > 0

// === TRIGGER FOR NEW TRADES ===
new_trade_allowed = not has_open_trade and cooldown_timer <= 0

// === ENTRY ===
if new_trade_allowed
    sl_price := close * (1 - sl_percent)
    tp_price := close * (1 + tp_percent)

    strategy.entry("long", strategy.long, alert_message = "enter Long now! SL @ " + str.tostring(sl_price) + "; TP @ " + str.tostring(tp_price))

    // marker: how many bars do we have to wait for re-entering?
    cooldown_timer := na

// === EXIT-BEFEHL ===
if has_open_trade
    strategy.exit("exit", "long", stop=sl_price, limit=tp_price, alert_loss = "stop your loss now!", alert_profit = "take yout profit! (yay)")

// === Evaluation of closed trades ===
if not has_open_trade and had_position_prev_bar
    // There was an exit
    last_idx = strategy.closedtrades - 1
    pnl = strategy.closedtrades.profit(last_idx)

    if pnl < 0
        loss_count += 1
        cooldown_bars := f_cooldown(loss_count) % max_cooldown
    else
        loss_count := 0
        cooldown_bars := 0

    cooldown_timer := cooldown_bars   // Setze Countdown aktiv

// === DECREMENT COOLDOWN COUNTER ===
if not has_open_trade and cooldown_timer > 0
    cooldown_timer -= 1

// === POSITION-STATUS ===
had_position_prev_bar := has_open_trade

