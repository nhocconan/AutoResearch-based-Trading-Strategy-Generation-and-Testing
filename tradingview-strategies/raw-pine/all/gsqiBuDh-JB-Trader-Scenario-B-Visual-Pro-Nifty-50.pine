//@version=5
strategy("Scenario B: Visual Pro (No Premium) [Nifty 50]", overlay=true, process_orders_on_close=true, default_qty_type=strategy.fixed, default_qty_value=1)

// --- 1. SETTINGS ---
// A. Filters
useVwap = input.bool(true, "Use VWAP Filter?")
stFactor = input.float(3.0, "SuperTrend Factor")
stPeriod = input.int(10, "SuperTrend Period")

// B. Time (09:15 - 14:45)
useTimeFilter = input.bool(true, "Trade 09:15 - 14:45 Only?")

// --- 2. CALCULATIONS ---
t = time(timeframe.period, "0915-1445")
inSession = not useTimeFilter or not na(t)

vwapValue = ta.vwap(close)
[superTrend, direction] = ta.supertrend(stFactor, stPeriod)

// --- 3. MOOD LOGIC ---
// Bullish: Above VWAP + Green SuperTrend
isBullishMood = (direction < 0) and (close > vwapValue)

// Bearish: Below VWAP + Red SuperTrend
isBearishMood = (direction > 0) and (close < vwapValue)

// Choppy: Anything else (The "Gray Zone")
isChoppy = not isBullishMood and not isBearishMood

// --- 4. VISUAL UPGRADES (THE "TRAFFIC LIGHT") ---
// Logic: If Choppy, paint Gray. If Bullish, paint Lime. If Bearish, paint Red.
barcolor(isChoppy ? color.gray : (isBullishMood ? color.lime : color.red))

// Plot Buy/Sell Labels on the chart (Your "Visual Alert")
plotshape(isBullishMood and not isBullishMood[1], title="BUY START", style=shape.labelup, location=location.belowbar, color=color.lime, textcolor=color.black, text="BUY\nMOOD", size=size.small)
plotshape(isBearishMood and not isBearishMood[1], title="SELL START", style=shape.labeldown, location=location.abovebar, color=color.red, textcolor=color.white, text="SELL\nMOOD", size=size.small)

// --- 5. DASHBOARD ---
var table dash = table.new(position.top_right, 4, 1, bgcolor = color.black, frame_color = color.white, frame_width = 1, border_width = 1)

if barstate.islast
    // VWAP
    VwapText  = close > vwapValue ? "ABOVE VWAP" : "BELOW VWAP"
    table.cell(dash, 0, 0, VwapText, bgcolor=close > vwapValue ? color.lime : color.red, text_color=color.black, text_size=size.small)

    // SUPERTREND
    TrendText  = direction < 0 ? "TREND UP" : "TREND DOWN"
    table.cell(dash, 1, 0, TrendText, bgcolor=direction < 0 ? color.lime : color.red, text_color=color.black, text_size=size.small)

    // MOOD (The Decision)
    MoodText  = isBullishMood ? "TRADE LONG" : (isBearishMood ? "TRADE SHORT" : "NO TRADE")
    MoodColor = isBullishMood ? color.green : (isBearishMood ? color.red : color.gray)
    table.cell(dash, 2, 0, MoodText, bgcolor=MoodColor, text_color=color.white, text_size=size.small)

    // P&L
    pnlColor = strategy.netprofit >= 0 ? color.green : color.red
    table.cell(dash, 3, 0, "PTS: " + str.tostring(math.round(strategy.netprofit)), bgcolor=pnlColor, text_color=color.white, text_size=size.small)

// --- 6. EXECUTION ---
plot(vwapValue, "VWAP", color=color.purple, linewidth=2)
plot(direction < 0 ? superTrend : na, "ST Up", color = color.green, style=plot.style_linebr)
plot(direction < 0? na : superTrend, "ST Down", color = color.red, style=plot.style_linebr)

if (isBullishMood and inSession)
    strategy.entry("Long", strategy.long)

if (direction > 0)
    strategy.close("Long")

if (isBearishMood and inSession)
    strategy.entry("Short", strategy.short)

if (direction < 0)
    strategy.close("Short")
    
if not inSession
    strategy.close_all()

