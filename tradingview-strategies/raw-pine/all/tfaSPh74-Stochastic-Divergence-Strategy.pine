//     longBuySignal := true
//     shortSellSignal := true
// else if dChange > 0 and priceChange == 0
//     minorDlow := true
//     bgColor := color.new(color.teal, 80) // 80% transparent green
//     longBuySignal := true
//     shortSellSignal := true
// else if dChange > 0 and priceChange < 0
//     majorDlow := true
//     bgColor := color.new(color.green, 80) // 80% transparent green
//     longBuySignal := true
//     shortSellSignal := true
// else if dChange > 0 and priceChange > 0
//     bgColor := color.new(color.black, 100) // 80% transparent black
// else if dChange == 0 and priceChange == 0
//     bgColor := color.new(color.black, 100) // 80% transparent black
// else if dChange < 0 and priceChange < 0
//     bgColor := color.new(color.black, 100) // 80% transparent black


var doubleDip = false
doubleDip := false
var buyDipD = close
var buyDipP = close
var freezeBuyDip = false

if d>80
    freezeBuyDip := false


var buyDipCount = 0
if d[2] > d[1] and d > d[1] and freezeBuyDip == false
    buyDipD := d[1]
    buyDipP := close[1]
    buyDipCount := buyDipCount + 1
if buyDipP - buyDipP[1] < 0 and buyDipD - buyDipD[1] > 0 and freezeBuyDip == false
    if (buyDipCount - buyDipCount[1]) < 10
        bgColor := color.rgb(0, 255, 0)
        buyDipP := 0
        longBuySignal := true
        freezeBuyDip := true
        normalCandle := false
        doubleDip := true

    else 
        buyDipP:= 0 
        freezeBuyDip := true

var sellPeakD = close
var sellPeakP = close
var freezeSellPeak = false

if d < 20
    freezeSellPeak := false


var sellPeakCount = 0
if d[2] < d[1] and d < d[1] and freezeSellPeak == false
    sellPeakD := d[1]
    sellPeakP := close[1]
    sellPeakCount := sellPeakCount + 1
if sellPeakP - sellPeakP[1] > 0 and sellPeakD - sellPeakD[1] < 0 and freezeSellPeak == false
    if (sellPeakCount - sellPeakCount[1]) < 10
        bgColor := color.rgb(255, 0, 0)
        sellPeakP := 0    
        freezeSellPeak := true
        normalCandle := false
        doubleDip := true
    else 
        sellPeakP:= 0 
        freezeSellPeak := true


atr_value = ta.atr(periodK)
// stoploss = close[1]
// stoplossshort = close[1]
stoploss = close - (atr_value * 1.5)
stoplossshort = close + (atr_value * 1.5)
// strategy.entry("Buy", strategy.long, when=longCond, qty=qty)
// strategy.exit("Close Buy","Buy", limit=take, stop=stop)

// if longBuySignal
//     if dmid > 20 or d > 20 or dold > 20 or doldest > 35
//         longBuySignal := false
// if d[1] > 70 and d - d[1] < 0
//     longSellSignal := true
// if longSellSignal
//     if dmid < 80 or d < 80 //or dold  80 or doldest < 80
//         longSellSignal := false
var float previousClosedTradesCount = 0
currentClosedTradesCount = strategy.closedtrades

justClosedTrade = currentClosedTradesCount > previousClosedTradesCount[1] ?
                   currentClosedTradesCount - previousClosedTradesCount[1] > 0 : false

// IMPORTANT: Update previous count for the next bar
previousClosedTradesCount := currentClosedTradesCount


// Check if the *last* closed trade (which just happened) was a stop loss exit
// You need to ensure it's the specific stop loss ID you want to track
isStopLossExit = justClosedTrade and strategy.closedtrades.exit_id(math.floor(strategy.closedtrades - 1.0)) == "Long SL"
var bool cooldown = false
// if isStopLossExit
//     cooldown := true
// if doldest < 10
//     cooldown := true
// if cooldown
//     if dmid > 80 
//         cooldown := false

// if doldest > 75 and d < 25
//     longBuySignal := true


if longsOn
    if longBuySignal == true and cooldown == false
        strategy.entry("Long", strategy.long,limit = close ) // Enters a long position
        // strategy.exit("Long SL", from_entry="Long", profit = close + atr_value * 1, stop = close - atr_value * 1)


    // Long Exit (optional: can be based on a signal or risk management)
    if longSellSignal == true
        strategy.close("Long")

if shortsOn
    if shortBuySignal == true
        strategy.entry("Short", strategy.short,limit = close ) // Enters a long position

    // Long Exit (optional: can be based on a signal or risk management)
    if shortSellSignal == true
        strategy.close("Short")

// bgcolor(bgColor)
// barcolor(bgColor)
// plotcandle(open, high, low, close, title="My Candle", color=color.white, bordercolor=bgColor, wickcolor=bgColor)
// plotcandle(open, high, low, close, title = "My Candle",color = bgColor, bordercolor = bgColor)

plotbar(
   normalCandle == false ? open : na,
   high,
   low,
   close,
   color = bgColor,
   editable = false,
   display = display.pane,
   force_overlay = true)

plotcandle(
   normalCandle == false ? open : na,
   high,
   low,
   close,
   color = bgColor,
   bordercolor = doubleDip == true ? color.white :bgColor,
   wickcolor = bgColor,
   editable = false,
   display = display.pane,
   force_overlay = true)



