//     shortBuySignal := true
// else if dChange == 0 and priceChange > 0
//     minorDhigh := true
//     bgColor := color.new(color.maroon, 80) // 80% transparent red
//     longSellSignal := true
//     shortBuySignal := true
// else if dChange == 0 and priceChange < 0
