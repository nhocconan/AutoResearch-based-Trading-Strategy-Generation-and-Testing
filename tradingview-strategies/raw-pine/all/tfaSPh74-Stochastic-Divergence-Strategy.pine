//@version=6
strategy("Stochastic Divergence Strategy", overlay=true,behind_chart = false,max_labels_count=500)

periodK = input.int(12, title="Controlling %K Length", minval=1)
smoothK = input.int(1, title="Controlling %K Smoothing", minval=1)
periodD = input.int(1, title="Controlling %D Smoothing", minval=1)
k = ta.sma(ta.stoch(close, high, low, periodK), smoothK)
d = ta.sma(k, periodD)
//plot(k, title="%K", color=#2962FF)
plot(d, title="%D", color=#FF6D00)

periodKmid = input.int(16, title="%K Length", minval=1)
smoothKmid = input.int(1, title="%K Smoothing", minval=1)
periodDmid = input.int(3, title="%D Smoothing", minval=1)
kmid = ta.sma(ta.stoch(close, high, low, periodKmid), smoothKmid)
dmid = ta.sma(kmid, periodDmid)
//plot(k, title="%K", color=#2962FF)
plot(dmid, title="%Dmid", color=color.rgb(223, 252, 3, 6))

periodKold = input.int(40, title="%K Length", minval=1)
smoothKold = input.int(1, title="%K Smoothing", minval=1)
periodDold = input.int(4, title="%D Smoothing", minval=1)
kold = ta.sma(ta.stoch(close, high, low, periodKold), smoothKold)
dold = ta.sma(kold, periodDold)
//plot(k, title="%K", color=#2962FF)
plot(dold, title="%Dold", color=color.rgb(2, 253, 44))

periodKoldest = input.int(60, title="%K Length", minval=1)
smoothKoldest = input.int(1, title="%K Smoothing", minval=1)
periodDoldest = input.int(10, title="%D Smoothing", minval=1)
koldest = ta.sma(ta.stoch(close, high, low, periodKoldest), smoothKoldest)
doldest = ta.sma(koldest, periodDoldest)
//plot(k, title="%K", color=#2962FF)
plot(doldest, title="%Doldest", color=color.rgb(47, 146, 245))



shortsOn = input.bool(false,title="Turn Short buy and sell on")
longsOn = input.bool(false,title="Turn Long buy and sell on")


h0 = hline(80, "Upper Band", color=#787B86)
hline(50, "Middle Band", color=color.new(#787B86, 50))
h1 = hline(20, "Lower Band", color=#787B86)
fill(h0, h1, color=color.rgb(33, 150, 243, 90), title="Background")

longBuySignal = false
shortBuySignal = false
longSellSignal = false
shortSellSignal = false

minorDhigh = false
minorDlow = false
majorDhigh = false
majorDlow = false

var color bgColor = na
dChange = d - d[1]
if (dChange == 0 and d == 0) or (dChange == 0 and d == 100) 
    dChange := dmid - dmid[1]

priceChange = 25 * (close - close[1])
var div = 0.00
div := dChange - priceChange
var col=float(0)
var normalCandle = false
normalCandle := false
if div > 0 
    col := int(div *5) + 100

    // bgColor:=  color.rgb(0,col,0,0)
else if div < 0
    col := int(div *-5) + 100

    // bgColor:=  color.rgb(col,0,0,0)
if dChange < 0 and priceChange > 0 
    majorDhigh := true
    bgColor:=  color.rgb(col,0,0,0)
    longSellSignal := true
    shortBuySignal := true
else if dChange < 0 and priceChange == 0
    minorDhigh := true
    bgColor:=  color.rgb(col,0,0,0)
    longSellSignal := true
    shortBuySignal := true
else if dChange == 0 and priceChange > 0
    minorDhigh := true
    bgColor:=  color.rgb(col,0,0,0)
    longSellSignal := true
    shortBuySignal := true
else if dChange == 0 and priceChange < 0
    minorDlow := true
    bgColor:=  color.rgb(0,col,0,0)
    longBuySignal := true
    shortSellSignal := true
else if dChange > 0 and priceChange == 0
    minorDlow := true
    bgColor:=  color.rgb(0,col,0,0)
    longBuySignal := true
    shortSellSignal := true
else if dChange > 0 and priceChange < 0
    majorDlow := true
    bgColor:=  color.rgb(0,col,0,0)
    longBuySignal := true
    shortSellSignal := true
else if dChange > 0 and priceChange > 0
    bgColor := color.new(color.black, 100) // 80% transparent black
    normalCandle := true
else if dChange == 0 and priceChange == 0
    bgColor := color.new(color.black, 100) // 80% transparent black
    normalCandle := true
else if dChange < 0 and priceChange < 0
    bgColor := color.new(color.black, 100) // 80% transparent black
    normalCandle := true


// label.new(bar_index, high, str.tostring(col), color=color.rgb(0,350,0,0))


// if dChange < 0 and priceChange > 0 
//     majorDhigh := true
//     bgColor := color.new(color.red, 80) // 80% transparent red
//     longSellSignal := true
//     shortBuySignal := true
// else if dChange < 0 and priceChange == 0
