//@version=5
strategy("DRACO TOMAS EMA Trend Follower", overlay=true, 
     default_qty_type=strategy.percent_of_equity, 
     default_qty_value=10)

// === INPUTS ===
emaS_len = input.int(12, "EMA Fast Length", minval=1)
emaB_len = input.int(21, "EMA Slow Length", minval=1)

// === CALCULATE EMAs & COLOR ===
emaS = ta.ema(close, emaS_len)
emaB = ta.ema(close, emaB_len)
emaUp = emaS >= emaB
emaDn = emaS <  emaB

plot(emaS, title="EMA Fast", color=emaUp ? color.green : color.red, linewidth=2)
plot(emaB, title="EMA Slow", color=emaUp ? color.green : color.red, linewidth=2)

// === ENTRY SIGNALS ===
// When the fast EMA crosses above the slow → go long
if ta.crossover(emaS, emaB)
    strategy.entry("Long", strategy.long)

// When the fast EMA crosses below the slow → go short
if ta.crossunder(emaS, emaB)
    strategy.entry("Short", strategy.short)

// === EXIT LOGIC ===
// Exit longs as soon as EMA turns red (fast EMA < slow EMA)
if strategy.position_size > 0 and emaDn
    strategy.close("Long")

// Exit shorts as soon as EMA turns green (fast EMA >= slow EMA)
if strategy.position_size < 0 and emaUp
    strategy.close("Short")

