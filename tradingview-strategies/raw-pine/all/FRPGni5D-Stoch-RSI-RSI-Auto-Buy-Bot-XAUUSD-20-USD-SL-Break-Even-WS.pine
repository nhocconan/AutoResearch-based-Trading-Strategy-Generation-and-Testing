//@version=6
strategy(
    "Stoch RSI + RSI Auto Buy Bot (XAUUSD 20 USD SL + Break-Even)",
    overlay = true,
    initial_capital = 10000,
    pyramiding = 0
)

// === INPUTS ===
rsiLength        = input.int(14, "RSI Length")
stochLength      = input.int(14, "Stoch RSI Length")
kLength          = input.int(3,  "K Smoothing")
dLength          = input.int(3,  "D Smoothing")
maxLossUSD       = input.float(20, "Stop Loss ($)", minval = 1)
breakEvenTrigger = input.float(10, "Break-Even Trigger Profit ($)", minval = 1)

// === INDICATORS ===
// RSI
rsiValue = ta.rsi(close, rsiLength)

// Correct Stochastic RSI
rsiLow  = ta.lowest(rsiValue, stochLength)
rsiHigh = ta.highest(rsiValue, stochLength)
stochRsi = (rsiHigh - rsiLow == 0) ? 0 : (rsiValue - rsiLow) / (rsiHigh - rsiLow) * 100

k = ta.sma(stochRsi, kLength)
d = ta.sma(k, dLength)

// === CONDITIONS ===
buyCondition  = (k < 5) and (rsiValue < 25) and (strategy.position_size == 0)
sellCondition = (k > 95) and (strategy.position_size > 0)

// === VARIABLES WITH TYPES ===
var float stopLossPrice = na
var float breakEvenPrice = na
var bool moveToBreakEven = false

// === STOP LOSS LOGIC ===
if strategy.position_size > 0
    stopLossPrice := strategy.position_avg_price - maxLossUSD

// === BREAK-EVEN LOGIC ===
if strategy.position_size > 0
    breakEvenPrice  := strategy.position_avg_price
    moveToBreakEven := close >= strategy.position_avg_price + breakEvenTrigger

// === ENTRY ===
if buyCondition
    strategy.entry("BUY", strategy.long)

// === SELL EXIT ===
if sellCondition
    strategy.close("BUY")

// === STOP LOSS + BREAK-EVEN EXIT ===
if strategy.position_size > 0
    strategy.exit(
        "EXIT",
        from_entry = "BUY",
        stop = moveToBreakEven ? breakEvenPrice : stopLossPrice
    )

// === PLOTS ===
plot(k, title = "Stoch RSI K", color = color.blue)
plot(d, title = "Stoch RSI D", color = color.orange)
plot(rsiValue, title = "RSI", color = color.purple)

hline(5,  "Stoch RSI Buy Level",  color = color.green)
hline(95, "Stoch RSI Sell Level", color = color.red)
hline(25, "RSI Buy Level",        color = color.gray)

