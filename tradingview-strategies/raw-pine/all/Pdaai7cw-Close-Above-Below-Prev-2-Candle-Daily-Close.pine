//@version=5
strategy("Close Above/Below Prev 2 Candle (Daily Close)", overlay=true, pyramiding=0)

// === Inputs ===
rr = input.float(2.0, "Risk/Reward Ratio", step=0.1)

// === Previous candle highs/lows on daily timeframe ===
prevHigh1 = request.security(syminfo.tickerid, "D", high[1])
prevHigh2 = request.security(syminfo.tickerid, "D", high[2])
prevLow1  = request.security(syminfo.tickerid, "D", low[1])
prevLow2  = request.security(syminfo.tickerid, "D", low[2])

// === Current daily close ===
dailyClose = request.security(syminfo.tickerid, "D", close)

// === Conditions based on daily candle close ===
closeAbovePrev2 = dailyClose > prevHigh1 and dailyClose > prevHigh2
closeBelowPrev2 = dailyClose < prevLow1 and dailyClose < prevLow2

// === Plot signals on intraday chart ===
plotshape(closeAbovePrev2, title="Daily Close Above Prev 2 Highs", location=location.abovebar, style=shape.triangleup, color=color.green, size=size.tiny)
plotshape(closeBelowPrev2, title="Daily Close Below Prev 2 Lows", location=location.belowbar, style=shape.triangledown, color=color.red, size=size.tiny)

// === Strategy entries (optional) ===
if closeAbovePrev2
    stopLoss   = dailyClose - (prevHigh1 - prevHigh2) // example
    takeProfit = dailyClose + (dailyClose - stopLoss) * rr
    strategy.entry("Long", strategy.long)
    strategy.exit("Exit Long", "Long", stop=stopLoss, limit=takeProfit)

if closeBelowPrev2
    stopLoss   = dailyClose + (prevLow1 - prevLow2) // example
    takeProfit = dailyClose - (stopLoss - dailyClose) * rr
    strategy.entry("Short", strategy.short)
    strategy.exit("Exit Short", "Short", stop=stopLoss, limit=takeProfit)

// === Alerts ===
alertcondition(closeAbovePrev2, title="Daily Close Above Prev 2 Highs", message="Daily candle closed above the previous two daily highs")
alertcondition(closeBelowPrev2, title="Daily Close Below Prev 2 Lows", message="Daily candle closed below the previous two daily lows")

