//@version=6
strategy(title="Commodity Channel Index CCI + EMA strategy", shorttitle="CCI + EMA", overlay=false)

length = input.int(20, minval=1, title="CCI Length", group="CCI Settings")
src = input(hlc3, title="CCI Source", group="CCI Settings")

maCCI = ta.sma(src, length)
cci = (src - maCCI) / (0.015 * ta.dev(src, length))

cciLowerLevel = input.int(-100, title="CCI Lower Level", group="CCI Settings")
cciUpperLevel = input.int(100, title="CCI Upper Level", group="CCI Settings")
cciMiddleLevel = input.int(0, title="CCI Middle Level", group="CCI Settings")

GRP = "Smoothing MA"
maTypeInput = input.string("SMA", "Type", options = ["None", "SMA", "EMA", "SMMA (RMA)", "WMA", "VWMA"], group = GRP)
maLengthInput = input.int(14, "Length", minval=7, maxval=28, step=7, group = GRP)
var enableMA = maTypeInput != "None"

ma(source, length, MAtype) =>
    switch MAtype
        "SMA"     => ta.sma(source, length)
        "EMA"     => ta.ema(source, length)
        "SMMA (RMA)"=> ta.rma(source, length)
        "WMA"     => ta.wma(source, length)
        "VWMA"    => ta.vwma(source, length)

smoothingMA = enableMA ? ma(cci, maLengthInput, maTypeInput) : na

emaLength1 = input.int(50, title="EMA 1 Length", group="EMA Filter")
emaLength2 = input.int(200, title="EMA 2 Length", group="EMA Filter")
useEmaFilter = input.bool(true, title="Use EMA Filter", group="EMA Filter", tooltip="If active, open LONG only if EMA50 > EMA200, SHORT only if EMA50 < EMA200")

ema1 = ta.ema(cci, emaLength1)
ema2 = ta.ema(cci, emaLength2)

isCrossover = ta.crossover(cci, smoothingMA)
isCrossunder = ta.crossunder(cci, smoothingMA)

emaFilterLong = not useEmaFilter or ema1 > ema2
emaFilterShort = not useEmaFilter or ema1 < ema2

longCrossover = enableMA and isCrossover and cci >= cciLowerLevel and cci <= cciMiddleLevel and emaFilterLong
shortCrossover = enableMA and isCrossunder and cci >= cciMiddleLevel and cci <= cciUpperLevel and emaFilterShort

if longCrossover
    if strategy.position_size < 0
        strategy.close_all()
    else if strategy.position_size == 0
        strategy.entry("Long", strategy.long)

if shortCrossover
    if strategy.position_size > 0
        strategy.close_all()
    else if strategy.position_size == 0
        strategy.entry("Short", strategy.short)

tpPercent = input.float(1.0, title="Take Profit (%)", minval=0.01, group="Risk Management") / 100
slPercent = input.float(0.5, title="Stop Loss (%)", minval=0.01, group="Risk Management") / 100

var float longTP = na
var float longSL = na
var float shortTP = na
var float shortSL = na

if strategy.position_size > 0 and na(longTP)
    longTP := strategy.position_avg_price * (1 + tpPercent)
    longSL := strategy.position_avg_price * (1 - slPercent)
    strategy.exit("TP/SL Long", "Long", limit=longTP, stop=longSL)

if strategy.position_size == 0 and not na(longTP)
    longTP := na
    longSL := na

if strategy.position_size < 0 and na(shortTP)
    shortTP := strategy.position_avg_price * (1 - tpPercent)
    shortSL := strategy.position_avg_price * (1 + slPercent)
    strategy.exit("TP/SL Short", "Short", limit=shortTP, stop=shortSL)

if strategy.position_size == 0 and not na(shortSL)
    shortTP := na
    shortSL := na

plot(cci, "CCI", color=#2962FF, linewidth=2)
plot(smoothingMA, "CCI-based MA", color=color.yellow, linewidth=1)

hline(cciUpperLevel, "Upper CCI Level", color=color.red, linestyle=hline.style_dashed)
hline(cciLowerLevel, "Lower CCI Level", color=color.green, linestyle=hline.style_dashed)
hline(cciMiddleLevel, "Middle CCI Level", color=color.yellow, linestyle=hline.style_dashed)

plot(longCrossover ? cci : na, title="Long Signal", color=color.green, style=plot.style_cross, linewidth=3)
plot(shortCrossover ? cci : na, title="Short Signal", color=color.red, style=plot.style_cross, linewidth=3)

