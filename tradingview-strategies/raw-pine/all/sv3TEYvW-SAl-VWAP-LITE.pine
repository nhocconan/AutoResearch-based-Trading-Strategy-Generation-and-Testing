//@version=6
strategy(
    "SA Final VWAP — LITE (L/S, SMA3/8 Gate + Prior Wick Flip + RSI)",
    overlay=true,
    max_labels_count=50,
    process_orders_on_close=true
)

//==================== Inputs ====================
htfTF = input.timeframe("60", "HTF")
midTF = input.timeframe("15", "MID")
use80 = input.bool(true, "Strict Mode (HTF = MID)")

tpUsd = input.float(55, "TP ($)")
slUsd = input.float(40, "SL ($)")

// Wick definition
wickMinTicks = input.int(1, "Min Prior Wick (ticks)", minval=0)

// RSI
rsiLen  = input.int(14, "RSI Length")
rsiBull = input.float(55, "RSI Bull >")
rsiBear = input.float(45, "RSI Bear <")

//==================== Helpers ====================
mint    = syminfo.mintick
tickVal = syminfo.pointvalue * syminfo.mintick
usdToTicks(x) => math.max(1, int(math.round(x / tickVal)))

// Prior wick sizes (in ticks)
upWick(i)   => (high[i] - math.max(open[i], close[i])) / mint
downWick(i) => (math.min(open[i], close[i]) - low[i]) / mint

// Wick meaning
priorBullWick = downWick(1) >= wickMinTicks   // bullish rejection
priorBearWick = upWick(1)   >= wickMinTicks   // bearish rejection

tpT = usdToTicks(tpUsd)
slT = usdToTicks(slUsd)

//==================== HTF / MID Direction ====================
f_dir() =>
    _h = (high + low + close) / 3.0
    close > ta.vwap(_h) ? 1 : -1

dirHTF = request.security(syminfo.tickerid, htfTF, f_dir(), barmerge.gaps_off, barmerge.lookahead_off)
dirMID = request.security(syminfo.tickerid, midTF, f_dir(), barmerge.gaps_off, barmerge.lookahead_off)

allowLong  = use80 ? (dirHTF == 1  and dirMID == 1)  : (dirHTF == 1)
allowShort = use80 ? (dirHTF == -1 and dirMID == -1) : (dirHTF == -1)

//==================== EXECUTION GATE (UPDATED SMA) ====================
sma3 = ta.sma(close, 3)
sma8 = ta.sma(close, 8)

bullGate = (sma3 > sma8) and (close > sma8)
bearGate = (sma3 < sma8) and (close < sma8)

//==================== VWAP Context ====================
vwap  = ta.vwap((high + low + close) / 3.0)
above = close > vwap
below = close < vwap

//==================== RSI FILTER ====================
rsiVal = ta.rsi(close, rsiLen)
rsiLongOK  = rsiVal > rsiBull
rsiShortOK = rsiVal < rsiBear

//==================== FINAL SIGNALS ====================
// Bull: SMA3>8 + above VWAP + prior BEAR wick + RSI>55
// Bear: SMA3<8 + below VWAP + prior BULL wick + RSI<45
longSig  = allowLong  and bullGate and above and priorBearWick and rsiLongOK
shortSig = allowShort and bearGate and below and priorBullWick and rsiShortOK

//==================== Visuals ====================
barcolor(longSig ? color.green : shortSig ? color.red : color.gray)

//==================== Entries ====================
if longSig
    strategy.entry("L", strategy.long)

if shortSig
    strategy.entry("S", strategy.short)

//==================== Exits ====================
strategy.exit("Lx", from_entry="L", profit=tpT, loss=slT)
strategy.exit("Sx", from_entry="S", profit=tpT, loss=slT)

