strategy("4H MACD Strategy", overlay=false, initial_capital=5000, currency="AUD")

// === INPUT BACKTEST RANGE ===
FromMonth = input(defval = 9, title = "From Month", minval = 1, maxval = 12)
FromDay   = input(defval = 1, title = "From Day", minval = 1, maxval = 31)
FromYear  = input(defval = 2019, title = "From Year", minval = 2017)
ToMonth   = input(defval = 1, title = "To Month", minval = 1, maxval = 12)
ToDay     = input(defval = 1, title = "To Day", minval = 1, maxval = 31)
ToYear    = input(defval = 2021, title = "To Year", minval = 2018)

// === FUNCTION EXAMPLE ===
start     = timestamp(FromYear, FromMonth, FromDay, 00, 00)  // backtest start window
finish    = timestamp(ToYear, ToMonth, ToDay, 23, 59)        // backtest finish window
window()  => time >= start and time <= finish ? true : false // create function "within window of time"
fastMA = input(title="Fast moving average", type=input.integer, defval=12, minval=7)
slowMA = input(title="Slow moving average", type=input.integer, defval=26, minval=7)
[currMacd, _, _] = macd(close[0], fastMA, slowMA, 9)
[prevMacd, _, _] = macd(close[1], fastMA, slowMA, 9)
plotColor = currMacd > 0 ? currMacd > prevMacd ? color.lime : color.green : 
   currMacd < prevMacd ? color.maroon : color.red
plot(currMacd, style=plot.style_histogram, color=plotColor, linewidth=3)
plot(0, title="Zero line", linewidth=1, color=color.gray)

strategy.entry("Buy", strategy.long, 1000, comment="Buy", when=window() and currMacd > 0 and prevMacd < 0)
strategy.entry("Sell", strategy.short, 1000, comment="Sell", when=window() and  currMacd < 0 and prevMacd > 0)
strategy.exit("Buy E", "long", profit=200, loss=100, trail_points=100, trail_offset=100)
strategy.exit("Sell E", "short", profit=200, loss=100, trail_points=100, trail_offset=100)

