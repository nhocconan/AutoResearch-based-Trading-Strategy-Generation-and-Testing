//@version=6
strategy("Quantum Flux Universal Strategy v1.0", shorttitle="Quantum Flux Universal", overlay=false, max_labels_count=200)

// =============== GROUPS
group_input  = "Inputs"
group_adapt  = "Adaptive Engine"
group_norm   = "Normalization"
group_gate   = "Dynamic Gate"
group_vol    = "Volume Weighting"
group_ui     = "UI"

// =============== INPUTS
// Core
srcx           = input.source(ohlc4, "Price source", group=group_input,
     tooltip="Which price to feed into the Quantum Flux engine. ohlc4 is stable and reduces single print noise.")
fast_span     = input.int(12, "Fast span",  minval=2, group=group_input,
     tooltip="Nominal length for the fast one pole filter. Smaller is more reactive. Adaptive engine will rescale this.")
slow_span     = input.int(28, "Slow span",  minval=3, group=group_input,
     tooltip="Nominal length for the slow one pole filter. Sets baseline trend horizon and is also adaptively rescaled.")

// Adaptive Engine
guide_span    = input.int(6,  "Guide span", minval=2, group=group_adapt,
     tooltip="Smoothing span for the guide line applied on the normalized core with a small phase assist.")
blend_power   = input.float(0.60, "Adapt strength 0..1", minval=0.0, maxval=1.0, step=0.05, group=group_adapt,
     tooltip="How strongly drivers modulate base gains. 0 means fixed spans. 1 means full influence of intensity, efficiency, and volatility.")
vol_win       = input.int(40,  "Vol window", minval=10, group=group_adapt,
     tooltip="Lookback used for directional intensity and volatility scaling. Larger is smoother, smaller is faster.")
eff_win       = input.int(20,  "Efficiency window", minval=5, group=group_adapt,
     tooltip="Lookback for Kaufman style path efficiency. High efficiency favors trend, low efficiency favors chop.")
eff_gamma     = input.float(1.20, "Efficiency gamma", minval=0.1, maxval=3.0, step=0.05, group=group_adapt,
     tooltip="Shapes the efficiency curve. Above 1 increases contrast in clean trends. Below 1 flattens the response.")
min_gain      = input.float(0.50, "Min alpha multiplier", minval=0.10, maxval=1.00, step=0.05, group=group_adapt,
     tooltip="Lower clamp for adaptive gain. 0.50 halves the base gain which lengthens smoothing.")
max_gain      = input.float(2.00, "Max alpha multiplier", minval=1.00, maxval=4.00, step=0.05, group=group_adapt,
     tooltip="Upper clamp for adaptive gain. 2.00 doubles the base gain which shortens smoothing.")
phase_profile = input.string("Robust", "Phase profile", options=["Reactive","Balanced","Robust"], group=group_adapt,
     tooltip="Sets the lead factor used in phase assist. Reactive is lowest lag with more overshoot. Robust is calmer with more lag.")
reactive = input.float(0.90, step=0.01, group=group_adapt, tooltip="Lead factor used if Reactive is selected.")
robust   = input.float(0.50, step=0.01, group=group_adapt, tooltip="Lead factor used if Robust is selected.")

// Normalization
dist_win      = input.int(200, "Distribution window", minval=50, group=group_norm,
     tooltip="Window for distribution estimates used to normalize the core. Larger windows reduce drift in the baseline.")
dist_mode     = input.string("zscore", "Mode", options=["zscore","percentrank","madz"], group=group_norm,
     tooltip="Normalization method. zscore uses mean and stdev. percentrank maps to [-1, 1]. madz uses robust median absolute deviation.")
clamp_abs     = input.float(3.0, "Clip normalized at ±", minval=1.0, maxval=10.0, step=0.1, group=group_norm,
     tooltip="Hard limits for the normalized core to prevent extreme spikes from dominating signals.")

// Colors
col_pos       = color.new(color.teal, 0)
col_neg       = color.new(color.red,  0)
col_guide     = color.new(color.gray, 0)
col_core      = color.new(color.white, 0)

// =============== CORE CALC
src = srcx

// UTIL
binary_intensity(dir, length) =>
    p  = ta.rma(dir ? 1.0 : 0.0, length)
    hp = -(p > 0 ? p * math.log(p) : 0) - ((1 - p) > 0 ? (1 - p) * math.log(1 - p) : 0)
    h  = hp / math.log(2.0)
    1.0 - h

z_norm(x, length) =>
    m = ta.sma(x, length)
    s = ta.stdev(x, length)
    s == 0 ? 0 : (x - m) / s

m_norm(x, length) =>
    m   = ta.sma(x, length)
    dev = math.abs(x - m)
    mad = ta.sma(dev, length)
    mad == 0 ? 0 : 0.6745 * (x - m) / mad

pr_norm(x, length) => ta.percentrank(x, length) / 100.0

path_eff(x, length) =>
    net   = math.abs(x - x[length])
    denom = math.sum(math.abs(ta.change(x)), length)
    denom == 0 ? 0 : math.min(1.0, net / denom)

base_gain(len) => 2.0 / (len + 1.0)

// =============== ADAPTIVE ENGINE
dir_up     = src > src[1]
dir_int    = binary_intensity(dir_up, vol_win)

step       = ta.change(src)
vol_kz     = z_norm(math.abs(step), vol_win)
vol_squash = math.max(0.0, math.min(1.0, 0.5 + 0.5 * math.atan(vol_kz)))

eff_raw    = path_eff(src, eff_win)
eff_shaped = math.pow(eff_raw, eff_gamma)

gain_map(a0) =>
    w_int = 0.50
    w_eff = 0.30
    w_vol = 0.20
    drive = w_int * dir_int + w_eff * eff_shaped + w_vol * vol_squash
    boost = blend_power * drive
    a_min = a0 * min_gain
    a_max = a0 * max_gain
    a_min + (a_max - a_min) * boost

g_fast = gain_map(base_gain(fast_span))
g_slow = gain_map(base_gain(slow_span))
feed   = src

// Filters
var float int_a = na
var float int_b = na
int_a := na(int_a[1]) ? feed : int_a[1] + g_fast * (feed - int_a[1])
int_b := na(int_b[1]) ? feed : int_b[1] + g_slow * (feed - int_b[1])

// Differential with phase assist
diff_raw  = int_a - int_b
lag_bars  = int(math.round(slow_span * 0.5))
lead_gain = phase_profile == "Reactive" ? reactive : phase_profile == "Robust" ? robust : 0.5
flux_zl   = nz(diff_raw) * (1 + lead_gain) - lead_gain * nz(diff_raw[lag_bars])

// Normalization and clamp
flux_n_unclipped = switch dist_mode
    "zscore"      => z_norm(flux_zl, dist_win)
    "percentrank" => pr_norm(flux_zl, dist_win) * 2.0 - 1.0
    => m_norm(flux_zl, dist_win)
flux_n = math.max(-clamp_abs, math.min(clamp_abs, flux_n_unclipped))

// Guide line
guide_lag  = math.max(1, int(math.floor((guide_span - 1) * 0.5)))
guide_line = ta.ema(flux_n + (flux_n - nz(flux_n[guide_lag])), guide_span)

// Optional impulse
impulse = flux_n - guide_line

// Regime
polarity = (flux_n > 0 and guide_line > 0) ? 1 : (flux_n < 0 and guide_line < 0 ? -1 : 0)
bg_col   = polarity > 0 ? color.new(col_pos, 90) : polarity < 0 ? color.new(col_neg, 90) : color.new(color.gray, 95)
bgcolor(bg_col)

// =============== PLOTS
plot(polarity, "Quantum Flux Polarity", color=col_core, linewidth=2)
hline(0, title="Zen", color=color.blue, linestyle=hline.style_dotted, linewidth=4)

// =============== ORDERS
if polarity > 0
    strategy.entry("long", strategy.long)

if polarity < 0 and nz(polarity[1]) > 0
    strategy.close("long")
    strategy.entry("short", strategy.short)

if ta.crossover(flux_n, guide_line)
    strategy.close("short")

