//@version=5
// Strategy: 5-Min Scalping (EMA + VWAP)
// Enhancements: 
// 1. Optional confirmation filters for Price Action (Engulfing) and Volume Spikes.
// 2. Toggles to enable Longs-Only or Shorts-Only trading modes.
// 3. Automatic plotting of Take Profit and Stop Loss lines for each individual trade.
// 4. Optional ATR-based Trailing Stop to replace fixed Take Profit.
// 5. Visual plotting of the active Trailing Stop Loss line. (Corrected)

strategy("Ultimate Scalping Strategy v2.3 (Corrected TSL Plot)",
         shorttitle="Ult. EMA+VWAP v2.3",
         overlay=true,
         initial_capital=10000,
         default_qty_type=strategy.percent_of_equity,
         default_qty_value=10) 

// === Input Parameters ===
group_main = "Main Indicator Settings"
fastEMA_len = input.int(9, title="Fast EMA Length", group=group_main)
slowEMA_len = input.int(21, title="Slow EMA Length", group=group_main)

group_direction = "Trade Direction Settings"
allowLongs = input.bool(true, title="✅ Allow Longs (Buys)?", group=group_direction)
allowShorts = input.bool(true, "✅ Allow Shorts (Sells)?", group=group_direction)

group_filters = "Confirmation Filters (Optional)"
usePriceAction = input.bool(false, title="Use Price Action (Engulfing)?", group=group_filters)
useVolume = input.bool(false, title="Use Volume Confirmation?", group=group_filters)
vol_ma_len = input.int(20, title="Volume MA Length", group=group_filters)

group_exits = "Exit Logic Settings"
atr_len = input.int(14, title="ATR Length for SL/TP", group=group_exits)
sl_atr_multiplier = input.float(1.5, title="Stop Loss ATR Multiplier", step=0.1, group=group_exits)
tp_atr_multiplier = input.float(2.0, title="Take Profit ATR Multiplier", step=0.1, group=group_exits)
useExitOnOppositeSignal = input.bool(true, title="Exit on Opposite Signal?", group=group_exits)

// --- Trailing Stop Inputs ---
useTrailingStop = input.bool(false, title="✅ Use Trailing Stop Loss?", tooltip="If checked, this will replace the fixed Take Profit. The Stop Loss will still be active from the start.", group=group_exits)
ts_activation_multiplier = input.float(1.0, title="Trailing Activation ATR Multiplier", step=0.1, tooltip="Price must move this many ATRs in your favor before the trail begins.", group=group_exits)
ts_atr_multiplier = input.float(2.0, title="Trailing Stop ATR Multiplier", step=0.1, tooltip="The distance the stop will trail behind the price.", group=group_exits)


// === Indicator & Confirmation Calculations ===
emaFast = ta.ema(close, fastEMA_len)
emaSlow = ta.ema(close, slowEMA_len)
vwapLine = ta.vwap
atr = ta.atr(atr_len)
isBullishCandle = close > open
isBearishCandle = close < open
bullishEngulfing = isBullishCandle and isBearishCandle[1] and close > open[1] and open < close[1]
bearishEngulfing = isBearishCandle and isBullishCandle[1] and close < open[1] and open > close[1]
volumeMA = ta.sma(volume, vol_ma_len)
isVolumeSpike = volume > volumeMA

// === Entry Conditions ===
baseLongCond = ta.crossover(emaFast, emaSlow) and close > vwapLine
baseShortCond = ta.crossunder(emaFast, emaSlow) and close < vwapLine
longCond = baseLongCond and (not usePriceAction or bullishEngulfing) and (not useVolume or isVolumeSpike)
shortCond = baseShortCond and (not usePriceAction or bearishEngulfing) and (not useVolume or isVolumeSpike)

// === Plotting on Chart ===
plot(emaFast, color=color.blue, title="Fast EMA")
plot(emaSlow, color=color.orange, title="Slow EMA")
plot(vwapLine, color=color.white, title="VWAP")
plotshape(longCond and allowLongs, title="Buy Signal Arrow", location=location.belowbar, color=color.new(color.green, 0), style=shape.triangleup, size=size.small)
plotshape(shortCond and allowShorts, title="Sell Signal Arrow", location=location.abovebar, color=color.new(color.red, 0), style=shape.triangledown, size=size.small)

// === Strategy Execution Logic ===
if (longCond and allowLongs)
    strategy.entry("Long", strategy.long)

if (shortCond and allowShorts)
    strategy.entry("Short", strategy.short)

// --- Exit Logic ---
if (strategy.position_size > 0)
    initialStopPrice = strategy.position_avg_price - atr * sl_atr_multiplier
    if (useTrailingStop)
        trailActivationPrice = strategy.position_avg_price + atr * ts_activation_multiplier
        trailDistance = atr * ts_atr_multiplier
        strategy.exit("Long Trail Exit", from_entry="Long", stop=initialStopPrice, trail_price=trailActivationPrice, trail_offset=trailDistance)
    else
        takeProfitPrice = strategy.position_avg_price + atr * tp_atr_multiplier
        strategy.exit("Long Exit", from_entry="Long", stop=initialStopPrice, limit=takeProfitPrice)
    
    if (shortCond and useExitOnOppositeSignal)
        strategy.close("Long", comment="Exit on Short Signal")

if (strategy.position_size < 0)
    initialStopPrice = strategy.position_avg_price + atr * sl_atr_multiplier
    if (useTrailingStop)
        trailActivationPrice = strategy.position_avg_price - atr * ts_activation_multiplier
        trailDistance = atr * ts_atr_multiplier
        strategy.exit("Short Trail Exit", from_entry="Short", stop=initialStopPrice, trail_price=trailActivationPrice, trail_offset=trailDistance)
    else
        takeProfitPrice = strategy.position_avg_price - atr * tp_atr_multiplier
        strategy.exit("Short Exit", from_entry="Short", stop=initialStopPrice, limit=takeProfitPrice)
    
    if (longCond and useExitOnOppositeSignal)
        strategy.close("Short", comment="Exit on Long Signal")


// === CORRECTED: Advanced Exit Plotting Logic ===

// Declare persistent variables to hold plot levels and captured trade data
var float plot_sl_level = na
var float plot_tp_level = na
var float trade_high = na
var float trade_low = na
var float trade_entry_price = na
var float trade_entry_atr = na

// Detect trade state changes
bool isNewTrade = strategy.position_size != 0 and strategy.position_size[1] == 0
bool isTradeClosed = strategy.position_size == 0 and strategy.position_size[1] != 0

// If a new trade starts, set initial plot levels and CAPTURE data
if (isNewTrade)
    trade_entry_price := strategy.position_avg_price
    trade_entry_atr := atr
    if (strategy.position_size > 0) // New Long
        plot_sl_level := trade_entry_price - trade_entry_atr * sl_atr_multiplier
        plot_tp_level := trade_entry_price + trade_entry_atr * tp_atr_multiplier
        trade_high := high
    else // New Short
        plot_sl_level := trade_entry_price + trade_entry_atr * sl_atr_multiplier
        plot_tp_level := trade_entry_price - trade_entry_atr * tp_atr_multiplier
        trade_low := low

// If a trade is ongoing, update the trail plot using CAPTURED data
if (strategy.position_size != 0 and useTrailingStop)
    if (strategy.position_size > 0) // Ongoing Long
        trade_high := math.max(trade_high, high)
        trailActivationPrice = trade_entry_price + trade_entry_atr * ts_activation_multiplier
        if (trade_high >= trailActivationPrice)
            trailDistance = trade_entry_atr * ts_atr_multiplier
            potentialNewStop = trade_high - trailDistance
            plot_sl_level := math.max(plot_sl_level, potentialNewStop)
    else // Ongoing Short
        trade_low := math.min(trade_low, low)
        trailActivationPrice = trade_entry_price - trade_entry_atr * ts_activation_multiplier
        if (trade_low <= trailActivationPrice)
            trailDistance = trade_entry_atr * ts_atr_multiplier
            potentialNewStop = trade_low + trailDistance
            plot_sl_level := math.min(plot_sl_level, potentialNewStop)

// If a trade closes, reset all plots and captured data to 'na'
if (isTradeClosed)
    plot_sl_level := na
    plot_tp_level := na
    trade_high := na
    trade_low := na
    trade_entry_price := na
    trade_entry_atr := na

// --- Final Plots ---
plot(useTrailingStop ? na : plot_tp_level, title="Take Profit", color=color.new(color.green, 0), style=plot.style_linebr, linewidth=2)
plot(plot_sl_level, title="Stop Loss / Trailing Stop", color=useTrailingStop ? color.new(color.purple, 0) : color.new(color.red, 0), style=plot.style_linebr, linewidth=2)


// === Alerts ===
alertcondition(longCond and allowLongs, title="Long Entry Alert", message="Strategy Long: {{ticker}} at {{close}}")
alertcondition(shortCond and allowShorts, title="Short Entry Alert", message="Strategy Short: {{ticker}} at {{close}}")

