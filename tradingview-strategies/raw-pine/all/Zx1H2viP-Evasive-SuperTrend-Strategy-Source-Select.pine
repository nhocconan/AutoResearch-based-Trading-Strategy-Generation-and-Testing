//@version=6
strategy("Evasive SuperTrend Strategy [Source Select]", overlay = true, 
     initial_capital = 10000, 
     default_qty_type = strategy.cash, 
     default_qty_value = 1000, 
     commission_type = strategy.commission.percent, 
     commission_value = 0.05)

// --- INPUTS ---
string ST_GROUP      = 'Supertrend Settings'
int lengthInput      = input.int(10, 'ATR Length', minval = 1, group = ST_GROUP)
float multiplierInput = input.float(3.0, 'Base Multiplier', minval = 0.1, step = 0.1, group = ST_GROUP)
series float srcInput = input.source(hl2, 'Source', group = ST_GROUP) // Тот самый выбор источника

string NOISE_GROUP   = 'Noise Avoidance Logic'
float thresholdInput = input.float(1.0, 'Noise Threshold (xATR)', minval = 0.0, step = 0.1, group = NOISE_GROUP)
float alphaInput     = input.float(0.5, 'Expansion Alpha (xATR)', minval = 0.0, step = 0.1, group = NOISE_GROUP)

// --- CORE CALCULATIONS ---
float atr = ta.atr(lengthInput)
var float st_line = na
var int trend = 1 

float upperBase = srcInput + multiplierInput * atr
float lowerBase = srcInput - multiplierInput * atr

float prevLine = nz(st_line[1], trend == 1 ? lowerBase : upperBase)
bool isNoisy = math.abs(close - prevLine) < (atr * thresholdInput)

if trend == 1
    st_line := isNoisy ? prevLine - (atr * alphaInput) : math.max(lowerBase, prevLine)
    if close < st_line
        trend := -1
        st_line := upperBase
else
    st_line := isNoisy ? prevLine + (atr * alphaInput) : math.min(upperBase, prevLine)
    if close > st_line
        trend := 1
        st_line := lowerBase

// --- VISUALS ---
color trendColor = trend == 1 ? color.teal : color.maroon
plot(isNoisy ? na : st_line, "Solid Band", color = trendColor, linewidth = 2, style = plot.style_linebr)
plot(isNoisy ? st_line : na, "Dotted Band", color = trendColor, linewidth = 2, style = plot.style_linebr, linestyle = plot.linestyle_dotted)

// --- STRATEGY ---
if (ta.change(trend) > 0)
    strategy.entry("Long", strategy.long)
if (ta.change(trend) < 0)
    strategy.entry("Short", strategy.short)

