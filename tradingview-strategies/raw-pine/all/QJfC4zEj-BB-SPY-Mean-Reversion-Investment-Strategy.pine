//@version=6
strategy("BB SPY Mean Reversion Investment Strategy", overlay=true, margin_long = 0 , margin_short =0)

maxIdLossPcnt = input.float(1, "Max intraday loss (%)")
strategy.risk.max_intraday_loss(maxIdLossPcnt, strategy.percent_of_equity)
// =========================
// config
// =========================
src_close         = close
bb_len_input      = input.int(14, "BB Length", minval=1)
bb_mult_input     = input.float(1.1, "BB Mult", minval=0.001, maxval=50)
dir_selector      = input.int(1, "Strategy Direction", minval=-1, maxval=1)
ema_len_long_inp  = input.int(20, "EMA Length long")
ema_len_short_inp = input.int(10, "EMA Length short")
adx_min_inp       = input.int(25, "ADX Minimum for short")

// Adaptive bands (optional)
use_adaptive_mult = input.bool(false, "Use Adaptive Multiplier")
vov_len           = input.int(20, "VOV Length", minval=5)
vov_gain          = input.float(0.6, "VOV Gain", step=0.05)
vov_scale_min     = input.float(0.5, "VOV Scale Min")
vov_scale_max     = input.float(2.0, "VOV Scale Max")
use_eff_for_sigs  = input.bool(false, "Use Adaptive Bands For Signals")

// Regime (optional, does not control bias flips)
regime_type       = input.string("none", "Regime Type", options=["none","trend","mean_reversion"])
rank_len          = input.int(200, "Regime Rank Lookback", minval=50)
trend_rank_min    = input.float(60, "Trend Min Width Percentile", minval=0, maxval=100)
slope_len         = input.int(10, "Basis Slope Length", minval=1)
slope_thr         = input.float(0.10, "Norm Slope Threshold", step=0.01)
apply_filters_to  = input.string("both", "Apply Filters To", options=["both","longs","shorts"])

// Risk management segmentation
use_atr_exit      = input.bool(true, "Use ATR Exit")
atr_len           = input.int(14, "ATR Length", minval=1)
atr_stop_mult     = input.float(1.5, "ATR Stop Mult", step=0.1)
atr_tp_mult       = input.float(3.0, "ATR Take Profit Mult", step=0.1)
be_trigger_r      = input.float(1.0, "Breakeven Trigger R")

use_time_exit         = input.bool(false, "Use Time Exit")
bars_min_hold         = input.int(30, "Min Bars In Trade", minval=1)
extend_bars_if_profit = input.int(15, "Extend Bars If Profit")
time_profit_gate_r    = input.float(0.25, "Profit Gate ATR R")

// Bias memory and re-arm
bias_history_len      = input.int(16, "Bias flips kept", minval=1)
keep_rearm_when_flat  = input.bool(true, "Keep pending order while flat")

// Direction permission identical to base
strategy.risk.allow_entry_in(
     dir_selector == 0 ? strategy.direction.all
   : dir_selector  < 0 ? strategy.direction.short
   :                    strategy.direction.long)

// =========================
// calc
// =========================
bb_basis = ta.sma(src_close, bb_len_input)
bb_dev   = bb_mult_input * ta.stdev(src_close, bb_len_input)
bb_upper = bb_basis + bb_dev
bb_lower = bb_basis - bb_dev
[_, _, adx_series] = ta.dmi(14, 14)

// Adaptive bands
vov        = ta.stdev(ta.roc(src_close, 1), vov_len)
vov_ma     = ta.sma(vov, vov_len)
vov_ratio  = nz(vov_ma) == 0 ? 1.0 : vov / vov_ma
vov_scale  = math.min(math.max(1 + vov_gain * (vov_ratio - 1), vov_scale_min), vov_scale_max)
bb_mult_eff  = use_adaptive_mult ? bb_mult_input * vov_scale : bb_mult_input
bb_dev_eff   = bb_mult_eff * ta.stdev(src_close, bb_len_input)
bb_upper_eff = bb_basis + bb_dev_eff
bb_lower_eff = bb_basis - bb_dev_eff

band_upper_for_sig = use_adaptive_mult and use_eff_for_sigs ? bb_upper_eff : bb_upper
band_lower_for_sig = use_adaptive_mult and use_eff_for_sigs ? bb_lower_eff : bb_lower

// Regime gates
bb_width   = bb_upper - bb_lower
width_rank = ta.percentrank(bb_width, rank_len)
norm_slope = (bb_basis - bb_basis[slope_len]) / math.max(bb_width, syminfo.mintick)
trend_gate = width_rank > trend_rank_min and math.abs(norm_slope) > slope_thr
mr_gate    = width_rank < (100 - trend_rank_min)
regime_ok  = regime_type == "none" or (regime_type == "trend" and trend_gate) or (regime_type == "mean_reversion" and mr_gate)

apply_long  = apply_filters_to == "both" or apply_filters_to == "longs"
apply_short = apply_filters_to == "both" or apply_filters_to == "shorts"

// Base signals (used for entries and for bias flips)
long_cond_base  = ta.crossover(src_close, band_lower_for_sig) and close > open and close > ta.ema(close, ema_len_long_inp)
short_cond_base = ta.crossunder(src_close, band_upper_for_sig) and close < open and close < ta.ema(close, ema_len_short_inp) and adx_series > adx_min_inp

filters_ok = regime_ok
long_cond  = long_cond_base  and (apply_long  ? filters_ok : true)
short_cond = short_cond_base and (apply_short ? filters_ok : true)

// =========================
// bias memory using array
// =========================
DIR_NONE  = 0
DIR_LONG  = 1
DIR_SHORT = -1
var dir_hist = array.new_int()

f_bias_get() =>
    sz = array.size(dir_hist)
    sz > 0 ? array.get(dir_hist, sz - 1) : DIR_NONE

f_bias_push(d) =>
    if array.size(dir_hist) == 0 or array.get(dir_hist, array.size(dir_hist) - 1) != d
        array.push(dir_hist, d)
        if array.size(dir_hist) > bias_history_len
            array.shift(dir_hist)

bias_now = f_bias_get()

// init or flip only on opposite base signal
if bias_now == DIR_NONE
    if long_cond_base
        f_bias_push(DIR_LONG)
    else if short_cond_base
        f_bias_push(DIR_SHORT)
else
    if bias_now == DIR_LONG and short_cond_base
        f_bias_push(DIR_SHORT)
    else if bias_now == DIR_SHORT and long_cond_base
        f_bias_push(DIR_LONG)

bias_now := f_bias_get()

// =========================
// risk segmentation exits
// =========================
atr_val = request.security(syminfo.tickerid, "M", ta.atr(atr_len))

in_long_prev  = strategy.position_size[1] > 0
in_short_prev = strategy.position_size[1] < 0
in_long_now   = strategy.position_size > 0
in_short_now  = strategy.position_size < 0

long_stop_raw  = strategy.position_avg_price - atr_stop_mult * atr_val
short_stop_raw = strategy.position_avg_price + atr_stop_mult * atr_val
long_be_on     = in_long_now  and (close - strategy.position_avg_price) >= be_trigger_r * atr_stop_mult * atr_val
short_be_on    = in_short_now and (strategy.position_avg_price - close) >= be_trigger_r * atr_stop_mult * atr_val
long_stop      = long_be_on  ? math.max(long_stop_raw,  strategy.position_avg_price) : long_stop_raw
short_stop     = short_be_on ? math.min(short_stop_raw, strategy.position_avg_price) : short_stop_raw
long_tp        = strategy.position_avg_price + atr_tp_mult * atr_val
short_tp       = strategy.position_avg_price - atr_tp_mult * atr_val

if use_atr_exit
    strategy.exit("long_exit",  from_entry="long",  stop=long_stop,  limit=long_tp)
    strategy.exit("short_exit", from_entry="short", stop=short_stop, limit=short_tp)

// Time exit with profit extension
var int long_entry_bar  = na
var int short_entry_bar = na
new_long_pos  =  in_long_now  and not in_long_prev
new_short_pos =  in_short_now and not in_short_prev
if new_long_pos
    long_entry_bar := bar_index
if not in_long_now and in_long_prev
    long_entry_bar := na
if new_short_pos
    short_entry_bar := bar_index
if not in_short_now and in_short_prev
    short_entry_bar := na

bars_in_long  = in_long_now  ? bar_index - nz(long_entry_bar, bar_index)  : 0
bars_in_short = in_short_now ? bar_index - nz(short_entry_bar, bar_index) : 0

long_profit_ok  = in_long_now  and (close - strategy.position_avg_price) >= time_profit_gate_r * atr_stop_mult * atr_val
short_profit_ok = in_short_now and (strategy.position_avg_price - close) >= time_profit_gate_r * atr_stop_mult * atr_val

if use_time_exit and in_long_now
    cond_time_close_l = (bars_in_long >= bars_min_hold and not long_profit_ok) or (bars_in_long >= bars_min_hold + extend_bars_if_profit)
    if cond_time_close_l
        strategy.close("long", comment="time")

if use_time_exit and in_short_now
    cond_time_close_s = (bars_in_short >= bars_min_hold and not short_profit_ok) or (bars_in_short >= bars_min_hold + extend_bars_if_profit)
    if cond_time_close_s
        strategy.close("short", comment="time")

// Refresh state after exits
in_long_now  := strategy.position_size > 0
in_short_now := strategy.position_size < 0
just_exited_long  = not in_long_now  and in_long_prev
just_exited_short = not in_short_now and in_short_prev

// =========================
// entry + re-arm engine
// =========================
want_long_rearm  = (bias_now == DIR_LONG)  and not in_long_now  and (keep_rearm_when_flat or just_exited_long)
want_short_rearm = (bias_now == DIR_SHORT) and not in_short_now and (keep_rearm_when_flat or just_exited_short)

long_entry_plan  = long_cond  or want_long_rearm
short_entry_plan = short_cond or want_short_rearm

if long_entry_plan
    // Keep the original "close before entry" behavior
    strategy.close("long")
    strategy.entry("long", strategy.long, stop=band_lower_for_sig, oca_name="BollingerBands", oca_type=strategy.oca.cancel, comment="long")
else
    // Cancel only if we are not supposed to keep a rearm order
    if not want_long_rearm
        strategy.cancel(id="long")

if short_entry_plan
    strategy.entry("short", strategy.short, stop=band_upper_for_sig, oca_name="BollingerBands", oca_type=strategy.oca.cancel, comment="short")
else
    if not want_short_rearm
        strategy.cancel(id="short")

// =========================
// visuals
// =========================
plot(bb_basis, "BB Basis", color=color.silver)
plot(bb_upper, "BB Upper", color=color.new(color.teal, 40))
plot(bb_lower, "BB Lower", color=color.new(color.teal, 40))
plot(use_adaptive_mult ? bb_upper_eff : na, "BB Upper Adaptive", color=color.teal)
plot(use_adaptive_mult ? bb_lower_eff : na, "BB Lower Adaptive", color=color.teal)

View in Pine Editor・223 lines
Use on chart
