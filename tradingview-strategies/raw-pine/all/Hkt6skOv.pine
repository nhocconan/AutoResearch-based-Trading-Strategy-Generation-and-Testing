//@version=5
// 백휘선물장기홀딩스크립트 (Fix v2)
// ✅ ATH(HIGH) 기준 -50%, -72.5% 구간에서 각각 1회씩만 진입 (새 ATH 갱신 시 리셋)
// ✅ 실시간에서 low<=trigger “계속 true”로 재진입하는 문제 방지: 최저점(lowestLowSinceATH) ‘관통(cross)’ 이벤트로 1회만
// ✅ Last Fill Price = 최근 “추가로 체결된 구간의 평균 체결가(역산 추정)”
// ✅ Liq Price(Approx) = (평단 - 담보/수량) / (1 - MMR)  (거래소 1:1은 아님, 근사)
//    - 담보 기준은 선택 가능: Wallet(실현) or Equity(미실현 포함)

strategy("백휘선물장기홀딩스크립트 (Fix v2)",
     overlay=true,
     initial_capital=10000,
     default_qty_type=strategy.fixed,
     pyramiding=200,
     calc_on_every_tick=true,
     calc_on_order_fills=true,
     process_orders_on_close=false,
     commission_type=strategy.commission.percent,
     commission_value=0.05,
     max_labels_count=500)

//──────────────────────────────────────
// Inputs
//──────────────────────────────────────
leverageInput = input.int(1, "Leverage (Sizing Multiplier)", minval=1)

drawdownBuy1  = input.float(50.0, "Buy %-from-ATH (first)",  minval=0.1, maxval=99.9)
drawdownBuy2  = input.float(72.5, "Buy %-from-ATH (second)", minval=0.1, maxval=99.9)

buy1Pct       = input.float(10.0,  "Buy % on first drop (when NOT first position)",  minval=0.1, maxval=400.0)
buy2Pct       = input.float(300.0, "Buy % on second drop (when NOT first position)", minval=0.1, maxval=400.0)

// 첫 포지션(맨 처음 진입)일 때의 베이스/하이 퍼센트 (기존 100/300을 입력으로 분리)
firstEntryHighDD   = input.float(72.5, "First Entry High DD %", minval=0.0, maxval=99.9,
     tooltip="첫 포지션 진입 시, ATH 대비 하락률이 이 값 이상이면 High%로 진입")
firstEntryBasePct  = input.float(100.0, "First Entry Base %", minval=0.1, maxval=400.0)
firstEntryHighPct  = input.float(300.0, "First Entry High %", minval=0.1, maxval=400.0)

// 추가매수 금액 산정 기준
sizingBaseOpt = input.string("Position Value", "Sizing Base",
     options=["Position Value", "Equity"],
     tooltip="추가매수 금액 산정 기준.\n- Position Value: 현재 포지션 가치(수량*현재가) 기준\n- Equity: strategy.equity 기준(미실현 포함)\n※ 첫 진입은 항상 Equity 기준으로 계산됩니다.")

// 청산가 근사용 유지증거금률
mmrInput = input.float(0.005, "Maintenance Margin Rate (MMR)", minval=0.0, maxval=0.2, step=0.0001)

// 청산가 계산에서 담보로 무엇을 볼지
liqMarginBaseOpt = input.string("Wallet (Realized)", "Liq Margin Base",
     options=["Wallet (Realized)", "Equity (Including PnL)"],
     tooltip="청산가 근사 계산에서 담보로 보는 값.\n- Wallet(Realized): 초기자본+실현손익(보수적)\n- Equity(Including PnL): 미실현손익 포함(크로스 느낌)")

// (선택) 청산가 터치 시 전략에서 강제청산 시뮬레이션
simulateLiquidation = input.bool(false, "Simulate Liquidation? (close if low <= liq)", tooltip="ON이면 low가 Liq Price(Approx) 이하로 내려가면 strategy.close_all로 강제청산 시뮬레이션")

// 라벨
labelPosOpt = input.string("Below Bar", "Entry Label Position",
     options=["Below Bar", "Above Bar", "At Price"])
entryLabelYloc = labelPosOpt == "Below Bar" ? yloc.belowbar :
     labelPosOpt == "Above Bar" ? yloc.abovebar : yloc.price
showEntryLabels = input.bool(true, "Show Entry Labels? (Buy/Lev)")

// Kill switch
forceCloseAll = input.bool(false, "Force Close All Positions (Kill Switch)",
     tooltip="ON이면 마지막 바에서 포지션 청산 + 미체결 주문 취소 후 신규 진입 차단")

// Date filter
useDateFilter = input.bool(false, "Limit Strategy to Date Range?")
startTime     = input.time(timestamp("01 Jan 2020 00:00 +0000"), "Start Date/Time")
endTime       = input.time(timestamp("01 Jan 2030 00:00 +0000"), "End Date/Time")
inTradeWindow = not useDateFilter or (time >= startTime and time <= endTime)

killActiveThisBar = forceCloseAll and barstate.islast

//──────────────────────────────────────
// Account values
//──────────────────────────────────────
float equityNow = strategy.equity
float walletNow = strategy.initial_capital + strategy.netprofit
walletNow := math.max(walletNow, 0.0)

float marginForLiq = liqMarginBaseOpt == "Equity (Including PnL)" ? equityNow : walletNow
marginForLiq := math.max(marginForLiq, 0.0)

//──────────────────────────────────────
// ✅ Real-time safe states (varip)
//──────────────────────────────────────
varip bool buy1Done = false
varip bool buy2Done = false
varip int  lastBuy1Bar = na
varip int  lastBuy2Bar = na

// same-bar 계산용
varip float posSizeBeforeBar  = na
varip float newLongQtyThisBar = 0.0

if barstate.isnew
    posSizeBeforeBar  := math.abs(strategy.position_size)
    newLongQtyThisBar := 0.0

//──────────────────────────────────────
// Track ATH + Lowest Low since ATH
//──────────────────────────────────────
varip float ath       = na
varip float prevAth   = na
varip int   athBarIdx = na

prevAth := ath
ath     := na(ath) ? high : math.max(ath, high)

bool newATH = not na(prevAth) and ath > prevAth
if newATH
    athBarIdx := bar_index

bool isAthBarRealtime = barstate.isrealtime and not na(athBarIdx) and athBarIdx == bar_index
float lowSample = isAthBarRealtime ? close : low

varip float lowestLowSinceATH = na
float prevLowest = lowestLowSinceATH

if newATH
    // ✅ 새 ATH 나오면 사이클 리셋
    buy1Done    := false
    buy2Done    := false
    lastBuy1Bar := na
    lastBuy2Bar := na

    // ✅ 이전 사이클 미체결 주문이 남아있을 수 있으니 취소
    strategy.cancel("Buy_1")
    strategy.cancel("Buy_2")

    // 최저점 리셋
    lowestLowSinceATH := lowSample
else
    if na(lowestLowSinceATH)
        lowestLowSinceATH := lowSample
    else
        lowestLowSinceATH := math.min(lowestLowSinceATH, lowSample)

// Drawdown
float percentFromATHNow = (close / ath - 1.0) * 100.0

// Trigger prices
float triggerPrice1 = ath * (1.0 - drawdownBuy1 / 100.0)
float triggerPrice2 = ath * (1.0 - drawdownBuy2 / 100.0)

// ✅ “최저점이 트리거를 처음 관통하는 순간”만 true
bool crossed1 = not na(lowestLowSinceATH) and lowestLowSinceATH <= triggerPrice1 and (na(prevLowest) or prevLowest > triggerPrice1)
bool crossed2 = not na(lowestLowSinceATH) and lowestLowSinceATH <= triggerPrice2 and (na(prevLowest) or prevLowest > triggerPrice2)

bool firstBuyCond  = (not buy1Done) and crossed1 and (na(lastBuy1Bar) or lastBuy1Bar != bar_index)
bool secondBuyCond = (not buy2Done) and crossed2 and (na(lastBuy2Bar) or lastBuy2Bar != bar_index)

//──────────────────────────────────────
// Position sizing
//──────────────────────────────────────
float posQtyNow    = strategy.position_size
float posQtyAbsNow = math.abs(posQtyNow)
float posValueNow  = posQtyAbsNow * close

// ✅ 추가매수 베이스
float sizingBase = equityNow
if posQtyAbsNow > 0 and sizingBaseOpt == "Position Value"
    sizingBase := posValueNow
else if sizingBaseOpt == "Equity"
    sizingBase := equityNow
else
    sizingBase := equityNow

// 첫 진입은 항상 Equity 기준
if posQtyAbsNow == 0
    sizingBase := equityNow

float orderValue1 = sizingBase * (buy1Pct / 100.0) * leverageInput
float orderValue2 = sizingBase * (buy2Pct / 100.0) * leverageInput

float effectiveBuy1Qty = triggerPrice1 > 0 ? orderValue1 / triggerPrice1 : 0.0
float effectiveBuy2Qty = triggerPrice2 > 0 ? orderValue2 / triggerPrice2 : 0.0

//──────────────────────────────────────
// Equity MDD (참고용)
//──────────────────────────────────────
varip float equityPeak = na
varip float maxDDPerc  = 0.0

equityPeak := na(equityPeak) ? equityNow : math.max(equityPeak, equityNow)
float ddNowEquity = equityPeak != 0.0 ? (equityNow / equityPeak - 1.0) * 100.0 : 0.0
maxDDPerc := math.min(maxDDPerc, ddNowEquity)

//──────────────────────────────────────
// Kill / Date filter : 미체결 주문 취소
//──────────────────────────────────────
if killActiveThisBar
    strategy.cancel("Buy_1")
    strategy.cancel("Buy_2")
    if strategy.position_size != 0
        strategy.close_all(comment="Force Close All (Kill Switch)")

if not inTradeWindow
    strategy.cancel("Buy_1")
    strategy.cancel("Buy_2")

//──────────────────────────────────────
// Entries
//──────────────────────────────────────
if not killActiveThisBar and inTradeWindow and equityNow > 0
    // 1차(-50%)
    if firstBuyCond
        bool  isFirstPosEntry = (posSizeBeforeBar == 0) and (newLongQtyThisBar == 0)
        float usedQty = 0.0
        float usedPct = na

        if isFirstPosEntry
            float ddForRule = (lowSample / ath - 1.0) * 100.0
            float firstPct  = ddForRule <= -firstEntryHighDD ? firstEntryHighPct : firstEntryBasePct
            float firstVal  = equityNow * (firstPct / 100.0) * leverageInput
            usedQty := triggerPrice1 > 0 ? firstVal / triggerPrice1 : 0.0
            usedPct := firstPct
        else
            usedQty := effectiveBuy1Qty
            usedPct := buy1Pct

        if usedQty > 0
            buy1Done    := true
            lastBuy1Bar := bar_index

            newLongQtyThisBar += usedQty

            float posValAfter = (posSizeBeforeBar + newLongQtyThisBar) * triggerPrice1
            float levAfter    = marginForLiq != 0 ? posValAfter / marginForLiq : na
            float levText     = not na(levAfter) ? math.round(levAfter * 100.0) / 100.0 : na

            if showEntryLabels
                if not na(levText)
                    label.new(bar_index, low, "Lev " + str.tostring(levText) + "x",
                         yloc=entryLabelYloc, style=label.style_label_down, size=size.large,
                         color=color.new(color.gray, 0), textcolor=color.white)

                label.new(bar_index, low,
                     "Buy " + str.tostring(usedPct, format.mintick) + "% @ " + str.tostring(triggerPrice1, format.mintick),
                     yloc=entryLabelYloc, style=label.style_label_up, size=size.large,
                     color=color.new(color.lime, 10), textcolor=color.black)

            strategy.entry("Buy_1", strategy.long, qty=usedQty, limit=triggerPrice1,
                 comment="ATH -" + str.tostring(drawdownBuy1) + "%")

    // 2차(-72.5%)
    if secondBuyCond
        bool  isFirstPosEntry = (posSizeBeforeBar == 0) and (newLongQtyThisBar == 0)
        float usedQty = 0.0
        float usedPct = na

        if isFirstPosEntry
            float ddForRule = (lowSample / ath - 1.0) * 100.0
            float firstPct  = ddForRule <= -firstEntryHighDD ? firstEntryHighPct : firstEntryBasePct
            float firstVal  = equityNow * (firstPct / 100.0) * leverageInput
            usedQty := triggerPrice2 > 0 ? firstVal / triggerPrice2 : 0.0
            usedPct := firstPct
        else
            usedQty := effectiveBuy2Qty
            usedPct := buy2Pct

        if usedQty > 0
            buy2Done    := true
            lastBuy2Bar := bar_index

            newLongQtyThisBar += usedQty

            float posValAfter = (posSizeBeforeBar + newLongQtyThisBar) * triggerPrice2
            float levAfter    = marginForLiq != 0 ? posValAfter / marginForLiq : na
            float levText     = not na(levAfter) ? math.round(levAfter * 100.0) / 100.0 : na

            if showEntryLabels
                if not na(levText)
                    label.new(bar_index, low, "Lev " + str.tostring(levText) + "x",
                         yloc=entryLabelYloc, style=label.style_label_down, size=size.large,
                         color=color.new(color.gray, 0), textcolor=color.white)

                label.new(bar_index, low,
                     "Buy " + str.tostring(usedPct, format.mintick) + "% @ " + str.tostring(triggerPrice2, format.mintick),
                     yloc=entryLabelYloc, style=label.style_label_up, size=size.large,
                     color=color.new(color.teal, 10), textcolor=color.black)

            strategy.entry("Buy_2", strategy.long, qty=usedQty, limit=triggerPrice2,
                 comment="ATH -" + str.tostring(drawdownBuy2) + "%")

//──────────────────────────────────────
// Avg Entry plot
//──────────────────────────────────────
float avgEntryPrice = na
avgEntryPrice := strategy.position_size != 0 ? strategy.position_avg_price : na
plot(avgEntryPrice, title="Avg Entry Price (평단가)", color=color.yellow, linewidth=2)

//──────────────────────────────────────
// ✅ Liquidation Price (Approx, Dynamic)
// 롱 근사: (AvgEntry - margin/qty) / (1 - MMR)
//──────────────────────────────────────
float liqPriceReal = na
if posQtyNow > 0 and posQtyAbsNow > 0 and not na(avgEntryPrice)
    float denom = 1.0 - mmrInput
    float base  = avgEntryPrice - (marginForLiq / posQtyAbsNow)
    liqPriceReal := denom != 0 ? (base / denom) : na
    liqPriceReal := liqPriceReal < 0 ? 0 : liqPriceReal
else
    liqPriceReal := na

plot(liqPriceReal, title="Liq Price (Approx)", color=color.red, linewidth=2, style=plot.style_linebr)

// (선택) 청산 시뮬레이션
if simulateLiquidation and not killActiveThisBar and inTradeWindow
    if posQtyNow > 0 and not na(liqPriceReal) and low <= liqPriceReal
        strategy.cancel("Buy_1")
        strategy.cancel("Buy_2")
        strategy.close_all(comment="Simulated Liquidation")

//──────────────────────────────────────
// ✅ Last Fill Price(최근 체결가) 계산 (역산)
// fill = (avgNew*qNew - avgPrev*qPrev) / (qNew-qPrev)
//──────────────────────────────────────
varip float prevPosSize  = 0.0
varip float prevAvgPrice = na
varip float lastFillPrice = na
varip float lastFillQty   = na
varip float lastEntryLev  = na  // 최근 체결 직후 레버리지(담보 기준)

bool posChangedFill = posQtyNow != prevPosSize

if posChangedFill
    // 추가매수(증가)만 업데이트
    if posQtyNow > prevPosSize and posQtyNow > 0 and not na(avgEntryPrice)
        float qPrev = math.abs(prevPosSize)
        float qNew  = math.abs(posQtyNow)
        float qAdd  = qNew - qPrev

        float fill = na
        if qAdd > 0
            if qPrev == 0 or na(prevAvgPrice)
                fill := avgEntryPrice
            else
                fill := (avgEntryPrice * qNew - prevAvgPrice * qPrev) / qAdd

        lastFillPrice := fill
        lastFillQty   := qAdd

        float posValAtAvg = qNew * avgEntryPrice
        lastEntryLev := marginForLiq != 0 ? (posValAtAvg / marginForLiq) : na

    // 포지션 종료면 초기화
    if posQtyNow <= 0
        lastFillPrice := na
        lastFillQty   := na
        lastEntryLev  := na

    prevPosSize  := posQtyNow
    prevAvgPrice := avgEntryPrice
else
    prevAvgPrice := avgEntryPrice

//──────────────────────────────────────
// Visuals: ATH + buy markers
//──────────────────────────────────────
plot(ath, color=color.orange, linewidth=2, title="ATH (HIGH 기반)")

plotshape(firstBuyCond  and not killActiveThisBar and inTradeWindow, title="First Buy",  style=shape.triangleup, color=color.lime, size=size.tiny,  location=location.belowbar, text="Buy")
plotshape(secondBuyCond and not killActiveThisBar and inTradeWindow, title="Second Buy", style=shape.triangleup, color=color.teal, size=size.small, location=location.belowbar, text="Buy")

//──────────────────────────────────────
// Info table
//──────────────────────────────────────
float maxDDSinceATH = not na(lowestLowSinceATH) ? (lowestLowSinceATH / ath - 1.0) * 100.0 : na

// 16 rows
var table info = table.new(position.top_right, 2, 16, border_width=1)

if barstate.islast
    float posQtyT    = strategy.position_size
    float posQtyAbsT = math.abs(posQtyT)
    float posValT    = posQtyAbsT * close

    float levWallet = walletNow != 0 ? posValT / walletNow : na
    float levEquity = equityNow != 0 ? posValT / equityNow : na

    float ddFromAth = percentFromATHNow

    float posCost = (posQtyAbsT > 0 and not na(avgEntryPrice)) ? (posQtyAbsT * avgEntryPrice) : na
    float pnlPerc = (not na(posCost) and posCost > 0) ? (strategy.openprofit / posCost) * 100.0 : na
    float equityRetPerc = strategy.initial_capital != 0 ? (equityNow / strategy.initial_capital - 1.0) * 100.0 : na

    color bg  = color.new(color.blue, 0)
    color txt = color.white

    // 0
    table.cell(info, 0, 0, "Pos Qty", bgcolor=bg, text_color=txt)
    table.cell(info, 1, 0, posQtyAbsT != 0 ? str.tostring(posQtyAbsT, format.mintick) : "0", bgcolor=bg, text_color=txt)

    // 1
    table.cell(info, 0, 1, "Pos Value", bgcolor=bg, text_color=txt)
    table.cell(info, 1, 1, posValT != 0 ? str.tostring(posValT, format.mintick) : "0", bgcolor=bg, text_color=txt)

    // 2
    table.cell(info, 0, 2, "Lev (Wallet)", bgcolor=bg, text_color=txt)
    table.cell(info, 1, 2, not na(levWallet) ? str.tostring(levWallet, format.mintick) + "x" : "N/A", bgcolor=bg, text_color=txt)

    // 3
