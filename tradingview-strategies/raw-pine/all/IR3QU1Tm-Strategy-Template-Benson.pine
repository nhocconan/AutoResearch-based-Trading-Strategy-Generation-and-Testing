//@version=5
// This source code is subject to the terms of the Mozilla Public License 2.0 at https://mozilla.org/MPL/2.0/
// © bensonsuntw

strategy('Strategy Template[Benson]', pyramiding=1, default_qty_type=strategy.percent_of_equity, default_qty_value=100)

backtest_year = input(2019, title='backtest_year')
backtest_month = input.int(01, title='backtest_month', minval=1, maxval=12)
backtest_day = input.int(01, title='backtest_day', minval=1, maxval=31)
start_time = timestamp(backtest_year, backtest_month, backtest_day, 00, 00)
stop_loss_and_tp = input(title='Enable Stop Loss and Take Profit', defval=true)
trail_stop = input(title='Enable Trail Stop', defval=true)
buy_stop_loss = input(0.2, title='buy_stop_loss')
sell_stop_loss = input(0.1, title='sell_stop_loss')
buy_tp = input(0.4, title='buy_tp')
sell_tp = input(0.2, title='sell_tp')
trail_stop_long = input(1.1, title='trail_stop_long')
trail_stop_short = input(0.9, title='trail_stop_short')
trail_stop_long_offset = input(0.05, title='trail_stop_long_offset')
trail_stop_short_offset = input(0.05, title='trail_stop_short_offset')


// you can set your own logic here
shortCondition = ta.crossunder(ta.sma(close, 7), ta.sma(close, 14))
longCondition = ta.crossover(ta.sma(close, 7), ta.sma(close, 14))

if longCondition and time >= start_time
    strategy.entry('Buy', strategy.long)

if shortCondition
    strategy.close('Buy')

strategy.exit('Close Buy', 'Buy', limit=stop_loss_and_tp ? strategy.position_avg_price * (1 + buy_tp) : na, stop=stop_loss_and_tp ? strategy.position_avg_price * (1 - buy_stop_loss) : na, trail_price=trail_stop ? strategy.position_avg_price * trail_stop_long : na, trail_offset=trail_stop ? -strategy.position_avg_price * trail_stop_long_offset : na)


if shortCondition and time >= start_time
    strategy.entry('Sell', strategy.short)

if longCondition
    strategy.close('Sell')

strategy.exit('Close Sell', 'Sell', limit=stop_loss_and_tp ? strategy.position_avg_price * (1 - sell_tp) : na, stop=stop_loss_and_tp ? strategy.position_avg_price * (1 + sell_stop_loss) : na, trail_price=trail_stop ? strategy.position_avg_price * trail_stop_short : na, trail_offset=trail_stop ? strategy.position_avg_price * trail_stop_short_offset : na)


net_profit = strategy.netprofit + strategy.openprofit

plot(net_profit, title='Net Profit', linewidth=2, style=plot.style_area, color=net_profit >= 0 ? color.rgb(38, 166, 154,50) : color.rgb(255,82,82,50))
