//@version=5
strategy("SuperTrend + RSI Strategy (Fixed SL/TP)", overlay=true, margin_long=100, margin_short=100)

// === Inputs ===
// SuperTrend
atrPeriod   = input.int(10, "SuperTrend ATR Period")
atrMult     = input.float(3.0, "SuperTrend ATR Multiplier")

// RSI
rsiLength   = input.int(14, "RSI Length")
rsiLongLvl  = input.int(40, "RSI Long Level (Oversold)")
rsiShortLvl = input.int(80, "RSI Short Level (Overbought)")

// Pip-based SL/TP
slPips      = input.int(20, "Stop Loss (pips)")
tpPips      = input.int(30, "Take Profit (pips)")

// === SuperTrend Calculation ===
[superTrend, dir] = ta.supertrend(atrMult, atrPeriod)
// dir == -1 → bullish trend, dir == 1 → bearish trend
bullTrend = dir == -1
bearTrend = dir == 1

plot(superTrend, "SuperTrend", color=bullTrend ? color.green : color.red)

// === RSI Calculation ===
rsi = ta.rsi(close, rsiLength)
plot(rsi, "RSI", color=color.blue)
hline(rsiLongLvl, "Oversold", color=color.green)
hline(rsiShortLvl, "Overbought", color=color.red)

// === Pip Conversion ===
pipValue = syminfo.mintick
slDist   = slPips * pipValue
tpDist   = tpPips * pipValue

// === Entry Conditions ===
// Long: RSI oversold + SuperTrend bullish
longCondition  = rsi <= rsiLongLvl and bullTrend and strategy.position_size == 0

// Short: RSI overbought + SuperTrend bearish
shortCondition = rsi >= rsiShortLvl and bearTrend and strategy.position_size == 0

// === Orders ===
if (longCondition)
    strategy.entry("Long", strategy.long)
    strategy.exit("TP/SL Long", "Long", stop=close - slDist, limit=close + tpDist)

if (shortCondition)
    strategy.entry("Short", strategy.short)
    strategy.exit("TP/SL Short", "Short", stop=close + slDist, limit=close - tpDist)

