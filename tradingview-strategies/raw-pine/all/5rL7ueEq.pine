//@version=5
strategy("EMA 1 & SALMA Kesişim Stratejisi", overlay=true, initial_capital=10000, default_qty_type=strategy.cash)

// --- Girdiler ---
salma_len = input.int(15, title="SALMA Periyodu")
ema_len = input.int(1, title="EMA Periyodu (Fiyat)")
rsi_len = input.int(14, title="RSI Periyodu")

// --- Hesaplamalar ---
float salma = ta.sma(ta.sma(close, salma_len), 5) 
float ema1 = ta.ema(close, ema_len)
float rsi = ta.rsi(close, rsi_len)

// --- Al-Sat Mantığı (Kesişim Odaklı) ---

// AL Sinyali: EMA 1, SALMA'yı aşağıdan yukarıya kestiğinde
longCondition = ta.crossover(ema1, salma) and rsi > 50
if (longCondition)
    strategy.entry("Long", strategy.long, comment="EMA Kes-Yukarı (AL)")

// SAT Sinyali: EMA 1, SALMA'yı yukarıdan aşağıya kestiğinde
shortCondition = ta.crossunder(ema1, salma) and rsi < 50
if (shortCondition)
    strategy.entry("Short", strategy.short, comment="EMA Kes-Aşağı (SAT)")

// --- Grafik Çizimi ---
plot(salma, color=color.new(color.gray, 0), linewidth=2, title="SALMA Çizgisi")
plot(ema1, color=color.blue, linewidth=1, title="EMA 1 (Fiyat)")

// Sinyal Görselleri
plotshape(series=longCondition, title="Al", location=location.belowbar, color=color.green, style=shape.triangleup, size=size.small, text="AL")
plotshape(series=shortCondition, title="Sat", location=location.abovebar, color=color.red, style=shape.triangledown, size=size.small, text="SAT")

