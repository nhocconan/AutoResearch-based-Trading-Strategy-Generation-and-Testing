//@version=6
// Strategie basierend auf Sweeps der Fractals (MTF Fractals [RunRox])
// Sweep High → Short | Sweep Low → Long (optional: bullish/bearish Filter)
// Entry: Sweep-Kerze (wenn bearish/bullish) ODER erste Attempted-Kerze danach | SL = Low/High der Attempted-Kerze | CRV = 3
strategy("Fractal Sweep Strategy", overlay=true, process_orders_on_close=true, default_qty_type=strategy.percent_of_equity, default_qty_value=1, pyramiding=2, max_lines_count=500, max_labels_count=500)

ClampFutureBars(int bars) => math.max(0, math.min(bars, 500))

// ═══════════════════════════════════════════════════════════════════════════════
// INPUTS
// ═══════════════════════════════════════════════════════════════════════════════
grpFractal = "Fractals"
inputFractalType = input.string("5", "Bars in Fractal", options=["3", "5", "7", "9"], group=grpFractal, tooltip="Anzahl Bars für Fractal-Erkennung: 3=kompakt, 5=Standard, 7/9=breiter.")
inputFractalTF = input.timeframe("", "Fractals Timeframe", group=grpFractal, tooltip="Leer = Chart-TF. Höher = MTF Fractals (z.B. 15 für M15).")
attempted_candle_tf = input.string("Chart-TF", "Attempted-Kerze für bullish/bearish", options=["Chart-TF", "Fractal-TF"], group=grpFractal, tooltip="Chart-TF = sichtbare Kerze. Fractal-TF = HTF-Kerze (bei MTF).")
require_candle_direction = input.bool(false, "Bullish/Bearish Attempted erforderlich", group=grpFractal, tooltip="An: Short nur bei bearish, Long nur bei bullish Kerze. Aus: Jeder Sweep = Trade (auch bullish Kerze bei Fractal High).")
maxFractalAge = input.int(500, "Max Age (Bars)", minval=50, group=grpFractal, tooltip="Fractals älter als N Bars werden ignoriert.")

grpEntry = "Entry Model"
entry_model = input.string("Beide", "Entry-Modell", options=["Attempted Candle", "Trigger Level", "Beide"], group=grpEntry, tooltip="Attempted: Sweep + bearish/bullish oder erste Attempted-Kerze. Trigger: Sweep bullish, Folgekerze nicht Attempted → Short bei Durchbruch unter Body-Low. Beide: Beide Modelle parallel aktiv.")
rr_attempted = input.float(2.0, "CRV Attempted Candle", minval=0.5, step=0.5, group=grpEntry, tooltip="Risk:Reward für Attempted-Modell. TP = Entry ± CRV × Risiko.")
rr_trigger = input.float(2.0, "CRV Trigger Level", minval=0.5, step=0.5, group=grpEntry, tooltip="Risk:Reward für Trigger-Level-Modell. TP = Entry ± CRV × Risiko.")

grpSupertrend = "Supertrend (H1 Bias)"
use_supertrend_bias = input.string("Aus", "Directional Bias", options=["Aus", "Mit Trend", "Gegen Trend"], group=grpSupertrend, tooltip="H1-Supertrend als Filter: Mit Trend = Long bei Uptrend, Short bei Downtrend. Gegen Trend = umgekehrt.")
st_atr_len = input.int(10, "ATR Length", minval=1, group=grpSupertrend, tooltip="ATR-Periode für Supertrend-Berechnung auf H1.")
st_factor = input.float(3.0, "Factor", minval=0.01, step=0.01, group=grpSupertrend, tooltip="Multiplikator für Supertrend-Bänder (typisch 2–4).")

grpRisk = "Risk"
max_trades_per_day = input.int(5, "Max Trades per Day", minval=1, maxval=20, group=grpRisk, tooltip="Maximale Anzahl Trades pro Tag (über beide Entry-Modelle).")

grpSession = "Session (optional)"
use_session = input.bool(false, "Nur in Session handeln", group=grpSession, tooltip="Trades nur innerhalb der definierten Handelszeiten.")
session_start_h = input.int(8, "Session Start (Stunde)", minval=0, maxval=23, group=grpSession, tooltip="Stunde (0–23) für Session-Start.")
session_end_h = input.int(17, "Session Ende (Stunde)", minval=0, maxval=23, group=grpSession, tooltip="Stunde (0–23) für Session-Ende.")
inputTz = input.string("Europe/Berlin", "Timezone", options=["Europe/Berlin", "Etc/UTC", "America/New_York"], group=grpSession, tooltip="Zeitzone für Session und Tageswechsel.")

grpVisuals = "Visuals"
show_debug_labels = input.bool(false, "Debug-Labels aktivieren", group=grpVisuals, tooltip="Aktiviert alle Debug-Labels (Trade-Erklärung, Sweep-Labels, Sweep ohne Trade) auf einmal.")
show_trade_explainer = input.bool(false, "Trade-Erklärung (Labels + Hintergrund)", group=grpVisuals, tooltip="Attempted-Kerze markieren, Entry-Labels und farbigen Hintergrund bei Trades.")
show_fractal_lines = input.bool(true, "Fractal-Linien anzeigen", group=grpVisuals, tooltip="Horizontale Linien an jedem Fractal High/Low.")
show_fractal_labels = input.bool(true, "Fractal-Marker (▲/▼)", group=grpVisuals, tooltip="Dreiecks-Marker an Fractal-Punkten.")
frac_high_color = input.color(color.green, "Fractal High Farbe", inline="frac", group=grpVisuals, tooltip="Farbe für Fractal High Linien und Marker.")
frac_low_color = input.color(color.red, "Fractal Low Farbe", inline="frac", group=grpVisuals, tooltip="Farbe für Fractal Low Linien und Marker.")
frac_line_style = input.string("Solid", "Linien-Stil", options=["Solid", "Dashed", "Dotted"], group=grpVisuals, tooltip="Linien-Stil für Fractal-Linien.")
frac_line_width = input.int(2, "Linien-Stärke", minval=1, maxval=4, group=grpVisuals, tooltip="Dicke der Fractal-Linien.")
show_sweep_labels = input.bool(false, "Sweep-Labels anzeigen", group=grpVisuals, tooltip="Labels bei Sweep-Signalen (warum Trade).")
show_sweep_no_trade = input.bool(false, "Sweep ohne Trade anzeigen", group=grpVisuals, tooltip="Labels wenn Sweep erkannt, aber kein Trade (z.B. warte auf Attempted).")
show_sl_tp_lines = input.bool(true, "SL/TP-Linien anzeigen", group=grpVisuals, tooltip="Stop-Loss und Take-Profit Linien bei offenen Trades.")
show_supertrend = input.bool(false, "Supertrend H1 anzeigen", group=grpVisuals, tooltip="H1-Supertrend-Linie auf Chart (nur wenn Bias aktiv).")
line_extend_bars = input.int(50, "SL/TP Linien-Extension (Bars)", minval=0, group=grpVisuals, tooltip="Wie viele Bars SL/TP-Linien nach rechts verlängert werden.")

show_trade_explainer_eff = show_trade_explainer or show_debug_labels
show_sweep_labels_eff = show_sweep_labels or show_debug_labels
show_sweep_no_trade_eff = show_sweep_no_trade or show_debug_labels

// ═══════════════════════════════════════════════════════════════════════════════
// FRACTAL LOGIC (MTF Fractals [RunRox] – 1:1 Sweep-Detection)
// ═══════════════════════════════════════════════════════════════════════════════
period = inputFractalType == "3" ? 1 : inputFractalType == "5" ? 2 : inputFractalType == "7" ? 3 : 4
isHTF = inputFractalTF != "" and timeframe.in_seconds(inputFractalTF) > timeframe.in_seconds(timeframe.period)
htf = isHTF ? inputFractalTF : timeframe.period
tfRatio = math.ceil(timeframe.in_seconds(htf) / timeframe.in_seconds(timeframe.period))

fractalHigh(int len) =>
    res = true
    for i = 1 to len
        res := res and high[len] > high[len - i] and high[len] > high[len + i]
    if res
        high[len]

fractalLow(int len) =>
    res = true
    for i = 1 to len
        res := res and low[len] < low[len - i] and low[len] < low[len + i]
    if res
        low[len]

// ═══════════════════════════════════════════════════════════════════════════════
// FRACTAL ARRAYS (Preis + Bar-Index + Linien)
// ═══════════════════════════════════════════════════════════════════════════════
const int MAX_FRACTALS = 100
var array<float> fracHighPrices = array.new<float>()
var array<int> fracHighBars = array.new<int>()
var array<line> fracHighLines = array.new<line>()
var array<label> fracHighLabels = array.new<label>()
var array<float> fracLowPrices = array.new<float>()
var array<int> fracLowBars = array.new<int>()
var array<line> fracLowLines = array.new<line>()
var array<label> fracLowLabels = array.new<label>()

fracLineStyle = frac_line_style == "Dashed" ? line.style_dashed : frac_line_style == "Dotted" ? line.style_dotted : line.style_solid

// HTF-Daten für MTF
[htfOpen, htfHigh, htfLow, htfClose, htfTime, htfUpFractal, htfDnFractal] = request.security(syminfo.tickerid, htf, [open, high, low, close, time, fractalHigh(period), fractalLow(period)], barmerge.gaps_on, barmerge.lookahead_off)
var array<int> htfTimestamps = array.new<int>()
isNewCandleHtf = not na(htfTime)
var int prevHtfTs = 0
if isNewCandleHtf
    array.unshift(htfTimestamps, htfTime)
    if array.size(htfTimestamps) > period + 1
        prevHtfTs := array.get(htfTimestamps, period)

// Fractals hinzufügen (mit Linie + optional Label)
addFractal(bool isHigh, float price, int barIdx) =>
    if not na(price)
        arrP = isHigh ? fracHighPrices : fracLowPrices
        arrB = isHigh ? fracHighBars : fracLowBars
        arrL = isHigh ? fracHighLines : fracLowLines
        arrLb = isHigh ? fracHighLabels : fracLowLabels
        if array.size(arrP) >= MAX_FRACTALS
            oldLn = array.shift(arrL)
            if not na(oldLn)
                line.delete(oldLn)
            oldLb = array.shift(arrLb)
            if not na(oldLb)
                label.delete(oldLb)
            array.shift(arrP)
            array.shift(arrB)
        clr = isHigh ? frac_high_color : frac_low_color
        ln = show_fractal_lines ? line.new(barIdx, price, bar_index, price, xloc=xloc.bar_index, color=clr, style=fracLineStyle, width=frac_line_width) : line.new(barIdx, price, bar_index, price, xloc=xloc.bar_index, color=color.new(color.gray, 100), width=1)
        lb = show_fractal_labels ? label.new(barIdx, price, isHigh ? "▲" : "▼", xloc=xloc.bar_index, yloc=yloc.price, style=label.style_label_center, color=clr, textcolor=color.white, size=size.small) : na
        array.push(arrP, price)
        array.push(arrB, barIdx)
        array.push(arrL, ln)
        array.push(arrLb, lb)

// Gebrochene Fractals entfernen und Sweep prüfen (inline – Pine erlaubt keine globalen Änderungen in Funktionen)
// Sweep High: high > frac AND open < frac AND close < frac → Long
// Sweep Low:  low < frac AND open > frac AND close > frac → Short
var bool sweepHighDetected = false
var bool sweepLowDetected = false

processBrokenFractals(bool isHigh, float o, float h, float l, float c, int currentBar) =>
    foundSweep = false
    arrP = isHigh ? fracHighPrices : fracLowPrices
    arrB = isHigh ? fracHighBars : fracLowBars
    arrL = isHigh ? fracHighLines : fracLowLines
    arrLb = isHigh ? fracHighLabels : fracLowLabels
    i = array.size(arrP) - 1
    while i >= 0
        price = array.get(arrP, i)
        barIdx = array.get(arrB, i)
        ln = array.get(arrL, i)
        lb = array.get(arrLb, i)
        if currentBar - barIdx > maxFractalAge
            if not na(ln)
                line.delete(ln)
            if not na(lb)
                label.delete(lb)
            array.remove(arrP, i)
            array.remove(arrB, i)
            array.remove(arrL, i)
            array.remove(arrLb, i)
        else if isHigh ? h > price : l < price
            if isHigh and o < price and c < price
                foundSweep := true
            else if not isHigh and o > price and c > price
                foundSweep := true
            if not na(ln)
                line.delete(ln)
            if not na(lb)
                label.delete(lb)
            array.remove(arrP, i)
            array.remove(arrB, i)
            array.remove(arrL, i)
            array.remove(arrLb, i)
        else
            break
        i -= 1
    foundSweep

// ═══════════════════════════════════════════════════════════════════════════════
// MAIN LOOP – Fractals sammeln & Sweep erkennen
// ═══════════════════════════════════════════════════════════════════════════════
sweepHighDetected := false
sweepLowDetected := false

if isHTF
    if isNewCandleHtf
        addFractal(true, htfUpFractal, bar_index - tfRatio)
        addFractal(false, htfDnFractal, bar_index - tfRatio)
        sweepHighDetected := processBrokenFractals(true, htfOpen, htfHigh, htfLow, htfClose, bar_index)
        sweepLowDetected := processBrokenFractals(false, htfOpen, htfHigh, htfLow, htfClose, bar_index)
else
    upFractal = fractalHigh(period)
    dnFractal = fractalLow(period)
    addFractal(true, upFractal, bar_index - period)
    addFractal(false, dnFractal, bar_index - period)
    if barstate.isconfirmed
        sweepHighDetected := processBrokenFractals(true, open, high, low, close, bar_index)
        sweepLowDetected := processBrokenFractals(false, open, high, low, close, bar_index)

// Fractal-Linien jeden Bar nach rechts verlängern
if show_fractal_lines and array.size(fracHighLines) > 0
    for i = 0 to array.size(fracHighLines) - 1
        ln = array.get(fracHighLines, i)
        if not na(ln)
            line.set_x2(ln, bar_index)
if show_fractal_lines and array.size(fracLowLines) > 0
    for i = 0 to array.size(fracLowLines) - 1
        ln = array.get(fracLowLines, i)
        if not na(ln)
            line.set_x2(ln, bar_index)
// ═══════════════════════════════════════════════════════════════════════════════
// SESSION
// ═══════════════════════════════════════════════════════════════════════════════
y_ = year(time, inputTz)
m_ = month(time, inputTz)
d_ = dayofmonth(time, inputTz)
sessionStartTs = timestamp(inputTz, y_, m_, d_, session_start_h, 0)
sessionEndTs = timestamp(inputTz, y_, m_, d_, session_end_h, 0)
inSession = not use_session or (time >= sessionStartTs and time < sessionEndTs)
isNewDay = ta.change(time("D", inputTz)) != 0

// ═══════════════════════════════════════════════════════════════════════════════
// SUPERTREND H1 (Directional Bias)
// ═══════════════════════════════════════════════════════════════════════════════
[st_val, st_dir] = request.security(syminfo.tickerid, "60", ta.supertrend(st_factor, st_atr_len), barmerge.gaps_on, barmerge.lookahead_off)
st_uptrend = not na(st_dir) and st_dir < 0
st_downtrend = not na(st_dir) and st_dir > 0
bias_ok_long = use_supertrend_bias == "Aus" or (use_supertrend_bias == "Mit Trend" and st_uptrend) or (use_supertrend_bias == "Gegen Trend" and st_downtrend)
bias_ok_short = use_supertrend_bias == "Aus" or (use_supertrend_bias == "Mit Trend" and st_downtrend) or (use_supertrend_bias == "Gegen Trend" and st_uptrend)

// ═══════════════════════════════════════════════════════════════════════════════
// TRADE MANAGEMENT
// ═══════════════════════════════════════════════════════════════════════════════
var int entries_today = 0
var bool pending_sweep_high = false
var bool pending_sweep_low = false
var bool pending_trigger_high = false
var float trigger_level = na
var float trigger_sl = na
var bool sweep_high_bullish_prev = false
var float last_sweep_high_candle_low = na
var float last_sweep_high_candle_high = na
if isNewDay
    entries_today := 0
    pending_sweep_high := false
    pending_sweep_low := false
    pending_trigger_high := false
    trigger_level := na
    trigger_sl := na
    sweep_high_bullish_prev := false

// Einstieg am Close der Attempted-Kerze (Sweep-Kerze), SL = Low/High der Attempted-Kerze
// Effektive OHLC: bei MTF = HTF-Kerze, sonst = Chart-Kerze
eff_open = isHTF ? htfOpen : open
eff_close = isHTF ? htfClose : close
eff_low = isHTF ? htfLow : low
eff_high = isHTF ? htfHigh : high

// Attempted bullish/bearish: Chart-TF = sichtbare Kerze (bei MTF = letzte Chart-Kerze der HTF-Periode)
attempted_open = (isHTF and attempted_candle_tf == "Chart-TF") ? open[1] : eff_open
attempted_close = (isHTF and attempted_candle_tf == "Chart-TF") ? close[1] : eff_close
bearish_attempted = attempted_close < attempted_open
bullish_attempted = attempted_close > attempted_open
candle_ok_long = require_candle_direction ? bullish_attempted : true
candle_ok_short = require_candle_direction ? bearish_attempted : true

// Aktuelle Chart-Kerze (für "Attempted direkt nach Sweep")
// Attempted = nimmt High/Low der Kerze zuvor: Short braucht high > high[1], Long braucht low < low[1]
bearish_curr = close < open
bullish_curr = close > open
attempted_short_curr = bearish_curr and (high > high[1])   // bearish + nimmt Hoch der Kerze zuvor
attempted_long_curr = bullish_curr and (low < low[1])    // bullish + nimmt Tief der Kerze zuvor

// Sweep High → Short | Sweep Low → Long
// Variante A: Sweep-Kerze = Attempted (sofortiger Trade) – NUR wenn Sweep-Kerze selbst bearish/bullish
// Variante B: Attempted-Kerze kann mehrere Bars später kommen (pending bis Attempted erscheint)
// Variante C (Trigger Level): Sweep bullishe Kerze, Folgekerze NICHT Attempted → Trigger = Low der Sweep-Kerze, Short bei Close < Trigger
immediate_long = sweepLowDetected and bullish_attempted   // Sweep-Kerze muss bullish sein
immediate_short = sweepHighDetected and bearish_attempted // Sweep-Kerze muss bearish sein

use_attempted = entry_model == "Attempted Candle" or entry_model == "Beide"
use_trigger = entry_model == "Trigger Level" or entry_model == "Beide"

if use_attempted
    if sweepHighDetected and not immediate_short
        pending_sweep_high := true
    if sweepLowDetected and not immediate_long
        pending_sweep_low := true
if use_trigger
    if sweepHighDetected and bullish_attempted
        last_sweep_high_candle_low := eff_low
        last_sweep_high_candle_high := eff_high
        trigger_level := math.min(eff_open, eff_close)
        trigger_sl := eff_high
        pending_trigger_high := true
        sweep_high_bullish_prev := true
    if barstate.isconfirmed and sweep_high_bullish_prev and not attempted_short_curr
        sweep_high_bullish_prev := false
    if barstate.isconfirmed and sweep_high_bullish_prev and attempted_short_curr
        pending_trigger_high := false
        sweep_high_bullish_prev := false

delayed_long = pending_sweep_low and attempted_long_curr   // Attempted kann beliebig viele Bars später kommen
delayed_short = pending_sweep_high and attempted_short_curr

// Trigger: Close-Break = Entry am Close; Vorbar brach = Entry am Open (Fallback wenn Folgekerze brach)
trigger_ready = use_trigger and pending_trigger_high and not sweep_high_bullish_prev and not na(trigger_level)
trigger_short_at_close = trigger_ready and close < trigger_level
trigger_short_at_open = trigger_ready and close[1] < trigger_level and not (close < trigger_level)
trigger_short = trigger_short_at_close or trigger_short_at_open

long_signal_attempted = use_attempted and (immediate_long or delayed_long) and inSession and bias_ok_long and strategy.position_size >= 0 and entries_today < max_trades_per_day
short_signal_attempted = use_attempted and (immediate_short or delayed_short) and inSession and bias_ok_short and strategy.position_size <= 0 and entries_today < max_trades_per_day
short_signal_trigger = trigger_short and inSession and strategy.position_size <= 0 and entries_today < max_trades_per_day

long_signal = long_signal_attempted
short_signal = short_signal_attempted or short_signal_trigger

// SL/TP pro Modell
use_delayed_long = delayed_long and not immediate_long
use_delayed_short = delayed_short and not immediate_short
float sl_long = use_delayed_long ? low : eff_low
float sl_short_attempted = use_delayed_short ? high : eff_high
float sl_short_trigger = trigger_sl
float entry_long = (use_delayed_long ? close : eff_close)
float entry_short_attempted = (use_delayed_short ? close : eff_close)
float entry_short_trigger = trigger_short_at_close ? close : open
float risk_long = math.abs(entry_long - sl_long)
float risk_short_attempted = math.abs(sl_short_attempted - entry_short_attempted)
float risk_short_trigger = math.abs(sl_short_trigger - entry_short_trigger)
float tp_long = entry_long + rr_attempted * risk_long
float tp_short_attempted = entry_short_attempted - rr_attempted * risk_short_attempted
float tp_short_trigger = entry_short_trigger - rr_trigger * risk_short_trigger

var line current_sl_line = na
var line current_tp_line = na
position_just_closed = strategy.position_size == 0 and strategy.position_size[1] != 0
if position_just_closed and not na(current_sl_line)
    line.set_x2(current_sl_line, bar_index)
    line.set_x2(current_tp_line, bar_index)
    current_sl_line := na
    current_tp_line := na

// ═══════════════════════════════════════════════════════════════════════════════
// EXECUTION – Entry am Close (repainting-safe: nur bei bestätigter Kerze)
// ═══════════════════════════════════════════════════════════════════════════════
bar_confirmed = barstate.isconfirmed
if bar_confirmed and long_signal_attempted
    entries_today += 1
    if use_delayed_long
        pending_sweep_low := false
    strategy.entry("Long", strategy.long, limit=entry_long, comment="Sweep L")
    strategy.exit("Exit Long", "Long", limit=tp_long, stop=sl_long)
    if show_sl_tp_lines
        current_sl_line := line.new(bar_index, sl_long, bar_index + ClampFutureBars(line_extend_bars), sl_long, color=color.red, width=2)
        current_tp_line := line.new(bar_index, tp_long, bar_index + ClampFutureBars(line_extend_bars), tp_long, color=color.green, width=2)

if bar_confirmed and short_signal_attempted
    entries_today += 1
    if use_delayed_short
        pending_sweep_high := false
    strategy.entry("Short Attempted", strategy.short, limit=entry_short_attempted, comment="Sweep S")
    strategy.exit("Exit Short Attempted", "Short Attempted", limit=tp_short_attempted, stop=sl_short_attempted)
    if show_sl_tp_lines
        current_sl_line := line.new(bar_index, sl_short_attempted, bar_index + ClampFutureBars(line_extend_bars), sl_short_attempted, color=color.red, width=2)
        current_tp_line := line.new(bar_index, tp_short_attempted, bar_index + ClampFutureBars(line_extend_bars), tp_short_attempted, color=color.green, width=2)

if bar_confirmed and short_signal_trigger
    entries_today += 1
    pending_trigger_high := false
    strategy.entry("Short Trigger", strategy.short, limit=entry_short_trigger, comment="Trigger S")
    strategy.exit("Exit Short Trigger", "Short Trigger", limit=tp_short_trigger, stop=sl_short_trigger)
    if show_sl_tp_lines
        current_sl_line := line.new(bar_index, sl_short_trigger, bar_index + ClampFutureBars(line_extend_bars), sl_short_trigger, color=color.red, width=2)
        current_tp_line := line.new(bar_index, tp_short_trigger, bar_index + ClampFutureBars(line_extend_bars), tp_short_trigger, color=color.green, width=2)

// ═══════════════════════════════════════════════════════════════════════════════
// VISUALS – Trade-Erklärung: wann & warum getradet wird
// ═══════════════════════════════════════════════════════════════════════════════
// 1) Attempted-Kerze hervorheben (Hintergrund) – nur bei gültigem Trade (richtige Kerzenrichtung)
barcolor(show_trade_explainer_eff and long_signal ? color.new(#00e677, 85) : show_trade_explainer_eff and short_signal ? color.new(#ff5252, 85) : na)

// 2) Sweep-Label: Warum? → Fractal gesweept (sofort oder Attempted direkt danach) oder Trigger Level
if show_sweep_labels_eff and short_signal_attempted
    lbl = "Sweep → Short\nFractal High gebrochen" + (require_candle_direction ? "\nbearish Attempted" : "") + (use_delayed_short ? "\n(bearish, high>high[1])" : "")
    label.new(bar_index, use_delayed_short ? high : eff_high, lbl, style=label.style_label_lower_left, color=color.new(#ff5252, 20), textcolor=color.white, size=size.small)
if show_sweep_labels_eff and short_signal_trigger
    lbl = "Trigger → Short\n" + (trigger_short_at_close ? "Close < Trigger" : "Open (Vorbar brach Trigger)")
    label.new(bar_index, high, lbl, style=label.style_label_lower_left, color=color.new(#ff5252, 20), textcolor=color.white, size=size.small)
if show_sweep_labels_eff and long_signal
    lbl = "Sweep → Long\nFractal Low gebrochen" + (require_candle_direction ? "\nbullish Attempted" : "") + (use_delayed_long ? "\n(bullish, low<low[1])" : "")
    label.new(bar_index, use_delayed_long ? low : eff_low, lbl, style=label.style_label_upper_left, color=color.new(#00e677, 20), textcolor=color.white, size=size.small)

// 2b) Sweep OHNE Trade – Grund anzeigen
if show_sweep_no_trade_eff and sweepHighDetected and not short_signal
    reason = use_trigger and bullish_attempted ? "Sweep bullish\n(warte auf Trigger: Close < Body-Low)" : (not bearish_attempted ? "Sweep-Kerze nicht bearish\n(warte auf Attempted)" : (not bias_ok_short ? "Supertrend H1 Bias" : (not inSession ? "außerhalb Session" : (strategy.position_size > 0 ? "Long offen" : (entries_today >= max_trades_per_day ? "Max Trades erreicht" : "?")))))
    label.new(bar_index, eff_high, "Sweep (kein Trade)\n" + reason, style=label.style_label_lower_left, color=color.new(color.orange, 30), textcolor=color.white, size=size.tiny)
if show_sweep_no_trade_eff and sweepLowDetected and not long_signal
    reason = not bullish_attempted ? "Sweep-Kerze nicht bullish\n(warte auf Attempted)" : (not bias_ok_long ? "Supertrend H1 Bias" : (not inSession ? "außerhalb Session" : (strategy.position_size < 0 ? "Short offen" : (entries_today >= max_trades_per_day ? "Max Trades erreicht" : "?"))))
    label.new(bar_index, eff_low, "Sweep (kein Trade)\n" + reason, style=label.style_label_upper_left, color=color.new(color.orange, 30), textcolor=color.white, size=size.tiny)

// 3) Entry-Label: Wann? → Am Close dieser Kerze
if show_trade_explainer_eff and long_signal
    label.new(bar_index, entry_long, "Entry Long @ Close", style=label.style_label_up, color=color.green, textcolor=color.white, size=size.small)
if show_trade_explainer_eff and short_signal_attempted
    label.new(bar_index, entry_short_attempted, "Entry Short Attempted", style=label.style_label_down, color=color.red, textcolor=color.white, size=size.small)
if show_trade_explainer_eff and short_signal_trigger
    label.new(bar_index, entry_short_trigger, "Entry Short Trigger", style=label.style_label_down, color=color.orange, textcolor=color.white, size=size.small)

// 4) Entry-Marker (Dreiecke)
plotshape(long_signal, "Entry Long", shape.triangleup, location.belowbar, color.green, size=size.normal)
plotshape(short_signal_attempted, "Entry Short Attempted", shape.triangledown, location.belowbar, color.red, size=size.normal)
plotshape(short_signal_trigger, "Entry Short Trigger", shape.triangledown, location.belowbar, color.orange, size=size.normal)

// 5) Supertrend H1 (optional)
plot(show_supertrend and use_supertrend_bias != "Aus" ? st_val : na, "Supertrend H1", color=st_uptrend ? color.green : color.red, linewidth=2)

// 6) Trigger Level Linie (wenn aktiv)
var line trigger_line = na
if pending_trigger_high and not na(trigger_level) and show_sl_tp_lines
    if na(trigger_line)
        trigger_line := line.new(bar_index, trigger_level, bar_index + ClampFutureBars(line_extend_bars), trigger_level, xloc=xloc.bar_index, color=color.new(color.orange, 50), width=1)
    line.set_x2(trigger_line, bar_index + ClampFutureBars(line_extend_bars))
else if not pending_trigger_high and not na(trigger_line)
    line.delete(trigger_line)
    trigger_line := na

// 7) Legende: Ablauf erklärt (einmalig)
var table legendTable = table.new(position.top_right, 2, 6, bgcolor=color.new(color.gray, 90), border_width=1)
if show_trade_explainer_eff and barstate.islast
    table.cell(legendTable, 0, 0, "Fractal Sweep – Ablauf", text_color=color.white, text_size=size.small)
    table.cell(legendTable, 0, 1, "1. Fractal High/Low", text_color=color.gray, text_size=size.tiny)
    table.cell(legendTable, 1, 1, "▲/▼ + Linie", text_color=color.gray, text_size=size.tiny)
    table.cell(legendTable, 0, 2, "2. Attempted / Trigger", text_color=color.gray, text_size=size.tiny)
    table.cell(legendTable, 1, 2, "Attempted: bearish+high>high[1], Trigger: Close < Low Sweep", text_color=color.gray, text_size=size.tiny)
    table.cell(legendTable, 0, 3, "3. Entry", text_color=color.gray, text_size=size.tiny)
    table.cell(legendTable, 1, 3, "Attempted/Trigger parallel | Close oder Open bei Break", text_color=color.gray, text_size=size.tiny)
    table.cell(legendTable, 0, 4, "4. SL / TP", text_color=color.gray, text_size=size.tiny)
    table.cell(legendTable, 1, 4, "SL = Low/High der Kerze, CRV=2", text_color=color.gray, text_size=size.tiny)
    table.cell(legendTable, 0, 5, "5. Supertrend H1", text_color=color.gray, text_size=size.tiny)
    table.cell(legendTable, 1, 5, use_supertrend_bias, text_color=color.gray, text_size=size.tiny)

