//@version=4
strategy("disparity and sdv", overlay=true) //1min FXbtcJPY 2020/1/30

//backtest
testStartYear = input(2018, "Backtest Start Year")
testStartMonth = input(1, "Backtest Start Month")
testStartDay = input(1, "Backtest Start Day")
testPeriodStart = timestamp(testStartYear,testStartMonth,testStartDay,0,0)
testStopYear = input(2020, "Backtest Stop Year")
testStopMonth = input(12, "Backtest Stop Month")
testStopDay = input(31, "Backtest Stop Day")
testPeriodStop = timestamp(testStopYear,testStopMonth,testStopDay,0,0)
testPeriod() =>
    time >= testPeriodStart and time <= testPeriodStop ? true : false

//input value
input_length = input(8)
input_sdv = input(1500,title="threshold_sdv_value")
timeframe = input(title="Timeframe", type=input.integer, minval=1, defval=8)

//calc
disparity = (close - sma(close, input_length))/close
disp = disparity*10000
sdv = stdev(close, input_length)
bars = barssince(strategy.opentrades == 0)

//strategy
eL = sdv > input_sdv and -13 <= disp and disp <= -8
eS = sdv > input_sdv and 13 >= disp and disp >= 8

if testPeriod()
    if eL
        strategy.entry("eL", strategy.long)
    if eS
        strategy.entry("eS", strategy.short)

strategy.close_all(when=(bars>=timeframe))

//exit - 8 candles after.(timeframe value)
//I don't come up with good exit signal but seems like not a bad way.

View in Pine Editor・40 lines
