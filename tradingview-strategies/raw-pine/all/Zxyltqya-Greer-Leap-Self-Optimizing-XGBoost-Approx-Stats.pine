//@version=6
strategy("DEPRECATED - DO NOT USE", overlay=true)

// only trigger once on the very first bar
if bar_index == 0
    strategy.entry("DEMO", strategy.long)

// immediately close it on next bar
if bar_index == 1
    strategy.close("DEMO")

plot(na, display=display.none)

