//@version=6
// ============================================================================
// MODIFICATIONS EXPLANATION
// ============================================================================
// This version has been modified to meet the following requirements:
//
// 1. ENTRY/EXIT ON CANDLE CLOSE:
//    - All strategy entries and exits are executed only when a candle closes
//    - Uses barstate.isconfirmed to ensure actions happen at bar close
//    - Prevents intrabar actions (no trades during candle formation)
//
// 2. REPAINTING (Visual Updates During Candle):
//    - Visual elements (lines, labels, Fibonacci levels) update in real-time
//    - This allows you to see how the trend develops as the candle forms
//    - Visual updates use current bar data (close[0], high[0], low[0])
//
// 3. NO FLICKERING (Stable Signals):
//    - Entry/exit signals use historical values (close[1], open[2], etc.)
//    - Trend completion detection uses confirmed previous bar data
//    - This prevents signals from changing constantly during candle formation
//    - Signals are calculated once at bar close and remain stable
//
// 4. NO INTRABAR ACTIONS:
//    - All strategy.entry() and strategy.exit() calls are wrapped in
//      barstate.isconfirmed checks
//    - Pending signals are stored in variables and executed only at bar close
//    - This ensures backtesting accuracy and prevents unrealistic executions
//
// KEY CHANGES:
// - Added pending entry/exit variables to store signals until bar close
// - Modified trend completion logic to use close[1] instead of close[0]
// - Entry/exit execution moved to a dedicated section that runs only on bar close
// - Visual updates continue to use current bar data for repainting effect
// ============================================================================

strategy('Fibonacci 5 Candles Retracement VERSION 2 - Close Bar', 'Fib5CClose', overlay = true, max_labels_count = 500, initial_capital = 10000, default_qty_type = strategy.percent_of_equity, default_qty_value = 100)

GREEN = #7bff23
RED   = #F23645
YELLOW = #FFD700
ORANGE = #FFA500
AZURE = #00CED1
GREEN_FIB = #00FF00

showLabelsInput = input.bool(true, 'Show Start/End Labels', group = 'VISUALIZATION')
labelSizeInput = input.string('small', 'Label Size', group = 'VISUALIZATION', options = ['tiny', 'small', 'normal', 'large', 'huge'])
showStartEndLinesInput = input.bool(true, 'Show Start/End Lines', group = 'VISUALIZATION')
show50LineInput = input.bool(true, 'Show 50% Line', group = 'VISUALIZATION')
show25LineInput = input.bool(true, 'Show 25% Line', group = 'VISUALIZATION')
show618LineInput = input.bool(true, 'Show 60% Line', group = 'VISUALIZATION')
show786LineInput = input.bool(true, 'Show 70% Line', group = 'VISUALIZATION')
showPendingOrdersInput = input.bool(true, 'Show Pending Orders', group = 'VISUALIZATION')

colorStartEndLineInput = input.color(color.white, 'Start/End Line Color', group = 'LINE COLORS')
color50LineInput = input.color(#FFD700, '50% Line Color', group = 'LINE COLORS')
color25LineInput = input.color(#00FF00, '25% Line Color', group = 'LINE COLORS')
color60LineInput = input.color(#00CED1, '60% Line Color', group = 'LINE COLORS')
color70LineInput = input.color(#F23645, '70% Line Color', group = 'LINE COLORS')

pendingOrderLevelInput = input.string('50%', 'Pending Order Level', group = 'STRATEGY', options = ['25%', '50%', '60%', '70%'])
tpMultiplierInput = input.float(0.0, 'Extended TP (%)', group = 'STRATEGY', minval = 0.0, step = 0.1)
minTrendPipsInput = input.float(0.0, 'Minimum Trend (pips)', group = 'FILTERS', minval = 0.0, step = 1.0, tooltip = 'If trend is below this value, start/end will be gray and pending order will not be placed')
useEmaFilterInput = input.bool(false, 'Use EMA Filter', group = 'FILTERS', tooltip = 'If active, open LONG only if EMA50 > EMA200, SHORT only if EMA50 < EMA200')
extendedTrendInput = input.bool(false, 'Extended Trend', group = 'FILTERS', tooltip = 'If active, trend remains in formation until a candle closes beyond the dynamic 50%. When this happens, end freezes but trend can continue.')
enableAlertsInput = input.bool(false, 'Enable Alerts', group = 'ALERTS', tooltip = 'If active, sends alerts when a pending order is created/updated or when filled')

getPendingOrderLevel(pointA, pointB) =>
    float level = na
    if pendingOrderLevelInput == '25%'
        level := pointB + (pointA - pointB) * 0.25
    else if pendingOrderLevelInput == '50%'
        level := pointB + (pointA - pointB) * 0.50
    else if pendingOrderLevelInput == '60%'
        level := pointB + (pointA - pointB) * 0.60
    else if pendingOrderLevelInput == '70%'
        level := pointB + (pointA - pointB) * 0.70
    level

getExtendedTP(pointA, pointB, isBullish) =>
    float tp = na
    if tpMultiplierInput > 0.0
        if isBullish
            tp := pointA + (pointB - pointA) * (1.0 + tpMultiplierInput / 100.0)
        else
            tp := pointB - (pointA - pointB) * (tpMultiplierInput / 100.0)
    else
        tp := pointB
    tp

calculatePips(price1, price2) =>
    float diff = math.abs(price1 - price2)
    float pipValue = 0.0001
    if syminfo.type == "forex"
        if str.contains(syminfo.ticker, "JPY") or str.contains(syminfo.tickerid, "JPY")
            pipValue := 0.01
        else
            pipValue := 0.0001
    else
        pipValue := syminfo.mintick
    diff / pipValue

isTrendValid(pointA, pointB) =>
    if minTrendPipsInput <= 0.0
        true
    else
        float trendPips = calculatePips(pointA, pointB)
        trendPips >= minTrendPipsInput

ema50 = ta.ema(close, 50)
ema200 = ta.ema(close, 200)

isEmaFilterValid(isBullish) =>
    if not useEmaFilterInput
        true
    else
        if isBullish
            ema50 > ema200
        else
            ema50 < ema200

sendPendingOrderAlert(direction, entryPrice, slPrice, tpPrice, isUpdate) =>
    if enableAlertsInput
        string message = isUpdate ? "Pending Updated - " : "Pending Created - "
        message += direction + "\n"
        message += "Entry: " + str.tostring(entryPrice, format.mintick) + "\n"
        message += "SL: " + str.tostring(slPrice, format.mintick) + "\n"
        message += "TP: " + str.tostring(tpPrice, format.mintick)
        alert(message, alert.freq_once_per_bar)

sendOrderFilledAlert(direction, entryPrice) =>
    if enableAlertsInput
        string message = "Order Opened - " + direction + "\n"
        message += "Entry: " + str.tostring(entryPrice, format.mintick)
        alert(message, alert.freq_once_per_bar)

isRedCandle(index) => close[index] < open[index]

isGreenCandle(index) => close[index] > open[index]

isBearishTrend() =>
    isRedCandle(0) and isRedCandle(1) and isRedCandle(2) and isRedCandle(3) and isRedCandle(4)

isBullishTrend() =>
    isGreenCandle(0) and isGreenCandle(1) and isGreenCandle(2) and isGreenCandle(3) and isGreenCandle(4)

var bool activeBearishTrend = false
var bool activeBullishTrend = false
var float pointA = na
var float pointB = na
var int barA = na
var int barB = na
var label labelA = na
var label labelB = na
var label pendingOrderLabel = na
var line lineStart = na
var line lineEnd = na
var line line50 = na
var line line25 = na
var line line618 = na
var line line786 = na
var bool trendCompleted = false
var string pendingOrderId = na
var bool isBullishOrder = false
var float finalPointA = na
var float finalPointB = na
var float lastLevel50 = na
var int lastOpenTrades = 0
var bool currentTrendValid = true
var bool endFrozen = false
// New variables for pending entry/exit signals (executed only at bar close)
var bool pendingShortEntry = false
var bool pendingLongEntry = false
var float pendingEntryPrice = na
var float pendingStopLoss = na
var float pendingTakeProfit = na

if isBearishTrend() and not isBearishTrend()[1] and (not activeBearishTrend or trendCompleted)
    activeBearishTrend := true
    activeBullishTrend := false
    trendCompleted := false
    lastOpenTrades := 0
    endFrozen := false
    
    if high[4] >= high[5]
        pointA := high[4]
        barA := bar_index - 4
    else
        pointA := high[5]
        barA := bar_index - 5
    
    pointB := math.min(low[0], math.min(low[1], math.min(low[2], math.min(low[3], low[4]))))
    
    if pointB == low[0]
        barB := bar_index
    else if pointB == low[1]
        barB := bar_index - 1
    else if pointB == low[2]
        barB := bar_index - 2
    else if pointB == low[3]
        barB := bar_index - 3
    else if pointB == low[4]
        barB := bar_index - 4
    
    currentTrendValid := isTrendValid(pointA, pointB)
    
    if showLabelsInput
        color labelAColor = currentTrendValid ? RED : color.gray
        labelA := label.new(barA, pointA, 'start', xloc.bar_index, yloc.price, labelAColor, textcolor = color.white, 
                           size = labelSizeInput == 'tiny' ? size.tiny : labelSizeInput == 'small' ? size.small : labelSizeInput == 'normal' ? size.normal : labelSizeInput == 'large' ? size.large : size.huge, 
                           style = label.style_label_down)
        color labelBColor = currentTrendValid ? RED : color.gray
        labelB := label.new(barB, pointB, 'end', xloc.bar_index, yloc.price, labelBColor, textcolor = color.white,
                           size = labelSizeInput == 'tiny' ? size.tiny : labelSizeInput == 'small' ? size.small : labelSizeInput == 'normal' ? size.normal : labelSizeInput == 'large' ? size.large : size.huge,
                           style = label.style_label_up)
    
    if showStartEndLinesInput
        lineStart := line.new(chart.point.from_index(barA, pointA), chart.point.from_index(bar_index, pointA), color = colorStartEndLineInput, width = 1, style = line.style_solid, extend = extend.none)
        lineEnd := line.new(chart.point.from_index(barB, pointB), chart.point.from_index(bar_index, pointB), color = colorStartEndLineInput, width = 1, style = line.style_solid, extend = extend.none)
    
    if show50LineInput
        float level50 = pointB + (pointA - pointB) * 0.50
        line50 := line.new(chart.point.from_index(barA, level50), chart.point.from_index(bar_index, level50), color = color50LineInput, width = 1, style = line.style_solid, extend = extend.none)
    
    if show25LineInput
        float level25 = pointB + (pointA - pointB) * 0.25
        line25 := line.new(chart.point.from_index(barA, level25), chart.point.from_index(bar_index, level25), color = color25LineInput, width = 1, style = line.style_solid, extend = extend.none)
    
    if show618LineInput
        float level618 = pointB + (pointA - pointB) * 0.60
        line618 := line.new(chart.point.from_index(barA, level618), chart.point.from_index(bar_index, level618), color = color60LineInput, width = 1, style = line.style_solid, extend = extend.none)
    
    if show786LineInput
        float level786 = pointB + (pointA - pointB) * 0.70
        line786 := line.new(chart.point.from_index(barA, level786), chart.point.from_index(bar_index, level786), color = color70LineInput, width = 1, style = line.style_solid, extend = extend.none)

if activeBearishTrend and not trendCompleted
    float level50 = pointB + (pointA - pointB) * 0.50
    bool shouldComplete = false
    
    // Use historical values to prevent flickering - check completed previous bar
    if extendedTrendInput
        if barstate.isconfirmed and close[1] > level50
            shouldComplete := true
            endFrozen := true
    else
        if barstate.isconfirmed and close[1] > open[2]
            shouldComplete := true
    
    if shouldComplete
        if not endFrozen
            trendCompleted := true
        // Use historical low[1] for stable signal calculation
        if not endFrozen and low[1] < pointB
            pointB := low[1]
            barB := bar_index - 1
            currentTrendValid := isTrendValid(pointA, pointB)
            if showLabelsInput
                if not na(labelA)
                    label.delete(labelA)
                    color labelAColor = currentTrendValid ? RED : color.gray
                    labelA := label.new(barA, pointA, 'start', xloc.bar_index, yloc.price, labelAColor, textcolor = color.white,
                                       size = labelSizeInput == 'tiny' ? size.tiny : labelSizeInput == 'small' ? size.small : labelSizeInput == 'normal' ? size.normal : labelSizeInput == 'large' ? size.large : size.huge,
                                       style = label.style_label_down)
                if not na(labelB)
                    label.delete(labelB)
                    color labelBColor = currentTrendValid ? RED : color.gray
                    labelB := label.new(barB, pointB, 'end', xloc.bar_index, yloc.price, labelBColor, textcolor = color.white,
                                       size = labelSizeInput == 'tiny' ? size.tiny : labelSizeInput == 'small' ? size.small : labelSizeInput == 'normal' ? size.normal : labelSizeInput == 'large' ? size.large : size.huge,
                                       style = label.style_label_up)
            if show50LineInput and not na(line50)
                level50 := pointB + (pointA - pointB) * 0.50
                line.set_xy1(line50, barA, level50)
                line.set_xy2(line50, bar_index, level50)
            if show25LineInput and not na(line25)
                float level25 = pointB + (pointA - pointB) * 0.25
                line.set_xy1(line25, barA, level25)
                line.set_xy2(line25, bar_index, level25)
            if show618LineInput and not na(line618)
                float level618 = pointB + (pointA - pointB) * 0.60
                line.set_xy1(line618, barA, level618)
                line.set_xy2(line618, bar_index, level618)
            if show786LineInput and not na(line786)
                float level786 = pointB + (pointA - pointB) * 0.70
                line.set_xy1(line786, barA, level786)
                line.set_xy2(line786, bar_index, level786)
        
        finalPointA := pointA
        finalPointB := pointB
        
        // Store entry signal instead of executing immediately - will execute at bar close
        if currentTrendValid and isEmaFilterValid(false) and barstate.isconfirmed
            if not na(pendingOrderId)
                strategy.cancel(pendingOrderId)
                pendingOrderId := na
            
            float entryLevel = getPendingOrderLevel(pointA, pointB)
            pendingShortEntry := true
            pendingLongEntry := false
            pendingEntryPrice := entryLevel
            pendingStopLoss := pointA
            pendingTakeProfit := pointB
            pendingOrderId := "FibShort"
            isBullishOrder := false
            lastLevel50 := entryLevel
            
            sendPendingOrderAlert("SHORT", entryLevel, pointA, pointB, false)
            
            if showPendingOrdersInput
                if not na(pendingOrderLabel)
                    label.delete(pendingOrderLabel)
                float shortPendingOffset = (pointA - pointB) * 0.25
                float shortPendingPrice = pointB - shortPendingOffset
                pendingOrderLabel := label.new(bar_index, shortPendingPrice, "SHORT Pending\nEntry: " + str.tostring(entryLevel, format.mintick) + "\nSL: " + str.tostring(pointA, format.mintick) + "\nTP: " + str.tostring(pointB, format.mintick), 
                                             xloc.bar_index, yloc.price, color.red, textcolor = color.white, style = label.style_label_up, size = size.small)
        
        activeBearishTrend := false
    else
        // Visual updates during candle (repainting) - uses current bar data
        if not endFrozen and low[0] < pointB
            pointB := low[0]
            barB := bar_index
            currentTrendValid := isTrendValid(pointA, pointB)
            if showLabelsInput
                if not na(labelA)
                    label.delete(labelA)
                    color labelAColor = currentTrendValid ? RED : color.gray
                    labelA := label.new(barA, pointA, 'start', xloc.bar_index, yloc.price, labelAColor, textcolor = color.white,
                                       size = labelSizeInput == 'tiny' ? size.tiny : labelSizeInput == 'small' ? size.small : labelSizeInput == 'normal' ? size.normal : labelSizeInput == 'large' ? size.large : size.huge,
                                       style = label.style_label_down)
                if not na(labelB)
                    label.delete(labelB)
                    color labelBColor = currentTrendValid ? RED : color.gray
                    labelB := label.new(barB, pointB, 'end', xloc.bar_index, yloc.price, labelBColor, textcolor = color.white,
                                       size = labelSizeInput == 'tiny' ? size.tiny : labelSizeInput == 'small' ? size.small : labelSizeInput == 'normal' ? size.normal : labelSizeInput == 'large' ? size.large : size.huge,
                                       style = label.style_label_up)
            if showStartEndLinesInput and not na(lineStart)
                line.set_xy1(lineStart, barA, pointA)
                line.set_xy2(lineStart, bar_index, pointA)
            if showStartEndLinesInput and not na(lineEnd)
                line.set_xy1(lineEnd, barB, pointB)
                line.set_xy2(lineEnd, bar_index, pointB)
            if show50LineInput and not na(line50)
                level50 := pointB + (pointA - pointB) * 0.50
                line.set_xy1(line50, barA, level50)
                line.set_xy2(line50, bar_index, level50)
                if showPendingOrdersInput and not na(pendingOrderLabel) and not isBullishOrder
                    label.delete(pendingOrderLabel)
                    float pendingLevel = getPendingOrderLevel(pointA, pointB)
                    float shortPendingOffset = (pointA - pointB) * 0.25
                    float shortPendingPrice = pointB - shortPendingOffset
                    pendingOrderLabel := label.new(bar_index, shortPendingPrice, "SHORT Pending\nEntry: " + str.tostring(pendingLevel, format.mintick) + "\nSL: " + str.tostring(pointA, format.mintick) + "\nTP: " + str.tostring(pointB, format.mintick), 
                                                 xloc.bar_index, yloc.price, color.red, textcolor = color.white, style = label.style_label_up, size = size.small)
                    sendPendingOrderAlert("SHORT", pendingLevel, pointA, pointB, true)
            if show25LineInput and not na(line25)
                float level25 = pointB + (pointA - pointB) * 0.25
                line.set_xy1(line25, barA, level25)
                line.set_xy2(line25, bar_index, level25)
            if show618LineInput and not na(line618)
                float level618 = pointB + (pointA - pointB) * 0.60
                line.set_xy1(line618, barA, level618)
                line.set_xy2(line618, bar_index, level618)
            if show786LineInput and not na(line786)
                float level786 = pointB + (pointA - pointB) * 0.70
