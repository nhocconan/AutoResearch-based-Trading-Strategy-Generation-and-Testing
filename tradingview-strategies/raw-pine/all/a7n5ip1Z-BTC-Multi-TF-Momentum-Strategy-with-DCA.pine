//@version=5
strategy("BTC Multi-TF Momentum Strategy with DCA", overlay=true,
     initial_capital=10000,
     commission_type=strategy.commission.percent,
     commission_value=0.05,
     pyramiding=3)

// ----------------
// Inputs
// ----------------

rsiLen = input.int(14)
stochLen = input.int(14)
atrLen = input.int(14)

riskPercent = input.float(0.10)

oversold = input.int(20)
overbought = input.int(80)

stopATR = input.float(1.5)
tpATR = input.float(1.0)
trailATR = input.float(0.8)

dca1ATR = input.float(0.5)
dca2ATR = input.float(1.0)

// ----------------
// Higher TF Trend
// ----------------

ema1h = request.security(syminfo.tickerid, "60", ta.ema(close,200))

bullTrend = close > ema1h
bearTrend = close < ema1h

// ----------------
// 15m RSI
// ----------------

rsi15 = request.security(syminfo.tickerid,"15", ta.rsi(close,rsiLen))

// ----------------
// 3m Stoch RSI
// ----------------

rsi3 = request.security(syminfo.tickerid,"3", ta.rsi(close,rsiLen))

k = ta.stoch(rsi3,rsi3,rsi3,stochLen)
d = ta.sma(k,3)

longSignal = ta.crossover(k,d) and k < oversold
shortSignal = ta.crossunder(k,d) and k > overbought

// ----------------
// Entry Conditions
// ----------------

longCond =
     bullTrend and
     rsi15 < 40 and
     longSignal

shortCond =
     bearTrend and
     rsi15 > 60 and
     shortSignal

// ----------------
// ATR
// ----------------

atr = ta.atr(atrLen)

qtyTotal = strategy.equity * riskPercent / close

qtyBase = qtyTotal * 0.4
qtyDCA1 = qtyTotal * 0.3
qtyDCA2 = qtyTotal * 0.3

// ----------------
// Base Entry
// ----------------

if longCond
    strategy.entry("Long Base", strategy.long, qty=qtyBase)

if shortCond
    strategy.entry("Short Base", strategy.short, qty=qtyBase)

// ----------------
// DCA Entries
// ----------------

longDCA1 = strategy.position_avg_price - atr * dca1ATR
longDCA2 = strategy.position_avg_price - atr * dca2ATR

shortDCA1 = strategy.position_avg_price + atr * dca1ATR
shortDCA2 = strategy.position_avg_price + atr * dca2ATR

if strategy.position_size > 0
    strategy.entry("Long DCA1", strategy.long, qty=qtyDCA1, limit=longDCA1)
    strategy.entry("Long DCA2", strategy.long, qty=qtyDCA2, limit=longDCA2)

if strategy.position_size < 0
    strategy.entry("Short DCA1", strategy.short, qty=qtyDCA1, limit=shortDCA1)
    strategy.entry("Short DCA2", strategy.short, qty=qtyDCA2, limit=shortDCA2)

// ----------------
// Stop / Profit
// ----------------

stopLong = strategy.position_avg_price - atr * stopATR
stopShort = strategy.position_avg_price + atr * stopATR

tpLong = strategy.position_avg_price + atr * tpATR
tpShort = strategy.position_avg_price - atr * tpATR

trail = atr * trailATR

strategy.exit("L Partial", from_entry="Long Base", qty_percent=50, limit=tpLong, stop=stopLong)
strategy.exit("L Trail", from_entry="Long Base", qty_percent=50, trail_points=trail, stop=stopLong)

strategy.exit("S Partial", from_entry="Short Base", qty_percent=50, limit=tpShort, stop=stopShort)
strategy.exit("S Trail", from_entry="Short Base", qty_percent=50, trail_points=trail, stop=stopShort)

