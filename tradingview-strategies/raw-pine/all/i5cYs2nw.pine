//@version=5
strategy("RSI Filtreli Al-Sat Stratejisi", overlay=true, initial_capital=10000)

// --- KULLANICI GİRİŞLERİ ---
ma_length = input.int(50, "MA Uzunluğu", minval=1)
rsi_length = input.int(14, "RSI Uzunluğu", minval=1)

// --- GÖSTERGELERİN HESAPLANMASI ---
ma50 = ta.sma(close, ma_length)
rsi = ta.rsi(close, rsi_length)

// --- SİNYAL KOŞULLARI ---
// ALIM KOŞULU:
// 1. RSI 50'yi yukarı keser VE RSI 70'in altındaysa
// 2. Fiyat MA 50'nin üzerindeyse
buy_condition = ta.crossover(rsi, 50) and (rsi < 70) and (close > ma50)

// SATIM KOŞULU:
// 1. RSI 40'ı aşağı keserse VEYA
// 2. Fiyat MA 50'yi aşağı keserse
sell_condition = ta.crossunder(rsi, 45) or ta.crossunder(close, ma50)

// --- İŞLEM YÜRÜTME VE GÖRSELLEŞTİRME ---
if buy_condition
    strategy.entry("ALIM", strategy.long)

if sell_condition
    strategy.close("ALIM", comment="SATIM")

plot(ma50, title="MA 50", color=color.blue, linewidth=2)

plotshape(series=buy_condition ? close : na, title="AL", location=location.belowbar, color=color.rgb(65, 172, 100), style=shape.triangleup, size=size.small)
plotshape(series=sell_condition ? close : na, title="SAT", location=location.abovebar, color=color.rgb(255, 69, 58), style=shape.triangledown, size=size.small)

