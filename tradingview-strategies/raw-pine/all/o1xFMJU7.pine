//@version=6
strategy(title="SMPivot Gaussian Trend Strategy [Js.K]", shorttitle="SMPivot GT", overlay = true, margin_long=0, margin_short=0,default_qty_type=strategy.percent_of_equity, default_qty_value=100, process_orders_on_close=true, initial_capital=10000)

// 输入
length = input.int(30, 'Gaussian Length', group = 'Gaussian')
Gaussian_plot = input.bool(true, "Gaussian Scatterplot", group = 'Gaussian ')

// 启用多/空
enable_long_strategy = input.bool(true, title = 'Enable Long Strategy', inline = '1')
long_stoploss_value = input.float(defval = 1, title = 'Long SL %', minval = 0.1, inline = '2')
long_stoploss_percentage = close * (long_stoploss_value / 100) / syminfo.mintick
long_takeprofit_value = input.float(defval = 30, title = 'Long TP %', minval = 0.1, inline = '2')
long_takeprofit_percentage = close * (long_takeprofit_value / 100) / syminfo.mintick

enable_short_strategy = input.bool(true, title = 'Enable Short Strategy', inline = '3')
short_stoploss_value = input.float(defval = 1, title = 'Short SL %', minval = 0.1, inline = '4')
short_stoploss_percentage = close * (short_stoploss_value / 100) / syminfo.mintick
short_takeprofit_value = input.float(defval = 30, title = 'Short TP %', minval = 0.1, inline = '4')
short_takeprofit_percentage = close * (short_takeprofit_value / 100) / syminfo.mintick

// 颜色
col_up = input.color(#00bcd4, title="Bull", inline="1", group = 'Smart Money Pivot')
col_dn = input.color(#ff9800, title="Bear", inline="1", group = 'Smart Money Pivot')

// 变量
var float UpdatedHigh = na
var float UpdatedLow = na
var int HighIndex = na
var bool phActive = false
var bool plActive = false
var int LowIndex = na
int Sync = bar_index
bool BUY = false
bool SELL = false
int period = input.int(20, 'Pivot Length', group = 'Smart Money Pivot')

// 平滑函数
Gaussian(src, length) =>
    sum_w = 0.0
    sum_wx = 0.0
    sum_wy = 0.0
    for i = 0 to length - 1
        w = math.pow(1 - math.pow(i / length, 3), 3)
        sum_w += w
        sum_wx += w * i
        sum_wy += w * src[i]
    a = sum_wy / sum_w
    b = sum_wx / sum_w
    a + b / (length - 1) / 2000

// 高斯移动平均函数
GaussianMA(src, length) =>
    h_l = array.new<float>(length)
    float gma = 0.0
    float sumOfWeights = 0.0
    float sigma = (ta.atr(length) + ta.stdev(close, length)) / 2
    float highest = 0.0
    float lowest = 0.0
    float smoothed = 0.0
    for i = 0 to length - 1
        h_l.push(close[i])
        highest := h_l.max()
        lowest := h_l.min()
        weight = math.exp(-math.pow(((i - (length - 1)) / (2 * sigma)), 2) / 2)
        value = math.max(highest[i], highest) + math.min(lowest[i], lowest)
        gma := gma + (value * weight)
        sumOfWeights += weight
    gma := (gma / sumOfWeights) / 2
    smoothed := Gaussian(gma, 10)
    [gma, smoothed]

// 计算高斯移动平均和低频平滑的高斯移动平均
[gma, smoothed] = GaussianMA(close, length)

// 绘制高斯移动平均
plot(gma, "Gaussian Moving Average", Gaussian_plot ? col_up : na, 1, plot.style_cross)
plot(smoothed, "Smoothed Gaussian Moving Average", smoothed > smoothed[2] ? col_up : col_dn)

// 枢轴点计算
PH = ta.pivothigh(high, period, period)
PL = ta.pivotlow(low, period, period)
ScrHigh = high
ScrLow = low

if ta.change(fixnan(PH)) != 0
    UpdatedHigh := PH
    phActive := true
    HighIndex := Sync - period

if ta.change(fixnan(PL)) != 0
    UpdatedLow := PL
    plActive := true
    LowIndex := Sync - period

// LONG 信号逻辑
if ScrHigh > UpdatedHigh and ScrHigh > smoothed and phActive
    BUY := true
    phActive := false

// SHORT 信号逻辑
if ScrLow < UpdatedLow and ScrLow < smoothed and plActive
    SELL := true
    plActive := false

// 执行交易
if SELL and enable_short_strategy and strategy.position_size >= -1
    strategy.close('Short')
if BUY and enable_long_strategy and strategy.position_size <= 1
    strategy.entry('Long', strategy.long, alert_message = 'Long Entry')
    strategy.exit('Long', from_entry = 'Long', loss = long_stoploss_percentage, profit = long_takeprofit_percentage, alert_loss = 'Long SL', alert_profit = 'Long TP', comment_loss = 'Long SL', comment_profit = 'Long TP')

if BUY and enable_long_strategy and strategy.position_size <= 1
    strategy.close('Long')
if SELL and enable_short_strategy and strategy.position_size >= -1
    strategy.entry('Short', strategy.short, alert_message = 'Short Entry')
    strategy.exit('Short', from_entry = 'Short', loss = short_stoploss_percentage, profit = short_takeprofit_percentage, alert_loss = 'Short SL', alert_profit = 'Short TP', comment_loss = 'Short SL', comment_profit = 'Short TP')

// Plot Pivot Points and Trend Change Markers
if BUY
    line.new(HighIndex, UpdatedHigh, bar_index, UpdatedHigh, color = col_up, style = line.style_solid, width = 1)
    label.new(x = HighIndex + (bar_index - HighIndex) / 2, y = UpdatedHigh + syminfo.mintick * 5, text = "BoS PH", color = col_up, textcolor = color.white, style = label.style_none, size = size.tiny)

if SELL
    line.new(LowIndex, UpdatedLow, bar_index, UpdatedLow, color = col_dn, style = line.style_solid, width = 1)
    label.new(x = LowIndex + (bar_index - LowIndex) / 2, y = UpdatedLow - syminfo.mintick * 5, text = "BoS PL", color = col_dn, textcolor = color.white, style = label.style_none, size = size.tiny)

plotshape(smoothed, "", shape.diamond, location.absolute, color = ta.crossover(smoothed, smoothed[2]) ? col_up : ta.crossunder(smoothed, smoothed[2]) ? col_dn : na, offset = 0, size = size.tiny)

