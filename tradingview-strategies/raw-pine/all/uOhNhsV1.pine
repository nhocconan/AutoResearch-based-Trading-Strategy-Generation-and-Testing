//@version=6
strategy("週一普跌策略",
 overlay=true,
 default_qty_type=strategy.cash,
 default_qty_value=100,
 initial_capital=1000,
 pyramiding=0,
 margin_long=0,
 margin_short=0
 )

// 判斷時間
t = time(timeframe.period, "Asia/Taipei")
isMonday = dayofweek(t) == dayofweek.sunday
is8am = hour(t) == 23 and minute(t) == 0
// 記錄是否已掛 TP/SL
var bool ordersPlaced = false

// 固定% 止盈止損
tpPercent = input.float(0.1,'止盈', step=0.01)  // 止盈
slPercent = input.float(0.01,'止損', step=0.01)  // 止損

// 進場：每週一 08:00 第一根 K
enterShort = isMonday and is8am and barstate.isnew

// 計算本次下單金額 = 當前全部 equity
cashToUse = strategy.equity

if (enterShort and strategy.position_size == 0)
    entryPrice = close[1]
    qty = strategy.equity / entryPrice   // 全倉
    strategy.entry("MonShort", strategy.short, qty = qty) // 市價進場
    ordersPlaced := false

// 持倉後掛 TP/SL
if (strategy.position_size < 0 and not ordersPlaced)
    avg = strategy.position_avg_price
    tpPrice = avg * (1 - tpPercent)
    slPrice = avg * (1 + slPercent)

    strategy.exit("Exit", "MonShort", stop = slPrice, limit = tpPrice)
    ordersPlaced := true

// 平倉後 reset
if (strategy.position_size == 0)
    ordersPlaced := false

