//@version=5
strategy("Estrategia Timing SMA 10 (Meb Faber/Cárpatos) [MENSUAL]", overlay=true, initial_capital=10000, default_qty_type=strategy.percent_of_equity, default_qty_value=100)

// --- CONFIGURACIÓN ---
length = input.int(10, minval=1, title="Longitud de la Media (Meses)")
// Forzamos la fuente a ser el cierre, ya que Cárpatos usa cierres mensuales.
src_input = close 

// --- CÁLCULOS MULTI-TIMEFRAME (MTF) ---
// Aquí es donde ocurre la magia: solicitamos datos del timeframe "1M" (1 Mes)
// independientemente de en qué gráfico estés.

// 1. Obtenemos el precio de cierre actual de la vela MENSUAL
monthly_close = request.security(syminfo.tickerid, "1M", src_input)

// 2. Obtenemos la SMA calculada sobre velas MENSUALES
monthly_ma = request.security(syminfo.tickerid, "1M", ta.sma(src_input, length))

// --- LÓGICA DE TRADING (Meb Faber) ---
// Comparamos el cierre mensual contra la media mensual
longCondition = monthly_close > monthly_ma
exitCondition = monthly_close < monthly_ma

// --- EJECUCIÓN ---
if (longCondition)
    strategy.entry("Entrada", strategy.long)

if (exitCondition)
    strategy.close("Entrada", comment="A Cash")

// --- VISUALIZACIÓN ---
// Dibujamos la media móvil mensual. 
// Se verá como una escalera si estás en gráfico diario (porque el valor es constante todo el mes).
plot(monthly_ma, "SMA 10 Meses", color=color.blue, linewidth=2)

// Coloreamos el fondo
bgcolor(strategy.position_size > 0 ? color.new(color.green, 90) : color.new(color.red, 90))

