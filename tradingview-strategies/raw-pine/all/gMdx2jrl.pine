//@version=6
strategy('Golden Cross 50/200 EMA', 
     overlay=true, 
     initial_capital=10000, 
     default_qty_type=strategy.percent_of_equity, 
     default_qty_value=10,
     margin_long=0,
     commission_type=strategy.commission.percent, 
     commission_value=0.1)

// EMA Parameters
ema50 = ta.ema(close, 50)
ema200 = ta.ema(close, 200)

// Detect crosses
bullCross = ta.crossover(ema50, ema200)
bearCross = ta.crossunder(ema50, ema200)

// Calculate recent swing low
swingLow = ta.lowest(low, 15)

// Variable to store swing low at crossover moment
var float entryStopLoss = na

// IMPROVED ENTRY CONDITION
if bullCross
    entryStopLoss := swingLow
    strategy.entry('Long', strategy.long, comment='EMA Cross Entry')

// EXIT CONDITIONS
if bearCross
    strategy.close('Long', comment='Exit Bear Cross')

if strategy.position_size > 0 and low < entryStopLoss
    strategy.close('Long', comment='SL Hit')

// VISUALIZATION
plot(ema50, color=color.new(#0a477c, 0), title='EMA 50', linewidth=2)
plot(ema200, color=color.new(#a91a1a, 0), title='EMA 200', linewidth=2)

plotshape(bullCross, style=shape.triangleup, location=location.belowbar, 
          color=color.new(color.green, 0), size=size.normal, title='Buy Signal')
plotshape(bearCross, style=shape.triangledown, location=location.abovebar, 
          color=color.new(color.red, 0), size=size.normal, title='Sell Signal')

// Stop Loss Line
plot(strategy.position_size > 0 ? entryStopLoss : na, 
     color=color.new(#c88212, 0), style=plot.style_linebr, 
     linewidth=2, title='Stop Loss Level')

// Alerts
alertcondition(bullCross, title='Long Entry', 
               message='EMA Cross - Long entry with 10% capital')
alertcondition(bearCross, title='Bearish Cross Exit', 
               message='Bearish cross - Position close')
alertcondition(strategy.position_size > 0 and low < entryStopLoss, 
               title='Stop Loss Triggered', 
               message='Stop Loss reached')

