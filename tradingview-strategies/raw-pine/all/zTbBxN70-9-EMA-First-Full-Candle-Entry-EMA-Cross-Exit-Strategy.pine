//@version=5
strategy("9 EMA First Full Candle Entry + EMA Cross Exit (Strategy)",
     overlay=true,
     pyramiding=0,
     process_orders_on_close=true)

// === Inputs
emaLen = input.int(9, "EMA Length", minval=1)

// === EMA
ema9 = ta.ema(close, emaLen)

// === "Fully above / fully below" definitions
fullyAbove = low > ema9
fullyBelow = high < ema9

// === Only take the FIRST qualifying candle while flat
flat = strategy.position_size == 0

entryLong  = flat and fullyAbove
entryShort = flat and fullyBelow

// === Exits (after entry)
// Long exits when price crosses DOWN through EMA
exitLong  = strategy.position_size > 0 and ta.crossunder(close, ema9)
// Short exits when price crosses UP through EMA
exitShort = strategy.position_size < 0 and ta.crossover(close, ema9)

// === Orders
if entryLong
    strategy.entry("L", strategy.long)

if entryShort
    strategy.entry("S", strategy.short)

if exitLong
    strategy.close("L")

if exitShort
    strategy.close("S")

// === Visuals (exactly what you described)
// 1) Highlight ONLY the entry candle yellow
barcolor((entryLong or entryShort) ? color.yellow : na)

// 2) Plot EMA: normal orange, but turn it yellow ONLY on the exit bar
emaColor = (exitLong or exitShort) ? color.yellow : color.orange
plot(ema9, "9 EMA", color=emaColor, linewidth=2)

