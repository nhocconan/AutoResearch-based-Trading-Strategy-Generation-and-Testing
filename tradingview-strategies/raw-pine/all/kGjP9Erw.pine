//@version=5
strategy("Ichimoku Crosses_RSI_AIT", overlay=true)

// 사용자 입력
tenkanLength = input(21, title="Tenkan-sen 기간")
kijunLength = input(120, title="Kijun-sen 기간")
senkouBLength = input(52, title="Senkou Span B 기간")
rsiLength = input(14, title="RSI 기간")
rsiLongLevel = input(60, title="RSI 롱 진입 수준")
rsiShortLevel = input(40, title="RSI 숏 진입 수준")

// Ichimoku Cloud 계산
tenkan = ta.sma(close, tenkanLength)
kijun = ta.sma(close, kijunLength)
senkouA = (tenkan + kijun) / 2
senkouB = ta.sma(close, senkouBLength)
chikou = close[26]

// RSI 계산
vrsi = ta.rsi(close, rsiLength)

// 색상 설정
redcolor = #D2042D
orangecolor = #FF7900
yellowcolor = #FFE812
greencolor = #2DD204
navybluecolor = #0088CC
bluecolor = #0033A0
purplecolor = #6524FF

// 진입 조건
longCondition = ta.crossover(tenkan, kijun) and vrsi >= rsiLongLevel
shortCondition = ta.crossunder(tenkan, kijun) and vrsi <= rsiShortLevel

// 청산 조건
exitLongCondition = ta.crossunder(tenkan, kijun)
exitShortCondition = ta.crossover(tenkan, kijun)

if (longCondition)
    strategy.entry("Long", strategy.long)
if (shortCondition)
    strategy.entry("Short", strategy.short)
if (exitLongCondition)
    strategy.close("Long")
if (exitShortCondition)
    strategy.close("Short")

// 라인 표시
plot(kijun, title="Kijun-sen", color=color.white, linewidth=1)
plot(tenkan, title="Tenkan-sen", color=tenkan > kijun ? greencolor : redcolor, linewidth=2)

// 포지션 진입 화살표 표시
plotshape(series=longCondition, title="Long", location=location.belowbar, color=yellowcolor, style=shape.triangleup, size=size.tiny)
plotshape(series=shortCondition, title="Short", location=location.abovebar, color=color.fuchsia, style=shape.triangledown, size=size.tiny)

