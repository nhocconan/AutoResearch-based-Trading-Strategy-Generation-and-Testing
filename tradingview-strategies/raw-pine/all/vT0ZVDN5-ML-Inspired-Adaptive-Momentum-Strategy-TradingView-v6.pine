//@version=6
strategy(
     title = "ML-Inspired Adaptive Momentum Strategy",
     overlay = true,
     initial_capital = 10000,
     commission_type = strategy.commission.percent,
     commission_value = 0.1,
     slippage = 2,
     default_qty_type = strategy.percent_of_equity,
     default_qty_value = 5
)


// -------- Utility --------
clamp(val, minVal, maxVal) =>
    math.min(math.max(val, minVal), maxVal)


// -------- Inputs --------
emaLen      = input.int(50, "EMA Length")
atrLen      = input.int(14, "ATR Length")
threshold   = input.float(0.3, "Signal Threshold")


// -------- Core Logic --------
emaValue = ta.ema(close, emaLen)
emaSlope = emaValue - emaValue[1]


atrValue = ta.atr(atrLen)


// Normalize slope by volatility (ML-style feature scaling)
rawScore = emaSlope / atrValue
score    = clamp(rawScore, -1.0, 1.0)


// -------- Signals --------
longCond  = score > threshold
shortCond = score < -threshold


if longCond
    strategy.entry("Long", strategy.long)


if shortCond
    strategy.entry("Short", strategy.short)


// -------- Plot --------
plot(emaValue, title="EMA", linewidth=2)

