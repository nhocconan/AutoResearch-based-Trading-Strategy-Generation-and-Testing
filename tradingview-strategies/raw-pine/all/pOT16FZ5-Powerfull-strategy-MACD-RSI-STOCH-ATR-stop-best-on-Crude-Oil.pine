//@version=2
strategy("Simple strat", shorttitle="Simple Strat", overlay=true)

// X001TK MACD + Stochastic + RSI Strategy
//
// 
// This strategy combines the special approach in stochastic and rsi
// strategy to buy once stochastic and rsi closes above center line "50" level 
// with a MACD strategy to buy when the MACD value goes above Signal line.
//
//
// This strategy goes long if the MACD goes above Signal and stochastic 
// goes above 50 level and rsi goes above 50 level.
//
// This pure strategy does not have any
// stop loss or take profit money management logic.
//
// Exit rule is simple. We close the position once MACD goes below Signal line
//
// 
// 
//
// Input
fastMAlen = input(12, minval=1, title="MACD fast moving average")
slowMAlen=input(26,minval=1, title="MACD slow moving average")
signalMACDlen = input(9,minval=1, title="MACD signal line moving average")
StochLength = input(14, minval=1, title="Stochastic Length")
switch=input(true, title="Enable MACD Bar Color?")
length = input(10, minval=1)
atr = rma(tr(true), length)
tp = input(6)
sl = input(2)


// === INPUT BACKTEST RANGE ===
FromMonth = input(defval = 1, title = "From Month", minval = 1, maxval = 12)
FromDay   = input(defval = 1, title = "From Day", minval = 1, maxval = 31)
FromYear  = input(defval = 2014, title = "From Year", minval = 2000)
ToMonth   = input(defval = 2, title = "To Month", minval = 1, maxval = 12)
ToDay     = input(defval = 1, title = "To Day", minval = 1, maxval = 31)
ToYear    = input(defval = 2019, title = "To Year", minval = 2017)



// === FUNCTION EXAMPLE ===
start     = timestamp(FromYear, FromMonth, FromDay, 00, 00)  // backtest start window
finish    = timestamp(ToYear, ToMonth, ToDay, 23, 59)        // backtest finish window
window()  => time >= start and time <= finish ? true : false // create function "within window of time"

// MACD Calculation
MACD = ema(close, fastMAlen) - ema(close, slowMAlen)
signalMACD = ema(MACD, signalMACDlen)
delta = MACD - signalMACD
fastMA = ema(close,fastMAlen)
slowMA = ema(close,slowMAlen)

// Stochastic Calculation
smoothK = input(3, title="Smoothing of Stochastic %K ")
smoothD = input(3, title="Moving Average of Stochastic %K")
k = sma(stoch(close, high, low, StochLength), smoothK)
d = sma(k, smoothD)

//RSI Calculation
xRSI = rsi(close, 14)

// Colors
bartrendcolor = MACD > signalMACD and k > 50 and xRSI > 50? green : MACD < signalMACD and k < 50 and xRSI < 50? red : MACD < signalMACD? yellow : gray   
barcolor(switch?bartrendcolor:na)
plot(close-(atr*sl), color=red, style=line)
plot(close+(atr*tp), color=lime, style=line)



// === STRATEGY ===
// conditions
longCond = MACD > signalMACD and k > 50 and xRSI > 50
XlongCond = MACD < signalMACD or close<strategy.position_avg_price-(atr*sl) or close>strategy.position_avg_price+(atr*tp)
ShortCond = MACD < signalMACD and k < 50 and xRSI < 50
XShortCond = MACD > signalMACD or close>strategy.position_avg_price+(atr*sl) or close<strategy.position_avg_price-(atr*tp)


strategy.entry("long", strategy.long, when=longCond==true and window()==true, stop=high )
strategy.close("long", when=XlongCond==true and window()==true)
strategy.entry("short", strategy.short,  when=ShortCond==true and window()==true, stop=low )
strategy.close("short", when=XShortCond==true and window()==true)

// === /STRATEGY ===

