//@version=5
strategy("BTC Momentum Trading - RSI Cross", overlay=false, initial_capital=10000, default_qty_type=strategy.percent_of_equity, default_qty_value=10)

// --- Inputs ---
rsiLen   = input.int(14, "RSI Length")
upperTh  = input.float(55.0, "Upper Threshold")
lowerTh  = input.float(45.0, "Lower Threshold")
midLevel = input.float(50.0, "Midline for Exits")

// --- Indicator ---
rsi = ta.rsi(close, rsiLen)

// --- Entry Conditions ---
// Long when RSI crosses up through upper threshold
longEntry  = ta.crossover(rsi, upperTh)

// Short when RSI crosses down through lower threshold
shortEntry = ta.crossunder(rsi, lowerTh)

// --- Exit Conditions ---
// Exit long when RSI crosses down through midline
exitLong  = strategy.position_size > 0 and ta.crossunder(rsi, midLevel)

// Exit short when RSI crosses up through midline
exitShort = strategy.position_size < 0 and ta.crossover(rsi, midLevel)

// --- Orders ---
if longEntry
    strategy.entry("Long", strategy.long)

if shortEntry
    strategy.entry("Short", strategy.short)

if exitLong
    strategy.close("Long")

if exitShort
    strategy.close("Short")

// --- Plot RSI ---
plot(rsi, "RSI", color=color.new(color.purple, 0))
hline(upperTh, "Upper", color=color.new(color.green, 50))
hline(lowerTh, "Lower", color=color.new(color.red, 50))
hline(midLevel, "Midline", color=color.new(color.gray, 60))

