//@version=6
strategy("HKEX:1810 | Regime Guard + Turtle Breakout + MFE 2-Stage Trail | Long-only | v6 (offline-optimized)",
     overlay=true,
     pyramiding=2,
     initial_capital=100000,
     commission_type=strategy.commission.percent,
     commission_value=0.15,
     slippage=1,
     process_orders_on_close=true)

boardLotShares = input.int(200, "Board Lot Shares (每手股数)", minval=1)
minOrderShares = boardLotShares
roundToLot(shares) =>
    s = math.floor(shares)
    math.floor(s / boardLotShares) * boardLotShares

atr = ta.atr(14)
atrPct = atr / close * 100.0
ema200 = ta.ema(close, 200)

slopeBars = input.int(60, "EMA slope lookback", minval=5, maxval=120)
requireSlope = input.bool(true, "Require EMA slope up")
emaUp = ema200 > ema200[slopeBars]
bullRegime = close > ema200 and (not requireSlope or emaUp)

useAtrGuard = input.bool(true, "ATR% guard")
atrPctGuard = input.float(9.54, "Block entry if ATR% > x", minval=3.0, step=0.1)
atrOk = (not useAtrGuard) or (atrPct <= atrPctGuard)

var float peakEq = na
peakEq := na(peakEq) ? strategy.equity : math.max(peakEq, strategy.equity)
ddPct = peakEq > 0 ? (peakEq - strategy.equity) / peakEq * 100.0 : 0.0

ddStart = input.float(5.89, "DD scale start %", minval=0.5, step=0.5)
ddEnd   = input.float(16.41,   "DD scale end %",   minval=1.0, step=0.5)
ddMinScale = input.float(0.49, "Min scale", minval=0.1, maxval=1.0, step=0.01)
scaleDD = ddPct <= ddStart ? 1.0 : ddPct >= ddEnd ? ddMinScale : (1.0 - (ddPct - ddStart)/(ddEnd - ddStart) * (1.0 - ddMinScale))

useVolTarget = input.bool(true, "Volatility targeting")
volTargetPct = input.float(3.66, "Target ATR%", minval=0.5, step=0.1)
volMinLev = input.float(0.61, "Min lev", minval=0.1, maxval=3.0, step=0.01)
volMaxLev = input.float(1.54, "Max lev", minval=0.5, maxval=5.0, step=0.01)
lev = (useVolTarget and atrPct > 0) ? math.min(volMaxLev, math.max(volMinLev, volTargetPct/atrPct)) : 1.0
scale = scaleDD * lev

maxExposurePct = input.float(257.4, "Max exposure cap (% equity)", minval=10, maxval=600, step=5)
entryPct = input.float(100.7, "Entry exposure (% equity)", minval=1, maxval=400, step=1)
addPct   = input.float(77.5,   "Add exposure (% equity)",   minval=0, maxval=400, step=1)

useRiskCap = input.bool(true, "Risk cap sizing")
riskCapPct = input.float(3.69, "Max loss at stop (% equity)", minval=0.1, step=0.1)

qtyFromPct(pct) =>
    desiredValue  = strategy.equity * (pct / 100.0)
    desiredShares = desiredValue / close
    capValue  = strategy.equity * (maxExposurePct / 100.0)
    capShares = capValue / close
    curShares    = math.max(strategy.position_size, 0)
    remainShares = math.max(0.0, capShares - curShares)
    raw = math.min(desiredShares, remainShares)
    roundToLot(raw)

riskCapShares(stopDist) =>
    raw = (useRiskCap and stopDist > 0) ? (strategy.equity * (riskCapPct/100.0) / stopDist) : 1e18
    roundToLot(raw)

entryLen = input.int(31, "Entry breakout len", minval=10, maxval=200)
exitLen  = input.int(10,  "Exit breakout len",  minval=5,  maxval=100)
addLen   = input.int(6,   "Add breakout len",   minval=5,  maxval=100)

hiEntry = ta.highest(high, entryLen)[1]
loExit  = ta.lowest(low,  exitLen)[1]
hiAdd   = ta.highest(high, addLen)[1]
entrySignal = not na(hiEntry) and ta.crossover(close, hiEntry)
exitSignal  = not na(loExit)  and ta.crossunder(close, loExit)
addSignal   = not na(hiAdd)   and ta.crossover(close, hiAdd)

initStopATR = input.float(2.38, "Init stop ATR mult", minval=0.5, step=0.1)
trailBase   = input.float(4.66, "Trail ATR mult (base)", minval=1.0, step=0.1)
trailTight  = input.float(2.30, "Trail ATR mult (tight)", minval=1.0, step=0.1)
tightenAtR  = input.float(2.68, "Tighten after MFE >= R", minval=0.5, step=0.1)
useBE = input.bool(true, "Breakeven after +R")
beR   = input.float(1.32, "BE trigger (R)", minval=0.2, step=0.1)

useRegimeExit = input.bool(true, "Regime exit (close < EMA200)")

maxAdds = input.int(2, "Max adds", minval=0, maxval=5)
addCooldown = input.int(3, "Add cooldown (bars)", minval=0, maxval=50)
addAfterR = input.float(1.03, "Add after profit >= R", minval=0.0, step=0.05)

inPos = strategy.position_size > 0
avg   = strategy.position_avg_price
var float entryStopDist = na
var float hhSince = na
var float trailMono = na
var int addCount = 0
var int lastAddBar = na

newPos  = (strategy.position_size > 0) and (strategy.position_size[1] <= 0)
exitPos = (strategy.position_size == 0) and (strategy.position_size[1] > 0)

if newPos
    hhSince := high
    trailMono := na
    addCount := 0
    lastAddBar := na

if not inPos
    entryStopDist := na
    hhSince := na
    trailMono := na
    addCount := 0
    lastAddBar := na

if (not inPos) and atrOk and bullRegime and entrySignal
    stopDistNow = initStopATR * atr
    entryStopDist := stopDistNow
    qPct = qtyFromPct(entryPct * scale)
    q = math.min(qPct, riskCapShares(stopDistNow))
    if q >= minOrderShares
        strategy.entry("L", strategy.long, qty=q)

profitR_now = (inPos and not na(entryStopDist) and entryStopDist > 0) ? ((close - avg) / entryStopDist) : 0.0
addCoolOk = addCooldown == 0 ? true : (na(lastAddBar) or (bar_index - lastAddBar >= addCooldown))
canAdd = inPos and atrOk and bullRegime and addSignal and addCoolOk and (addCount < maxAdds) and (close > avg) and (profitR_now >= addAfterR)

if canAdd
    stopDistNow = initStopATR * atr
    qPctA = qtyFromPct(addPct * scale)
    qA = math.min(qPctA, riskCapShares(stopDistNow))
    if qA >= minOrderShares
        strategy.entry("L", strategy.long, qty=qA)
        addCount += 1
        lastAddBar := bar_index

if inPos and not na(entryStopDist)
    hhSince := na(hhSince) ? high : math.max(hhSince, high)
    profitR_mfe = (hhSince - avg) / entryStopDist
    tMult = (profitR_mfe >= tightenAtR) ? trailTight : trailBase
    trailRaw = hhSince - tMult * atr
    trailMono := na(trailMono[1]) ? trailRaw : math.max(trailMono[1], trailRaw)

    initStop = avg - entryStopDist
    effStop = math.max(initStop, trailMono)

    if useBE and (close - avg >= beR * entryStopDist)
        effStop := math.max(effStop, avg)

    strategy.exit("X", from_entry="L", stop=effStop)

    if exitSignal
        strategy.close("L", comment="DonchianExit")
    if useRegimeExit and close < ema200
        strategy.close("L", comment="RegimeExit")

showMarks = input.bool(true, "Show BUY/SELL")
plotshape(showMarks and newPos, title="BUY", text="BUY", style=shape.triangleup, location=location.belowbar, size=size.tiny)
plotshape(showMarks and exitPos, title="SELL", text="SELL", style=shape.triangledown, location=location.abovebar, size=size.tiny)
plot(ema200, "EMA200", linewidth=2)

