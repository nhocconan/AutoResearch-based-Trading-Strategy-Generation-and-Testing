//indicator(title='ORB 15 Min By EquityDurai', shorttitle='ORB15Min', overlay=true)
up15on = input(true, title='15 Minute Opening Range High')
down15on = input(true, title='15 Minute Opening Range Low')

is_newbar(res) =>
    ta.change(time(res)) != 0

adopt(r, s) =>
    request.security(syminfo.tickerid, r, s)

high_range = ta.valuewhen(is_newbar('D'), high, 0)
low_range = ta.valuewhen(is_newbar('D'), low, 0)

high_rangeL = ta.valuewhen(is_newbar('D'), high, 0)
low_rangeL = ta.valuewhen(is_newbar('D'), low, 0)

adopt__1 = adopt('15', high_rangeL)
//up15 = plot(up15on ? adopt__1 : na, color=color.new(#009900, 0), linewidth=2)
adopt__2 = adopt('15', low_rangeL)
//down15 = plot(down15on ? adopt__2 : na, color=color.new(#ff0000, 0), linewidth=2)

ORBup = (close > teeth) and close > adopt__1 and ( close[1] < adopt__1) and ( close[2] < adopt__1) and ( close[3] < adopt__1) and ( close[4] < adopt__1) and tyme
ORBdwn = (close < teeth) and close < adopt__2 and ( close[1] > adopt__2) and ( close[2] > adopt__2) and ( close[3] > adopt__2) and ( close[4] > adopt__2)   and tyme

b_z_TGT = str.tostring(math.round(close) + 30)
s_z_TGT = str.tostring(math.round(close) - 30)

//plotshape(ORBup, style=shape.labelup, text= b_z_TGT, color=color.green,location=location.belowbar, title="ORB uptrend", size = size.normal) //
//plotshape(ORBdwn, style=shape.labeldown, text=s_z_TGT, color= color.red,location=location.abovebar, title="ORB downtrend", size = size.normal) //
// Use labels to display dynamic text
if ORBup
    label.new(bar_index, low, text=b_z_TGT, style=label.style_label_up, color=color.green, textcolor=color.white, size=size.normal)


if ORBdwn
    label.new(bar_index, high, text=s_z_TGT, style=label.style_label_down, color=color.red, textcolor=color.white, size=size.normal)

