//@version=6
strategy("WJ BUY Strategy", overlay=true, initial_capital=5000000, default_qty_type=strategy.cash, default_qty_value=100000, pyramiding=50, process_orders_on_close=true, calc_on_every_tick=true)

// [설정] 1회 진입 시 투자할 고정 금액 (기본값: 100000)
entry_amount = input.float(100000)

// ==========================================
// 1. 입력 설정
// ==========================================
bb_len = input.int(40, title="BB 길이")
bb_mult = input.float(2.0, title="BB 표준편차")
ma_len1 = input.int(120, title="MA 1 (0.5점)")
ma_len2 = input.int(240, title="MA 2 (1.0점)")
ma_len3 = input.int(400, title="MA 3 (1.5점)")
rsi_len = input.int(14, title="RSI 길이")

confirm_days = input.int(2, title="점수 하강 유지 기간(일)", minval=1)
entry_ma_len = input.int(10, title="진입 기준 이평선(일)", minval=1)

start_year = input.int(2021, title="시작 연도")
start_month = input.int(1, title="시작 월")
start_day = input.int(1, title="시작 일")

start_time = timestamp(start_year, start_month, start_day, 0, 0)
in_date_range = time >= start_time


// ==========================================
// 2. WJ Score 및 지표 계산
// ==========================================
[_, bb_upper, bb_lower] = ta.bb(close, bb_len, bb_mult)
ma1 = ta.sma(close, ma_len1)
ma2 = ta.sma(close, ma_len2)
ma3 = ta.sma(close, ma_len3)
rsi_val = ta.rsi(close, rsi_len)

// 1) 볼린저밴드 점수
score_bb = 0.0
if close < bb_lower
    score_bb := 1.0

// 2) 이동평균선 점수
score_ma = 0.0
if close < ma3
    score_ma := 1.5
else if close < ma2
    score_ma := 1.0
else if close < ma1
    score_ma := 0.5

// 3) RSI 점수 (25이하 조건 포함)
score_rsi = 0.0
if rsi_val <= 25        // RSI 25 이하: 2.0점
    score_rsi := 2.0
else if rsi_val <= 30   // RSI 30 이하: 1.5점
    score_rsi := 1.5
else if rsi_val <= 35   // RSI 35 이하: 1.0점
    score_rsi := 1.0
else if rsi_val <= 40   // RSI 40 이하: 0.5점
    score_rsi := 0.5

final_score = score_bb + score_ma + score_rsi
entry_ma = ta.sma(close, entry_ma_len)


// ==========================================
// 3. 전략 로직 (Hybrid A+B 버전)
// ==========================================

// 상태 변수
var int monitor_mode = 0  
var int days_maintained = 0       

// B전략 매수 가격 및 시간 기록
var float last_buy_B_price = na
var int last_buy_B_time = na

// 직전 매수 가격 기록 (영구 보존)
var float last_buy_price = na

// A전략 연속 하락 차단용 변수
var int last_buy_type = 0  // 0: 없음, 1: A전략, 2: B전략
var int a_down_streak = 0  // A전략 연속 하락 매수 횟수

// [수정] 포지션이 청산되어도 last_buy_price는 절대 지워지지 않음
if strategy.position_size == 0
    last_buy_B_price := na
    last_buy_B_time := na
    last_buy_type := 0
    a_down_streak := 0

// alertcondition을 위한 신호 캡처 변수
bool trigger_buy_A = false
bool trigger_buy_B = false

if in_date_range
    // ------------------------------------------
    // A. 감시 시작 (Trigger)
    // ------------------------------------------
    if final_score >= 3.0
        monitor_mode := 2
        days_maintained := 0
        
    else if final_score[1] < 2.0 and final_score >= 2.0 and monitor_mode != 2
        monitor_mode := 1
        days_maintained := 0
    
    // ------------------------------------------
    // B. 감시 중 (Action)
    // ------------------------------------------
    bool is_A_active = (monitor_mode == 1 and final_score < 2.0)
    bool is_B_active = (monitor_mode == 2 and final_score < 3.0)
    
    if is_A_active or is_B_active
        
        if final_score > final_score[1]
            days_maintained := 0
        else
            days_maintained += 1

        cond_days = days_maintained >= confirm_days
        
        // 10일선 조건 유동적 적용 로직
        bool is_lower_price = not na(last_buy_price) and (close < last_buy_price)
        bool cond_ma = false
        
        if is_lower_price
            // (2) 현재 가격이 직전 매수했던 가격보다 낮을 때: 전일 종가 10일선 위 & 현재 가격 10일선 위
            cond_ma := (close >= entry_ma) and (close[1] >= entry_ma[1])
        else
            // (1) 현재 가격이 직전 매수했던 가격보다 높거나 같을 때 (또는 첫 매수): 현재 가격 10일선 위
            cond_ma := (close >= entry_ma)
        
        if cond_days and cond_ma
            if monitor_mode == 1
                // 2주(14일) 경과 여부 확인 (1일 = 86,400,000 밀리초)
                bool is_two_weeks_passed = na(last_buy_B_time) or (time - last_buy_B_time >= 14 * 86400000)
                
                // A 연속 하락 매수 2회 초과 시 차단
                bool is_a_blocked = (last_buy_type == 1) and (a_down_streak >= 2) and (close < last_buy_price)
                
                // 매수 조건: (B 매수가 없거나 / 가격이 더 높고) AND 2주가 지났을 때 AND 연속하락 차단에 걸리지 않았을 때
                if (na(last_buy_B_price) or (close > last_buy_B_price)) and is_two_weeks_passed and not is_a_blocked
                    strategy.entry(" ", strategy.long)
                    alert("WJ BUY A", alert.freq_once_per_bar)
                    trigger_buy_A := true // 알림 조건 스위치 ON
                    
                    label.new(bar_index, na, text="A\n" + str.tostring(close, "#.00"), yloc=yloc.belowbar, style=label.style_none, textcolor=color.orange, size=size.normal)
                    
                    // A전략 역배열 매수 카운트 업데이트
                    if last_buy_type == 1 and close < last_buy_price
                        a_down_streak += 1
                    else
                        a_down_streak := 1 // 상승 매수이거나, B 이후 첫 A매수면 1로 리셋
                        
                    last_buy_type := 1
                    last_buy_price := close 
                    monitor_mode := 0 
                else
                    // 가격이 낮거나, 아직 2주가 안 지나서, 또는 3연속 하락 매수라서 튕겨낸 경우
                    monitor_mode := 0 

            else if monitor_mode == 2
                strategy.entry(" ", strategy.long)
                alert("WJ BUY B", alert.freq_once_per_bar)
                trigger_buy_B := true // 알림 조건 스위치 ON
                
                label.new(bar_index, na, text="B\n" + str.tostring(close, "#.00"), yloc=yloc.belowbar, style=label.style_none, textcolor=color.rgb(215, 118, 235), size=size.normal)
                
                // 새로운 B 타점 발생 시 상태값 리셋 및 갱신
                last_buy_B_price := close 
                last_buy_B_time := time
                last_buy_price := close 
                last_buy_type := 2
                a_down_streak := 0
                monitor_mode := 0

// ==========================================
// 4. 최종 청산 (수익률 확인용)
// ==========================================
// [수정] 실시간 봉에서 꼬이는 것을 막기 위해 '확정된 과거 마지막 봉'에서만 실행되도록 변경
if barstate.islastconfirmedhistory
    strategy.close_all(comment=" ")

