//@version=6
strategy("Divergence IQ [TradingIQ]",  overlay = false, precision = 3, slippage = 1, initial_capital = 1000, process_orders_on_close = true, calc_on_every_tick = true, default_qty_value = 5, default_qty_type = strategy.percent_of_equity, commission_type = strategy.commission.percent, commission_value = 0.02, max_lines_count = 500,  max_labels_count = 500, max_boxes_count = 500, max_polylines_count = 100)

enum divInput 

    pivotPoints = "Pivots"
    immediate   = "Immediate"

enum normalizationInput 

    rollingMinMax = "Rolling Min Max"
    rollingZscore = "Rolling Z-score"
    robustScaling = "Robust Scaling"
    none          = "None"

enum exitInput 

    atr = "ATR"
    percent = "Percentage"

src        = input.source(defval = close, title = "Indicator", group = "Divergence Detection Setup")
divMethod  = input.enum(defval = divInput.pivotPoints, title = "Divergence Detection Method", options = [divInput.pivotPoints, divInput.immediate])
useCloses  = input.bool(defval = false, title = "Use Closing Prices For Divergence Detection", group = "Divergence Detection Setup")

leftLook   = input.int(defval = 6, minval = 1, title = "Left Lookback", group = "Divergence Detection Setup")
rightLook  = input.int(defval = 6, minval = 1, title = "Right Lookahead", group = "Divergence Detection Setup")

normMethod = input.enum(defval = normalizationInput.none, title = "Normalize Indicator", group = "Normalization", options =   
             [normalizationInput.none, normalizationInput.robustScaling, normalizationInput.rollingZscore, normalizationInput.rollingMinMax])
window     = input.int(defval = 50, minval = 2, title = "Normalization Window", group = "Normalization")
showFinal  = input.bool(defval = true, title = "Plot Indicator (Required When Using Normalization)", group = "Normalization")
showPrice  = input.bool(defval = true, title = "Plot Price", group = "Normalization")

onChart       = input.bool(defval = true, title = "Show Divergences On Price", group = "Divergence Settings")

bullDivShow  = input.bool(defval = true, title = "Bullish Divergence Color", group = "Divergence Settings", inline = "BullDiv")
bearDivShow  = input.bool(defval = true, title = "Bearish Divergence Color", group = "Divergence Settings", inline = "BearDiv")
bullHDivShow = input.bool(defval = true, title = "Bullish Hidden Divergence Color", group = "Divergence Settings", inline = "BullHDiv")
bearHDivShow = input.bool(defval = true, title = "Bearish Hidden Divergence Color", group = "Divergence Settings", inline = "BearHDiv")

bullDivCol  = input.color(defval = #74ffbc, title = "", group = "Divergence Settings", inline = "BullDiv")
bearDivCol  = input.color(defval = color.rgb(255, 116, 116), title = "", group = "Divergence Settings", inline = "BearDiv")
bullHDivCol = input.color(defval = #ffb674, title = "", group = "Divergence Settings", inline = "BullHDiv")
bearHDivCol = input.color(defval = color.rgb(223, 116, 255), title = "", group = "Divergence Settings", inline = "BearHDiv")


bullDivTrade  = input.bool(defval = true, title = "Trade", group = "Divergence Settings", inline = "BullDiv")
bearDivTrade  = input.bool(defval = true, title = "Trade", group = "Divergence Settings", inline = "BearDiv")
bullHDivTrade = input.bool(defval = true, title = "Trade", group = "Divergence Settings", inline = "BullHDiv")
bearHDivTrade = input.bool(defval = true, title = "Trade", group = "Divergence Settings", inline = "BearHDiv")


exitType         = input.enum (defval = exitInput.atr, title = "Stop Loss & Target Type", options = [exitInput.atr, exitInput.percent], group = "Strategy Settings")
profitTargetMult = input.float(defval = 2, minval = 0, title = "Profit Target ATR Multiplier (Or Perecntage)", group = "Strategy Settings")
stopLossMult     = input.float(defval = 2, minval = 0, title = "Stop Loss ATR Multiplier (Or Percentage)", group = "Strategy Settings")
gradientFlow     = input.bool(defval = true, title = "Show Gradient Flow", group = "Gradient Flow Settings")
gradientFlowCol  = input.color(defval = #f23645, title = "Gradient Flow Color", group = "Gradient Flow Settings")

if not onChart and divMethod == divInput.immediate

    bullDivCol  := color(na)
    bearDivCol  := color(na)
    bullHDivCol := color(na)
    bearHDivCol := color(na)

type pivotData

    chart.point indicatorPiv
    chart.point pricePiv

type mapValuesString

    string direction = "Direction"
    string trades    = "Trades"
    string wins      = "Wins"
    string profit    = "Profit"
    string grossGain = "Gross Gain"
    string grossLoss = "Gross Loss"
    string target    = "Target"
    string stop      = "Stop"
    string entry     = "Entry"

type exitDrawings 

    float targetPrice
    float stopPrice 
    label exitLabel

var tradeMap  = map.new<string, float>()
var mapValues = mapValuesString.new()
atr = ta.atr(14)

normalize() => 

    normSrc = src

    var srcArr = array.new<float>()

    srcArr.push(src)

    if srcArr.size() > window
        srcArr.shift()

    if normMethod == normalizationInput.rollingMinMax

        srcMax = srcArr.max(), srcMin = srcArr.min()

        normSrc := (src - srcMin) / (srcMax - srcMin)

    if normMethod == normalizationInput.rollingZscore

        mean = srcArr.avg(), stdDev = srcArr.stdev()

        normSrc := switch stdDev 

            0 => 0
            =>   (src - mean) / stdDev

    if normMethod == normalizationInput.robustScaling

        median = srcArr.median()

        devArr = array.new_float(srcArr.size(), na)

        for [i, data] in devArr 

            devArr.set(i, math.abs(srcArr.get(i) - median))

        mad = devArr.median()

        normSrc := switch mad != 0

            true => 0.6745 * (src - median) / mad  
            => 0


    normSrc    

method appendPivot(array<pivotData> id, float value, float price, bool upPivot) =>

    if not na(value)

        id.push(
                 pivotData.new(
                         chart.point.from_time(time[rightLook], value),
                         chart.point.from_time(time[rightLook], price[rightLook])))

method add(map<string, float> id, string key, float value, bool isShort) =>

    finalValue = value

    if isShort

        finalValue *= -1

    id.put(key, nz(id.get(key)) + finalValue)

method addAll(map<string, float> id, bool isProfit, float getTarget, float getEntry, float getStop, bool isShort, exitDrawings exitData) => 

    [ylocNow, textNow, tooltipNow, mult] = switch isShort 

        false => [yloc.abovebar, "▽", "Long Exit At: ", 1]
        =>       [yloc.belowbar, "△", "Short Exit At: ", -1]

    switch isProfit

        true => 

             id.add(mapValues.wins  , 1, false), 
             id.add(mapValues.trades, 1, false),
             id.add(mapValues.profit, (getTarget / getEntry - 1) * 100, isShort),
             id.add(mapValues.grossGain, math.abs(getTarget - getEntry), false),
             id.put(mapValues.direction, 0), 

             exitData.stopPrice := float(na),  exitData.targetPrice := float(na),

             exitData.exitLabel  := label.new(bar_index, getTarget, yloc = ylocNow, 
                                         color         = color.new(color.rgb(128, 116, 255), 80),
                                         textcolor     = color.rgb(128, 116, 255), 
                                         text          = textNow, 
                                         style         = label.style_text_outline,
                                         force_overlay = true,
                                         tooltip       = tooltipNow + str.tostring(getTarget, format.mintick) 
                                         + "\nReturn: " + str.tostring((getTarget / getEntry - 1) * 100 * mult, format.percent)
                                         )

        =>  

             id.add(mapValues.trades, 1, false),
             id.add(mapValues.profit, (getStop / getEntry - 1) * 100, isShort),
             id.add(mapValues.grossLoss, math.abs(getStop - getEntry), false), 
             id.put(mapValues.direction, 0),

             exitData.stopPrice := float(na),  exitData.targetPrice := float(na),

             exitData.exitLabel  := label.new(bar_index, getStop, yloc = ylocNow, 
                                         color         = color.new(color.rgb(128, 116, 255), 80),
                                         textcolor     = color.rgb(128, 116, 255), 
                                         text          = textNow, 
                                         style         = label.style_text_outline,
                                         force_overlay = true,
                                         tooltip       = tooltipNow + str.tostring(getStop, format.mintick) 
                                         + "\nReturn: " + str.tostring((getStop / getEntry - 1) * 100 * mult, format.percent)
                                         )


var pivotsUp  = array.new<pivotData>(), var pivotsDn  = array.new<pivotData>()
var pivotsUpH = array.new<pivotData>(), var pivotsDnH = array.new<pivotData>()

finalSrc = normalize()

getPH = ta.pivothigh(finalSrc, leftLook, rightLook)
getPL = ta.pivotlow (finalSrc, leftLook, rightLook)

[getHigh, getLow] = switch useCloses

    true => [close, close]
    =>      [high , low  ]

pivotsUp .appendPivot(getPH, getHigh, true), pivotsDn .appendPivot(getPL, getLow, false)
pivotsUpH.appendPivot(getPH, getHigh, true), pivotsDnH.appendPivot(getPL, getLow, false)

[o, h, l, c] = request.security_lower_tf(syminfo.tickerid, "1", [open, high, low, close])
var exitData = exitDrawings.new(float(na), float(na), label(na))

method tradeExits(map<string, float> tradeMap) => 


    if na(tradeMap.get(mapValues.direction))
        tradeMap.put(mapValues.direction, 0)

    if tradeMap.get(mapValues.direction) == 1

        isShort = false 

        getTarget = tradeMap.get(mapValues.target)
        getStop   = tradeMap.get(mapValues.stop)
        getEntry  = tradeMap.get(mapValues.entry)

        if open >= getTarget 

            tradeMap.addAll(true, getTarget, getEntry, getStop, isShort, exitData)

        else if open <= getStop 

            tradeMap.addAll(false, getTarget, getEntry, getStop, isShort, exitData)
            
        else if high >= getTarget 

            if low > getStop 

                tradeMap.addAll(true, getTarget, getEntry, getStop, isShort, exitData)

            else 

                if h.size() > 0

                    for i = 0 to h.size() - 1

                        ltfHigh = h.get(i), ltfLow = l.get(i), ltfClose = c.get(i), ltfOpen = o.get(i)

                        if ltfHigh >= getTarget 

                            if ltfLow > getStop 

                                tradeMap.addAll(true, getTarget, getEntry, getStop, isShort, exitData)

                            else 
                                
                                closer2low = math.abs(ltfOpen - ltfHigh) > math.abs(ltfOpen - ltfLow)

                                switch closer2low

                                    true => 
                            
                                         tradeMap.addAll(false, getTarget, getEntry, getStop, isShort, exitData)

                                    =>       

                                         tradeMap.addAll(true, getTarget, getEntry, getStop, isShort, exitData)
                            break 

                        else if ltfLow <= getStop 

                            tradeMap.addAll(false, getTarget, getEntry, getStop, isShort, exitData)

                            break 


                else 

                    closer2low = math.abs(open - high) > math.abs(open - low)

                    switch closer2low

                        true => 
                            
                             tradeMap.addAll(false, getTarget, getEntry, getStop, isShort, exitData)

                        =>       
                             tradeMap.addAll(true, getTarget, getEntry, getStop, isShort, exitData)

        else if low <= getStop

            tradeMap.addAll(false, getTarget, getEntry, getStop, isShort, exitData)
            

    else if tradeMap.get(mapValues.direction) == -1


        isShort = true

        getTarget = tradeMap.get(mapValues.target)
        getStop   = tradeMap.get(mapValues.stop)
        getEntry  = tradeMap.get(mapValues.entry)

        if open <= getTarget 

            tradeMap.addAll(true, getTarget, getEntry, getStop, isShort, exitData)

        else if open >= getStop 

            tradeMap.addAll(false, getTarget, getEntry, getStop, isShort, exitData)
            
        else if low <= getTarget 

            if high < getStop 

                tradeMap.addAll(true, getTarget, getEntry, getStop, isShort, exitData)

            else 

                if h.size() > 0

                    for i = 0 to h.size() - 1

                        ltfHigh = h.get(i), ltfLow = l.get(i), ltfClose = c.get(i), ltfOpen = o.get(i)

                        if ltfLow <= getTarget 

                            if ltfHigh < getStop 

                                tradeMap.addAll(true, getTarget, getEntry, getStop, isShort, exitData)

                            else 
                                
                                closer2low = math.abs(ltfOpen - ltfHigh) > math.abs(ltfOpen - ltfLow)

                                switch closer2low

                                    true => 
                            
                                         tradeMap.addAll(true, getTarget, getEntry, getStop, isShort, exitData)

                                    =>       

                                         tradeMap.addAll(false, getTarget, getEntry, getStop, isShort, exitData)
                            break 

                        else if ltfHigh >= getStop 

                            tradeMap.addAll(false, getTarget, getEntry, getStop, isShort, exitData)

                            break 


                else 

                    closer2low = math.abs(open - high) > math.abs(open - low)

                    switch closer2low

                        true => 
                            
                             tradeMap.addAll(true, getTarget, getEntry, getStop, isShort, exitData)

                        =>       
                             tradeMap.addAll(false, getTarget, getEntry, getStop, isShort, exitData)

        else if high >= getStop

            tradeMap.addAll(false, getTarget, getEntry, getStop, isShort, exitData)
            
    float(na)

pivotsMethod() =>
    

    bearDiv = false, bearHdiv = false 

    tradeMap.tradeExits()

    if barstate.isconfirmed

        if not na(getPH) and pivotsUp.size() > 1

            recentPiv = pivotsUp.last()
            prevPiv   = pivotsUp.get(-2)

            if bearDivShow or bearDivTrade

                if recentPiv.pricePiv.price > prevPiv.pricePiv.price 

                    if recentPiv.indicatorPiv.price < prevPiv.indicatorPiv.price

                        bearDiv := true 

                        if bearDivTrade and tradeMap.get(mapValues.direction) == 0 and not na(atr)

                            [stop, target] = switch exitType

                                exitInput.atr =>     [close + atr * stopLossMult, close - atr * profitTargetMult]
                                exitInput.percent => [close * (1 + stopLossMult / 100), close * (1 - profitTargetMult / 100)]

                            stop   := math.round_to_mintick(stop)
                            target := math.round_to_mintick(target)

                            strategy.entry("Short Bearish Divergence", strategy.short)
                            strategy.exit("SB Exit", "Short Bearish Divergence", stop = stop, limit = target)

                            label.new(bar_index, close, text = "▽", textcolor = color.rgb(255, 116, 116), 
                                             color         = color.new(color.rgb(255, 116, 116), 80), 
                                             style         = label.style_text_outline, 
                                             size          = size.normal, 
                                             tooltip       = "Bearish Divergence Short Entry At: " + str.tostring(close, format.mintick) 
                                                             + "\nTarget: " + str.tostring(target) + "\nStop: " + str.tostring(stop),
                                             force_overlay = true,
                                             yloc          = yloc.abovebar
                                             )

                            exitData.stopPrice := stop, exitData.targetPrice := target

                            tradeMap.put(mapValues.direction, -1)
                            tradeMap.put(mapValues.target, target)
                            tradeMap.put(mapValues.stop  , stop)
                            tradeMap.put(mapValues.entry , close)

                        alert("Bearsih Divergence Detected", freq = alert.freq_once_per_bar_close)


            if bearHDivShow

                if recentPiv.pricePiv.price < prevPiv.pricePiv.price 

                    if recentPiv.indicatorPiv.price > prevPiv.indicatorPiv.price

                        bearHdiv := true 

                        if bearHDivTrade and tradeMap.get(mapValues.direction) == 0 and not na(atr)


                            [stop, target] = switch exitType

                                exitInput.atr =>     [close + atr * stopLossMult, close - atr * profitTargetMult]
                                exitInput.percent => [close * (1 + stopLossMult / 100), close * (1 - profitTargetMult / 100)]

                            stop   := math.round_to_mintick(stop)
                            target := math.round_to_mintick(target)

                            strategy.entry("Short Hidden Bearish Divergence", strategy.short)
                            strategy.exit("SHB Exit", "Short Hidden Bearish Divergence", stop = stop, limit = target)

                            label.new(bar_index, close, text = "▽", textcolor = color.rgb(255, 116, 116), 
                                             color         = color.new(color.rgb(255, 116, 116), 80), 
                                             style         = label.style_text_outline, 
                                             size          = size.normal, 
                                             tooltip       = "Hidden Bearish Divergence Short Entry At: " + str.tostring(close, format.mintick)
                                                             + "\nTarget: " + str.tostring(target) + "\nStop: " + str.tostring(stop),

                                             force_overlay = true,
                                             yloc          = yloc.abovebar
                                             )


                            exitData.stopPrice := stop, exitData.targetPrice := target

                            tradeMap.put(mapValues.direction, -1)
                            tradeMap.put(mapValues.target, target)
                            tradeMap.put(mapValues.stop  , stop)
                            tradeMap.put(mapValues.entry , close)

                        alert("Hidden Bearsih Divergence Detected", freq = alert.freq_once_per_bar_close)


    bullDiv = false, bullHdiv = false

    if barstate.isconfirmed

        if not na(getPL) and pivotsDn.size() > 1

            recentPiv = pivotsDn.last()
            prevPiv   = pivotsDn.get(-2)

            if bullDivShow

                if recentPiv.pricePiv.price < prevPiv.pricePiv.price 

                    if recentPiv.indicatorPiv.price > prevPiv.indicatorPiv.price

                        bullDiv := true 

                        if bullDivTrade and tradeMap.get(mapValues.direction) == 0 and not na(atr)


                            [stop, target] = switch exitType

                                exitInput.atr =>     [close - atr * stopLossMult, close + atr * profitTargetMult]
                                exitInput.percent => [close * (1 - stopLossMult / 100), close * (1 + profitTargetMult / 100)]

                            stop   := math.round_to_mintick(stop)
                            target := math.round_to_mintick(target)

                            strategy.entry("Long Bullish Divergence", strategy.long)
                            strategy.exit("LB Exit", "Long Bullish Divergence", stop = stop, limit = target)

                            label.new(bar_index, close, text = "△", textcolor = #74ffbc, 
                                             color         = color.new(#74ffbc, 80), 
                                             style         = label.style_text_outline, 
                                             size          = size.normal, 
                                             tooltip       = "Bullish Divergence Long Entry At: " + str.tostring(close, format.mintick)
                                                             + "\nTarget: " + str.tostring(target) + "\nStop: " + str.tostring(stop),
                                             force_overlay = true,
                                             yloc          = yloc.belowbar
                                             )


                            exitData.stopPrice := stop, exitData.targetPrice := target

                            tradeMap.put(mapValues.direction, 1)
                            tradeMap.put(mapValues.target, target)
                            tradeMap.put(mapValues.stop  , stop)
                            tradeMap.put(mapValues.entry , close)


                        alert("Bullish Divergence Detected", freq = alert.freq_once_per_bar_close)



            if bullHDivShow

                if recentPiv.pricePiv.price > prevPiv.pricePiv.price 

                    if recentPiv.indicatorPiv.price < prevPiv.indicatorPiv.price

                        bullHdiv := true 

                        if bullHDivTrade and tradeMap.get(mapValues.direction) == 0 and not na(atr)


                            [stop, target] = switch exitType

                                exitInput.atr =>     [close - atr * stopLossMult, close + atr * profitTargetMult]
                                exitInput.percent => [close * (1 - stopLossMult / 100), close * (1 + profitTargetMult / 100)]

                            stop   := math.round_to_mintick(stop)
                            target := math.round_to_mintick(target)

                            strategy.entry("Long Hidden Bullish Divergence", strategy.long)
                            strategy.exit("LHB Exit", "Long Hidden Bullish Divergence", stop = stop, limit = target)

                            label.new(bar_index, close, text = "△", textcolor = #74ffbc, 
                                             color         = color.new(#74ffbc, 80), 
                                             style         = label.style_text_outline, 
                                             size          = size.normal, 
                                             tooltip       = "Hidden Bullish Divergence Long Entry At: " + str.tostring(close, format.mintick)
                                                             + "\nTarget: " + str.tostring(target) + "\nStop: " + str.tostring(stop),
                                             force_overlay = true,
                                             yloc          = yloc.belowbar
                                             )


                            exitData.stopPrice := stop, exitData.targetPrice := target

                            tradeMap.put(mapValues.direction, 1)
                            tradeMap.put(mapValues.target, target)
                            tradeMap.put(mapValues.stop  , stop)
                            tradeMap.put(mapValues.entry , close)

                        alert("Hidden Bullish Divergence Detected", freq = alert.freq_once_per_bar_close)



    [bearDiv, bearHdiv, bullDiv, bullHdiv]


immediateMethod() => 

    bearDiv = false, bearHdiv = false, bullDiv = false, bullHdiv = false

    tradeMap.tradeExits()

    if barstate.isconfirmed

        if pivotsUp.size() > 1

            getRecent = pivotsUp.last(), getRecentHidden = pivotsUpH.last()

            var includesTime = array.new<int>()
            var divLine      = line(na)
            var priceLine    = line(na)

            var includesTimeHidden = array.new<int>()
            var divLineHidden      = line(na)
            var priceLineHidden    = line(na)

            if finalSrc > getRecent.indicatorPiv.price 

                pivotsUp.push(
                         pivotData.new(
                                 chart.point.from_time(time, finalSrc), 
                                 chart.point.from_time(time, getHigh)))

            if bearDivShow or bearDivTrade

                if not includesTime.includes(getRecent.indicatorPiv.time) 

                    if finalSrc[1] < getRecent.indicatorPiv.price and getHigh[1] > getRecent.pricePiv.price 

                        if finalSrc[1] > finalSrc[2] and finalSrc[1] > finalSrc

                            if na(divLine)

                                divLine   := line.new(getRecent.indicatorPiv.time, getRecent.indicatorPiv.price, 
                                                         time[1], 
                                                         finalSrc [1], 
                                                         xloc  = xloc.bar_time, 
                                                         color = bearDivCol, 
                                                         style = line.style_dotted,
                                                         width = 2
                                                         )

                                priceLine := line.new(getRecent.pricePiv.time, getRecent.pricePiv.price, 
