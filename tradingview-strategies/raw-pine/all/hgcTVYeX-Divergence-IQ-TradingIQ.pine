[bearDiv, bearHdiv, bullDiv, bullHdiv] = switch divMethod

    divInput.pivotPoints => pivotsMethod()
    divInput.immediate   => immediateMethod()


if barstate.islast or barstate.islastconfirmedhistory

    var performanceTable = table.new(position.bottom_right, 99, 99, bgcolor = #20222C, border_color = #363843, 
                                         frame_color   = #363843, 
                                         border_width  = 1, 
                                         frame_width   = 1, 
                                         force_overlay = true
                                         )

    textCol = switch math.sign(tradeMap.get(mapValues.profit))

        1  => #74ffbc 
        -1 => color.rgb(255, 116, 116)
        =>    color.white

    performanceTable.cell(0, 0, "Divergence IQ", text_color = #f874ff)

    performanceTable.cell(0, 1, "Profit: ", text_color = color.white)
    performanceTable.cell(0, 2, "Win Rate: ", text_color = color.white)
    performanceTable.cell(0, 3, "PF: ", text_color = color.white)
    performanceTable.cell(0, 4, "Trades: ", text_color = color.white)

    performanceTable.cell(1, 1, str.tostring(tradeMap.get(mapValues.profit), format.percent), 
                                                     text_color = textCol)
    performanceTable.cell(1, 2, str.tostring(tradeMap.get(mapValues.wins) / tradeMap.get(mapValues.trades) * 100, format.percent), 
                                                     text_color = color.white)
    performanceTable.cell(1, 3, str.tostring(tradeMap.get(mapValues.grossGain) / tradeMap.get(mapValues.grossLoss), "###,###.##"), 
                                                     text_color = textCol)
    performanceTable.cell(1, 4, str.tostring(tradeMap.get(mapValues.trades), "###,###.##"), 
                                                     text_color = textCol)

    performanceTable.merge_cells(0, 0, 1, 0)

    pricesArr = array.from(close, high, low, open, hl2, hlc3, ohlc4, hlcc4)

    if pricesArr.includes(src) 

        var warningTable = table.new(position.bottom_right, 99, 99, bgcolor = #20222C, border_color = #363843, 
