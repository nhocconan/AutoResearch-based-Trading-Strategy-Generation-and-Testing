                                    [stop, target] = switch exitType

                                        exitInput.atr =>     [close + atr * stopLossMult, close - atr * profitTargetMult]
                                        exitInput.percent => [close * (1 + stopLossMult / 100), close * (1 - profitTargetMult / 100)]

                                    stop   := math.round_to_mintick(stop)
                                    target := math.round_to_mintick(target)

                                    strategy.entry("Short Bearish Divergence", strategy.short)
                                    strategy.exit("SB Exit", "Short Bearish Divergence", stop = stop, limit = target)

                                    label.new(bar_index, close, text = "▽", textcolor = color.rgb(255, 116, 116), 
                                                     color         = color.new(color.rgb(255, 116, 116), 80), 
                                                     style         = label.style_text_outline, 
                                                     size          = size.normal, 
                                                     tooltip       = "Bearish Divergence Short Entry At: " + str.tostring(close, format.mintick) 
                                                                     + "\nTarget: " + str.tostring(target) + "\nStop: " + str.tostring(stop),
                                                     force_overlay = true,
                                                     yloc          = yloc.abovebar
                                                     )

                                    exitData.stopPrice := stop, exitData.targetPrice := target

                                    tradeMap.put(mapValues.direction, -1)
                                    tradeMap.put(mapValues.target, target)
                                    tradeMap.put(mapValues.stop  , stop)
                                    tradeMap.put(mapValues.entry , close)


                                alert("Bearish Divergence Detected", freq = alert.freq_once_per_bar_close)

                                bearDiv := true

                            else 

                                if finalSrc[1] > divLine.get_y2()

                                    divLine  .set_xy2(time[1], finalSrc [1])
                                    priceLine.set_xy2(time[1], getHigh[1])

                    else 

