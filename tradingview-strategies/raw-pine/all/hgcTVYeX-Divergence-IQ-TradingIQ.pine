                             frame_width   = 1
                             )

        warningTable.cell(0, 0, "In The Divergence IQ Settings, Please Add An Indicator To Calculate Divergences On.\nThe Indicator Must Be On The Chart", 
                                     text_color = color.white)

plot(showFinal or normMethod != normalizationInput.none ? finalSrc : na, color = gradientFlowCol)
plot(showFinal or normMethod != normalizationInput.none ? finalSrc : na, color = color.new(gradientFlowCol, 80), linewidth = 5)


var showCond = divMethod == divInput.pivotPoints

plot(showCond and not na(getPH) ? finalSrc[rightLook] : na, offset = -rightLook, color = bearDiv ? bearDivCol : na, display = display.pane)
