plot(showCond and not na(getPL) ? finalSrc[rightLook] : na, offset = -rightLook, color = bullHdiv ? bullHDivCol : na, display = display.pane)
plot(showCond and not na(getPL) ? finalSrc[rightLook] : na, offset = -rightLook, color = bullHdiv ? color.new(bullHDivCol, 80) : na, linewidth = 5, display = display.pane)


