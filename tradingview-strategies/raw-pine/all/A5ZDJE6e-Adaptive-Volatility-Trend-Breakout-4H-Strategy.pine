//@version=6

// This source code is subject to the terms of the Mozilla Public License 2.0 at https://mozilla.org
// © YourUsername (Open Source)
//
// ---Adaptive Volatility Trend Breakout (4H+ Strategy) ---
// Dit script is Open Source. Je mag het vrij gebruiken, aanpassen en delen.
// Ontworpen voor Trend Trading op de 4H chart en hoger.
//
// DISCLAIMER:
// Trading brengt aanzienlijke risico's met zich mee. Resultaten uit het verleden bieden geen garantie 
// voor de toekomst. Gebruik dit script op eigen risico en doe altijd je eigen onderzoek (DYOR).


strategy("Adaptive Volatility Trend Breakout (4H+ Strategy)", overlay=true, initial_capital=1000, default_qty_type=strategy.percent_of_equity, default_qty_value=1)

// --- Inputs ---
maLength   = input.int(30, "MA Lengte", minval=1)
lookback   = input.int(100, "Historische Data (Bars)", minval=10)
multiplier = input.float(3.3, "Gevoeligheid (StdDev)", step=0.1)

// --- Berekening Moving Average ---
baseMA = ta.ema(close, maLength)

// --- Het Echte Percentage Berekenen ---
priceChangePct = math.abs(close - close[1]) / close[1] 
stdDevPct      = ta.stdev(priceChangePct, lookback)
dynamicPct     = stdDevPct * multiplier

upperBand = baseMA * (1 + dynamicPct)
lowerBand = baseMA * (1 - dynamicPct)

// --- Geheugen Logica (Filtering) ---
// We gebruiken een variabele die onthoudt in welke trend we zitten
// 0 = neutraal, 1 = long, -1 = short
var int trendState = 0

longCondition  = ta.crossover(close, upperBand) and trendState <= 0
shortCondition = ta.crossunder(close, lowerBand) and trendState >= 0

if longCondition
    trendState := 1
    strategy.entry("Long", strategy.long)

if shortCondition
    trendState := -1
    strategy.entry("Short", strategy.short)

// --- Visualisatie ---
p_ma    = plot(baseMA, "Basis MA", color.new(color.blue, 50))
p_upper = plot(upperBand, "Bovengrens", color.new(color.red, 40))
p_lower = plot(lowerBand, "Ondergrens", color.new(color.green, 40))

fill(p_upper, p_lower, color=color.new(color.gray, 90), title="Neutrale Zone")

// Kleur de bars op basis van de actieve trendState
barcolor(trendState == 1 ? color.green : trendState == -1 ? color.red : color.gray)

// Dashboard
var table dash = table.new(position.top_right, 1, 1)
if barstate.islast
    table.cell(dash, 0, 0, "Berekende Zone: " + str.tostring(dynamicPct * 100, "#.##") + "%", bgcolor=color.new(color.black, 0), text_color=color.white)

