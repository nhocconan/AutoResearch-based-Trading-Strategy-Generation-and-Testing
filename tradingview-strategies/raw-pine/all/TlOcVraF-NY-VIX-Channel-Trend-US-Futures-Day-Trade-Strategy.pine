//@version=6
strategy("NY VIX Channel Trend Strategy", overlay=true,
     initial_capital=100000, pyramiding=0,
     default_qty_type=strategy.fixed, default_qty_value=1,
     commission_type=strategy.commission.cash_per_contract, commission_value=2.5,
     calc_on_every_tick=true, process_orders_on_close=true, margin_long=0, margin_short=0,
     max_lines_count=200, max_labels_count=50, max_boxes_count=0)

//============================= CONFIG =============================
grp_ny     = "New York Session"
ny_time    = input.session("0930-1600", "NY session time", group=grp_ny)
ny_tz      = input.string("America/New_York", "Timezone", group=grp_ny)

grp_vix    = "VIX Channel"
use_vix9d  = input.bool(true, "Use VIX9D for width else VIX", group=grp_vix)
use_open   = input.bool(false, "Use daily OPEN instead of CLOSE", group=grp_vix)
vix_color  = input.color(color.new(color.orange, 0), "Channel color", group=grp_vix)
fill_alpha = input.int(92, "Fill transparency", minval=0, maxval=100, group=grp_vix)

grp_bias   = "Window Trend"
window_min = input.int(30, "Window minutes", minval=5, maxval=120, step=5, group=grp_bias)
bg_long    = input.color(color.new(color.teal, 88), "Long background", group=grp_bias)
bg_short   = input.color(color.new(color.red, 88),  "Short background", group=grp_bias)

grp_risk   = "Risk and Time Exit"
vix_factor_sl = input.float(1.0, "VIX factor for SL", step=0.25, minval=0.1, group=grp_risk)
vix_factor_tp = input.float(1.0, "VIX factor for TP", step=0.25, minval=0.1, group=grp_risk)
exit_cut_min  = input.int(30, "Exit N minutes before session close", minval=5, maxval=180, group=grp_risk)

//============================= SESSION FLAGS ======================
in_sess  = not na(time("", ny_time, ny_tz))
new_sess = in_sess and not in_sess[1]

//============================= DAILY IV ===========================
sym_vix   = input.symbol("VIX",   "VIX 1M symbol", group=grp_vix)
sym_vix9d = input.symbol("VIX9D", "VIX 9D symbol", group=grp_vix)

req_src(x) => request.security(x, "D", use_open ? open : close, lookahead=barmerge.lookahead_off)
vix1m_d    = req_src(sym_vix)
vix9d_d    = req_src(sym_vix9d)
base_vix_d = use_vix9d and not na(vix9d_d) ? vix9d_d : vix1m_d
sigma_d    = (base_vix_d / 100.0) / math.sqrt(252.0)  // daily fraction

//============================= CHANNEL ============================
var float sess_open_px = na
var float sess_width   = na
if new_sess
    sess_open_px := open
    sess_width   := sigma_d
if not in_sess
    sess_open_px := na
    sess_width   := na

vix_upper = in_sess and not na(sess_open_px) and not na(sess_width) ? sess_open_px * (1 + sess_width) : na
vix_lower = in_sess and not na(sess_open_px) and not na(sess_width) ? sess_open_px * (1 - sess_width) : na
vix_mid   = in_sess and not na(sess_open_px) ? sess_open_px : na

pu = plot(vix_upper, "VIX Upper", vix_color, 1)
pl = plot(vix_lower, "VIX Lower", vix_color, 1)
pm = plot(vix_mid,   "VIX Mid",   color.new(vix_color, 60), 1)
fill(pu, pl, color.new(vix_color, fill_alpha))

//============================= WINDOW TREND =======================
var int   sess_start_ms      = na
var float ny_open_for_bias   = na
var float window_close_px    = na
var int   bias_trend_state   = 0        // 1 long  -1 short  0 flat
var int   window_end_bar_idx = na
var bool  entered_this_sess  = false

if new_sess
    sess_start_ms      := time
    ny_open_for_bias   := open
    window_close_px    := na
    bias_trend_state   := 0
    window_end_bar_idx := na
    entered_this_sess  := false
if not in_sess
    sess_start_ms      := na
    ny_open_for_bias   := na
    window_close_px    := na
    bias_trend_state   := 0
    window_end_bar_idx := na
    entered_this_sess  := false

win_ms     = window_min * 60 * 1000
win_done   = in_sess and not na(sess_start_ms) and time >= sess_start_ms + win_ms
if win_done and na(window_end_bar_idx)
    window_close_px    := close
    bias_trend_state   := window_close_px > ny_open_for_bias ? 1 : window_close_px < ny_open_for_bias ? -1 : 0
    window_end_bar_idx := bar_index

after_window = in_sess and not na(window_end_bar_idx) and bar_index > window_end_bar_idx
bgcolor(after_window ? (bias_trend_state == 1 ? bg_long : bias_trend_state == -1 ? bg_short : na) : na)

//============================= STRATEGY ===========================
get_minutes(sess) =>
    sh = str.tonumber(str.substring(sess, 0, 2))
    sm = str.tonumber(str.substring(sess, 2, 4))
    eh = str.tonumber(str.substring(sess, 5, 7))
    em = str.tonumber(str.substring(sess, 7, 9))
    (eh * 60 + em) - (sh * 60 + sm)

sess_len_min = get_minutes(ny_time)
sess_end_ms  = not na(sess_start_ms) ? sess_start_ms + sess_len_min * 60 * 1000 : na
cut_ms       = not na(sess_end_ms) ? sess_end_ms - exit_cut_min * 60 * 1000 : na
force_exit   = in_sess and not na(cut_ms) and time >= cut_ms

enter_long  = after_window and bias_trend_state == 1 and not entered_this_sess and strategy.position_size == 0
enter_short = after_window and bias_trend_state == -1 and not entered_this_sess and strategy.position_size == 0

if enter_long
    strategy.entry("L", strategy.long)
    entered_this_sess := true
if enter_short
    strategy.entry("S", strategy.short)
    entered_this_sess := true

risk_tp = sigma_d * vix_factor_tp
risk_sl = sigma_d * vix_factor_sl

long_stop  = strategy.position_avg_price * (1 - risk_sl)
long_tp    = strategy.position_avg_price * (1 + risk_tp)
short_stop = strategy.position_avg_price * (1 + risk_sl)
short_tp   = strategy.position_avg_price * (1 - risk_tp)

if strategy.position_size > 0
    strategy.exit("XL", from_entry="L", stop=long_stop, limit=long_tp)
if strategy.position_size < 0
    strategy.exit("XS", from_entry="S", stop=short_stop, limit=short_tp)

// Exit on channel breach
exit_long_ch  = strategy.position_size > 0 and not na(vix_upper) and close >= vix_upper
exit_short_ch = strategy.position_size < 0 and not na(vix_lower) and close <= vix_lower
if exit_long_ch
    strategy.close("L", comment="ChTop")
if exit_short_ch
    strategy.close("S", comment="ChBot")

// Forced flat before session close
if strategy.position_size != 0 and force_exit
    if strategy.position_size > 0
        strategy.close("L", comment="TimeExit")
    else
        strategy.close("S", comment="TimeExit")

