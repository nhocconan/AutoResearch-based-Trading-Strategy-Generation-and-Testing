//@version=2
strategy(title="Simple Relative Strength Index", shorttitle="Simple RSI + Buy Sell")
src = close, len = input(14, minval=1, title="Length")
up = sma(max(change(src), 0), len)
down = sma(-min(change(src), 0), len)
rsi = down == 0 ? 100 : up == 0 ? 0 : 100 - (100 / (1 + up / down))
plot(rsi, color=red)

lowerrsi=input(15, title="RSI Lower Band", type=integer)
upperrsi=input(85, title="RSI Upper Band", type=integer)


band1 = hline(upperrsi)
band0 = hline(lowerrsi)
fill(band1, band0, color=blue, transp=90)

take_Profit=input(15, title="Take Profit", type=integer)
close_Overbought = input(true, "Close at overbought levels", type=bool)

if rsi<=lowerrsi
    strategy.entry("BuyOS", strategy.long)
if close_Overbought == true
    if rsi>=upperrsi and strategy.position_size>=1
        strategy.close("BuyOS")

