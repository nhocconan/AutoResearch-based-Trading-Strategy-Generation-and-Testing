//@version=6
strategy("DayFlow VWAP Relay — Majors",
     shorttitle="DayFlow Relay",
     overlay=true, pyramiding=0,
     initial_capital=10000,
     default_qty_type=strategy.percent_of_equity, default_qty_value=3,
     commission_type=strategy.commission.cash_per_contract, commission_value=0.0001,
     slippage=3,
     process_orders_on_close=true,
     calc_on_every_tick=false, calc_on_order_fills=false,
     margin_long=0, margin_short=0)

// =============== GROUPS
grp_setup   = "Setup"
grp_bands   = "VWAP Bands"
grp_micro   = "Micro Flow"
grp_sess    = "Sessions"
grp_risk    = "Risk"
grp_view    = "View"

// =============== INPUTS
// Setup
sig_len     = input.int(63, "Signal length", minval=20, group=grp_setup, tooltip="Lookback window for regime math on residuals")
lower_tf    = input.timeframe("1", "Micro TF", group=grp_micro, tooltip="Lower timeframe used to read micro flow inside the current bar")
micro_span  = input.int(10, "Micro span bars", minval=3, group=grp_micro, tooltip="How many lower TF bars to summarize for micro flow")
micro_gate  = input.float(0.20, "Micro flow gate 0..1", minval=0.0, maxval=1.0, step=0.05, group=grp_micro, tooltip="Minimum absolute micro flow needed to trust a trigger")

// Bands and regime
stdev_mult  = input.float(1.0, "VWAP stdev multiplier", minval=0.2, step=0.1, group=grp_bands, tooltip="Width of daily anchored VWAP envelope")
exp_gate    = input.float(0.65, "Expansion gate 0..3", minval=0.0, maxval=3.0, step=0.05, group=grp_bands, tooltip="If expansion score above this, prefer breakouts. Otherwise prefer fades")

// Sessions
sess_en     = input.bool(true, "Use session filter", group=grp_sess)
sess_str    = input.session("0700-1700", "Trade window UTC", group=grp_sess, tooltip="Common London through NY window")

// Risk
atr_len     = input.int(14, "ATR length", minval=5, group=grp_risk)
sl_atr      = input.float(1.2, "Stop ATR x", minval=0.2, step=0.1, group=grp_risk)
tp_atr      = input.float(1.8, "Target ATR x", minval=0.2, step=0.1, group=grp_risk)
cooldown    = input.int(10, "Cooldown bars after close", minval=0, group=grp_risk)
side_opt    = input.string("Both", "Side", options=["Both","Long only","Short only"], group=grp_risk)

// View
show_bands  = input.bool(true, "Show VWAP and bands", group=grp_view)
show_resid  = input.bool(true, "Color bars by residual regime", group=grp_view)

// =============== HELPERS
micro_flow(array<float> a, int span) =>
    int n = array.size(a)
    if n < 2
        0.0
    else
        int last = math.max(1, n - 1)  // exclude freshest element
        int from = math.max(1, last - span + 1)
        float acc = 0.0
        for i = from to last
            float prev = array.get(a, i - 1)
            float curr = array.get(a, i)
            acc += curr > prev ? 1 : curr < prev ? -1 : 0
        acc /= math.max(1, last - from + 1)

// =============== CALC
anchor_daily = timeframe.change("1D")
[vwap_d, vup, vdn] = ta.vwap(hlc3, anchor_daily, stdev_mult)

resid = close - vwap_d

v_slope   = ta.linreg(vwap_d, sig_len, 0) - ta.linreg(vwap_d, sig_len, 1)
expansion = ta.stdev(resid, sig_len) / math.max(1e-10, ta.stdev(close, sig_len))

const float PCT_UP = 75.0
const float PCT_DN = 25.0
res_hi = ta.percentile_linear_interpolation(resid, sig_len, PCT_UP)
res_lo = ta.percentile_linear_interpolation(resid, sig_len, PCT_DN)

arr_close = request.security_lower_tf(syminfo.tickerid, lower_tf, close)
mf = micro_flow(arr_close, micro_span)

in_sess = not sess_en or not na(time(timeframe.period, sess_str))

since_closed = ta.barssince(ta.change(strategy.closedtrades) > 0)
cool_ok = na(since_closed) or since_closed >= cooldown

allow_long  = side_opt != "Short only"
allow_short = side_opt != "Long only"

// =============== SIGNALS
balanced_day = expansion < exp_gate
trend_day    = expansion >= exp_gate

long_fade   = balanced_day and resid <= res_lo and mf >  micro_gate and in_sess and cool_ok
short_fade  = balanced_day and resid >= res_hi and mf < -micro_gate and in_sess and cool_ok
long_break  = trend_day    and close > vup and v_slope > 0 and mf >  micro_gate and in_sess and cool_ok
short_break = trend_day    and close < vdn and v_slope < 0 and mf < -micro_gate and in_sess and cool_ok

go_long  = allow_long  and (long_fade or long_break)
go_short = allow_short and (short_fade or short_break)

// =============== RISK
atr = ta.atr(atr_len)
to_ticks(x) => int(math.round(x / syminfo.mintick))
loss_ticks   = to_ticks(atr * sl_atr)
profit_ticks = to_ticks(atr * tp_atr)

if go_long
    strategy.entry("L", strategy.long)
if go_short
    strategy.entry("S", strategy.short)

if strategy.position_size > 0
    strategy.exit("Lx", from_entry="L", loss=loss_ticks, profit=profit_ticks)
    if go_short
        strategy.close("L")
if strategy.position_size < 0
    strategy.exit("Sx", from_entry="S", loss=loss_ticks, profit=profit_ticks)
    if go_long
        strategy.close("S")

// =============== PLOTS
col_bal = color.new(color.teal, 80)
col_trd = color.new(color.orange, 80)
bgcolor(show_resid ? (balanced_day ? col_bal : col_trd) : na, title="Regime")

plot(show_bands ? vwap_d : na, "VWAP D", color=color.white, linewidth=2)
plot(show_bands ? vup    : na, "VWAP Up", color=color.green)
plot(show_bands ? vdn    : na, "VWAP Dn", color=color.red)

plotshape(go_long,  title="Go Long",  style=shape.triangleup,   location=location.belowbar, color=color.lime, size=size.tiny, text="L")
plotshape(go_short, title="Go Short", style=shape.triangledown, location=location.abovebar, color=color.red,  size=size.tiny, text="S")

alertcondition(go_long,  title="DayFlow Long",  message="DayFlow Relay long {{ticker}} {{interval}}")
alertcondition(go_short, title="DayFlow Short", message="DayFlow Relay short {{ticker}} {{interval}}")

