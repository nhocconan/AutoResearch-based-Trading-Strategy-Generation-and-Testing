//@version=4
strategy("Silver Long/Short ", shorttitle="Silver Long/Short", process_orders_on_close=true, initial_capital=100000.00, default_qty_type=strategy.percent_of_equity, default_qty_value=100, overlay=true, max_bars_back=5000)

//tickers
GSR_close = security("TVC:GOLDSILVER", "D", close) 
Silver_close = security("TVC:SILVER", "D", close) 

//inputs
multiplier = input(title="Multiplier", defval=1.00)
FromYear   = input(defval = 2000, title = "From Year", minval = 2000)
FromMonth  = input(defval = 1, title = "From Month", minval = 1, maxval = 12)
FromDay    = input(defval = 1, title = "From Day", minval = 1, maxval = 31)
ToYear     = input(defval = 2020, title = "To Year", minval = 2000)
ToMonth    = input(defval = 2, title = "To Month", minval = 1, maxval = 12)
ToDay      = input(defval = 1, title = "To Day", minval = 1, maxval = 31)

//SMA periods
len1 = input(50, minval=1, title="SMA Silver Short")
len2 = input(200, minval=1, title="SMA Silver Long")
len3 = input(6, minval=1, title="SMA GSR Short")
len4 = input(26, minval=1, title="SMA GSR Long")

//GSR levels for overbought/oversold
overbought = input(60, minval=1, title="GSR overboughl")
oversold = input(45, minval=1, title="GSR oversold")

//position size
contracts_to_buy = (multiplier*strategy.equity)/close


//backtest period
testPeriodStart = timestamp(FromYear, FromMonth, FromDay, 00, 00)
testPeriodStop = timestamp(ToYear, ToMonth, ToDay, 23, 59) 

//plot closing prices and moving averages for silver
plot(Silver_close, color=color.black, title="Silver")
plot(sma(Silver_close, len1), color=color.red, title="SMA Short")
plot(sma(Silver_close, len2), color=color.blue, title="SMA Long")

//plot closing prices and moving averages for GSR
plot(GSR_close, color=color.black, title="GSR")
plot(sma(GSR_close,len3), color=color.red, title="SMA GSR Short")
plot(sma(GSR_close,len4), color=color.blue, title="SMA GSR Long")

//Buy if GSR is overbought and silver uptrend is true, sell if GSR is oversold and downtrend is true
if time >= testPeriodStart and time <= testPeriodStop
    if  crossover(sma(Silver_close, len1),sma(Silver_close, len2))  and GSR_close > overbought and sma(GSR_close,len3) < sma(GSR_close,len4)
        strategy.close_all()
        strategy.entry(id="EL", long=true, qty=contracts_to_buy)
    else 
        if  GSR_close < oversold  and crossover(sma(GSR_close,len3), sma(GSR_close,len4))
            strategy.close_all()
            strategy.entry(id="ES", long=false, qty=contracts_to_buy)

