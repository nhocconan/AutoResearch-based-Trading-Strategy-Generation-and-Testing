//@version=5
strategy("Kill Zone Strategy - Exact Match",
     shorttitle="KZ Strategy",
     overlay=true, 
     initial_capital=10000000,
     default_qty_type=strategy.percent_of_equity,
     default_qty_value=10, // 100에서 10으로 하향 조정 (하우스 룰 준수)
     commission_type=strategy.commission.percent,
     commission_value=0.04,
     slippage=2) // 슬리피지 추가 (현실적인 결과 반영)

// ============================================================================
// 설정
// ============================================================================
i_timezone = input.string("Asia/Seoul", "Timezone")
i_entry_type = input.string("1H Close", "Entry Price", options=["1H Close", "15M Close"])
i_close_eod = input.bool(true, "Close at End of Day")
i_eod_hour = input.int(15, "EOD Hour", minval=0, maxval=23)
i_show_labels = input.bool(true, "Show Entry/Exit Labels")

// ============================================================================
// Kill Zone 1시간봉 데이터 가져오기 (정확히 9-10시)
// ============================================================================
// request.security로 1시간봉 데이터 가져오기
[h1_time, h1_open, h1_high, h1_low, h1_close] = request.security(
     syminfo.tickerid, 
     "60", 
     [time, open, high, low, close],
     lookahead=barmerge.lookahead_off)

// 15분봉 데이터
[m15_close] = request.security(
     syminfo.tickerid, 
     "15", 
     [close],
     lookahead=barmerge.lookahead_off)

// ============================================================================
// 시간 확인
// ============================================================================
get_hour(t) =>
    hour(t, i_timezone)

// 현재 캔들이 Kill Zone 시간대(9시)인지 확인
is_killzone_hour(t) =>
    h = get_hour(t)
    h == 9

// 10시 첫 캔들 감지 (진입 시점)
is_entry_time(t) =>
    h = get_hour(t)
    h == 10

// 청산 시간
is_exit_time(t) =>
    h = get_hour(t)
    h >= i_eod_hour

// ============================================================================
// Kill Zone 방향 판단
// ============================================================================
var int kz_direction = 0  // 1=long, -1=short, 0=neutral
var float entry_price = 0.0
var bool position_opened = false

// 매일 초기화
if ta.change(dayofmonth(time, i_timezone))
    kz_direction := 0
    entry_price := 0.0
    position_opened := false

// Kill Zone 1시간봉이 완성되는 시점 (10시 첫 캔들)
if is_entry_time(time) and is_entry_time(time[1]) == false
    // 이전 1시간봉(9시)의 데이터 사용
    prev_h1_open = h1_open[1]
    prev_h1_close = h1_close[1]
    
    // 방향 결정
    if prev_h1_close > prev_h1_open
        kz_direction := 1  // 양봉 = LONG
    else if prev_h1_close < prev_h1_open
        kz_direction := -1  // 음봉 = SHORT
    
    // 진입 가격 결정
    if i_entry_type == "1H Close"
        entry_price := prev_h1_close  // 9시 1시간봉 종가
    else
        entry_price := m15_close[1]   // 9:45 15분봉 종가
    
    // 디버그 라벨
    if i_show_labels
        dir_text = kz_direction == 1 ? "LONG" : kz_direction == -1 ? "SHORT" : "NEUTRAL"
        label.new(bar_index, high, 
                 "KZ: " + dir_text + "\n진입가: " + str.tostring(entry_price, "#.##"),
                 color=kz_direction == 1 ? color.green : color.red,
                 textcolor=color.white,
                 style=label.style_label_down,
                 size=size.small)

// ============================================================================
// 진입 조건
// ============================================================================
long_condition = kz_direction == 1 and not position_opened and strategy.position_size == 0
short_condition = kz_direction == -1 and not position_opened and strategy.position_size == 0

// ============================================================================
// 주문 실행
// ============================================================================
if long_condition
    strategy.entry("Long", strategy.long, comment="KZ Long @ " + str.tostring(entry_price))
    position_opened := true
    
    if i_show_labels
        label.new(bar_index, low,
                 "✓ LONG Entry\n" + str.tostring(close, "#.##"),
                 color=color.new(color.green, 0),
                 textcolor=color.white,
                 style=label.style_label_up,
                 size=size.normal)

if short_condition
    strategy.entry("Short", strategy.short, comment="KZ Short @ " + str.tostring(entry_price))
    position_opened := true
    
    if i_show_labels
        label.new(bar_index, high,
                 "✓ SHORT Entry\n" + str.tostring(close, "#.##"),
                 color=color.new(color.red, 0),
                 textcolor=color.white,
                 style=label.style_label_down,
                 size=size.normal)

// ============================================================================
// 청산 (당일 종가)
// ============================================================================
if i_close_eod and is_exit_time(time)
    if strategy.position_size != 0
        strategy.close_all(comment="EOD Close")
        
        if i_show_labels
            label.new(bar_index, close,
                     "EOD Close\n" + str.tostring(close, "#.##"),
                     color=color.orange,
                     textcolor=color.white,
                     style=label.style_circle,
                     size=size.small)

// ============================================================================
// 시각화
// ============================================================================
// Kill Zone 시간 하이라이트
bgcolor(is_killzone_hour(time) ? color.new(color.yellow, 90) : na)

// ============================================================================
// 통계 테이블
// ============================================================================
var table stats = table.new(position.top_right, 2, 8, 
                           bgcolor=color.new(color.black, 85), 
                           border_width=1)

if barstate.islast
    table.cell(stats, 0, 0, "Kill Zone Strategy", text_size=size.normal, text_color=color.white)
    table.merge_cells(stats, 0, 0, 1, 0)
    
    table.cell(stats, 0, 1, "Entry Type", text_color=color.gray, text_size=size.small)
    table.cell(stats, 1, 1, i_entry_type, text_color=color.white, text_size=size.small)
    
    table.cell(stats, 0, 2, "Total Trades", text_color=color.gray, text_size=size.small)
    table.cell(stats, 1, 2, str.tostring(strategy.closedtrades), text_color=color.white, text_size=size.small)
    
    table.cell(stats, 0, 3, "Wins", text_color=color.gray, text_size=size.small)
    table.cell(stats, 1, 3, str.tostring(strategy.wintrades), text_color=color.green, text_size=size.small)
    
    table.cell(stats, 0, 4, "Losses", text_color=color.gray, text_size=size.small)
    table.cell(stats, 1, 4, str.tostring(strategy.losstrades), text_color=color.red, text_size=size.small)
    
    table.cell(stats, 0, 5, "Win Rate", text_color=color.gray, text_size=size.small)
    wr = strategy.closedtrades > 0 ? (strategy.wintrades / strategy.closedtrades) * 100 : 0
    table.cell(stats, 1, 5, str.tostring(wr, "#.#") + "%", text_color=color.white, text_size=size.small)
    
    table.cell(stats, 0, 6, "Net Profit", text_color=color.gray, text_size=size.small)
    np_color = strategy.netprofit > 0 ? color.green : color.red
    table.cell(stats, 1, 6, str.tostring(strategy.netprofit, "#.##"), text_color=np_color, text_size=size.small)
    
    table.cell(stats, 0, 7, "Today Direction", text_color=color.gray, text_size=size.small)
    dir_text = kz_direction == 1 ? "LONG ▲" : kz_direction == -1 ? "SHORT ▼" : "-"
    dir_color = kz_direction == 1 ? color.green : kz_direction == -1 ? color.red : color.gray
    table.cell(stats, 1, 7, dir_text, text_color=dir_color, text_size=size.small)

