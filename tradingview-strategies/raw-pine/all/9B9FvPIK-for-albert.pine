//@version=6 
strategy(title="ОБ с фильтром по объему v1.3 (кроссовер на предыдущей свече)", shorttitle="ОБ+Vol strategy v1.3", overlay=true, process_orders_on_close=true, pyramiding=5)
        
    

        ///     div-line     ///
// Объявляем переменную div_line с использованием var
var float div_line = na
var float long_in = na
var float short_in = na
var float direction = na
var float short_stop = na
var float long_stop = na


//Паттерн в шорт
short_pattern = (volume[1]>volume) and ((volume[2]<volume[1] and close[2]>open[2]) or (volume[2]<volume[1] and close[3]>open[3])) and (close[3]>open[3] or close[4]>open[4])
long_pattern = (volume[1]>volume) and ((volume[2]<volume[1] and close[2]<open[2]) or (volume[2]<volume[1] and close[3]<open[3])) and (close[3]<open[3] or close[4]<open[4])



if short_pattern
    div_line := math.min(close, open)
else if long_pattern
    div_line := math.max(close, open)
else
    div_line[1]

plot(div_line, "div line", color=color.new(#ffffff, 30))



            ///     OB        ///
//линии Alligator
smma(src, length) =>
    smma =  0.0
    smma := na(smma[1]) ? ta.sma(src, length) : (smma[1] * (length - 1) + src) / length
    smma
jawLength = input.int(13, minval=1, title="Jaw Length")
teethLength = input.int(8, minval=1, title="Teeth Length")
lipsLength = input.int(5, minval=1, title="Lips Length")
jawOffset = input(8, title="Jaw Offset")
teethOffset = input(5, title="Teeth Offset")
lipsOffset = input(3, title="Lips Offset")
jaw = smma(hl2, jawLength)
teeth = smma(hl2, teethLength)
lips = smma(hl2, lipsLength)
//plot(jaw, "Jaw", offset = jawOffset, color=#2962FF)
//plot(teeth, "Teeth", offset = teethOffset, color=#E91E63)
//plot(lips, "Lips", offset = lipsOffset, color=#66BB6A)

// Настройка периода усреднения
period = input.int(5, title="Период усреднения", minval=1)

// Расчет среднего объема
averageVolume = ta.sma(volume, period)

// отклоняющийся бар для Long
LongOB =  close[1]<open[1] and close>(high-low)/2+low and high<math.min(jaw[jawOffset], teeth[teethOffset], lips[lipsOffset]) and 
  jaw[jawOffset]>teeth[teethOffset] and lips[lipsOffset]<teeth[teethOffset] and close[2]<open[2] and low[2]> low[1] and low<low[1] //and close[3]<open[3] low<low[1] and 

// отклоняющийся бар для Short
ShortOB =  close[1]>open[1] and close<(high-low)/2+low and low>math.max(jaw[jawOffset], teeth[teethOffset], lips[lipsOffset]) and 
  jaw[jawOffset]<teeth[teethOffset] and lips[lipsOffset]>teeth[teethOffset] and close[2]>open[2] and high[2]<high[1] //and high>high[1] //and close[3]>open[3] high>high[1] and 

var LongTrend = false
var Strong_Long_signal = 0
var float LongVolume = 0.0
var ShortTrend = false
var Strong_Short_signal = 0
var float ShortVolume = 0.0
var Short_signal = false
var Long_signal = false
var Signal_color = color.red
var long_in_level = 0.0
var tpLevel = 0.0
var Short_in_level = 0.0
var Up_Line = 0.0
var Down_Line = 0.0
var Long_stop_Level = 0.0
var Short_stop_Level = 0.0

// определение начала и конца тренда Long
//отслеживание тренда
if ShortOB
    LongTrend := true
else if LongOB
    LongTrend := false
else 
    LongTrend := LongTrend[1]

//отслеживание объема в тренде long
if LongTrend and ShortOB
    LongVolume := volume[1]
else if LongTrend == false
    LongVolume := 0.0
else 
    LongVolume := LongVolume[1]

if LongVolume < LongVolume[1] and LongVolume>0
    Short_signal := true
else 
    Short_signal := false

//отслеживание тренда
if LongOB
    ShortTrend := true
else if ShortOB
    ShortTrend := false
else 
    ShortTrend := ShortTrend[1]

//отслеживание объема в тренде short
if ShortTrend and LongOB
    ShortVolume := volume[1]
else if ShortTrend == false
    ShortVolume := 0.0
else 
    ShortVolume := ShortVolume[1]

if ShortVolume < ShortVolume[1] and ShortVolume>0
    Long_signal := true
else 
    Long_signal := false

//  линии входа в лонг и шорт
LongLine = 0.0
ShortLine = 0.0
color longcolor = color.new(color.green, 100)
if LongOB or ShortOB
    LongLine := high
    ShortLine := low
else
    LongLine := LongLine[1]
    ShortLine := ShortLine[1]

//линии заднего фона при начальном сигнале
if LongOB //and 1>1
    longcolor := color.new(color.green, 60) 
else if ShortOB 
    longcolor := color.new(color.red, 60) 
else
    longcolor := color.new(color.green, 100)
bgcolor(longcolor)

// Визуализация индикатора OB линиями 
plot(LongLine, title="LongLevel",  color=color.rgb(0, 255, 8, 28) , linewidth=2)
plot(ShortLine, title="ShortLevel",  color=color.rgb(255, 0, 0, 28) , linewidth=2)


//линии заднего фона при сильном сигнале
if Short_signal //and 1>1
    Signal_color := color.new(#ff0000, 50) 
else if Long_signal 
    Signal_color := color.new(#3cff00, 50) 
else
    Signal_color := color.new(color.green, 100)

bgcolor(Signal_color)




// Создаем входной параметр для выбора таймфрейма и тейк профита
tf = input.timeframe(defval="15", title="Таймфрейм старшего графика", options=["1", "5", "15", "30", "60", "240", "D", "W", "MN"])
tp_percent = input(defval=8.0, title="Тейк-профит, %")
// Получение переменной с другого таймфрейма
[htf_div] = request.security(syminfo.tickerid, tf, [div_line], lookahead=barmerge.lookahead_off)
[htf_longcolor] = request.security(syminfo.tickerid, tf, [longcolor], lookahead=barmerge.lookahead_off)
bgcolor(htf_longcolor)
[htf_Signal_color] = request.security(syminfo.tickerid, tf, [Signal_color], lookahead=barmerge.lookahead_off)
bgcolor(htf_Signal_color)
[htf_Short_signal] = request.security(syminfo.tickerid, tf, [Short_signal], lookahead=barmerge.lookahead_off)
[htf_Long_signal] = request.security(syminfo.tickerid, tf, [Long_signal], lookahead=barmerge.lookahead_off)

//зона поиска вершины тренда (вход в шорт)
if Short_signal or htf_Short_signal
    Strong_Short_signal := 1
else if Long_signal or LongOB or htf_Long_signal
    Strong_Short_signal := 0
else 
    Strong_Short_signal := Strong_Short_signal[1]
plot(Strong_Short_signal, title="Strong_Short_signal",  color=color.rgb(0, 151, 66, 17) , linewidth=1)
//зона поиска дна тренда (вход в лонг)
if Long_signal or htf_Long_signal
    Strong_Long_signal := 1
else if Short_signal or ShortOB or htf_Short_signal
    Strong_Long_signal := 0
else 
    Strong_Long_signal := Strong_Long_signal[1]


//линия верхнего сигнала
if close >= div_line and open >= div_line and (close < (high-low)/2+low or close<open) and open[1]<close[1] and Strong_Long_signal==1 //low[1] < div_line[1] an//and div_line==div_line[1]
    Up_Line := math.max(high, high[1])
else if Strong_Short_signal==1 or ShortOB
    Up_Line := high*2
else
    Up_Line := Up_Line[1]
plot(Up_Line, title="Up_line",  color=color.rgb(255, 0, 187, 17) , linewidth=1)

//линия нижнего сигнала
if close <= div_line and open <= div_line and (close > (high-low)/2+low or close>open) and open[1]>close[1] and Strong_Short_signal==1 //high[1] > div_line[1] //and div_line==div_line[1]    
    Down_Line := math.min(low, low[1])
else if Strong_Long_signal==1 or LongOB
    Down_Line := low*0.5
else
    Down_Line := Down_Line[1]
plot(Down_Line, title="Down_Line",  color=color.rgb(0, 94, 255, 17) , linewidth=1)


// Условия для входа в лонг
longCondition = ta.crossover(high, Up_Line[1])
// Условия для входа в шорт
shortCondition = ta.crossunder(low, Down_Line[1]) 


// коэффициент atr для усреднения
k_atr = input.float(defval=5.0, title="Коэфф. atr для усреднения")
multiply_range = ta.atr(200)*k_atr
// коэффициент atr для усреднения
k_TP = input.float(defval=1.5, title="Коэфф. atr для TP")
TP_range = ta.atr(200)/close*k_TP
plot(TP_range, "TP_range", color=color.rgb(230, 0, 255, 17), style = plot.style_circles)

            ///        Открытие позиции        ///
//первоначальный размер позиции
first_order_USDT = input.float(defval=100, title="Размер первого ордера в USDT")
qty = first_order_USDT/high
// Вход в лонг
if longCondition and strategy.position_size <= 0  
    strategy.entry("Long", strategy.long, limit = Up_Line, stop=Long_stop_Level, qty=qty)
if longCondition and Up_Line<strategy.opentrades.entry_price(strategy.opentrades - 1)*(1-multiply_range/100) and strategy.position_size>0 //условие усреднения
    strategy.entry("Long", strategy.long, limit = Up_Line, stop=Long_stop_Level, qty=math.abs(strategy.position_size)*2) //усреднение с удвоением количества

if strategy.position_size > 0 and low > strategy.position_avg_price*(1+5*TP_range) and low[1] > strategy.position_avg_price*(1+5*TP_range) //условие 4 тейка
    Long_stop_Level := strategy.position_avg_price*(1+5*TP_range)
else if strategy.position_size > 0 and low > strategy.position_avg_price*(1+3*TP_range) and low[1] > strategy.position_avg_price*(1+3*TP_range) //условие 3 тейка
    Long_stop_Level := strategy.position_avg_price*(1+3*TP_range)
else if strategy.position_size > 0 and low > strategy.position_avg_price*(1+2*TP_range) and low[1] > strategy.position_avg_price*(1+2*TP_range) //условие 2 тейка
    Long_stop_Level := strategy.position_avg_price*(1+2*TP_range)
else if strategy.position_size > 0 and low > strategy.position_avg_price*(1+TP_range) and low[1] > strategy.position_avg_price*(1+TP_range) //условие 1 тейка
    Long_stop_Level := strategy.position_avg_price*(1+TP_range)
else if strategy.position_size > 0 and low > strategy.position_avg_price*1.003 and low[1] > strategy.position_avg_price*1.003 and low[2] > strategy.position_avg_price*1.003//условие выход в безубыток
    Long_stop_Level := strategy.position_avg_price * 1.003
else if strategy.position_size == 0
    Long_stop_Level := na
else if shortCondition and strategy.position_size > 0
    Long_stop_Level := Down_Line 
else
    Long_stop_Level := Long_stop_Level[1]
plot(Long_stop_Level, "Long_stop", color.rgb(0, 255, 145), style = plot.style_circles)

//выход из лонг    
strategy.exit("Exit Long", from_entry="Long", limit=strategy.position_avg_price*(100+tp_percent)/100, stop=Long_stop_Level)
//plot(strategy.position_avg_price, "avg", color.rgb(55, 0, 255), style = plot.style_circles)


// Вход в шорт
if shortCondition and strategy.position_size >= 0 
    strategy.entry("Short", strategy.short, limit = Down_Line, stop=Short_stop_Level, qty=qty)
if shortCondition and Down_Line>strategy.opentrades.entry_price(strategy.opentrades - 1)*(1+multiply_range/100) and strategy.position_size<0 //условие усреднения шорт
    strategy.entry("Short", strategy.short, limit = Down_Line, stop=Short_stop_Level, qty=math.abs(strategy.position_size)*2)
if strategy.position_size < 0 and high < strategy.position_avg_price*(1-5*TP_range) and high[1] < strategy.position_avg_price*(1-5*TP_range)// условие 4 тейка
    Short_stop_Level := strategy.position_avg_price*(1-5*TP_range)    
else if strategy.position_size < 0 and high < strategy.position_avg_price*(1-3*TP_range) and high[1] < strategy.position_avg_price*(1-3*TP_range)// условие 3 тейка
    Short_stop_Level := strategy.position_avg_price*(1-3*TP_range)
else if strategy.position_size < 0 and high < strategy.position_avg_price*(1-2*TP_range) and high[1] < strategy.position_avg_price*(1-2*TP_range) // условие 2 тейка
    Short_stop_Level := strategy.position_avg_price*(1-2*TP_range)
else if strategy.position_size < 0 and high < strategy.position_avg_price*(1-TP_range) and high[1] < strategy.position_avg_price*(1-TP_range) // условие 1 тейка
    Short_stop_Level := strategy.position_avg_price*(1-TP_range)
else if strategy.position_size < 0 and high < strategy.position_avg_price*0.997 and high[1] < strategy.position_avg_price*0.997 and high[2] < strategy.position_avg_price*0.997 // условие выход в безубыток
    Short_stop_Level := strategy.position_avg_price*0.997
else if strategy.position_size == 0
    Short_stop_Level := na
else if longCondition and strategy.position_size < 0
    Short_stop_Level := Up_Line
else
    Short_stop_Level := Short_stop_Level[1]
plot(Short_stop_Level, "Short_stop", color.rgb(255, 140, 0), style = plot.style_circles)

//выход из шорт    
strategy.exit("Exit Short", from_entry="Short", limit=strategy.position_avg_price*(100-tp_percent)/100, stop=Short_stop_Level)
plot(strategy.position_avg_price, "avg", color.rgb(255, 255, 0), style = plot.style_circles)


//if strategy.position_size < 0
//   short_tp_price = strategy.position_avg_price * 0.995
//    strategy.exit('Short Exit', 'Short', limit = short_tp_price)

