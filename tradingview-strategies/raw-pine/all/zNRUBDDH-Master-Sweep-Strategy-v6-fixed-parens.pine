//@version=6
strategy("Master Sweep Strategy (v6 - fixed parens)", overlay=true, initial_capital=100000, default_qty_type=strategy.percent_of_equity, default_qty_value=100)

// ────────────────────────────────────────
// Asian Session (NY 20:00–23:59)
// ────────────────────────────────────────
var float asian_high      = na
var float asian_low       = na
var float prev_asian_high = na
var float prev_asian_low  = na

bool is_asian = hour >= 20
bool new_day  = timeframe.change("D")

if new_day
    prev_asian_high := asian_high
    prev_asian_low  := asian_low
    asian_high := na
    asian_low  := na

if is_asian
    asian_high := nz(math.max(nz(asian_high, low), high), high)
    asian_low  := nz(math.min(nz(asian_low, high), low), low)

// ────────────────────────────────────────
// Previous HTF levels
// ────────────────────────────────────────
float pDayH  = request.security(syminfo.tickerid, "D", high[1],  lookahead=barmerge.lookahead_on)
float pDayL  = request.security(syminfo.tickerid, "D", low[1],   lookahead=barmerge.lookahead_on)
float pWkH   = request.security(syminfo.tickerid, "W", high[1],  lookahead=barmerge.lookahead_on)
float pWkL   = request.security(syminfo.tickerid, "W", low[1],   lookahead=barmerge.lookahead_on)
float pMthH  = request.security(syminfo.tickerid, "M", high[1],  lookahead=barmerge.lookahead_on)
float pMthL  = request.security(syminfo.tickerid, "M", low[1],   lookahead=barmerge.lookahead_on)

// ────────────────────────────────────────
// 8:30 NY candle
// ────────────────────────────────────────
bool is830 = (hour == 8) and (minute == 30)

// ────────────────────────────────────────
// Sweep conditions (split for readability & paren safety)
// ────────────────────────────────────────
bool sweptAsianH = high > nz(prev_asian_high)
bool sweptDayH   = high > pDayH
bool sweptWkH    = high > pWkH
bool sweptMthH   = high > pMthH
bool swept_high  = sweptAsianH or sweptDayH or sweptWkH or sweptMthH

bool sweptAsianL = low < nz(prev_asian_low)
bool sweptDayL   = low < pDayL
bool sweptWkL    = low < pWkL
bool sweptMthL   = low < pMthL
bool swept_low   = sweptAsianL or sweptDayL or sweptWkL or sweptMthL

// Reaction filters
bool bearish_react = (close < open) and (close < math.avg(open, close))
bool bullish_react = (close > open) and (close > math.avg(open, close))

// ────────────────────────────────────────
// Risk inputs
// ────────────────────────────────────────
int   atr_len = input.int(14,   "ATR Period", minval=1)
float slx     = input.float(1.2, "SL × ATR", minval=0.1, step=0.1)
float tpx     = input.float(2.5, "TP × ATR", minval=0.1, step=0.1)

float atr = ta.atr(atr_len)

// ────────────────────────────────────────
// Entries (at close of 8:30 candle)
// ────────────────────────────────────────
if is830
    if swept_high and bearish_react
        strategy.entry("Short", strategy.short)
    
    if swept_low and bullish_react
        strategy.entry("Long", strategy.long)

// ────────────────────────────────────────
// Exits (from entry price)
// ────────────────────────────────────────
if strategy.position_size > 0
    strategy.exit("Long Exit", from_entry="Long",
         stop  = strategy.position_avg_price - (atr * slx),
         limit = strategy.position_avg_price + (atr * tpx))

if strategy.position_size < 0
    strategy.exit("Short Exit", from_entry="Short",
         stop  = strategy.position_avg_price + (atr * slx),
         limit = strategy.position_avg_price - (atr * tpx))

// ────────────────────────────────────────
// Plots
// ────────────────────────────────────────
plot(prev_asian_high, "Prev Asian High", color.blue,   1, plot.style_linebr)
plot(prev_asian_low,  "Prev Asian Low",  color.blue,   1, plot.style_linebr)
plot(pDayH,           "Prev Day High",   color.green,  1, plot.style_linebr)
plot(pDayL,           "Prev Day Low",    color.green,  1, plot.style_linebr)
plot(pWkH,            "Prev Week High",  color.orange, 1, plot.style_linebr)
plot(pWkL,            "Prev Week Low",   color.orange, 1, plot.style_linebr)
plot(pMthH,           "Prev Month High", color.red,    1, plot.style_linebr)
plot(pMthL,           "Prev Month Low",  color.red,    1, plot.style_linebr)

