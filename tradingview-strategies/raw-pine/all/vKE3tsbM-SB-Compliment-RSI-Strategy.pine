//@version=3
strategy("SB_Compliment_RSI Strategy", overlay=true, default_qty_type = strategy.percent_of_equity, default_qty_value = 100.0, pyramiding = 0)
/////////////////////
//@version=3
//study(title="SB_Compliment_Relative Strength Index", shorttitle="RSI")
//src = close, len = input(14, minval=1, title="Length")
//up = rma(max(change(src), 0), len)
//down = rma(-min(change(src), 0), len)
//rsi = down == 0 ? 100 : up == 0 ? 0 : 100 - (100 / (1 + up / down))
//plot(rsi, color=purple)
//plot(100-rsi, color=orange)
//band1 = hline(70)
//band0 = hline(30)
//fill(band1, band0, color=purple, transp=90)
////////////////
length = input( 14 )
overSold = input( 30 )
overBought = input( 70 )
price = close

vrsi = rsi(price, length)
opp_vrsi= 100-vrsi
prev_rsi_low=input(0.0)
prev_rsi_low:=nz(prev_rsi_low[1])
if(prev_rsi_low==0)
    prev_rsi_low:=51

prev_rsi_high=input(0.0)
prev_rsi_high:=nz(prev_rsi_high[1])

if(prev_rsi_high==0)
    prev_rsi_high:=51

switch=input(0)
switch:=nz(switch[1])


if (not na(vrsi))
    if (crossover(vrsi, overSold))// and switch==0)
        if((100-prev_rsi_high)<=vrsi)
            strategy.entry("RsiLE", strategy.long, comment="RsiLE")
            prev_rsi_high:=0
        prev_rsi_low:=vrsi
        switch:=1
    if (crossunder(vrsi, overBought))// and switch==1)
        if((100-prev_rsi_low)>=vrsi)
            strategy.entry("RsiSE", strategy.short, comment="RsiSE")
            prev_rsi_low:=100
        //switch:=0
        prev_rsi_high:=vrsi

