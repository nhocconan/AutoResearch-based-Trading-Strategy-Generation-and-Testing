//@version=5
strategy("Script_Algo - High Low Range MA Crossover Strategy", overlay=true, margin_long=100, margin_short=100)

// Author: Script_Algo
// License: MIT
// Permission is hereby granted, free of charge, to any person obtaining a copy
// of this software and associated documentation files (the "Software"), to deal
// in the Software without restriction, including without limitation the rights
// to use, copy, modify, merge, publish, distribute, sublicense, and/or sell
// copies of the Software, subject to the following conditions:
// The above copyright notice and this permission notice shall be included in
// all copies or substantial portions of the Software.

// MA parameters
largeLength = input.int(50, title="Large MA Length", minval=1)
smallLength = input.int(20, title="Small MA Length", minval=1)

// Moving average type selection
maType = input.string("EMA", title="Moving Average Type", options=["EMA", "SMA", "SSMA", "WMA", "VWMA", "RMA", "DEMA", "TEMA"])

// SSMA function
ssma(src, length) =>
    var float sma = na
    sma := na(sma) ? ta.sma(src, length) : (sma * (length - 1) + src) / length

// MA type selection function
getMA(src, length) =>
    switch maType
        "SMA"  => ta.sma(src, length)
        "SSMA" => ssma(src, length)
        "WMA"  => ta.wma(src, length)
        "VWMA" => ta.vwma(src, length)
        "RMA"  => ta.rma(src, length)
        "DEMA" => ta.ema(ta.ema(src, length), length)
        "TEMA" => ta.ema(ta.ema(ta.ema(src, length), length), length)
        => ta.ema(src, length)

// MA calculation
maLargeHigh = getMA(high, largeLength)
maLargeLow  = getMA(low, largeLength)
maSmallHigh = getMA(high, smallLength)
maSmallLow  = getMA(low, smallLength)

// Visualization with fixed titles
plot(maLargeHigh, color=color.red,    title="Large High MA")
plot(maLargeLow,  color=color.blue,   title="Large Low MA")
plot(maSmallHigh, color=color.orange, title="Small High MA")
plot(maSmallLow,  color=color.green,  title="Small Low MA")

// Add MA type label
if barstate.islast
    label.new(bar_index, maSmallLow, text="MA Type: " + maType, style=label.style_label_left, color=color.green, textcolor=color.white)

// Entry/exit logic
longCondition  = ta.crossover(maSmallLow, maLargeHigh)
shortCondition = ta.crossunder(maSmallHigh, maLargeLow)
exitLong       = ta.crossunder(maSmallHigh, maLargeLow)
exitShort      = ta.crossover(maSmallLow, maLargeHigh)

// Position management with close-before-open logic
if strategy.position_size < 0 and longCondition
    strategy.close("Short")
    strategy.entry("Long", strategy.long)
else if longCondition
    strategy.entry("Long", strategy.long)
    
if strategy.position_size > 0 and shortCondition
    strategy.close("Long")
    strategy.entry("Short", strategy.short)
else if shortCondition
    strategy.entry("Short", strategy.short)

// Exit conditions for opposite signals
if exitLong
    strategy.close("Long")
if exitShort
    strategy.close("Short")

