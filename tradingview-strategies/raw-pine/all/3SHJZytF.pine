//@version=5
strategy("Strategy: HMA 50 + Supertrend Sniper", overlay=true, initial_capital=10000, default_qty_type=strategy.percent_of_equity, default_qty_value=100)

// --- 1. Settings ---
// HMA Settings
hmaLength = input.int(50, title="HMA Length (Trend)", minval=1)

// Supertrend Settings
atrPeriod = input.int(10, title="ATR Period")
factor = input.float(3.0, title="ATR Multiplier (ความกว้างของจุดคัท)", step=0.1)

// Strategy Settings
exitOnChoppy = input.bool(true, title="Exit when Choppy? (ปิดออเดอร์เมื่อเข้าโซนสีเทา)")
useDateFilter = input.bool(false, title="Use Date Filter")
startDate = input.time(timestamp("1 Jan 2024 00:00"), title="Start Date")
endDate = input.time(timestamp("1 Jan 2030 00:00"), title="End Date")

// --- 2. Calculations ---

// HMA
hmaValue = ta.hma(close, hmaLength)
hmaRising = hmaValue > hmaValue[1]
hmaFalling = hmaValue < hmaValue[1]

// Supertrend
[supertrend, direction] = ta.supertrend(factor, atrPeriod)
// direction: -1 = uptrend (Green), 1 = downtrend (Red)

// --- 3. Logic (The Confluence) ---

// เงื่อนไข Buy: HMA ขึ้น + Supertrend เขียว
isBullish = hmaRising and direction == -1
// เงื่อนไข Sell: HMA ลง + Supertrend แดง
isBearish = hmaFalling and direction == 1
// เงื่อนไข Choppy (ขัดแย้งกัน)
isChoppy = (hmaRising and direction == 1) or (hmaFalling and direction == -1)

// Date Filter Check
inDateRange = useDateFilter ? (time >= startDate and time <= endDate) : true

// --- 4. Strategy Execution ---

if inDateRange
    // เปิด Long
    if isBullish
        strategy.entry("Long", strategy.long, comment="LONG")
    
    // เปิด Short
    if isBearish
        strategy.entry("Short", strategy.short, comment="SHORT")
        
    // ปิดสถานะเมื่อเข้าโซนไม่ชัดเจน (Optional: เพื่อความปลอดภัย)
    if exitOnChoppy and isChoppy
        strategy.close_all(comment="Close (Choppy)")

// --- 5. Plotting & Visuals (เหมือนในรูป) ---

// สี HMA
hmaColor = isChoppy ? color.gray : (isBullish ? #00ff08 : #ff0000)

// Plot HMA
plot(hmaValue, title="HMA 50 Main", color=hmaColor, linewidth=3)

// Plot Supertrend
plot(supertrend, title="Stop Loss Line", color=direction == -1 ? color.new(color.green, 50) : color.new(color.red, 50), linewidth=1, style=plot.style_linebr)

// Plot Visual Signals (เพื่อให้เห็นจุดเข้าบนกราฟเหมือนเดิม)
// ใช้ logic state เพื่อไม่ให้รก
var int visualState = 0
visualBuy = isBullish and visualState != 1
visualSell = isBearish and visualState != -1

if visualBuy
    visualState := 1
if visualSell
    visualState := -1
if isChoppy
    visualState := 0

plotshape(visualBuy, title="Long Visual", location=location.belowbar, color=#00ff08, style=shape.cross, text="LONG", textcolor=color.white, size=size.small)
plotshape(visualSell, title="Short Visual", location=location.abovebar, color=#ff0000, style=shape.xcross, text="SHORT", textcolor=color.white, size=size.small)

// Bar Color
barcolor(isBullish ? #00ff08 : isBearish ? #ff0000 : color.gray)

