//@version=5
strategy("Intraday Momentum for Volatile Stocks (Nifty Filter)", overlay=true)

// =============================================================================
//                            INPUTS
// =============================================================================

// Session Timing
intra_end_hour = input.int(15, "End Hour Intraday (24h)", minval=9, maxval=15, group="Timing & Entry")
intra_end_min = input.int(0, "End Min Intraday", minval=0, maxval=59, group="Timing & Entry")
pct_above_open = input.float(2.5, "Entry: % Above Open", step=0.1, group="Timing & Entry") / 100

// Exit Parameters
atr_period = input.int(14, "ATR Period", minval=1, group="Exits")
atr_multiplier = input.float(3.0, "Stop Loss (ATR Multiplier)", minval=0.1, step=0.1, group="Exits")
// NEW: Profit target is now based on ATR, not a fixed percentage.
profit_target_atr_mult = input.float(4.0, "Profit Target (ATR Multiplier)", minval=0.5, step=0.1, group="Exits")

// Filters
// REVERTED: The filter is now fixed to the Nifty 50 index.
index_symbol = input.symbol("NIFTY", "Market Index Symbol", group="Filters")
mr_length = input.int(50, "Market Regime SMA Period", minval=1, group="Filters")
mfi_length = input.int(14, "MFI Period", minval=1, group="Filters")


// =============================================================================
//                      CALCULATIONS & LOGIC
// =============================================================================

// Time and Session Variables
var float today_open = na
var float daily_cum_vol = 0.0
is_newday = ta.change(time("D")) != 0

// Calculate the 20-day simple moving average of volume.
vol_sma_20 = ta.sma(volume, 20)
float volume_benchmark = request.security(syminfo.tickerid, "D", vol_sma_20[1], lookahead=barmerge.lookahead_off)

if is_newday
    today_open := open
    daily_cum_vol := volume
else
    daily_cum_vol += volume

// --- Filters ---
index_close = request.security(index_symbol, "D", close, lookahead=barmerge.lookahead_off)
index_sma = ta.sma(index_close, mr_length)
mr_filter = index_close > index_sma
mfi_filter = ta.mfi(hlc3, mfi_length) > 50

// --- Entry Conditions ---
is_intraday_time = (hour < intra_end_hour) or (hour == intra_end_hour and minute <= intra_end_min)
price_cross_up = high >= (today_open * (1 + pct_above_open))
vol_achieved = daily_cum_vol >= volume_benchmark

buy_signal = price_cross_up and vol_achieved and is_intraday_time and mr_filter and mfi_filter and strategy.position_size == 0


// --- Exit Conditions ---
var float long_stop_price = na
var float profit_target_price = na

sell_signal = false
profit_hit = false
atr_value = ta.atr(atr_period) // Calculate ATR once for both exits

if strategy.position_size > 0
    // Set Profit Target ONCE when the trade begins
    if strategy.position_size[1] == 0
        entry_price = strategy.opentrades.entry_price(strategy.opentrades - 1)
        // MODIFIED: Profit target calculation now uses the ATR multiplier.
        profit_target_price := entry_price + (atr_value * profit_target_atr_mult)

    // Calculate Trailing Stop on every bar of the trade
    new_stop = high - (atr_value * atr_multiplier)
    long_stop_price := na(long_stop_price) ? new_stop : math.max(new_stop, long_stop_price)

    // Check for exit conditions
    sell_signal := close < long_stop_price
    profit_hit := close >= profit_target_price
else
    // Reset prices when not in a position
    long_stop_price := na
    profit_target_price := na


// =============================================================================
//                      STRATEGY EXECUTION & PLOTS
// =============================================================================

if buy_signal
    strategy.entry("Buy", strategy.long)

if sell_signal or profit_hit
    strategy.close("Buy", comment = profit_hit ? "Profit Target Hit" : "ATR Stop")
    
plotshape(buy_signal, title="Buy Signal", style=shape.triangleup, color=color.new(color.green, 0), location=location.belowbar, size=size.small)
plotshape(sell_signal or profit_hit, title="Sell Signal", style=shape.triangledown, color=color.new(color.red, 0), location=location.abovebar, size=size.small)
plot(strategy.position_size > 0 ? long_stop_price : na, title="ATR Trailing Stop", color=color.orange, style=plot.style_linebr)
plot(strategy.position_size > 0 ? profit_target_price : na, title="Profit Target", color=color.new(color.teal, 0), style=plot.style_linebr)

