//@version=3

strategy("13-48 MA Cross", shorttitle = " ", overlay=true, initial_capital=10000, currency='USD', max_bars_back=200)

// === INPUT SMA ===
fastMA    = input(defval = 13, type = integer, title = "FastMA", minval = 1, step = 1)
slowMA    = input(defval = 48, type = integer, title = "SlowMA", minval = 1, step = 1)

// === INPUT BACKTEST RANGE ===
FromMonth = input(defval = 1, title = "From Month", minval = 1, maxval = 12)
FromDay   = input(defval = 1, title = "From Day", minval = 1, maxval = 31)
FromYear  = input(defval = 2016, title = "From Year", minval = 2016)
ToMonth   = input(defval = 2, title = "To Month", minval = 1, maxval = 12)
ToDay     = input(defval = 1, title = "To Day", minval = 1, maxval = 31)
ToYear    = input(defval = 2018, title = "To Year", minval = 2016)

// === FUNCTION EXAMPLE ===
start     = timestamp(FromYear, FromMonth, FromDay, 00, 00)  // backtest start window
finish    = timestamp(ToYear, ToMonth, ToDay, 23, 59)        // backtest finish window
window()  => time >= start and time <= finish ? true : false // create function "within window of time"

// === SERIES SETUP ===
buy  = crossover(ema(close, fastMA), ema(close, slowMA))     // buy when fastMA crosses over slowMA
sell = crossunder(ema(close, fastMA), ema(close, slowMA))    // sell when fastMA crosses under slowMA

// === EXECUTION ===
strategy.entry("L", strategy.long, when = window() and buy)  // buy long when "within window of time" AND crossover
strategy.close("L", when = window() and sell)                // sell long when "within window of time" AND crossunder

