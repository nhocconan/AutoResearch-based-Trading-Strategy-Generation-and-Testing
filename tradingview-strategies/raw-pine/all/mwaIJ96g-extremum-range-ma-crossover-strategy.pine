//@version=5
strategy("Extremum Range MA Crossover Strategy", overlay=true, margin_long=100, margin_short=100, default_qty_type=strategy.cash, default_qty_value=100, initial_capital=10000, commission_type=strategy.commission.percent, commission_value=0.1, slippage=3, currency=currency.USD)

// Author: Script_Algo
// License: MIT
// Permission is hereby granted, free of charge, to any person obtaining a copy
// of this software and associated documentation files (the "Software"), to deal
// in the Software without restriction, including without limitation the rights
// to use, copy, modify, merge, publish, distribute, sublicense, and/or sell
// copies of the Software, subject to the following conditions:
// The above copyright notice and this permission notice shall be included in
// all copies or substantial portions of the Software.

// Input parameters
lookbackPeriod = input.int(5, title="Lookback Period for High/Low")
maLength = input.int(20, title="MA Length")

// MA type selection
maType = input.string("EMA", title="MA Type", options=["SMA", "EMA", "WMA", "VWMA", "HMA", "DEMA", "TEMA", "ZLEMA"])
maSource = input.string("Close", title="MA Source", options=["Open", "High", "Low", "Close", "HL2", "HLC3", "OHLC4"])

// Calculate source based on selection
src = switch maSource
    "Open" => open
    "High" => high
    "Low" => low
    "Close" => close
    "HL2" => (high + low) / 2
    "HLC3" => (high + low + close) / 3
    "OHLC4" => (open + high + low + close) / 4
    => close

// Calculate MA based on selected type
ma = switch maType
    "SMA" => ta.sma(src, maLength)
    "EMA" => ta.ema(src, maLength)
    "WMA" => ta.wma(src, maLength)
    "VWMA" => ta.vwma(src, maLength)
    "HMA" => ta.hma(src, maLength)
    "DEMA" => 2 * ta.ema(src, maLength) - ta.ema(ta.ema(src, maLength), maLength)
    "TEMA" => 3 * (ta.ema(src, maLength) - ta.ema(ta.ema(src, maLength), maLength)) + ta.ema(ta.ema(ta.ema(src, maLength), maLength), maLength)
    "ZLEMA" => ta.ema(src + (src - src[math.max(1, maLength/2)]), maLength)
    => ta.ema(src, maLength)

// Calculate previous highs and lows
prevHigh = ta.highest(high, lookbackPeriod)
prevLow = ta.lowest(low, lookbackPeriod)

// Entry conditions
longCondition = ta.crossover(prevLow, ma)  // Previous low crosses above MA
shortCondition = ta.crossunder(prevHigh, ma)  // Previous high crosses below MA

// Exit conditions
exitLongCondition = close < ta.lowest(low, lookbackPeriod)  // Close below previous low
exitShortCondition = close > ta.highest(high, lookbackPeriod)  // Close above previous high

// Check open positions
isLongOpen = strategy.position_size > 0  // Long position is open
isShortOpen = strategy.position_size < 0  // Short position is open

// Close opposite position before entering new trade
if (longCondition and isShortOpen)
    strategy.close("Short")

if (shortCondition and isLongOpen)
    strategy.close("Long")

// Enter trades with fixed USDT amount
if (longCondition and not isLongOpen)
    strategy.entry("Long", strategy.long)

if (shortCondition and not isShortOpen)
    strategy.entry("Short", strategy.short)

// Exit trades
if (exitLongCondition)
    strategy.close("Long")

if (exitShortCondition)
    strategy.close("Short")

// Visualization on chart
plot(prevHigh, color=color.red, title="Previous High", linewidth=1)
plot(prevLow, color=color.green, title="Previous Low", linewidth=1)
plot(ma, color=color.blue, title="MA", linewidth=2)

