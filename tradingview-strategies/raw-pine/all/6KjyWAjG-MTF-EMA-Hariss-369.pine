//@version=5
strategy("MTF EMA Hariss 369", overlay=true, margin_long=100, margin_short=100)

// ================= INPUTS =================
kamaLen       = input.int(21, "KAMA Length")
fastLen       = input.int(2, "KAMA Fast Length")
slowLen       = input.int(30, "KAMA Slow Length")
emaLen        = input.int(20, "EMA Length")
htf           = input.timeframe("1D", "Higher Timeframe")
rvolThreshold = input.float(1.2, "RVOL Threshold")

// ================= CUSTOM KAMA FUNCTION =================
f_kama(_src, _len, _fast, _slow) =>
    change = math.abs(_src - _src[1])
    volatility = 0.0
    for i = 0 to _len - 1
        volatility += math.abs(_src[i] - _src[i+1])
    er = volatility != 0 ? change / volatility : 0
    sc = math.pow(er * (2/(_fast+1) - 2/(_slow+1)) + 2/(_slow+1), 2)
    kama = 0.0
    kama := na(kama[1]) ? _src : kama[1] + sc * (_src - kama[1])
    kama

// ================= INDICATORS =================
price    = close
kama     = f_kama(price, kamaLen, fastLen, slowLen)
ema_tf   = ta.ema(price, emaLen)
ema_htf  = request.security(syminfo.tickerid, htf, ta.ema(close, emaLen))

volAvg = ta.sma(volume, 20)
rvol   = volume / volAvg

// ================= KAMA SLOPE =================
kama_up   = kama > kama[1]
kama_down = kama < kama[1]

// ================= UPDATED CONDITIONS =================
longCond  = price > ema_tf and ema_tf > ema_htf and price > kama and rvol > rvolThreshold and kama_up
shortCond = price < ema_tf and ema_tf < ema_htf and price < kama and rvol > rvolThreshold and kama_down

// ================= STRATEGY ENTRIES =================
if (longCond)
    strategy.entry("Long", strategy.long)

if (shortCond)
    strategy.entry("Short", strategy.short)

// ================= LABELS =================
plotshape(longCond,  title="Buy",  location=location.belowbar, color=color.green, style=shape.labelup,   size=size.tiny, text="BUY")
plotshape(shortCond, title="Sell", location=location.abovebar, color=color.red,   style=shape.labeldown, size=size.tiny, text="SELL")

// ================= PLOTS =================
plot(kama,      color=color.orange,  title="KAMA",     linewidth=2)
plot(ema_tf,    color=color.blue,    title="TF EMA",   linewidth=2)
plot(ema_htf,   color=color.purple,  title="HTF EMA",  linewidth=3)

