//@version=6
strategy(title="RSI-Gauss-Velocity-Strategy-WiP", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=100, commission_type=strategy.commission.percent, commission_value=0.1, slippage=3)

// --- Time Settings ---
startDate  = input.time(timestamp("1 Nov 2014 00:00 +0000"), "Start Date")
endDate    = input.time(timestamp("1 Jan 2030 23:59 +0000"), "End Date")
timeFilter = time >= startDate and time <= endDate

// --- Core Stochastic RSI ---
smoothK = 3, smoothD = 3, lengthRSI = 14, lengthStoch = 14
rsiValue = ta.rsi(close, lengthRSI)
kValue = ta.sma(ta.stoch(rsiValue, rsiValue, rsiValue, lengthStoch), smoothK)
dValue = ta.sma(kValue, smoothD)

// --- Gaussian Filter Math ---
int N = input.int(4, "Gaussian Poles")
int per = input.int(144, "Sampling Period")
float mult = input.float(1.414, "Band Multiplier")

f_filt9x(_a, _s, _i) =>
    float _f = 0.0
    float _x = 1 - _a
    _m2 = _i == 4 ? 6 : _i == 3 ? 3 : _i == 2 ? 1 : 0
    _m3 = _i == 4 ? 4 : _i == 3 ? 1 : 0
    _m4 = _i == 4 ? 1 : 0
    _f := math.pow(_a, _i) * nz(_s) + _i * _x * nz(_f[1]) - (_i >= 2 ? _m2 * math.pow(_x, 2) * nz(_f[2]) : 0) + (_i >= 3 ? _m3 * math.pow(_x, 3) * nz(_f[3]) : 0) - (_i >= 4 ? _m4 * math.pow(_x, 4) * nz(_f[4]) : 0)
    _f

beta  = (1 - math.cos(4*math.asin(1)/per)) / (math.pow(1.414, 2.0/N) - 1)
alpha = - beta + math.sqrt(math.pow(beta, 2) + 2*beta)
filtn = f_filt9x(alpha, hlc3, N)
filttr = f_filt9x(alpha, ta.tr(true), N)
hband = filtn + filttr * mult

// --- Momentum Velocity Logic ---
filtSlope = filtn - filtn[1]
slopeMean = ta.sma(filtSlope, 20)
slopeStd  = ta.stdev(filtSlope, 20)
// Detection of trend "exhaustion" using StdDev of the filter slope
slopeExhaustion = filtSlope < (slopeMean - slopeStd) 

// --- Strategy Execution ---
gaussianGreen = filtn > filtn[1]
stochSignal   = kValue > dValue

// ENTRY: High-Conviction Core
longCondition = gaussianGreen and (close > hband) and stochSignal and timeFilter

// EXIT: Hybrid Logic (Standard Crossunder or Velocity Exhaustion in profit)
inProfit = strategy.position_size > 0 and close > strategy.position_avg_price
exitCondition = ta.crossunder(close, hband) or (slopeExhaustion and inProfit and (close < hband or close < hband[1]))

// --- Trade Execution ---
if longCondition
    strategy.entry("Long", strategy.long)
    alert("Gauss-Velocity LONG Entry: Price Breakout confirmed.", alert.freq_once_per_bar_close)

if exitCondition
    strategy.close("Long", comment="Vel-Exit")
    alert("Gauss-Velocity EXIT: Momentum exhaustion or Band crossunder.", alert.freq_once_per_bar_close)

// --- Visuals ---
fCol = gaussianGreen ? color.new(color.lime, 0) : color.new(color.red, 0)
plot(filtn, color=fCol, linewidth=3, title="Gaussian Filter")
plot(hband, color=color.new(color.gray, 50), title="High Band")
fill(plot(hband), plot(filtn), color=color.new(fCol, 90))
plotshape(slopeExhaustion and inProfit, "Exhaustion Detected", shape.labeldown, location.abovebar, color.orange, size=size.tiny)

// --- Alert Conditions for Alert Box Manual Setup ---
alertcondition(longCondition, title="Long Entry Alert", message="RSI-Gauss LONG Entry at {{close}}")
alertcondition(exitCondition, title="Exit Strategy Alert", message="RSI-Gauss EXIT at {{close}}")

