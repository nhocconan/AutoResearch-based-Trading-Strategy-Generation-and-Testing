//@version=6
strategy("SSL MACD - nhuthang83",overlay = false,process_orders_on_close = true,calc_on_every_tick = true,pyramiding = 10)


 
// exitonsig =  input.bool(true,"Exit on reverse signal",tooltip = "if you are in positon and find opposite signal then it will exit if uncheck then it will wait to exit on SL or TP or Trail")
slATR = input.float(2,"Stop Loss ATR Mulipler")
tgATR = input.float(3,"Target ATR Mulipler")

gratr = "======= ATR ======="
length = input.int(title="Length", defval=14, minval=1,group = gratr)
smoothing = input.string(title="Smoothing", defval="RMA", options=["RMA", "SMA", "EMA", "WMA"],group = gratr)
ma_function(source, length) =>
    switch smoothing
        "RMA" => ta.rma(source, length)
        "SMA" => ta.sma(source, length)
        "EMA" => ta.ema(source, length)
        => ta.wma(source, length)

atr = ma_function(ta.tr(true), length)

group_sess = "----------------------- Session -----------------------"
isCurstomSession = input.bool(true,"",inline = "session1",group = group_sess,tooltip = "Set Custom time zone if you not set then it will take chart timezone automatic")
sessionTimeZone = input.string("Asia/Bangkok","Set Tmezone",inline="session1",group = group_sess,options=["UTC","Exchange","America/New_York","America/Los_Angeles","America/Chicago","America/Phoenix","America/Toronto","America/Vancouver","America/Argentina/Buenos_Aires","America/El_Salvador","America/Sao_Paulo","America/Bogota","Europe/Moscow","Europe/Athens","Europe/Berlin","Europe/London","Europe/Madrid","Europe/Paris","Europe/Warsaw","Australia/Sydney","Australia/Brisbane","Australia/Adelaide","Australia/ACT","Asia/Almaty","Asia/Ashkhabad","Asia/Tokyo","Asia/Taipei","Asia/Singapore","Asia/Shanghai","Asia/Seoul","Asia/Tehran","Asia/Dubai","Asia/Kolkata","Asia/Hong_Kong","Asia/Bangkok","Pacific/Auckland","Pacific/Chatham","Pacific/Fakaofo","Pacific/Honolulu"])
sessClr  =  input.color(color.rgb(255, 82, 82, 94),"",group = group_sess,inline = 'session1')
useSession =  input.bool(true,"",inline = "s1",group = group_sess)
Session1        = input.session(title="Session Input", defval="0700-2200",inline="s1",group = group_sess)

isInSession = useSession ? not na(time(timeframe.period, Session1 + ":1234567",isCurstomSession ? sessionTimeZone : syminfo.timezone))   : true 
bgcolor(isInSession and useSession ? sessClr : na,title = "Session Backgraoud Color")
isSessionOut  =  useSession ?  isInSession[1] and not isInSession : false


grst = "=========== Supertrend ========="
atrPeriod = input.int(10,    "ATR Length", minval = 1,group = grst)
factor =    input.float(3.0, "Factor",     minval = 0.01, step = 0.01,group = grst)

[supertrend, direction] = ta.supertrend(factor, atrPeriod)

supertrend := barstate.isfirst ? na : supertrend
upTrend =    plot(direction < 0 ? supertrend : na, "Up Trend",   color = color.green, style = plot.style_linebr)
downTrend =  plot(direction < 0 ? na : supertrend, "Down Trend", color = color.red,   style = plot.style_linebr)
bodyMiddle = plot(barstate.isfirst ? na : (open + close) / 2, "Body Middle",display = display.none)

fill(bodyMiddle, upTrend,   title = "Uptrend background",   color = color.new(color.green, 90), fillgaps = false)
fill(bodyMiddle, downTrend, title = "Downtrend background", color = color.new(color.red,   90), fillgaps = false)

isGreenST  = direction < 0

isBuyST = isGreenST //and not isGreenST[1]
isSellST = not isGreenST //and isGreenST[1]


grSsl = "======== SSL channel ========"
period = input(title = 'Period', defval = 10,group = grSsl)
len = input(title = 'Period', defval = 10,group = grSsl)

smaHigh = ta.sma(high, len)
smaLow = ta.sma(low, len)
Hlv = int(na)
Hlv := close > smaHigh ? 1 : close < smaLow ? -1 : Hlv[1]
sslDown = Hlv < 0 ? smaHigh : smaLow
sslUp = Hlv < 0 ? smaLow : smaHigh

plot(sslDown, linewidth = 2, color = color.new(color.red, 0))
plot(sslUp, linewidth = 2, color = color.new(color.lime, 0))

isBuySSL = ta.crossover(sslUp,sslDown)
isSellSSL = ta.crossunder(sslUp,sslDown)


grmacd = "========= MACD ========"
fast_length = input(title = "Fast Length", defval = 12,group = grmacd)
slow_length = input(title = "Slow Length", defval = 26,group = grmacd)
src = input(title = "Source", defval = close,group = grmacd)
signal_length = input.int(title = "Signal Smoothing",  minval = 1, maxval = 50, defval = 9, display = display.data_window,group = grmacd)
sma_source = input.string(title = "Oscillator MA Type",  defval = "EMA", options = ["SMA", "EMA"], display = display.data_window,group = grmacd)
sma_signal = input.string(title = "Signal Line MA Type", defval = "EMA", options = ["SMA", "EMA"], display = display.data_window,group = grmacd)
// Calculating
fast_ma = sma_source == "SMA" ? ta.sma(src, fast_length) : ta.ema(src, fast_length)
slow_ma = sma_source == "SMA" ? ta.sma(src, slow_length) : ta.ema(src, slow_length)
macd = fast_ma - slow_ma
signal = sma_signal == "SMA" ? ta.sma(macd, signal_length) : ta.ema(macd, signal_length)
hist = macd - signal

// hline(0, "Zero Line", color = color.new(#787B86, 50))
// plot(hist, title = "Histogram", style = plot.style_columns, color = (hist >= 0 ? (hist[1] < hist ? #26A69A : #B2DFDB) : (hist[1] < hist ? #FFCDD2 : #FF5252)))
// plot(macd,   title = "MACD",   color = #2962FF)
// plot(signal, title = "Signal", color = #FF6D00)

isBuyMacd = macd > 0
isSellMacd = macd < 0


isGreen = close >= open

isBuy = isGreen and isBuyST and isBuySSL and isBuyMacd and isInSession and barstate.isconfirmed
isSell = not isGreen and isSellST and isSellSSL and isSellMacd and isInSession and barstate.isconfirmed




buyMess = ""
sellMess = ""

var float Entry_Price = na
var float StopLoss_Price = na
var float Target_Price = na

isBuyPlot = false
isSellPlot = false
 
var int ordId = 0

if isBuy  ///and (exitonsig ? strategy.position_size <= 0 : strategy.position_size == 0)  
    //strategy.close_all("Close")

    Entry_Price := close
    StopLoss_Price :=  Entry_Price - slATR*atr
    Target_Price := Entry_Price + tgATR*atr
   
    isBuyPlot := true
    ordId += 1
    strategy.entry("Buy"+str.tostring(ordId),strategy.long,alert_message = buyMess)
    strategy.exit("Exit"+str.tostring(ordId), "Buy"+str.tostring(ordId), limit=Target_Price, stop = StopLoss_Price,  comment_profit = "TP",comment_loss = "SL")

if isSell //and (exitonsig ? strategy.position_size >= 0 : strategy.position_size == 0) 
    //strategy.close_all("Close")

    Entry_Price := close
    StopLoss_Price :=  Entry_Price + slATR*atr
    Target_Price := Entry_Price - tgATR*atr

    isSellPlot := true
    ordId += 1
    strategy.entry("Sell"+str.tostring(ordId),strategy.short,alert_message = sellMess)
    strategy.exit("Exit"+str.tostring(ordId), "Sell"+str.tostring(ordId), limit=Target_Price, stop = StopLoss_Price,  comment_profit = "TP",comment_loss = "SL")

 
plotshape(isBuyPlot, 'Buy', text='Buy', style=shape.labelup, color=color.green, textcolor=color.white, size=size.tiny,location=location.belowbar,force_overlay = true)
plotshape(isSellPlot, 'Sell', text='Sell', style=shape.labeldown, color=color.red, textcolor=color.white, size=size.tiny,location=location.abovebar,force_overlay = true)
slplot = plot(strategy.position_size != 0 ? StopLoss_Price : na,"Stop Loss",style = plot.style_circles,color=color.red,force_overlay = true)
limtplot = plot(strategy.position_size != 0 ? Target_Price : na,"Limit",style = plot.style_circles,color=color.green,force_overlay = true)
entryplot = plot(strategy.position_size != 0 ? Entry_Price : na,"Entry",style = plot.style_circles,color=color.black,force_overlay = true)

fill(entryplot,slplot,color = color.rgb(255, 82, 82, 90))
fill(limtplot,entryplot,color = color.rgb(82, 255, 91, 90))
  
if isBuyPlot
    alert("Buy Signal")
if isSellPlot
    alert("Sell Signal")

