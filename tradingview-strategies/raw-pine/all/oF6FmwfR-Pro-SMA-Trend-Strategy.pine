//@version=5
strategy("Pro SMA Trend Strategy", overlay=true, initial_capital=10000)

// ==========================================
// ============= SETTINGS ===================
// ==========================================
grp_strat = "Strategy & Leverage Settings"
tradeDirection = input.string("Both", title="Trade Direction", options=["Both", "Long Only", "Short Only"], group=grp_strat)
longLeverage   = input.float(2.0, title="Long Leverage (e.g., 2.0 = 2x)", step=0.1, minval=0.1, group=grp_strat)
shortLeverage  = input.float(1.0, title="Short Leverage (e.g., 1.0 = 1x)", step=0.1, minval=0.1, group=grp_strat)

grp_ind = "Indicator Settings"
smaLength = input.int(44, title="SMA Length (Custom - Try 11, 37, 44, 58, 125)", minval=1, group=grp_ind)

// ==========================================
// ============= LOGIC ======================
// ==========================================
// Calculate the Simple Moving Average
smaValue = ta.sma(close, smaLength)

// Determine the cross signals based on candle closes
longCondition  = ta.crossover(close, smaValue)
shortCondition = ta.crossunder(close, smaValue)

// Calculate dynamic position size based on current equity and chosen leverage
longQty  = (strategy.equity * longLeverage) / close
shortQty = (strategy.equity * shortLeverage) / close

// ==========================================
// ============= EXECUTION ==================
// ==========================================
if longCondition
    if tradeDirection == "Both" or tradeDirection == "Long Only"
        strategy.entry("Long", strategy.long, qty=longQty)
    if tradeDirection == "Short Only"
        strategy.close("Short") // Just close the short, don't enter long

if shortCondition
    if tradeDirection == "Both" or tradeDirection == "Short Only"
        strategy.entry("Short", strategy.short, qty=shortQty)
    if tradeDirection == "Long Only"
        strategy.close("Long") // Just close the long, don't enter short

// ==========================================
// ============= VISUALS ====================
// ==========================================
// 1. Professional colored SMA line (Green when price is above, Red when price is below)
smaColor = close > smaValue ? color.rgb(38, 166, 154) : color.rgb(239, 83, 80)
plot(smaValue, color=smaColor, linewidth=3, title="Trend SMA")

// 2. Clear Buy and Short Labels on the chart
plotshape(longCondition, title="Buy Signal", text="BUY", location=location.belowbar, style=shape.labelup, size=size.small, color=color.rgb(38, 166, 154), textcolor=color.white)
plotshape(shortCondition, title="Short Signal", text="SHORT", location=location.abovebar, style=shape.labeldown, size=size.small, color=color.rgb(239, 83, 80), textcolor=color.white)

// 3. Subtle background shading to indicate the current trend zone
bgcolor(close > smaValue ? color.new(color.rgb(38, 166, 154), 90) : color.new(color.rgb(239, 83, 80), 90), title="Trend Background")

