//@version=5
strategy("Buy %50 - Sell %50 Strategy", 
     overlay = true,
     initial_capital = 100000,          // Başlangıç sermayen
     default_qty_type = strategy.percent_of_equity, 
     default_qty_value = 50)            // Her işlemde sermayenin %50'siyle işlem aç

// ==========================
// Basit örnek sinyaller
// ==========================
fastMA = ta.sma(close, 10)
slowMA = ta.sma(close, 30)

buySignal  = ta.crossover(fastMA, slowMA)
sellSignal = ta.crossunder(fastMA, slowMA)

// ==========================
// İşlem girişleri
// ==========================
if (buySignal)
    strategy.entry("BUY", strategy.long)     // Sermayenin %50’siyle alım

if (sellSignal)
    strategy.entry("SELL", strategy.short)   // Sermayenin %50’siyle satım

// ==========================
// Çıkışlar (örnek stop/take profit)
// ==========================
strategy.exit("Exit BUY",  from_entry="BUY",  profit = 200, loss = 100)
strategy.exit("Exit SELL", from_entry="SELL", profit = 200, loss = 100)

// ==========================
// Grafik gösterimleri
// ==========================
plot(fastMA, color=color.new(color.green, 0), title="Hızlı Ortalama")
plot(slowMA, color=color.new(color.red, 0),   title="Yavaş Ortalama")

