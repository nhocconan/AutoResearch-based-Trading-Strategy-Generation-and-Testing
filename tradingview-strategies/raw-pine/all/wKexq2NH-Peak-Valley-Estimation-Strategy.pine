//@version=3
strategy("Peak Valley Estimation Strategy", overlay=false)
length = input(50),smooth = input(50),mod = input(type=integer, defval=3, options=[1, 2, 3])
//
src = close
os = src-sma(src,length)
p = linreg(abs(os),smooth,0)
h = p/highest(p,length)
//
cnd = mod == 1 ? h == 1 and h[1] != 1 : mod == 2 ? crossunder(h,0.8) : mod == 3 ? h[1] == 1 and h < h[1] : na
sign = cnd and os < 0 ? 1 : cnd and os > 0 ? -1 : 0
//----
if sign == 1
    strategy.entry("Buy", strategy.long)
if sign == -1
    strategy.entry("Sell", strategy.short)
//----
plot(strategy.equity,title="Equity",color=red,transp=0)

