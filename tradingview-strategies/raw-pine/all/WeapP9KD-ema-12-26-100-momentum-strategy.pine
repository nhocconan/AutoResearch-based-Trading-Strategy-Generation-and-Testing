//@version=6
strategy(title='E<A 12-26-100 Momentum Strategy', 
         shorttitle='', 
         overlay=true, 
         pyramiding=0, 
         initial_capital=10000, 
         default_qty_type=strategy.percent_of_equity,
         default_qty_value=25,
         commission_type=strategy.commission.percent,
         commission_value=0.075,
         slippage=3,
         calc_on_every_tick=true,  // Нужно для barstate.islast в реальном времени
         process_orders_on_close=true)  // Но ордера все равно на закрытии!

// ЦЕЛЬ: $10,000 → $18,000+ за 2 года
// ПОДХОД: Трендовая стратегия + моментум + множественные входы

// ============================================================================
// НАСТРОЙКИ
// ============================================================================

// --- Тренд ---
emaFast = input.int(12, "Fast EMA", minval=5, maxval=50, group="Trend")
emaSlow = input.int(26, "Slow EMA", minval=20, maxval=100, group="Trend")
emaTrend = input.int(100, "Trend EMA", minval=50, maxval=200, group="Trend")

// --- Моментум ---
rsiLen = input.int(14, "RSI Length", group="Momentum")
rsiOB = input.int(70, "RSI Overbought", group="Momentum")
rsiOS = input.int(30, "RSI Oversold", group="Momentum")
macdFast = input.int(12, "MACD Fast", group="Momentum")
macdSlow = input.int(26, "MACD Slow", group="Momentum")
macdSignal = input.int(9, "MACD Signal", group="Momentum")

// --- Risk Management ---
stopLoss = input.float(2.0, "Stop Loss %", minval=1.0, maxval=5.0, step=0.5, group="Risk", 
                       tooltip="Меньше для фьючей с плечом")
takeProfit = input.float(5.5, "Take Profit %", minval=3.0, maxval=15.0, step=0.5, group="Risk",
                         tooltip="TP:SL = 2.75:1 для лучшей прибыльности")
useTrailing = input.bool(true, "Trailing Stop", group="Risk")
trailPct = input.float(1.3, "Trail %", minval=0.5, maxval=3.0, step=0.1, group="Risk")
trailActivate = input.float(1.8, "Trail Activation %", minval=1.0, maxval=5.0, step=0.2, group="Risk", tooltip="Быстрее активируем trailing")
maxHoldBars = input.int(36, "Max Hold Time (hours)", minval=12, maxval=168, group="Risk",tooltip="36ч = избегаем лишних funding платежей")

// --- Фильтры ---
minVolMultiplier = input.float(1.0, "Min Volume Multiplier", minval=0.5, maxval=3.0, step=0.5, group="Filters")
useADX = input.bool(true, "Use ADX Filter", group="Filters")
adxThreshold = input.int(20, "ADX Threshold", minval=15, maxval=40, group="Filters")

// ============================================================================
// ИНДИКАТОРЫ
// ============================================================================

// EMA
ema_fast = ta.ema(close, emaFast)
ema_slow = ta.ema(close, emaSlow)
ema_trend = ta.ema(close, emaTrend)

// RSI
rsi = ta.rsi(close, rsiLen)

// MACD
[macdLine, signalLine, histLine] = ta.macd(close, macdFast, macdSlow, macdSignal)

// Volume
volSMA = ta.sma(volume, 20)

// ADX (тренд силы)
[diPlus, diMinus, adx] = ta.dmi(14, 14)

// Bollinger Bands для волатильности
[bbMiddle, bbUpper, bbLower] = ta.bb(close, 20, 2)

// ATR
atr = ta.atr(14)

// Визуализация
plot(ema_fast, "EMA Fast", color.blue, 2)
plot(ema_slow, "EMA Slow", color.red, 2)
plot(ema_trend, "EMA Trend", color.orange, 3)

// ============================================================================
// ОПРЕДЕЛЕНИЕ ТРЕНДА
// ============================================================================

// Сильный бычий тренд
strongBullTrend = close > ema_trend and 
                  ema_fast > ema_slow and 
                  ema_slow > ema_trend and
                  close > close[1]

// Сильный медвежий тренд
strongBearTrend = close < ema_trend and 
                  ema_fast < ema_slow and 
                  ema_slow < ema_trend and
                  close < close[1]

// Средний тренд
mediumBullTrend = close > ema_trend and ema_fast > ema_slow
mediumBearTrend = close < ema_trend and ema_fast < ema_slow

// Общий тренд
bullTrend = mediumBullTrend
bearTrend = mediumBearTrend

// ADX фильтр (сила тренда)
adxOK = not useADX or adx > adxThreshold

// ============================================================================
// СИГНАЛЫ ВХОДА - МНОЖЕСТВЕННЫЕ
// ============================================================================

// --- 1. EMA CROSS (главный сигнал) ---
emaCrossUp = ta.crossover(ema_fast, ema_slow)
emaCrossDown = ta.crossunder(ema_fast, ema_slow)

// --- 2. MACD CROSS ---
macdCrossUp = ta.crossover(macdLine, signalLine)
macdCrossDown = ta.crossunder(macdLine, signalLine)

// --- 3. RSI REVERSAL ---
rsiReverseUp = rsi[1] < rsiOS and rsi > rsiOS and rsi > rsi[1]
rsiReverseDown = rsi[1] > rsiOB and rsi < rsiOB and rsi < rsi[1]

// --- 4. PRICE ACTION ---
bullishCandle = close > open and (close - open) > (high - low) * 0.6
bearishCandle = close < open and (open - close) > (high - low) * 0.6

// --- 5. VOLUME SPIKE ---
volumeSpike = volume > volSMA * minVolMultiplier

// --- 6. BREAKOUT ---
breakoutUp = close > ta.highest(high[1], 20) and volumeSpike
breakoutDown = close < ta.lowest(low[1], 20) and volumeSpike

// --- 7. PULLBACK TO EMA ---
pullbackBull = bullTrend and 
               low <= ema_fast * 1.01 and 
               close > ema_fast and
               bullishCandle

pullbackBear = bearTrend and 
               high >= ema_fast * 0.99 and 
               close < ema_fast and
               bearishCandle

// --- 8. BOLLINGER BOUNCE ---
bbBounceBull = close[1] <= bbLower and close > bbLower and bullishCandle
bbBounceBear = close[1] >= bbUpper and close < bbUpper and bearishCandle

// ============================================================================
// КОМБИНИРОВАННЫЕ УСЛОВИЯ ВХОДА
// ============================================================================

// ЛОНГ: Нужно минимум 2 сигнала из разных категорий
longSignalCount = (emaCrossUp ? 1 : 0) + 
                  (macdCrossUp ? 1 : 0) + 
                  (rsiReverseUp ? 1 : 0) + 
                  (breakoutUp ? 1 : 0) + 
                  (pullbackBull ? 1 : 0) + 
                  (bbBounceBull ? 1 : 0)

// ШОРТ
shortSignalCount = (emaCrossDown ? 1 : 0) + 
                   (macdCrossDown ? 1 : 0) + 
                   (rsiReverseDown ? 1 : 0) + 
                   (breakoutDown ? 1 : 0) + 
                   (pullbackBear ? 1 : 0) + 
                   (bbBounceBear ? 1 : 0)

// Финальные условия
longEntry = longSignalCount >= 1 and             bullTrend and             volumeSpike and             adxOK and            rsi < 75  // Не покупаем в перекупленности

shortEntry = shortSignalCount >= 1 and
             bearTrend and 
             volumeSpike and 
             adxOK and
             rsi > 25  // Не продаем в перепроданности

// ============================================================================
// ВИЗУАЛИЗАЦИЯ СИГНАЛОВ
// ============================================================================

plotshape(longEntry, "LONG", shape.labelup, location.belowbar, 
          color.new(color.green, 0), text="BUY", textcolor=color.white, size=size.normal)
plotshape(shortEntry, "SHORT", shape.labeldown, location.abovebar, 
          color.new(color.red, 0), text="SELL", textcolor=color.white, size=size.normal)

// Фон тренда
bgcolor(strongBullTrend ? color.new(color.green, 95) :         strongBearTrend ? color.new(color.red, 95) : na)

// ============================================================================
// ТОРГОВАЯ ЛОГИКА
// ============================================================================

var float entryPrice = na
var float stopPrice = na
var float profitPrice = na

// LONG ENTRY
if longEntry and strategy.position_size == 0
    entryPrice := close
    stopPrice := close * (1 - stopLoss / 100)
    profitPrice := close * (1 + takeProfit / 100)
    strategy.entry("Long", strategy.long)
    
    // Визуализация
    label.new(bar_index, low, str.tostring(longSignalCount) + " signals", 
              color=color.green, textcolor=color.white, style=label.style_label_up)

// SHORT ENTRY
if shortEntry and strategy.position_size == 0
    entryPrice := close
    stopPrice := close * (1 + stopLoss / 100)
    profitPrice := close * (1 - takeProfit / 100)
    strategy.entry("Short", strategy.short)
    
    // Визуализация
    label.new(bar_index, high, str.tostring(shortSignalCount) + " signals", 
              color=color.red, textcolor=color.white, style=label.style_label_down)

// TRAILING STOP
if useTrailing and strategy.position_size > 0 and not na(entryPrice)
    profitPct = (close - entryPrice) / entryPrice * 100
    if profitPct >= trailActivate
        newStop = close * (1 - trailPct / 100)
        if newStop > stopPrice
            stopPrice := newStop

if useTrailing and strategy.position_size < 0 and not na(entryPrice)
    profitPct = (entryPrice - close) / entryPrice * 100
    if profitPct >= trailActivate
        newStop = close * (1 + trailPct / 100)
        if newStop < stopPrice
            stopPrice := newStop

// EXITS
if strategy.position_size > 0
    strategy.exit("Exit Long", "Long", stop=stopPrice, limit=profitPrice)

if strategy.position_size < 0
    strategy.exit("Exit Short", "Short", stop=stopPrice, limit=profitPrice)

// Дополнительный выход при развороте тренда
if strategy.position_size > 0 and emaCrossDown
    strategy.close("Long", comment="Trend Reversal")

if strategy.position_size < 0 and emaCrossUp
    strategy.close("Short", comment="Trend Reversal")

// НОВОЕ: Закрытие по времени (для фьючерсов - избегаем funding)
var int entryBar = 0
if strategy.position_size != 0 and strategy.position_size[1] == 0
    entryBar := bar_index

barsInPosition = bar_index - entryBar
if barsInPosition >= maxHoldBars and strategy.position_size != 0
    strategy.close_all(comment="Max Hold Time")

// ============================================================================
// ВИЗУАЛИЗАЦИЯ УРОВНЕЙ
// ============================================================================

plot(strategy.position_size > 0 ? stopPrice : na, "Long SL", color.red, 3, plot.style_linebr)
plot(strategy.position_size > 0 ? profitPrice : na, "Long TP", color.green, 3, plot.style_linebr)
plot(strategy.position_size < 0 ? stopPrice : na, "Short SL", color.red, 3, plot.style_linebr)
plot(strategy.position_size < 0 ? profitPrice : na, "Short TP", color.green, 3, plot.style_linebr)

// Зона позиции
posColor = strategy.position_size > 0 ? color.new(color.green, 97) : 
           strategy.position_size < 0 ? color.new(color.red, 97) : na
bgcolor(posColor)

// ============================================================================
// ИНФОРМАЦИОННАЯ ПАНЕЛЬ (опционально)
// ============================================================================

// Если calc_on_every_tick=false, закомментируйте этот блок
var table infoTable = table.new(position.top_right, 2, 4, bgcolor=color.new(color.black, 80))

if barstate.islast
    table.cell(infoTable, 0, 0, "Trend:", text_color=color.white)
    table.cell(infoTable, 1, 0, strongBullTrend ? "BULL 🚀" : strongBearTrend ? "BEAR 📉" : "NEUTRAL", 
               text_color=strongBullTrend ? color.lime : strongBearTrend ? color.red : color.gray)
    
    table.cell(infoTable, 0, 1, "RSI:", text_color=color.white)
    table.cell(infoTable, 1, 1, str.tostring(math.round(rsi)), 
               text_color=rsi > 70 ? color.red : rsi < 30 ? color.lime : color.white)
    
    table.cell(infoTable, 0, 2, "ADX:", text_color=color.white)
    table.cell(infoTable, 1, 2, str.tostring(math.round(adx)), 
               text_color=adx > adxThreshold ? color.lime : color.gray)
    
    table.cell(infoTable, 0, 3, "Volume:", text_color=color.white)
    table.cell(infoTable, 1, 3, volumeSpike ? "HIGH 📈" : "Normal", 
               text_color=volumeSpike ? color.lime : color.gray)

