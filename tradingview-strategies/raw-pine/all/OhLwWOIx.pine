//@version=5
strategy("GROK ALTIN B2 ))", overlay=true,
         default_qty_type=strategy.fixed, default_qty_value=1.0,
         commission_type=strategy.commission.percent, commission_value=0.02,
         pyramiding=0)

// INPUTS
atr_mult = input.float(1.5, "ATR Stop Carpani")
tp1_pip = input.int(8, "1. Kademe TP (pip)")
tp2_pip = input.int(15, "2. Kademe TP (pip)")
tp3_pip = input.int(25, "3. Kademe TP (pip)")

// ATR STOP
atr = ta.atr(14)
stop_distance = atr * atr_mult
dynamic_stop = close - stop_distance

// EMA & RSI
ema9 = ta.ema(close, 9)
rsi = ta.rsi(close, 14)
long_signal = ta.crossover(ema9, close) and rsi > 50 and strategy.position_size == 0

// GIRIS
if (long_signal)
    strategy.entry("ALTIN LONG", strategy.long)

// DINAMIK STOP
strategy.exit("DYNAMIC_STOP", from_entry="ALTIN LONG", stop=dynamic_stop)

// KADEMELI CIKIS
strategy.exit("TP1", from_entry="ALTIN LONG", qty_percent=33, profit=tp1_pip * 10)
strategy.exit("TP2", from_entry="ALTIN LONG", qty_percent=33, profit=tp2_pip * 10)
strategy.exit("TP3", from_entry="ALTIN LONG", qty_percent=34, profit=tp3_pip * 10)

// KAR KILIT (TP1 SONRA)
var bool lock_triggered = false
var float lock_sl = na

if (strategy.position_size > 0 and strategy.closedtrades > strategy.closedtrades[1] and strategy.wintrades > strategy.wintrades[1] and not lock_triggered)
    lock_triggered := true
    lock_sl := close - (atr * 0.8)
    strategy.exit("KAR_KILIT", from_entry="ALTIN LONG", stop=lock_sl)

// GORSEL
plot(ema9, "EMA 9", color=color.green, linewidth=2)
plot(dynamic_stop, "DYNAMIC STOP", color=color.red, style=plot.style_linebr)
plot(lock_sl and strategy.position_size > 0 ? lock_sl : na, "KAR KILIDI", color=color.lime, style=plot.style_cross)

// SINYAL
plotshape(long_signal, location.belowbar, color=color.green, style=shape.triangleup, size=size.large, text="BUY")

// ALARM
alertcondition(long_signal, title="ALTIN 1 LOT AL", 
     message="ALTIN LONG! 1 LOT | 4000->4001 = 100$ | TP: 8-15-25 pip | {{ticker}} {{interval}}")

