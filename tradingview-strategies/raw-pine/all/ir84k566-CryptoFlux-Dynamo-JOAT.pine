//@version=6
strategy("CryptoFlux Dynamo: Velocity Scalping Strategy", "CFX Dyno", overlay=true, calc_on_every_tick=true, calc_on_order_fills=true, pyramiding=1, initial_capital=100000, commission_value=0.04, slippage=1, max_labels_count=500, max_lines_count=500)

// ─────────────────────────────────────────────────────────────────────────────
// CryptoFlux Dynamo • Configuration Architecture
// ─────────────────────────────────────────────────────────────────────────────
string groupCore      = "CryptoFlux Dynamo • Core Controls"
string groupOpt       = "Optimization Constants"
string groupRegime    = "Regime Intelligence"
string groupSignal    = "Signal Pathways"
string groupRisk      = "Risk Architecture"
string groupDisplay   = "Visualization & Diagnostics"

bool   enableShorts        = input.bool(true, "Enable Short Structure", group=groupCore)
bool   useSessionFilter    = input.bool(false, "Restrict to Session Window", group=groupCore)
string sessionWindow       = input.session("0000-2359:1234567", "Execution Session", group=groupCore,
     tooltip="Default keeps the engine live during the 24/7 crypto cycle.")
bool   allowReEntries      = input.bool(true, "Allow Same-Bar Re-Entry", group=groupCore)

// Optimization constants tuned for crypto-native momentum signatures
int    macdFastLen         = input.int(8,  "MACD Fast Length",   group=groupOpt, minval=1)
int    macdSlowLen         = input.int(21, "MACD Slow Length",   group=groupOpt, minval=2)
int    macdSignalLen       = input.int(5,  "MACD Signal Length", group=groupOpt, minval=1)
int    emaFastLen          = input.int(8,  "EMA Fast",            group=groupOpt, minval=1)
int    emaMidLen           = input.int(21, "EMA Mid",             group=groupOpt, minval=2)
int    emaSlowLen          = input.int(34, "EMA Slow",            group=groupOpt, minval=3)
int    emaSlopeLen         = input.int(8,  "EMA Slope Lookback",  group=groupOpt, minval=2)
int    structureLookback   = input.int(9,  "Structure Break Window", group=groupOpt, minval=2)

// Volatility regime intelligence
int    atrLen              = input.int(21, "ATR Length", group=groupRegime, minval=5)
int    volatilitySmooth    = input.int(13, "Volatility Soothing", group=groupRegime, minval=1)
float  atrLowThreshold     = input.float(0.8, "Low Vol Regime Threshold (% ATR)", group=groupRegime, step=0.05)
float  atrHighThreshold    = input.float(1.6, "High Vol Regime Threshold (% ATR)", group=groupRegime, step=0.05)
int    cycleLen            = input.int(55, "Cycle Bias Length", group=groupRegime, minval=10)
float  cycleThreshold      = input.float(0.15, "Cycle Bias Threshold (%)", group=groupRegime, step=0.01,
     tooltip="Positive values demand bullish cycle confirmation, negatives capture bearish bias.")
string dominanceSymbol     = input.symbol("CRYPTOCAP:BTC.D", "BTC Dominance Feed", group=groupRegime)
bool   useDominanceFilter  = input.bool(true, "BTC Dominance Confirmation", group=groupRegime,
     tooltip="Filters longs when BTC dominance is rising sharply (risk-off) and vice versa.")

// Signal pathway configuration
int    volumeLookback      = input.int(34, "Volume Baseline Length", group=groupSignal, minval=5)
float  volumeImpulseMult   = input.float(1.15, "Volume Impulse Multiplier", group=groupSignal, step=0.05)
float  volumeZThreshold    = input.float(0.5, "Volume Z-Score Threshold", group=groupSignal, step=0.1)
int    histSmoothLen       = input.int(5,  "MACD Histogram Smoothing", group=groupSignal, minval=1)
float  histSensitivity     = input.float(1.15, "MACD Histogram Sensitivity", group=groupSignal, step=0.05,
     tooltip="Higher values demand stronger momentum divergence before firing entries.")
int    rsiLen              = input.int(21, "RSI Length", group=groupSignal, minval=2)
float  rsiTrigger          = input.float(55, "RSI Momentum Trigger", group=groupSignal, minval=0, maxval=100, step=0.5)
int    mfiLen              = input.int(21, "MFI Length", group=groupSignal, minval=2)
float  mfiTrigger          = input.float(55, "MFI Momentum Trigger", group=groupSignal, minval=0, maxval=100, step=0.5)
int    squeezeLen          = input.int(20, "Squeeze Length", group=groupSignal, minval=5)
float  squeezeMult         = input.float(1.5, "Bollinger Multiplier", group=groupSignal, step=0.1)
float  kcMult              = input.float(1.8, "Keltner Multiplier", group=groupSignal, step=0.1)
float  squeezeReleaseGate  = input.float(1.0, "Squeeze Release Momentum Gate", group=groupSignal, step=0.1)
int    pullbackDepth       = input.int(7,  "Micro Pullback Depth", group=groupSignal, minval=2)
int    minSignalStrength   = input.int(55, "Minimum Composite Signal Strength", group=groupSignal, minval=0, maxval=100)

// Risk architecture tuned for crypto microstructure
float  riskPerTradePct     = input.float(0.65, "Risk Allocation per Trade (%)", group=groupRisk, minval=0.1, maxval=5, step=0.05)
float  maxExposurePct      = input.float(12.0, "Max Exposure (% of Equity)", group=groupRisk, minval=0.5, maxval=50, step=0.5)
float  baseRiskReward      = input.float(1.8, "Base Risk/Reward Anchor", group=groupRisk, minval=0.5, maxval=5, step=0.1)
float  stopMultLow         = input.float(1.05, "Stop Multiplier • Low Regime", group=groupRisk, step=0.05)
float  stopMultMed         = input.float(1.55, "Stop Multiplier • Medium Regime", group=groupRisk, step=0.05)
float  stopMultHigh        = input.float(2.1,  "Stop Multiplier • High Regime", group=groupRisk, step=0.05)
float  tpMultLow           = input.float(1.6,  "Take Profit Multiplier • Low Regime", group=groupRisk, step=0.1)
float  tpMultMed           = input.float(2.05, "Take Profit Multiplier • Medium Regime", group=groupRisk, step=0.1)
float  tpMultHigh          = input.float(2.8,  "Take Profit Multiplier • High Regime", group=groupRisk, step=0.1)
bool   adaptiveTrail       = input.bool(true, "Adaptive Trailing Engine", group=groupRisk)
float  trailOffsetBase     = input.float(0.9, "Trailing Offset Multiplier", group=groupRisk, step=0.05)
float  qtyGranularity      = input.float(0.001, "Quantity Granularity", group=groupRisk, step=0.001, minval=0.0001)
float  killSwitchDrawdown  = input.float(6.5, "Kill Switch Drawdown (%)", group=groupRisk, step=0.5,
     tooltip="Disables new entries once max drawdown exceeds the specified percentage.")

// Display options
bool   showDashboard       = input.bool(true, "Display CryptoFlux Dashboard", group=groupDisplay)
bool   showSignalLabels    = input.bool(true, "Plot Signal Labels", group=groupDisplay)
color  ribbonColorBull     = input.color(color.rgb(0, 218, 187), "Bull Ribbon Color", group=groupDisplay)
color  ribbonColorBear     = input.color(color.rgb(255, 92, 151), "Bear Ribbon Color", group=groupDisplay)
color  barColorBull        = input.color(color.rgb(0, 255, 195), "Bull Bar Accent", group=groupDisplay)
color  barColorBear        = input.color(color.rgb(255, 97, 136), "Bear Bar Accent", group=groupDisplay)
color  barColorNeutral     = input.color(color.rgb(120, 126, 255), "Neutral Bar Accent", group=groupDisplay)

// ─────────────────────────────────────────────────────────────────────────────
// Helper Functions
// ─────────────────────────────────────────────────────────────────────────────
calcQty(stopDistance) =>
    riskCapital = strategy.equity * (riskPerTradePct / 100.0)
    qtyRaw = stopDistance > 0 ? riskCapital / stopDistance : 0.0
    maxQty = strategy.equity * (maxExposurePct / 100.0) / close
    qtyCapped = math.min(qtyRaw, maxQty)
    qtyRounded = qtyGranularity > 0 ? math.round(qtyCapped / qtyGranularity) * qtyGranularity : qtyCapped
    math.max(qtyRounded, 0.0)

clamp01(value) => 
    math.max(0.0, math.min(1.0, value))

normalize(value, minValue, maxValue) =>
    maxValue == minValue ? 0.0 : clamp01((value - minValue) / (maxValue - minValue))

calcMFI(len) =>
    length = math.max(len, 1)
    typical = (high + low + close) / 3.0
    typicalPrev = nz(typical[1], typical)
    moneyFlow = typical * volume
    positiveFlow = typical > typicalPrev ? moneyFlow : 0.0
    negativeFlow = typical < typicalPrev ? moneyFlow : 0.0
    posAvg = ta.sma(positiveFlow, length)
    negAvg = ta.sma(negativeFlow, length)
    negAvg == 0.0 ? 100.0 : 100.0 - (100.0 / (1.0 + posAvg / negAvg))

// ─────────────────────────────────────────────────────────────────────────────
// Core Indicator Engine
// ─────────────────────────────────────────────────────────────────────────────
float emaFast = ta.ema(close, emaFastLen)
float emaMid  = ta.ema(close, emaMidLen)
float emaSlow = ta.ema(close, emaSlowLen)

bool  ribbonBull = emaFast > emaMid and emaMid > emaSlow
bool  ribbonBear = emaFast < emaMid and emaMid < emaSlow
float emaSlope   = emaSlopeLen > 0 ? (emaMid - emaMid[emaSlopeLen]) / emaSlopeLen : 0.0
float emaSlopeNorm = math.atan(emaSlope) * 180.0 / math.pi

float atrRaw   = ta.atr(atrLen)
float atrValue = ta.ema(atrRaw, volatilitySmooth)
float atrPct   = close == 0 ? 0 : atrValue / close * 100
int   regime   = atrPct < atrLowThreshold ? 0 : atrPct < atrHighThreshold ? 1 : 2
string regimeName = regime == 0 ? "Compression" : regime == 1 ? "Expansion" : "Velocity"

float stopMultiplier = regime == 0 ? stopMultLow : regime == 1 ? stopMultMed : stopMultHigh
float tpMultiplier   = regime == 0 ? tpMultLow  : regime == 1 ? tpMultMed  : tpMultHigh
float regimeRRBonus  = regime == 0 ? 0.9 : regime == 1 ? 1.0 : 1.15

float stopDistance   = atrValue * stopMultiplier
float targetDistance = atrValue * tpMultiplier * baseRiskReward * regimeRRBonus

float trailOffset    = atrValue * trailOffsetBase * (regime == 2 ? 0.8 : regime == 0 ? 1.1 : 1.0)

[macdLine, macdSignal, macdHistRaw] = ta.macd(close, macdFastLen, macdSlowLen, macdSignalLen)
float histSmooth = ta.ema(macdHistRaw, histSmoothLen)
float histBaseline = ta.ema(math.abs(macdHistRaw), histSmoothLen * 2)
float histAdaptive = histBaseline * histSensitivity

float rsiValue = ta.rsi(close, rsiLen)
float mfiValue = calcMFI(mfiLen)

float volMA     = ta.sma(volume, volumeLookback)
float volStdev  = ta.stdev(volume, volumeLookback)
float volumeZ   = volStdev == 0 ? 0 : (volume - volMA) / volStdev
bool  volumeImpulse = volume > volMA * volumeImpulseMult or volumeZ > volumeZThreshold

float cycleBasis = ta.ema(close, cycleLen)
float cycleOsc   = cycleBasis == 0 ? 0 : (close - cycleBasis) / cycleBasis * 100
bool  cycleBull  = cycleOsc > cycleThreshold
bool  cycleBear  = cycleOsc < -cycleThreshold

float domSeries  = request.security(dominanceSymbol, timeframe.period, close, lookahead=barmerge.lookahead_off)
float domSlope   = ta.sma(ta.change(domSeries), 5)
bool  dominanceNeutral = math.abs(domSlope) < 0.12
bool  dominanceRiskOff = domSlope > 0.12
bool  dominanceRiskOn  = domSlope < -0.12

bool  dominanceGateLong  = not useDominanceFilter or dominanceRiskOn or dominanceNeutral
bool  dominanceGateShort = not useDominanceFilter or dominanceRiskOff or dominanceNeutral

// Squeeze analytics
float bbBasis = ta.sma(close, squeezeLen)
float bbDev   = squeezeMult * ta.stdev(close, squeezeLen)
float bbUpper = bbBasis + bbDev
float bbLower = bbBasis - bbDev
float kcBasis = ta.ema(close, squeezeLen)
float kcRange = ta.atr(squeezeLen) * kcMult
float kcUpper = kcBasis + kcRange
float kcLower = kcBasis - kcRange
bool  squeezeOn = (bbUpper - bbLower) < (kcUpper - kcLower)
bool  squeezeRelease = not squeezeOn and squeezeOn[1]
bool  squeezeLong  = squeezeRelease and close > bbUpper[1] and histSmooth > 0 and math.abs(histSmooth) > histAdaptive * squeezeReleaseGate
bool  squeezeShort = squeezeRelease and close < bbLower[1] and histSmooth < 0 and math.abs(histSmooth) > histAdaptive * squeezeReleaseGate

// Micro pullback logic for sub-5m responsiveness
float lowestPullbackSeries = ta.lowest(low, pullbackDepth)
float highestPullbackSeries = ta.highest(high, pullbackDepth)
float structureHighSeries = ta.highest(high, structureLookback)
float structureLowSeries = ta.lowest(low, structureLookback)

bool microPullbackLong  = ribbonBull and close <= emaFast and close > emaMid and lowestPullbackSeries[1] == low[1]
bool microPullbackShort = ribbonBear and close >= emaFast and close < emaMid and highestPullbackSeries[1] == high[1]

// Structure break momentum logic
bool structureBreakLong  = ribbonBull and close > structureHighSeries[1]
bool structureBreakShort = ribbonBear and close < structureLowSeries[1]

bool momentumQualifiedLong  = histSmooth > histAdaptive and macdLine > macdSignal and rsiValue > rsiTrigger and mfiValue > mfiTrigger
bool momentumQualifiedShort = histSmooth < -histAdaptive and macdLine < macdSignal and rsiValue < (100 - rsiTrigger) and mfiValue < (100 - mfiTrigger)

// Composite signal pathways
bool pathTrendLong   = ribbonBull and emaSlopeNorm > 0 and structureBreakLong
bool pathTrendShort  = ribbonBear and emaSlopeNorm < 0 and structureBreakShort
bool pathMomentumLong  = momentumQualifiedLong and volumeImpulse
bool pathMomentumShort = momentumQualifiedShort and volumeImpulse
bool pathSqueezeLong   = squeezeLong
bool pathSqueezeShort  = squeezeShort
bool pathPullbackLong  = microPullbackLong and histSmooth > 0 and volumeImpulse
bool pathPullbackShort = microPullbackShort and histSmooth < 0 and volumeImpulse

float strengthLong = 0.0
strengthLong += pathTrendLong   ? 30 : 0
strengthLong += pathMomentumLong? 30 : 0
strengthLong += pathSqueezeLong ? 25 : 0
strengthLong += pathPullbackLong? 15 : 0
strengthLong += volumeImpulse   ? 5  : -5
strengthLong += regime == 2 ? 5 : regime == 0 ? -2 : 0
strengthLong += cycleBull ? 5 : -5
float longStrength = math.min(math.max(strengthLong, 0), 100)

float strengthShort = 0.0
strengthShort += pathTrendShort   ? 30 : 0
strengthShort += pathMomentumShort? 30 : 0
strengthShort += pathSqueezeShort ? 25 : 0
strengthShort += pathPullbackShort? 15 : 0
strengthShort += volumeImpulse    ? 5  : -5
strengthShort += regime == 2 ? 5 : regime == 0 ? -2 : 0
strengthShort += cycleBear ? 5 : -5
float shortStrength = math.min(math.max(strengthShort, 0), 100)

bool sessionActive = not useSessionFilter or not na(time(timeframe.period, sessionWindow))
bool killSwitchActive = strategy.max_drawdown_percent >= killSwitchDrawdown

bool longSignal  = sessionActive and not killSwitchActive and dominanceGateLong and cycleBull and volumeImpulse and longStrength >= minSignalStrength
bool shortSignal = sessionActive and not killSwitchActive and dominanceGateShort and cycleBear and volumeImpulse and shortStrength >= minSignalStrength

// Prevent conflict when both signals fire simultaneously
if longSignal and shortSignal
    longSignal := histSmooth > 0
    shortSignal := not longSignal

// Risk managed position sizing
float longQty  = calcQty(stopDistance)
float shortQty = calcQty(stopDistance)

// Entry & Exit orchestration
if longSignal and longQty > 0
    if strategy.position_size < 0
        strategy.close("CFD Short", comment="Trend Flip")
    if allowReEntries or strategy.position_size <= 0
        strategy.entry("CFD Long", strategy.long, qty=longQty, comment=regimeName)

if shortSignal and enableShorts and shortQty > 0
    if strategy.position_size > 0
        strategy.close("CFD Long", comment="Trend Flip")
    if allowReEntries or strategy.position_size >= 0
        strategy.entry("CFD Short", strategy.short, qty=shortQty, comment=regimeName)

float avgPrice = strategy.position_avg_price
float longStopPrice  = avgPrice - stopDistance
float longTakePrice  = avgPrice + targetDistance
float shortStopPrice = avgPrice + stopDistance
float shortTakePrice = avgPrice - targetDistance

if strategy.position_size > 0
    strategy.exit("CFD Long Exit", from_entry="CFD Long", stop=longStopPrice, limit=longTakePrice)
    if adaptiveTrail
        float trailStop = close - trailOffset
        if trailStop > longStopPrice
            strategy.exit("CFD Long Trail", from_entry="CFD Long", stop=trailStop)

if strategy.position_size < 0
    strategy.exit("CFD Short Exit", from_entry="CFD Short", stop=shortStopPrice, limit=shortTakePrice)
    if adaptiveTrail
        float trailStop = close + trailOffset
        if trailStop < shortStopPrice
            strategy.exit("CFD Short Trail", from_entry="CFD Short", stop=trailStop)

// Safety net: close on momentum reversal
bool longExitMomentum  = strategy.position_size > 0 and (macdHistRaw < 0 or not ribbonBull)
bool shortExitMomentum = strategy.position_size < 0 and (macdHistRaw > 0 or not ribbonBear)

if longExitMomentum
    strategy.close("CFD Long", comment="Momentum Fade")
if shortExitMomentum
    strategy.close("CFD Short", comment="Momentum Fade")

// Visualization Layer
plot(emaFast, "EMA 8", color=color.new(ribbonColorBull, 0), linewidth=2)
plot(emaMid,  "EMA 21", color=color.new(color.rgb(220, 220, 255), 45), linewidth=1)
plot(emaSlow, "EMA 34", color=color.new(ribbonColorBear, 0), linewidth=2)

color compressionColor = color.new(color.rgb(64, 74, 167), 90)
color expansionColor   = color.new(color.rgb(111, 56, 193), 86)
color velocityColor    = color.new(color.rgb(255, 83, 155), 82)
bgcolor(regime == 2 ? velocityColor : regime == 1 ? expansionColor : compressionColor, title="Volatility Regime Backdrop")

float biasDelta = longStrength - shortStrength
float biasMagnitude = math.min(math.abs(biasDelta), 60)
int dynamicTransparency = int(65 - math.round(biasMagnitude))
color activeBarColor = biasDelta > 10 ? color.new(barColorBull, dynamicTransparency) :
     biasDelta < -10 ? color.new(barColorBear, dynamicTransparency) :
     color.new(barColorNeutral, 75)
barcolor(activeBarColor, title="CryptoFlux Bar Accent")

plot(longStrength, "Long Signal Strength", color=color.new(barColorBull, 0), display=display.data_window)
plot(shortStrength, "Short Signal Strength", color=color.new(barColorBear, 0), display=display.data_window)
plot(atrPct, "ATR %", color=color.new(color.rgb(255, 230, 120), 0), display=display.data_window)

plotshape(showSignalLabels and longSignal, title="Long Signal", style=shape.triangleup, color=color.new(barColorBull, 0), size=size.tiny, location=location.belowbar, text="CFD Long")
plotshape(showSignalLabels and shortSignal and enableShorts, title="Short Signal", style=shape.triangledown, color=color.new(barColorBear, 0), size=size.tiny, location=location.abovebar, text="CFD Short")
plotshape(showSignalLabels and killSwitchActive, title="Kill Switch", style=shape.cross, color=color.new(color.gray, 0), size=size.small, location=location.top, text="Kill Switch")

// Dashboard telemetry
var table dash = na
if showDashboard
    if na(dash)
        dash := table.new(position.top_right, 4, 9, border_width=1, border_color=color.new(color.silver, 30))
    if barstate.islast
        color regimeColor = regime == 2 ? color.new(color.rgb(255, 83, 155), 55) : regime == 1 ? color.new(color.rgb(111, 56, 193), 50) : color.new(color.rgb(64, 74, 167), 50)
        table.cell(dash, 0, 0, "CryptoFlux Dynamo", text_color=color.white, bgcolor=color.new(color.rgb(12, 16, 40), 10), text_size=size.large)
        table.cell(dash, 1, 0, "Regime", text_color=color.white, bgcolor=regimeColor)
        table.cell(dash, 2, 0, regimeName, text_color=color.white, bgcolor=regimeColor)
        table.cell(dash, 3, 0, "ATR% " + str.tostring(atrPct, format.mintick), text_color=color.white, bgcolor=regimeColor)

        table.cell(dash, 0, 1, "Long Strength", text_color=color.new(color.lime, 0))
        table.cell(dash, 1, 1, str.tostring(longStrength, format.mintick), text_color=color.new(color.lime, 0))
        table.cell(dash, 2, 1, "Short Strength", text_color=color.new(color.red, 0))
        table.cell(dash, 3, 1, str.tostring(shortStrength, format.mintick), text_color=color.new(color.red, 0))

        table.cell(dash, 0, 2, "Cycle Osc", text_color=color.white)
        table.cell(dash, 1, 2, str.tostring(cycleOsc, format.mintick), text_color=color.white)
        table.cell(dash, 2, 2, "Dominance Δ", text_color=color.white)
        table.cell(dash, 3, 2, str.tostring(domSlope, format.mintick), text_color=color.white)

        table.cell(dash, 0, 3, "Position", text_color=color.white)
        table.cell(dash, 1, 3, strategy.position_size > 0 ? "Long" : strategy.position_size < 0 ? "Short" : "Flat", text_color=color.white)
        table.cell(dash, 2, 3, "Avg Price", text_color=color.white)
        table.cell(dash, 3, 3, str.tostring(avgPrice, format.price), text_color=color.white)

        table.cell(dash, 0, 4, "Stop", text_color=color.white)
        table.cell(dash, 1, 4, str.tostring(strategy.position_size > 0 ? longStopPrice : strategy.position_size < 0 ? shortStopPrice : na, format.price), text_color=color.white)
        table.cell(dash, 2, 4, "Target", text_color=color.white)
        table.cell(dash, 3, 4, str.tostring(strategy.position_size > 0 ? longTakePrice : strategy.position_size < 0 ? shortTakePrice : na, format.price), text_color=color.white)

        table.cell(dash, 0, 5, "RR", text_color=color.white)
        table.cell(dash, 1, 5, str.tostring(baseRiskReward * regimeRRBonus, format.mintick), text_color=color.white)
        table.cell(dash, 2, 5, "ATR", text_color=color.white)
        table.cell(dash, 3, 5, str.tostring(atrValue, format.price), text_color=color.white)

        table.cell(dash, 0, 6, "Kill Switch", text_color=color.white)
        table.cell(dash, 1, 6, killSwitchActive ? "ACTIVE" : "Standby", text_color=killSwitchActive ? color.new(color.red, 0) : color.new(color.lime, 0))
        table.cell(dash, 2, 6, "DD%", text_color=color.white)
        table.cell(dash, 3, 6, str.tostring(strategy.max_drawdown_percent, format.mintick), text_color=color.white)

        table.cell(dash, 0, 7, "Volume Z", text_color=color.white)
        table.cell(dash, 1, 7, str.tostring(volumeZ, format.mintick), text_color=color.white)
        table.cell(dash, 2, 7, "Impulse", text_color=color.white)
        table.cell(dash, 3, 7, volumeImpulse ? "Yes" : "No", text_color=volumeImpulse ? color.new(color.lime, 0) : color.new(color.gray, 0))

        table.cell(dash, 0, 8, "Dominance", text_color=color.white)
        table.cell(dash, 1, 8, dominanceGateLong ? "Long OK" : "Filtered", text_color=dominanceGateLong ? color.new(color.lime, 0) : color.new(color.orange, 0))
        table.cell(dash, 2, 8, dominanceGateShort ? "Short OK" : "Filtered", text_color=dominanceGateShort ? color.new(color.red, 0) : color.new(color.orange, 0))

