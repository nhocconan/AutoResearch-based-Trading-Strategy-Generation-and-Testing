//@version=5
strategy("MOMO – Imbalance Trend (SIMPLE BUY/SELL)",
     overlay = true,
     initial_capital = 10000,
     margin_long = 100,
     margin_short = 100,
     process_orders_on_close = true)

//──────────────────────────────────────
// 0. INPUTS
//──────────────────────────────────────
slP = input.float(0.8, "SL %", step = 0.1) / 100
tpP = input.float(1.8, "TP %", step = 0.1) / 100

//──────────────────────────────────────
// 1. TREND (HH/HL vs LH/LL)
//──────────────────────────────────────
swh = ta.pivothigh(high, 2, 2)
swl = ta.pivotlow(low, 2, 2)

var float lastHigh = na
var float lastLow  = na

if not na(swh)
    lastHigh := swh
if not na(swl)
    lastLow := swl

upNow   = not na(lastHigh) and close > lastHigh
downNow = not na(lastLow)  and close < lastLow

var int trend = 0        // 1 = up, -1 = down, 0 = range
int newTrend = trend
if upNow
    newTrend := 1
else if downNow
    newTrend := -1

bullBreak = trend == -1 and newTrend == 1
bearBreak = trend == 1  and newTrend == -1
trend := newTrend

plotshape(bullBreak, title = "TrendBreakUp",
          location = location.belowbar, style = shape.labelup,
          text = "Break↑", color = color.green, textcolor = color.white, size = size.small)
plotshape(bearBreak, title = "TrendBreakDown",
          location = location.abovebar, style = shape.labeldown,
          text = "Break↓", color = color.red, textcolor = color.white, size = size.small)

//──────────────────────────────────────
// 2. IMBALANCE (DISPLACEMENT CANDLES)
//──────────────────────────────────────
bullBody    = close - open
bearBody    = open - close
candleRange = high - low

bullDisp = bullBody > 0 and bullBody > candleRange * 0.6
bearDisp = bearBody > 0 and bearBody > candleRange * 0.6

plotshape(bullDisp, title = "BullImb",
          location = location.belowbar, style = shape.triangleup,
          text = "IMB", color = color.green, size = size.tiny)
plotshape(bearDisp, title = "BearImb",
          location = location.abovebar, style = shape.triangledown,
          text = "IMB", color = color.red, size = size.tiny)

//──────────────────────────────────────
// 3. DEMAND ZONE (BULLISH IMB)
//──────────────────────────────────────
var float dLow  = na
var float dHigh = na
var bool  dUsed = false
var box   dBox  = na

if bullDisp
    dLow  := low
    dHigh := open
    dUsed := false
    if not na(dBox)
        box.delete(dBox)
    dBox := box.new(bar_index, dHigh, bar_index + 1, dLow)
    box.set_bgcolor(dBox, color.new(color.teal, 85))
    box.set_border_color(dBox, color.new(color.teal, 40))

if not na(dBox) and not dUsed
    box.set_right(dBox, bar_index)

// FIRST TAP into demand (not imbalance candle)
firstTapDemand = not dUsed and not bullDisp and not na(dLow) and low <= dHigh and low >= dLow

if firstTapDemand
    dUsed := true
    if not na(dBox)
        box.delete(dBox)
        dBox := na

//──────────────────────────────────────
// 4. SUPPLY ZONE (BEARISH IMB)
//──────────────────────────────────────
var float sLow  = na
var float sHigh = na
var bool  sUsed = false
var box   sBox  = na

if bearDisp
    sHigh := high
    sLow  := open
    sUsed := false
    if not na(sBox)
        box.delete(sBox)
    sBox := box.new(bar_index, sHigh, bar_index + 1, sLow)
    box.set_bgcolor(sBox, color.new(color.red, 85))
    box.set_border_color(sBox, color.new(color.red, 40))

if not na(sBox) and not sUsed
    box.set_right(sBox, bar_index)

// FIRST TAP into supply (not imbalance candle)
firstTapSupply = not sUsed and not bearDisp and not na(sHigh) and high >= sLow and high <= sHigh

if firstTapSupply
    sUsed := true
    if not na(sBox)
        box.delete(sBox)
        sBox := na

//──────────────────────────────────────
// 5. ENTRY CONDITIONS (SIMPLE)
//──────────────────────────────────────
// Only trend + first tap
longEntry  = trend == 1  and firstTapDemand
shortEntry = trend == -1 and firstTapSupply

// Big BUY / SELL arrows
plotshape(longEntry,  title = "BUY",
          location = location.belowbar, style = shape.labelup,
          size = size.large, color = color.green, text = "BUY", textcolor = color.white)
plotshape(shortEntry, title = "SELL",
          location = location.abovebar, style = shape.labeldown,
          size = size.large, color = color.red, text = "SELL", textcolor = color.white)

// Extra labels so they *always* show
if longEntry
    label.new(bar_index, low, "BUY",
              style = label.style_label_up,
              color = color.green, textcolor = color.white)
if shortEntry
    label.new(bar_index, high, "SELL",
              style = label.style_label_down,
              color = color.red, textcolor = color.white)

//──────────────────────────────────────
// 6. STRATEGY ORDERS (ENTRY + EXIT)
//──────────────────────────────────────
if longEntry
    strategy.entry("Long", strategy.long)

if shortEntry
    strategy.entry("Short", strategy.short)

if strategy.position_size > 0
    strategy.exit("Exit L", "Long",
                  stop  = strategy.position_avg_price * (1 - slP),
                  limit = strategy.position_avg_price * (1 + tpP))

if strategy.position_size < 0
    strategy.exit("Exit S", "Short",
                  stop  = strategy.position_avg_price * (1 + slP),
                  limit = strategy.position_avg_price * (1 - tpP))

