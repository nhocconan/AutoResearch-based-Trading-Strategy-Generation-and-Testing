//@version=6
strategy("MA strategy", calc_on_order_fills = true, overlay=true, process_orders_on_close = true, use_bar_magnifier = true)

// Inputs
maType = input. string("EMA", "MA Type", options=["SMA", "EMA"])
fastLength = input.int(2, "Fast MA Length", minval=1, maxval=100)
ma1Fast = input.bool(true, "Show fastMA")
slowLength = input.int(21, "Slow MA Length", minval=1, maxval=200)
ma2slow = input.bool(true, "Show slowMA")
useDisplacement = input.bool(false, "Enable MA Displacement")
displacementBars = input.int(5, "Displacement (Bars)", minval=0, maxval=50)
showEntryExit = input.bool(true, "Show positions")
// Inputs for MA3
ma3Show = input.bool(false, "Show MA3")
ma3Type = input.string("EMA", "MA3 Type", options=["EMA", "SMA"])
ma3Length = input.int(50, "MA3 Length", minval=1)

// Inputs for MA4
ma4Show = input.bool(false, "Show MA4")
ma4Type = input.string("EMA", "MA4 Type", options=["EMA", "SMA"])
ma4Length = input.int(100, "MA4 Length", minval=1)
// Inputs for MA5 (50 SMA)
ma5Show = input.bool(false, "Show MA5 (50 Daily SMA)")
ma5Length = input.int(50, "MA5 Length", minval=1)

// Inputs for MA6 (200 SMA)
ma6Show = input.bool(false, "Show MA6 (100 Daily SMA)")
ma6Length = input.int(100, "MA6 Length", minval=1)
// Inputs for MA6 (100 SMA)
ma7Show = input.bool(false, "Show MA7 (200 Daily SMA)")
ma7Length = input.int(200, "MA7 Length", minval=1)

useTrailingStop = input(true, "Enable Trailing Stop")
stopType = input.string("Swing", "Stop Type", options=["ATR", "Swing"])
swingOffsetPoints = input.float(5.0, "Swing Stop Offset (Points)", maxval=50)
trailOffset = input.float(1.0, "ATR Multiplier (if using ATR)", step=0.1, minval=0.1, maxval=5)
moveAfterSecondSwing = input(true, "Move Stop Only After Second Swing Low/High")

// Fixed SL/TP by Points Inputs
useFixedSLTP = input. bool(false, "Enable Fixed SL/TP (Points)")
fixedSLPoints = input.float(10.0, "Fixed Stop Loss (Points)", minval=0.1, step=1.0)
fixedTPPoints = input.float(20.0, "Fixed Take Profit (Points)", minval=0.1, step=1.0)

// Volume Profile Inputs
vpGroup = "Volume Profile"
useVolumeProfile = input.bool(false, "Enable Volume Profile", group=vpGroup)
vpRows = input.int(24, "Number of Rows", minval=10, maxval=50, group=vpGroup)
lvnThreshold = input.float(25.0, "LVN Threshold (%)", minval=5, maxval=50, step=5, group=vpGroup)
vpSessionTime = input.session("0930-1600", "NY Session Time", group=vpGroup)
lvnColor = input.color(color.new(color.red, 70), "LVN Highlight Color", group=vpGroup)
pocColor = input.color(color.new(color.yellow, 0), "POC Line Color", group=vpGroup)

// Check if valid timeframe for volume profile (5M to 1H)
validVPTimeframe = timeframe.period == "5" or timeframe.period == "15" or timeframe. period == "30" or timeframe.period == "60"
showVP = useVolumeProfile and validVPTimeframe

// Calculate Moving Averages
fastMA = maType == "SMA" ?  ta.sma(close, fastLength) : ta.ema(close, fastLength)
slowMA = maType == "SMA" ? ta.sma(close, slowLength) : ta. ema(close, slowLength)

// Calculate offset for plotting
plotOffset = useDisplacement ? displacementBars : 0

// Function to calculate the selected MA type
f_ma(src, length, type) =>
    type == "EMA" ? ta.ema(src, length) : ta.sma(src, length)

// Calculate each MA series
ma3 = f_ma(close, ma3Length, ma3Type)
ma4 = f_ma(close, ma4Length, ma4Type)
// Get the big picture
ma5 = request.security(syminfo.tickerid, "D", ta.sma(close, ma5Length))
ma6 = request.security(syminfo.tickerid, "D", ta.sma(close, ma6Length))
ma7 = request.security(syminfo.tickerid, "D", ta.sma(close, ma7Length))

// Buy/sell signal based on 50 SMA and 200 SMA
string ma5_signal = na
if ma5 > ma7
    ma5_signal := "Buy"
else
    ma5_signal := "Sell"

// Check if price is below daily 50 MA
belowMA50 = close < ma5

// Create a table to display the signal
var table t = table.new(position.top_center, 1, 1)
// 1) Red if 50 < 200
// 2) Otherwise yellow if price is below 50
// 3) Otherwise green
table_cell_bgcolor =
     ma5_signal == "Sell" ? color.new(color.red, 50) :
     belowMA50            ? color.new(color.yellow, 50) :
                             color.new(color.green, 50)

//table_cell_bgcolor = belowMA50 ?  color.new(color.yellow, 50) : (ma5_signal == "Buy" ? color. new(color.green, 50) : color.new(color.red, 50))
table_cell_textcolor = color.black

if bar_index == 0
    table.clear(t, start_row = 0, start_column = 0)

table.cell(t, 0, 0, text = "\n\n50/200MA X\nMode: " + ma5_signal, bgcolor = table_cell_bgcolor, text_color = table_cell_textcolor, text_size = size.normal, tooltip = "50/200 MA X")

// ==================== VOLUME PROFILE LOGIC ====================
// Session detection (New York time)
inSession = not na(time(timeframe.period, vpSessionTime, "America/New_York"))
isNewSession = inSession and not inSession[1]

// Session tracking variables
var float sessionHigh = na
var float sessionLow = na
var int sessionStartBar = na
var float[] volumeProfile = array.new_float(vpRows, 0.0)

// Box and line arrays for drawing
var box[] lvnBoxes = array. new_box()
var line pocLine = na

// Reset and track session
if showVP
    if isNewSession
        // Clear previous drawings
        for i = 0 to array.size(lvnBoxes) - 1
            box. delete(array.get(lvnBoxes, i))
        array.clear(lvnBoxes)
        line.delete(pocLine)
        
        // Reset session values
        sessionHigh := high
        sessionLow := low
        sessionStartBar := bar_index
        array.fill(volumeProfile, 0.0)
    else if inSession
        sessionHigh := math.max(nz(sessionHigh, high), high)
        sessionLow := math.min(nz(sessionLow, low), low)

// Build volume profile during session
if showVP and inSession and not na(sessionHigh) and not na(sessionLow)
    rowSize = (sessionHigh - sessionLow) / vpRows
    if rowSize > 0
        // Add volume to appropriate bin
        binIndex = math.floor((close - sessionLow) / rowSize)
        binIndex := math.min(math. max(binIndex, 0), vpRows - 1)
        currentVol = array. get(volumeProfile, int(binIndex))
        array.set(volumeProfile, int(binIndex), currentVol + volume)

// Draw volume profile on last bar or when session ends
if showVP and (barstate.islast or (not inSession and inSession[1])) and not na(sessionHigh) and not na(sessionLow)
    // Clear previous drawings
    for i = 0 to array.size(lvnBoxes) - 1
        box.delete(array.get(lvnBoxes, i))
    array.clear(lvnBoxes)
    line.delete(pocLine)
    
    rowSize = (sessionHigh - sessionLow) / vpRows
    if rowSize > 0
        // Find max volume (POC) and calculate LVN threshold
        maxVol = array.max(volumeProfile)
        lvnLevel = maxVol * (lvnThreshold / 100)
        
        // Find POC index
        pocIndex = 0
        for i = 0 to vpRows - 1
            if array.get(volumeProfile, i) == maxVol
                pocIndex := i
                break
        
        // Draw POC line
        pocPrice = sessionLow + (pocIndex * rowSize) + (rowSize / 2)
        pocLine := line.new(nz(sessionStartBar, bar_index - 50), pocPrice, bar_index + 10, pocPrice, 
                           color=pocColor, width=2, style=line.style_solid)
        
        // Draw LVN zones
        for i = 0 to vpRows - 1
            binVol = array. get(volumeProfile, i)
            if binVol > 0 and binVol < lvnLevel
                lvnPriceLow = sessionLow + (i * rowSize)
                lvnPriceHigh = lvnPriceLow + rowSize
                newBox = box. new(nz(sessionStartBar, bar_index - 50), lvnPriceHigh, bar_index + 10, lvnPriceLow, 
                               bgcolor=lvnColor, border_color=color.new(color. red, 50), border_width=1)
                array.push(lvnBoxes, newBox)

// ==================== END VOLUME PROFILE LOGIC ====================

// Strategy Logic (using regular MAs - signals are not offset)
longCondition = ta.crossover(fastMA, slowMA)
shortCondition = ta.crossunder(fastMA, slowMA)

// Swing Detection Function
isSwingLow() =>
    low[1] < low[2] and low[1] < low[0]

isSwingHigh() =>
    high[1] > high[2] and high[1] > high[0]

// Track swing levels and count
var float currentSwingLow = na
var float currentSwingHigh = na
var int swingLowCount = 0
var int swingHighCount = 0
var float trailPrice = na
var bool isLong = false
var bool isShort = false

// Detect new swing levels
if isSwingLow()
    currentSwingLow := low[1]
    swingLowCount += 1
    
if isSwingHigh()
    currentSwingHigh := high[1]
    swingHighCount += 1

// Initialize trailing stop on new trades
if (longCondition and barstate.isconfirmed)
    if showEntryExit
        strategy.entry("Buy", strategy.long)
    alert("Buy signal", alert.freq_once_per_bar)
    if useFixedSLTP
        strategy.exit("Fixed Exit Long", "Buy", stop=close - fixedSLPoints, limit=close + fixedTPPoints)
    if useTrailingStop
        if stopType == "ATR"
            trailPrice := low - (trailOffset * ta.atr(14))
        else // Swing-based
            trailPrice := currentSwingLow + swingOffsetPoints
    isLong := true
    isShort := false
    swingLowCount := 0 // Reset counter on new trade
    swingHighCount := 0

if (shortCondition and barstate.isconfirmed)
    if showEntryExit
        strategy.entry("Sell", strategy.short)
    alert("Sell signal", alert.freq_once_per_bar)
    if useFixedSLTP
        strategy.exit("Fixed Exit Short", "Sell", stop=close + fixedSLPoints, limit=close - fixedTPPoints)
    if useTrailingStop
        if stopType == "ATR"
            trailPrice := high + (trailOffset * ta.atr(14))
        else // Swing-based
            trailPrice := currentSwingHigh + swingOffsetPoints
    isShort := true
    isLong := false
    swingLowCount := 0 // Reset counter on new trade
    swingHighCount := 0

// Update trailing stop each bar
if (isLong and strategy.position_size > 0 and useTrailingStop and not useFixedSLTP)
    if stopType == "Swing" and not na(currentSwingLow)
        // Only move stop after second swing low if enabled
        if (moveAfterSecondSwing and swingLowCount >= 2) or not moveAfterSecondSwing
            newStop = currentSwingLow - swingOffsetPoints
            if newStop > trailPrice
                trailPrice := newStop
    strategy.exit("Trail Exit Long", "Buy", stop=trailPrice)

if (isShort and strategy.position_size < 0 and useTrailingStop and not useFixedSLTP)
    if stopType == "Swing" and not na(currentSwingHigh)
        // Only move stop after second swing high if enabled
        if (moveAfterSecondSwing and swingHighCount >= 2) or not moveAfterSecondSwing
            newStop = currentSwingHigh + swingOffsetPoints
            if newStop < trailPrice
                trailPrice := newStop
    strategy.exit("Trail Exit Short", "Sell", stop=trailPrice)

// Plot trailing stop line
plot(useTrailingStop and not useFixedSLTP and not na(trailPrice) ? trailPrice : na,
     "Trailing Stop",
     color=stopType == "ATR" ? color. orange : color.purple,
     linewidth=2,
     style=plot.style_linebr)

plot(ma1Fast ?  fastMA : na, color=color.new(color.blue, 0), linewidth=2, title="MA1", offset=plotOffset)
plot(ma2slow ? slowMA : na, color=color. new(color.orange, 0), linewidth=2, title="MA2", offset=plotOffset)
plot(ma3Show ? ma3 : na, color=color.new(color. green, 0), linewidth=2, title="MA3")
plot(ma4Show ? ma4 : na, color=color.new(color.red, 0), linewidth=2, title="MA4")
plot(ma5Show ? ma5 : na, color=color.new(color.fuchsia, 0), linewidth=2, title="MA5")
plot(ma6Show ? ma6 : na, color=color.new(color.navy, 0), linewidth=2, title="MA6")
plot(ma7Show ? ma7 : na, color=color.new(color. blue, 0), linewidth=2, title="MA7")

// Reset flags when position closes
if (strategy.position_size == 0)
    isLong := false
    isShort := false
    trailPrice := na
    swingLowCount := 0
    swingHighCount := 0

