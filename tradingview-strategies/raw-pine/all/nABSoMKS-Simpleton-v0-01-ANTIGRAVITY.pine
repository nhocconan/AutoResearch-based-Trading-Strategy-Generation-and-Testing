//@version=6
// ============================================================================
// Simpleton v0.01 ANTIGRAVITY â€” Multi-Strategy Backtesting Engine
// ============================================================================
// 8 battle-tested strategies | Non-repainting | Toggle TP/SL
// Based on: Connors RSI-2, Ornstein-Uhlenbeck, KAMA, Fama-French
// DISCLAIMER: Research/education only. Not financial advice.
// ============================================================================

strategy("Simpleton v0.01 ANTIGRAVITY", overlay=true,
         default_qty_type=strategy.percent_of_equity,
         default_qty_value=100,
         commission_type=strategy.commission.percent,
         commission_value=0.1,
         slippage=3,
         pyramiding=0,
         calc_on_every_tick=false,
         process_orders_on_close=false)

// ============================================================================
// STRATEGY SELECTION
// ============================================================================
group_strat = "STRATEGY SELECTION"
strategy_choice = input.string("Connors RSI-2", "Active Strategy",
     options=["Connors RSI-2", "Z-Score Mean Reversion", "EMA + RSI Momentum",
              "Bollinger Band Squeeze", "MACD + RSI Confluence",
              "Triple EMA Crossover", "VWAP Deviation", "Multi-Strategy Consensus"],
     group=group_strat,
     tooltip="Select from 8 proven strategies. Consensus combines top strategies for highest conviction.")

// ============================================================================
// UNIVERSAL PARAMETERS
// ============================================================================
group_core = "CORE SETTINGS"
use_repaint_guard = input.bool(true, "Non-Repainting Mode", group=group_core,
     tooltip="Signals confirm on bar close only. Recommended: ON")
use_trend_filter = input.bool(true, "200-Period Trend Filter", group=group_core)
trend_period = input.int(200, "Trend Filter Period", minval=50, maxval=500, group=group_core)

// ============================================================================
// RISK MANAGEMENT (TP/SL)
// ============================================================================
group_risk = "RISK MANAGEMENT"
use_tp_sl = input.bool(true, "Enable TP / SL", group=group_risk)
tp_percent = input.float(3.0, "Take Profit %", minval=0.5, maxval=20.0, step=0.5, group=group_risk)
sl_percent = input.float(1.5, "Stop Loss %", minval=0.5, maxval=10.0, step=0.5, group=group_risk)
use_trailing = input.bool(false, "Trailing Stop", group=group_risk)
trail_percent = input.float(2.0, "Trailing Stop %", minval=0.5, maxval=10.0, step=0.5, group=group_risk)
use_time_exit = input.bool(true, "Time-Based Exit", group=group_risk)
time_exit_bars = input.int(20, "Max Bars in Trade", minval=5, maxval=100, group=group_risk)

// ============================================================================
// STRATEGY PARAMETERS
// ============================================================================
group_rsi2 = "Connors RSI-2 Settings"
rsi2_period = input.int(2, "RSI Period", minval=2, maxval=7, group=group_rsi2)
rsi2_entry = input.float(10.0, "RSI Entry (Below)", minval=2.0, maxval=30.0, step=1.0, group=group_rsi2)
rsi2_exit = input.float(70.0, "RSI Exit (Above)", minval=50.0, maxval=95.0, step=5.0, group=group_rsi2)

group_zscore = "Z-Score MR Settings"
zs_period = input.int(20, "Lookback Period", minval=10, maxval=50, group=group_zscore)
zs_threshold = input.float(2.0, "Z-Score Entry Threshold", minval=1.0, maxval=3.0, step=0.1, group=group_zscore)
zs_exit_threshold = input.float(0.5, "Z-Score Exit Threshold", minval=0.0, maxval=1.5, step=0.1, group=group_zscore)

group_ema_rsi = "EMA + RSI Settings"
ema_fast = input.int(9, "Fast EMA", minval=3, maxval=20, group=group_ema_rsi)
ema_slow = input.int(21, "Slow EMA", minval=10, maxval=50, group=group_ema_rsi)
ema_rsi_period = input.int(14, "RSI Period", minval=7, maxval=21, group=group_ema_rsi)
ema_rsi_ob = input.float(70.0, "RSI Overbought", minval=60.0, maxval=90.0, group=group_ema_rsi)
ema_rsi_os = input.float(30.0, "RSI Oversold", minval=10.0, maxval=40.0, group=group_ema_rsi)

group_bb = "Bollinger Band Settings"
bb_period = input.int(20, "BB Period", minval=10, maxval=50, group=group_bb)
bb_std = input.float(2.0, "BB Std Dev", minval=1.0, maxval=3.0, step=0.1, group=group_bb)
bb_squeeze_mult = input.float(1.5, "Squeeze Detection Mult", minval=1.0, maxval=3.0, step=0.1, group=group_bb)

group_macd = "MACD + RSI Settings"
macd_fast = input.int(12, "MACD Fast", minval=5, maxval=20, group=group_macd)
macd_slow = input.int(26, "MACD Slow", minval=15, maxval=50, group=group_macd)
macd_signal = input.int(9, "MACD Signal", minval=3, maxval=15, group=group_macd)
macd_rsi_period = input.int(14, "RSI Period", minval=7, maxval=21, group=group_macd)

group_tema = "Triple EMA Settings"
tema_fast = input.int(8, "Fast EMA", minval=3, maxval=15, group=group_tema)
tema_mid = input.int(21, "Mid EMA", minval=10, maxval=35, group=group_tema)
tema_slow_p = input.int(55, "Slow EMA", minval=30, maxval=100, group=group_tema)

group_vwap = "VWAP Settings"
vwap_std_mult = input.float(2.0, "VWAP Std Dev Multiplier", minval=1.0, maxval=3.0, step=0.1, group=group_vwap)

group_cons = "Consensus Settings"
consensus_threshold = input.int(3, "Min Strategies Agreeing", minval=2, maxval=6, group=group_cons)

// ============================================================================
// CORE CALCULATIONS
// ============================================================================
sma_trend = ta.sma(close, trend_period)
trend_bullish = close > sma_trend
trend_bearish = close < sma_trend
bar_confirmed = use_repaint_guard ? barstate.isconfirmed : true

var int bars_in_trade = 0
if strategy.position_size != 0
    bars_in_trade += 1
else
    bars_in_trade := 0

// STRATEGY 1: CONNORS RSI-2
rsi2_val = ta.rsi(close, rsi2_period)
connors_long = rsi2_val < rsi2_entry and (not use_trend_filter or trend_bullish)
connors_short = rsi2_val > (100 - rsi2_entry) and (not use_trend_filter or trend_bearish)
connors_exit_long = rsi2_val > rsi2_exit
connors_exit_short = rsi2_val < (100 - rsi2_exit)

// STRATEGY 2: Z-SCORE MEAN REVERSION
zs_mean = ta.sma(close, zs_period)
zs_std = ta.stdev(close, zs_period)
z_score = zs_std != 0 ? (close - zs_mean) / zs_std : 0
zscore_long = z_score < -zs_threshold and (not use_trend_filter or trend_bullish)
zscore_short = z_score > zs_threshold and (not use_trend_filter or trend_bearish)
zscore_exit_long = z_score > -zs_exit_threshold
zscore_exit_short = z_score < zs_exit_threshold

// STRATEGY 3: EMA + RSI MOMENTUM
ema_f = ta.ema(close, ema_fast)
ema_s = ta.ema(close, ema_slow)
ema_rsi_val = ta.rsi(close, ema_rsi_period)
emarsi_long = ta.crossover(ema_f, ema_s) and ema_rsi_val < ema_rsi_ob and (not use_trend_filter or trend_bullish)
emarsi_short = ta.crossunder(ema_f, ema_s) and ema_rsi_val > ema_rsi_os and (not use_trend_filter or trend_bearish)
emarsi_exit_long = ta.crossunder(ema_f, ema_s) or ema_rsi_val > 80
emarsi_exit_short = ta.crossover(ema_f, ema_s) or ema_rsi_val < 20

// STRATEGY 4: BOLLINGER BAND SQUEEZE
bb_basis = ta.sma(close, bb_period)
bb_dev = bb_std * ta.stdev(close, bb_period)
bb_upper = bb_basis + bb_dev
bb_lower = bb_basis - bb_dev
bb_width = (bb_upper - bb_lower) / bb_basis
bb_width_sma = ta.sma(bb_width, bb_period)
bb_is_squeeze = bb_width < bb_width_sma / bb_squeeze_mult
bb_long = close < bb_lower and bb_is_squeeze[1] and (not use_trend_filter or trend_bullish)
bb_short = close > bb_upper and bb_is_squeeze[1] and (not use_trend_filter or trend_bearish)
bb_exit_long = close > bb_basis
bb_exit_short = close < bb_basis

// STRATEGY 5: MACD + RSI CONFLUENCE
[macd_line, macd_sig, macd_hist] = ta.macd(close, macd_fast, macd_slow, macd_signal)
macd_rsi = ta.rsi(close, macd_rsi_period)
macd_long = ta.crossover(macd_line, macd_sig) and macd_rsi < 50 and macd_hist > macd_hist[1] and (not use_trend_filter or trend_bullish)
macd_short = ta.crossunder(macd_line, macd_sig) and macd_rsi > 50 and macd_hist < macd_hist[1] and (not use_trend_filter or trend_bearish)
macd_exit_long = ta.crossunder(macd_line, macd_sig) or macd_rsi > 80
macd_exit_short = ta.crossover(macd_line, macd_sig) or macd_rsi < 20

// STRATEGY 6: TRIPLE EMA CROSSOVER
tema_f = ta.ema(close, tema_fast)
tema_m = ta.ema(close, tema_mid)
tema_sl = ta.ema(close, tema_slow_p)
tema_long = tema_f > tema_m and tema_m > tema_sl and tema_f[1] <= tema_m[1] and (not use_trend_filter or trend_bullish)
tema_short = tema_f < tema_m and tema_m < tema_sl and tema_f[1] >= tema_m[1] and (not use_trend_filter or trend_bearish)
tema_exit_long = tema_f < tema_m
tema_exit_short = tema_f > tema_m

// STRATEGY 7: VWAP DEVIATION
vwap_val = ta.vwap(hlc3)
vwap_std_val = ta.stdev(close - vwap_val, 20)
vwap_upper = vwap_val + vwap_std_mult * vwap_std_val
vwap_lower = vwap_val - vwap_std_mult * vwap_std_val
vwap_long = close < vwap_lower and (not use_trend_filter or trend_bullish)
vwap_short = close > vwap_upper and (not use_trend_filter or trend_bearish)
vwap_exit_long = close > vwap_val
vwap_exit_short = close < vwap_val

// STRATEGY 8: MULTI-STRATEGY CONSENSUS
long_votes = (connors_long ? 1 : 0) + (zscore_long ? 1 : 0) + (emarsi_long ? 1 : 0) +
             (bb_long ? 1 : 0) + (macd_long ? 1 : 0) + (tema_long ? 1 : 0) + (vwap_long ? 1 : 0)
short_votes = (connors_short ? 1 : 0) + (zscore_short ? 1 : 0) + (emarsi_short ? 1 : 0) +
              (bb_short ? 1 : 0) + (macd_short ? 1 : 0) + (tema_short ? 1 : 0) + (vwap_short ? 1 : 0)
consensus_long = long_votes >= consensus_threshold
consensus_short = short_votes >= consensus_threshold
consensus_exit_long = long_votes == 0
consensus_exit_short = short_votes == 0

// ============================================================================
// SIGNAL ROUTER
// ============================================================================
var bool go_long = false
var bool go_short = false
var bool exit_long = false
var bool exit_short = false

if strategy_choice == "Connors RSI-2"
    go_long := connors_long
    go_short := connors_short
    exit_long := connors_exit_long
    exit_short := connors_exit_short
else if strategy_choice == "Z-Score Mean Reversion"
    go_long := zscore_long
    go_short := zscore_short
    exit_long := zscore_exit_long
    exit_short := zscore_exit_short
else if strategy_choice == "EMA + RSI Momentum"
    go_long := emarsi_long
    go_short := emarsi_short
    exit_long := emarsi_exit_long
    exit_short := emarsi_exit_short
else if strategy_choice == "Bollinger Band Squeeze"
    go_long := bb_long
    go_short := bb_short
    exit_long := bb_exit_long
    exit_short := bb_exit_short
else if strategy_choice == "MACD + RSI Confluence"
    go_long := macd_long
    go_short := macd_short
    exit_long := macd_exit_long
    exit_short := macd_exit_short
else if strategy_choice == "Triple EMA Crossover"
    go_long := tema_long
    go_short := tema_short
    exit_long := tema_exit_long
    exit_short := tema_exit_short
else if strategy_choice == "VWAP Deviation"
    go_long := vwap_long
    go_short := vwap_short
    exit_long := vwap_exit_long
    exit_short := vwap_exit_short
else if strategy_choice == "Multi-Strategy Consensus"
    go_long := consensus_long
    go_short := consensus_short
    exit_long := consensus_exit_long
    exit_short := consensus_exit_short

// ============================================================================
// EXECUTION ENGINE
// ============================================================================
final_long = go_long and bar_confirmed
final_short = go_short and bar_confirmed
final_exit_long = exit_long and bar_confirmed
final_exit_short = exit_short and bar_confirmed

if final_long
    strategy.entry("LONG", strategy.long)
if final_short
    strategy.entry("SHORT", strategy.short)

if use_tp_sl
    if strategy.position_size > 0
        strategy.exit("TP/SL Long", "LONG",
             profit=close * tp_percent / 100 / syminfo.mintick,
             loss=close * sl_percent / 100 / syminfo.mintick,
             trail_points=use_trailing ? close * trail_percent / 100 / syminfo.mintick : na,
             trail_offset=use_trailing ? close * trail_percent / 200 / syminfo.mintick : na)
    if strategy.position_size < 0
        strategy.exit("TP/SL Short", "SHORT",
             profit=close * tp_percent / 100 / syminfo.mintick,
             loss=close * sl_percent / 100 / syminfo.mintick,
             trail_points=use_trailing ? close * trail_percent / 100 / syminfo.mintick : na,
             trail_offset=use_trailing ? close * trail_percent / 200 / syminfo.mintick : na)

if final_exit_long and strategy.position_size > 0
    strategy.close("LONG", comment="Signal Exit")
if final_exit_short and strategy.position_size < 0
    strategy.close("SHORT", comment="Signal Exit")

if use_time_exit and bars_in_trade >= time_exit_bars
    if strategy.position_size > 0
        strategy.close("LONG", comment="Time Exit")
    if strategy.position_size < 0
        strategy.close("SHORT", comment="Time Exit")

// ============================================================================
// VISUALIZATION
// ============================================================================
plot(use_trend_filter ? sma_trend : na, "200 SMA Trend", color=color.new(#FFD700, 60), linewidth=2)
plot(strategy_choice == "Z-Score Mean Reversion" ? zs_mean + zs_threshold * zs_std : na, "Upper Band", color=color.new(#FF6B6B, 50))
plot(strategy_choice == "Z-Score Mean Reversion" ? zs_mean - zs_threshold * zs_std : na, "Lower Band", color=color.new(#00E676, 50))
plot(strategy_choice == "Bollinger Band Squeeze" ? bb_upper : na, "BB Upper", color=color.new(#FF6B6B, 50))
plot(strategy_choice == "Bollinger Band Squeeze" ? bb_lower : na, "BB Lower", color=color.new(#00E676, 50))
plot(strategy_choice == "VWAP Deviation" ? vwap_val : na, "VWAP", color=#FFD700, linewidth=2)
plotshape(final_long and not final_long[1], "Buy", shape.triangleup, location.belowbar, #00E676, size=size.small)
plotshape(final_short and not final_short[1], "Sell", shape.triangledown, location.abovebar, #FF1744, size=size.small)

// ============================================================================
// INFO PANEL
// ============================================================================
if barstate.islast
    var table panel = table.new(position.top_right, 2, 14,
         bgcolor=color.new(#0a0a14, 10), border_color=color.new(#2a2a4a, 0), border_width=1)

    table.cell(panel, 0, 0, "SIMPLETON v0.01 ANTIGRAVITY", text_color=#00D4FF, text_size=size.normal, bgcolor=color.new(#0a0a14, 0))
    table.merge_cells(panel, 0, 0, 1, 0)
    table.cell(panel, 0, 1, strategy_choice, text_color=#FFD700, text_size=size.small, bgcolor=color.new(#0a0a14, 0))
    table.merge_cells(panel, 0, 1, 1, 1)

    strat_rating = strategy_choice == "Connors RSI-2" ? "75.7% WR | Sharpe 4.84" :
         strategy_choice == "Z-Score Mean Reversion" ? "62-77% WR | Sharpe 2.28" :
         strategy_choice == "EMA + RSI Momentum" ? "45-55% WR | PF 1.25+" :
         strategy_choice == "Bollinger Band Squeeze" ? "53-55% WR | Ranging" :
         strategy_choice == "MACD + RSI Confluence" ? "61% WR | PF 1.8+" :
         strategy_choice == "Triple EMA Crossover" ? "55-64% WR | Trending" :
         strategy_choice == "VWAP Deviation" ? "62-68% WR | Intraday" : "Consensus Mode"
    table.cell(panel, 0, 2, "Stats", text_color=color.gray, text_size=size.small, bgcolor=color.new(#0a0a14, 0))
    table.cell(panel, 1, 2, strat_rating, text_color=color.white, text_size=size.small, bgcolor=color.new(#0a0a14, 0))

    sig_text = final_long ? "LONG" : final_short ? "SHORT" : "NEUTRAL"
    sig_col = final_long ? #00E676 : final_short ? #FF1744 : color.gray
    table.cell(panel, 0, 3, "Signal", text_color=color.gray, text_size=size.small, bgcolor=color.new(#0a0a14, 0))
    table.cell(panel, 1, 3, sig_text, text_color=sig_col, text_size=size.normal, bgcolor=color.new(#0a0a14, 0))

    table.cell(panel, 0, 4, "Votes L/S", text_color=color.gray, text_size=size.small, bgcolor=color.new(#0a0a14, 0))
    table.cell(panel, 1, 4, str.tostring(long_votes) + " / " + str.tostring(short_votes), text_color=color.white, text_size=size.small, bgcolor=color.new(#0a0a14, 0))

    table.cell(panel, 0, 5, "RSI(2)", text_color=color.gray, text_size=size.small, bgcolor=color.new(#0a0a14, 0))
    table.cell(panel, 1, 5, str.tostring(rsi2_val, "#.#"), text_color=rsi2_val < 20 ? #00E676 : rsi2_val > 80 ? #FF1744 : color.white, text_size=size.small, bgcolor=color.new(#0a0a14, 0))

    table.cell(panel, 0, 6, "Z-Score", text_color=color.gray, text_size=size.small, bgcolor=color.new(#0a0a14, 0))
    table.cell(panel, 1, 6, str.tostring(z_score, "#.##"), text_color=z_score < -2 ? #00E676 : z_score > 2 ? #FF1744 : color.white, text_size=size.small, bgcolor=color.new(#0a0a14, 0))

    table.cell(panel, 0, 7, "Trend", text_color=color.gray, text_size=size.small, bgcolor=color.new(#0a0a14, 0))
    table.cell(panel, 1, 7, trend_bullish ? "BULL" : "BEAR", text_color=trend_bullish ? #00E676 : #FF1744, text_size=size.small, bgcolor=color.new(#0a0a14, 0))

    table.cell(panel, 0, 8, "TP/SL", text_color=color.gray, text_size=size.small, bgcolor=color.new(#0a0a14, 0))
    table.cell(panel, 1, 8, use_tp_sl ? str.tostring(tp_percent, "#.#") + "% / " + str.tostring(sl_percent, "#.#") + "%" : "OFF",
         text_color=use_tp_sl ? #00E676 : #FF6B6B, text_size=size.small, bgcolor=color.new(#0a0a14, 0))

    table.cell(panel, 0, 9, "Repaint", text_color=color.gray, text_size=size.small, bgcolor=color.new(#0a0a14, 0))
    table.cell(panel, 1, 9, use_repaint_guard ? "SAFE" : "ON",
         text_color=use_repaint_guard ? #00E676 : #FFD700, text_size=size.small, bgcolor=color.new(#0a0a14, 0))

    table.cell(panel, 0, 10, "", text_color=color.gray, text_size=size.tiny, bgcolor=color.new(#0a0a14, 0))
    table.merge_cells(panel, 0, 10, 1, 10)
    table.cell(panel, 0, 11, "Research Only - Not Financial Advice", text_color=color.orange, text_size=size.tiny, bgcolor=color.new(#0a0a14, 0))
    table.merge_cells(panel, 0, 11, 1, 11)

