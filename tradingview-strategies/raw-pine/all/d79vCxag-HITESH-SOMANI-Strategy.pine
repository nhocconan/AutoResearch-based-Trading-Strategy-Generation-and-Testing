//@version=5
strategy("HITESH SOMANI Strategy (1:3 RR)", overlay=true, margin_long=100, default_qty_type=strategy.percent_of_equity, default_qty_value=10)

// Inputs
emaLength = input.int(9, "EMA Length")
riskReward = input.float(3.0, "Risk:Reward Ratio", step=0.1)

// Calculate EMA
ema9 = ta.ema(close, emaLength)

// Condition: Candle closes above EMA9
closeAboveEMA = close > ema9

// Store conditions
var float entryPrice = na
var float stopLoss = na
var float takeProfit = na

// Define potential long signal
if closeAboveEMA
    // If next candle breaks this candle's high → entry
    longCondition = ta.crossover(high, high[1]) and close[1] > ema9[1]
    if longCondition
        entryPrice := high
        stopLoss := math.min(low[1], low[2]) // Below previous 2 candles
        risk = entryPrice - stopLoss
        takeProfit := entryPrice + (risk * riskReward)
        strategy.entry("Buy", strategy.long, comment="Buy Signal")
        strategy.exit("TP/SL", "Buy", stop=stopLoss, limit=takeProfit)

// Plot EMA
plot(ema9, title="EMA9", color=color.new(color.yellow, 0))

// Plot stop loss and take profit levels
plot(stopLoss, "Stop Loss", color=color.new(color.red, 50))
plot(takeProfit, "Take Profit", color=color.new(color.green, 50))

