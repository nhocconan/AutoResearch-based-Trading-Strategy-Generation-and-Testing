ZERO_PLOT           = plot      (   00             , transp=25 , color=CLOSE_COLOR      , linewidth=1  , style=line                 , title="CLOSE"                 , editable=true)
//                    CLOSE
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
CLOSE_PLOT          = plot      (   close          , transp=25 , color=CLOSE_COLOR      , linewidth=1  , style=line                 , title="CLOSE"                 , editable=true)
//                    SMA FAST
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
SMA_PLOT_FAST       = plot      (   SMA_EMA_FAST   , transp=25 , color=XSMA_PHASE_COLOR , linewidth=2  , style=line                 , title="SMA FAST"              , editable=true)
//                    XSMA OFFSET TREND
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
XSMA_PLOT           = plot      (   XSMA            , transp=25 , color=XSMA_ANGLE_COLOR , linewidth=1  , style=line                 , title="XSMA ANGLE"            , editable=true)
//XSMA_HIGH_PLOT   = plot      (   XSMA_HIGH          , transp=25 , color=white            , linewidth=1  , style=line                 , title="XSMA HIGH"          , editable=true)
//XSMA_LOW_PLOT    = plot      (   XSMA_LOW           , transp=25 , color=white            , linewidth=1  , style=line                 , title="XSMA LOW"           , editable=true)
//                    SMA / XSMA :: RMI FILLER
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
SMA_DIR_DOWN        =               SMA_DIR_FAST    < 0         ? 1     : 0
SMA_DIR_UP          =               SMA_DIR_FAST    > 0         ? 1     : 0

RMI_O_HIGH_OUT      = iff       (   RMI_O_HIGH      and SMA_DIR_DOWN    , 1     , 0)
RMI_U_LOW_OUT       = iff       (   RMI_U_LOW       and SMA_DIR_UP      , 1     , 0)

RMI_O_HIGH_IN       = iff       (abs(1              - RMI_O_HIGH_OUT)   and RMI_O_HIGH  , 1     , 0)
RMI_U_LOW_IN        = iff       (abs(1              - RMI_U_LOW_OUT)    and RMI_U_LOW   , 1     , 0)

RMI_COLOR_FILL      =               RMI_O_HIGH_IN               ? oker  : RMI_O_HIGH_OUT    ? reds  : RMI_U_LOW_IN              ? cyan : RMI_U_LOW_OUT  ? blues     : K555
ARMI_COLOR_FILL     =               ARMI_O_HIGH and RMI_O_HIGH  ? oker  : ARMI_O_HIGH       ? dreds : ARMI_U_LOW and RMI_U_LOW  ? cyan : ARMI_U_LOW     ? dblues    :  K111

fill                ( XSMA_PLOT ,   SMA_PLOT_FAST   , transp=75 , color=RMI_COLOR_FILL                                              , title='RMI FILL'              , editable=false)
fill                ( CLOSE_PLOT,   SMA_PLOT_FAST   , transp=25 , color=ARMI_COLOR_FILL                                             , title='ARMI FILL'             , editable=false)

