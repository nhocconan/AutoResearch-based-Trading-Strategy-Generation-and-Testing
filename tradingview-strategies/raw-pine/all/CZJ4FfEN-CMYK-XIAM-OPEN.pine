//AM_AMOUNT           = input(defval=1        , minval=1                          , type=integer  , title="AMOUNT PER ENTRY"          )
//AM_MARGIN           = input(defval=1        , minval=1      , maxval=5          , type=integer  , title="MARGIN OF ENTRY"           )

//                                                                              CALCULATIONS
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
//                                                              SMA PHASE
//▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒
//                    TREND BY OFFSET SMA
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
XSMA                = sma       (   SMA_SOURCE_CLOSE    , XSMA_PHASE)
XSMA_OFFSET         = offset    (   SMA_SOURCE_CLOSE    , XSMA_PHASE    / 2)
//                    JITTER & VARIANCE
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
XSMA_DIFFERENCE     =               XSMA_OFFSET         - XSMA
XSMA_HIGHEST        = highest   (   XSMA_DIFFERENCE     , XSMA_PHASE    * 2)
XSMA_LOWEST         = lowest    (   XSMA_DIFFERENCE     , XSMA_PHASE    * 2)

JITTER              = sin       (   XSMA_HIGHEST        - XSMA_LOWEST)  / (XSMA_PHASE*(1+close))         // ODD BEHATVIOR REDO
SPREAD              = change    (   XSMA                , XSMA_PHASE)
VARIANCE            =               SPREAD              * 2
//                    BANDS
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
XSMA_HIGH           =               XSMA                + XSMA_HIGHEST
XSMA_LOW            =               XSMA                + XSMA_LOWEST 
XSMA_HL2            =           (   XSMA_HIGH           + XSMA_LOW)     / 2
//                    TREND BY OFFSET OPEN / CLOSE
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
XSMA_OFFSET_OPEN    = offset    (   XSMA                , 0)
XSMA_OFFSET_CLOSE   = offset    (   SMA_SOURCE_CLOSE    , XSMA_PHASE    / 2)                           // DITVIDING BY 2 :: this is the average factor, not the true factor (true factor variates by angle and momentum of movement within averaging lenght) abs(1+cos(x))Y?
//                    DIRECTION AND ANGLE
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
CLOSE_DIR           = rising    (   SMA_SOURCE_CLOSE    , 2)            ? +1    : falling   (   SMA_SOURCE_CLOSE    , 2)            ? -1    : 0
CLOSE_COLOR         =               CLOSE_DIR           > 0             ? reds  :               CLOSE_DIR           < 0             ? blues : na

SMA_EMA_FAST        = ema       (   SMA_SOURCE_FAST     , SMA_LENGHT_FAST)
SMA_DIR_FAST        = rising    (   SMA_EMA_FAST        , 2)            ? +1    : falling   (   SMA_EMA_FAST        , 2)            ? -1    : 0
SMA_FAST_COLOR      =               SMA_DIR_FAST        > 0             ? reds  :               SMA_DIR_FAST        < 0             ? blues : na

XSMA_ANGLE_COLOR    = change    (   sma(XSMA,XSMA_PHASE), 1)            > (0+(XSMA*JITTER)) ? oker :  change(sma(XSMA,XSMA_PHASE),1) < (0-(XSMA*JITTER)) ? cyan : magenta  // ODD BEHATVIOR REDO

//                                                              MOTVEMENT / FORCE
//▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒
SMA_PRICE               = sma       ( PRICE      , PERIOD)
SMA_VOLUME              = sma       ( VOLUME     , PERIOD)/10000

MOVEMENT                = change    ( SMA_PRICE  , 1)
FORCE                   =             MOVEMENT / offset (     SMA_VOLUME    , 1)
FORCE_SLOW              = sma       ( FORCE                 , SLOW)
FORCE_FAST              = sma       ( FORCE                 , FAST)

//                                                              MOMENTUM
//▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒
//                    RMI PHASE for event detection
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
RMI                 = rmi       (RMI_MOMENTUM           , RMI_LENGHT)
//                    RMI ACTIVE for dip/top selection
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
ARMI                = rmi       (ARMI_MOMENTUM          , ARMI_LENGHT)
//                    RMI TREND for boundary correction
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
//XRMI                = rmi       (XRMI_MOMENTUM          , XRMI_LENGHT)

//                                                                              CONDITIONS
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
//                                                              SMA PHASE
//▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒
//                    XSMA
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
XSMA_XO_OPEN        = crossover (   XSMA                , SMA_SOURCE_OPEN)
XSMA_XU_OPEN        = crossunder(   XSMA                , SMA_SOURCE_OPEN)

XSMA_PHASE_LONG     = fixnan    (iff(XSMA_XO_OPEN       , 1             , iff(XSMA_XU_OPEN      , 0     ,na)))
XSMA_PHASE_SHORT    = fixnan    (iff(XSMA_XU_OPEN       , 1             , iff(XSMA_XO_OPEN      , 0     ,na)))

XSMA_PHASE_COLOR    =               XSMA_PHASE_LONG     > 0             ? oker  : XSMA_PHASE_SHORT      > 0         ? cyan  : na
//                    XSMA OFFSET
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
XSMA_XO_OFFSET      = crossover (sma(XSMA*(1+SPREAD)    , XSMA_PHASE)   , sma(XSMA*(1-SPREAD)   ,XSMA_PHASE))
XSMA_XU_OFFSET      = crossunder(sma(XSMA*(1+SPREAD)    , XSMA_PHASE)   , sma(XSMA*(1-SPREAD)   ,XSMA_PHASE))

XSMA_OFFSET_LONG    = fixnan    (iff(XSMA_XO_OFFSET     , 1             , iff(XSMA_XU_OFFSET    , 0     ,na)))
XSMA_OFFSET_SHORT   = fixnan    (iff(XSMA_XU_OFFSET     , 1             , iff(XSMA_XO_OFFSET    , 0     ,na)))
    
XSMA_OFFSET_COLOR   =               XSMA_OFFSET_LONG    > 0             ? oker  : XSMA_OFFSET_SHORT     > 0         ? cyan : na

//                                                              MOVEMENT / FORCE
//▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒
REVERSAL                = cross     ( FORCE_FAST            , FORCE_SLOW )

PHASE_BULL_INIT         = crossover ( FORCE_FAST            , FORCE_SLOW ) and ( FORCE_SLOW            < 0 )
PHASE_BULL_EXIT         = crossunder( FORCE_FAST            , FORCE_SLOW ) and ( FORCE_SLOW            < 0 )

PHASE_BEAR_INIT         = crossunder( FORCE_FAST            , FORCE_SLOW ) and ( FORCE_SLOW            > 0 )
PHASE_BEAR_EXIT         = crossover ( FORCE_FAST            , FORCE_SLOW ) and ( FORCE_SLOW            > 0 )


//                    MF PHASE SWITCH
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
BULL                    = fixnan    ( PHASE_BULL_INIT       ? 1 :                PHASE_BULL_EXIT ? 0 :           PHASE_BEAR_INIT ? 0 :           na)
BEAR                    = fixnan    ( PHASE_BEAR_INIT       ? 1 :                PHASE_BEAR_EXIT ? 0 :           PHASE_BULL_INIT ? 0 :           na)

//                    MF SWEEP
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
BULL_EXIT_SWEEP         = sma       ( PHASE_BULL_EXIT       ? 1 :   0           , EXIT_SWEEP)    > 0    and     BULL != 1 ? 1 : 0
BULL_EXIT_SWEEP_OUT     = change    ( BULL_EXIT_SWEEP       , 1 ) < 0
BULL_EXIT_FINALIZE      = offset    ( BULL_EXIT_SWEEP_OUT   ? 1 : 0,1)          > 0                     and     BULL != 1 ? 1 : 0

BEAR_EXIT_SWEEP         = sma       ( PHASE_BEAR_EXIT       ? 1 : 0,EXIT_SWEEP) > 0                     and     BEAR != 1 ? 1 : 0
BEAR_EXIT_SWEEP_OUT     = change    ( BEAR_EXIT_SWEEP       , 1 ) < 0
BEAR_EXIT_FINALIZE      = offset    ( BEAR_EXIT_SWEEP_OUT   ? 1 : 0,1)          > 0                     and BEAR != 1 ? 1 : 0

//                                                              MOMENTUM
//▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒
//                    RMI PHASE for event detection
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
RMI_XO_HIGH         = crossover (   RMI                 , RMI_HIGH  ) //      + XRMI)
RMI_XU_HIGH         = crossunder(   RMI                 , RMI_HIGH  ) //     + XRMI)
RMI_XO_LOW          = crossover (   RMI                 , RMI_LOW   ) //      + XRMI)
RMI_XU_LOW          = crossunder(   RMI                 , RMI_LOW   ) //     + XRMI)

RMI_O_HIGH          =               RMI                 > (RMI_HIGH ) //  + XRMI)
RMI_U_LOW           =               RMI                 < (RMI_LOW  ) //      + XRMI)
//                    RMI ACTIVE for dip/top selection
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
ARMI_O_HIGH         =               ARMI                > (ARMI_HIGH) //    + XRMI)
ARMI_U_LOW          =               ARMI                < (ARMI_LOW ) //    + XRMI)

//                                                                              DIFFERENTIATORS
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
//                                                              SMA PHASE
//▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒


//                                                              MOMENTUM
//▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒
//                    RMI PHASE INIT
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░ 
RMI_IN_HIGH         = fixnan    (iff(RMI_XO_LOW         , 1             , iff(RMI_XU_HIGH   , 0, na)))
RMI_IN_LOW          = fixnan    (iff(RMI_XU_HIGH        , 1             , iff(RMI_XO_LOW    , 0, na)))

RMI_IV_HIGH         = fixnan    (iff(RMI_IN_HIGH        and RMI_XO_HIGH , close             , na))
RMI_IV_LOW          = fixnan    (iff(RMI_IN_LOW         and RMI_XU_LOW  , close             , na))
//                    RMI PHASE END
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
RMI_EV_HIGH         = fixnan    (iff(RMI_XU_HIGH        , close         , na))
RMI_EV_LOW          = fixnan    (iff(RMI_XO_LOW         , close         , na))
//                    RMI PHASE LARGEST
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
///////////////////// ON AND LARGER THAN INIT     VALUE
RMI_LI_HIGH         = fixnan    (iff(RMI_IN_HIGH        , close         , iff(RMI_IV_HIGH   < close, close, na)))
RMI_LI_LOW          = fixnan    (iff(RMI_IN_LOW         , close         , iff(RMI_IV_LOW    > close, close, na)))

///////////////////// LARGER THAN ANY PREVIOUS    CONDITION
RMI_LX_HIGH         =               RMI_LI_HIGH         >= highest  (     RMI_LI_HIGH       , RMI_SWEEP)
RMI_LX_LOW          =               RMI_LI_LOW          <= lowest   (     RMI_LI_LOW        , RMI_SWEEP)

///////////////////// LARGER THAN ANY PREVIOUS    VALUE
RMI_LC_HIGH         = fixnan    (iff(RMI_LX_HIGH        , RMI_LI_HIGH   , na))
RMI_LC_LOW          = fixnan    (iff(RMI_LX_LOW         , RMI_LI_LOW    , na))

///////////////////// ONLY OVER AND UNDER         CONDITION
RMI_LV_HIGH         = fixnan    (iff(RMI_O_HIGH         , RMI_LC_HIGH   , na))
RMI_LV_LOW          = fixnan    (iff(RMI_U_LOW          , RMI_LC_LOW    , na))

///////////////////// NOCHANGE         CONDITION
RMI_LN_HIGH         = iff(change(RMI_LV_HIGH,1) > 0,0,1)
RMI_LN_LOW          = iff(change(RMI_LV_LOW,1) > 0,0,1)

    
//                                                                              PLACEMENT VARIABLES
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
//                                                              SMA PHASE
//▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒


//                                                              MOMENTUM
//▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒
RMI_IVLV_HIGH       =           (   RMI_IV_HIGH         + RMI_LV_HIGH)  / 2
RMI_IVLV_HIGH_SMA   = sma       (   RMI_IVLV_HIGH       , SMA_LENGHT_FAST)

RMI_IVLV_LOW        =           (   RMI_IV_LOW          + RMI_LV_LOW)   / 2
RMI_IVLV_LOW_SMA    = sma       (   RMI_IVLV_LOW        , SMA_LENGHT_FAST)

