//                                                                              FUNCTIONS
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
//                                                              RMI
//▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒ 
rmi(MOMENTUM,LENGHT)=>
    INC             = ema   (max(close              - close[MOMENTUM]   , 0)    , LENGHT)
    DEC             = ema   (max(close[MOMENTUM]    - close             , 0)    , LENGHT)
    RMI             = DEC   == 0    ? 0     : 50 - 100 / (1     + INC / DEC)

//                                                                              INPUTS
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
//                                                              SMA PHASE
//▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒                                          
XSMA_PHASE          = input(defval=240                                          , type=integer  , title="XSMA PHASE FOR OFFSET"     )
SMA_SOURCE_CLOSE    = close
SMA_SOURCE_OPEN     = open
SMA_SOURCE_FAST     = close
SMA_LENGHT_FAST     = input(defval=21       , minval=1                                          , title="SMA EMA FAST"              )

//                                                              MOVEMENT / FORCE
//▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒
PRICE               = SMA_SOURCE_CLOSE
CLEANVOLUME         = input     (defval=open                                        , type=source   , title="CLEANSIGNAL ◊ VOLUME SOURCE" )
USECLEANNO          = input     (defval=true                                        , type=bool     , title="USE TICKER VOLUME INSTEAD" )
PERIOD              = input     (defval=250     , minval=1                          , type=integer  , title="PERIOD"        )
SLOW                = input     (defval=250     , minval=1                          , type=integer  , title="SLOW"          )
FAST                = input     (defval=130     , minval=1                          , type=integer  , title="FAST"          )

EXIT_SWEEP          = input     (defval=200     , minval=1      , maxval=500        , type=integer  , title="EXIT ORDER SWEEP LENGHT"   )

VOLUME              = iff       (USECLEANNO     , volume        , CLEANVOLUME)
//                                                              MOMENTUM
//▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒
RMI_SWEEP           = EXIT_SWEEP
//                    RMI TREND for boundary correction
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
//XRMI_LENGHT         = input(defval=2500     , minval=1                          , type=integer  , title="RMI TREND EMA LENGHT"      )
//XRMI_MOMENTUM       = input(defval=5        , minval=1                                          , title="RMI TREND MOMENTUM"        )
//                    RMI PHASE for event detection
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
RMI_LENGHT          = input(defval=250      , minval=1                          , type=integer  , title="RMI EMA LENGHT"            )
RMI_MOMENTUM        = input(defval=20       , minval=1                                          , title="RMI MOMENTUM"              )
//                    RMI ACTIVE for dip/top selection
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
ARMI_LENGHT         = input(defval=20       , minval=1                          , type=integer  , title="RMI ACTIVE EMA LENGHT"     )
ARMI_MOMENTUM       = input(defval=5        , minval=1                                          , title="RMI ACTIVE MOMENTUM"       )
//                    RMI PHASE     BOUNDARIES
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
RMI_HIGH            = input(defval=15       , minval=00     , maxval=50         , type=integer  , title="RMI PHASE BOUNDARY HIGH"   )
RMI_LOW             = input(defval=-15      , minval=-50    , maxval=00         , type=integer  , title="RMI PHASE BOUNDARY LOW"    )
//                    RMI ACTITVE   BOUNDARIES
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
ARMI_HIGH           = input(defval=40       , minval=00     , maxval=50         , type=integer  , title="RMI ACTIVE BOUNDARY HIGH"  )
ARMI_LOW            = input(defval=-40      , minval=-50    , maxval=00         , type=integer  , title="RMI ACTIVE BOUNDARY LOW"   )

//                                                              ASSET MANAGEMENT
//▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒
