//@version=3
strategy("BTC strategy",overlay=true,calc_on_every_tick=false,default_qty_type=strategy.percent_of_equity,default_qty_value=100,initial_capital=1000000)

rsi_threshold=input(31)
rsi_length = input(15)
srsi_length = input(10)
srsi_smooth = input(4)
srsi_sell_threshold = input(61)
length=input(17)
dma_signal_threshold=input(-1)
fastLength = input(11)
slowlength = input(18)
MACDLength = input(6)
MACD_signal_threshold = input(-2)
short_loss_tol = input(8)
long_loss_tol = input(6)
ema_length = input(100)

FromMonth = input(defval = 1, title = "From Month", minval = 1, maxval = 12)
FromDay   = input(defval = 1, title = "From Day", minval = 1, maxval = 31)
FromYear  = input(defval = 2017, title = "From Year", minval = 2013)
ToMonth   = input(defval = 5, title = "To Month", minval = 1, maxval = 12)
ToDay     = input(defval = 5, title = "To Day", minval = 1, maxval = 31)
ToYear    = input(defval = 2119, title = "To Year", minval = 2010)

price= close //security(tickerid, 'D', close)
price4=security(tickerid, '4h', close)
ohlc=ohlc4 //ohlc4 //security(tickerid, 'D', ohlc4)

stop_level_long = strategy.position_avg_price * (1 - long_loss_tol/100.0)
stop_level_short = strategy.position_avg_price * (1 + short_loss_tol/100.0)

//strategy.risk.max_drawdown(50, strategy.percent_of_equity) 

//Compute MACD 

em = price-ema(price,ema_length)

MACD = ema(price, fastLength) - ema(price, slowlength)
aMACD = ema(MACD, MACDLength)
delta = MACD - aMACD




//RSI and stochastic RSI 
rs =rsi(price, rsi_length)
k = sma(stoch(rs, rs, rs, srsi_length), srsi_smooth)


//SMA 
norm =sma(ohlc,length)
threshold = price - norm   

//Time window for testing 
start     = timestamp(FromYear, FromMonth, FromDay, 00, 00)  // backtest start window
finish    = timestamp(ToYear, ToMonth, ToDay, 23, 59)        // backtest finish window
window()  => time >= start and time <= finish ? true : false // create function "within window of time"

price_now() => price=security(tickerid, 'D', close) 


// buy/sell signals setup 

buy = ((crossover(delta,MACD_signal_threshold) or crossover(rs,rsi_threshold)) and k<srsi_sell_threshold) 
sell = (crossunder(delta,0) or crossunder(threshold,dma_signal_threshold) and k>srsi_sell_threshold)

decimal_odds() => strategy.wintrades / strategy.closedtrades

// === EXECUTION ===
strategy.entry("L", strategy.long, when = window() and buy)
strategy.close("L",when = (window() and sell))
strategy.entry("S", strategy.short, when = (window() and sell))
strategy.close("S",when = window() and buy)
strategy.exit("stop loss long", from_entry = "L", stop = stop_level_long)
strategy.exit("stop loss short", from_entry = "S", stop = stop_level_short)


//bgcolor( buy ? green : sell ? red : white, transp=20)

