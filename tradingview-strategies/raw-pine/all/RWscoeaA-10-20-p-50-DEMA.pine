//─────────────────────────────────────────────
// BACKGROUND COLORS
//─────────────────────────────────────────────
// Green background when Daily 10 EMA > Daily 20 EMA AND intraday price > Daily 50 EMA
green_condition = ema10 > ema20 and close > ema50
bgcolor(green_condition ? color.new(color.green, 90) : na, title="Bullish Background")

// Red background when Daily 10 EMA < Daily 20 EMA AND intraday price < Daily 50 EMA
red_condition = ema10 < ema20 and close < ema50
bgcolor(red_condition ? color.new(color.red, 90) : na, title="Bearish Background")

