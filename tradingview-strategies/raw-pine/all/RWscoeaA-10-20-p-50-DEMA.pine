//         sl_info = use_stop_loss and not na(sl_long) ? "\nStop Loss: @" + str.tostring(sl_long, "#.##") + "$" + sl_pips_str : ""
//         tp_info = use_take_profit and not na(tp_long) ? "\nTake Profit: @" + str.tostring(tp_long, "#.##") + "$" : ""
//         exit_params = "\n\nstrategy.exit() params:\ntrail_price=" + str.tostring(trailing_stop_activation_price, "#.####") + "\ntrail_offset=" + str.tostring(trail_offset_long_atr_cents, "#") + " cents ($" + str.tostring(trail_offset_long_atr, "#.####") + ")"
//         exit_params := exit_params + (use_stop_loss and not na(sl_long) ? "\nstop=" + str.tostring(sl_long, "#.####") : "\nstop=na")
//         exit_params := exit_params + (use_take_profit and not na(tp_long) ? "\nlimit=" + str.tostring(tp_long, "#.####") : "\nlimit=na")
//         label_text = "Setup Trail Stop\nCurrent Price: " + str.tostring(close, "#.##") + "$\nActivation Price: " + str.tostring(trailing_stop_activation_price, "#.##") + "$\nTrail Offset: " + str.tostring(trail_offset_long_atr, "#.##") + "$" + trail_offset_display + sl_info + tp_info + exit_params + "\nATR: " + str.tostring(trail_offset_long_atr, "#.####")
//         label_y = high * (1 + label_offset_pct / 200.0)
//         label.new(bar_index, label_y, label_text, color=color.new(#FF69B4, 0), textcolor=color.black, style=label.style_label_down, size=size.normal)

// if use_trailing_stop_atr and not use_trailing_stop_pct and strategy.position_size < 0 and not na(lowest_price_short) and not na(atr_smoothed_x5)
//     trail_offset_short_atr = atr_smoothed_x5 * (trailing_stop_atr_multiplier / 100.0)
//     trail_offset_short_atr_cents = math.round(trail_offset_short_atr * 100.0)
//     if use_stop_loss or use_take_profit
//         strategy.exit("Short Trailing", "Short", trail_price=lowest_price_short, trail_offset=trail_offset_short_atr_cents, stop=use_stop_loss ? sl_short : na, limit=use_take_profit ? tp_short : na, comment_trailing="Trail Stop ATR", comment_loss=use_stop_loss ? "Stop Loss" : na, comment_profit=use_take_profit ? "Take Profit" : na)
//     else
//         strategy.exit("Short Trailing", "Short", trail_price=lowest_price_short, trail_offset=trail_offset_short_atr_cents, comment_trailing="Trail Stop ATR")
//     trailing_stop_set_short := true
//     if not prev_trailing_stop_set_short
//         pip_size = 0.0001
//         sl_distance_pips = use_stop_loss and not na(sl_short) ? math.floor((sl_short - close) / pip_size) : na
//         sl_pips_str = na(sl_distance_pips) ? "" : " (" + str.tostring(sl_distance_pips, "#") + " pips)"
//         trail_offset_ticks = math.round(trail_offset_short_atr / syminfo.mintick)
//         trail_offset_pips = math.floor(trail_offset_short_atr / pip_size)
//         trail_offset_display = " (" + str.tostring(trail_offset_ticks, "#") + " ticks, " + str.tostring(trail_offset_pips, "#") + " pips)"
//         sl_info = use_stop_loss and not na(sl_short) ? "\nStop Loss: @" + str.tostring(sl_short, "#.##") + "$" + sl_pips_str : ""
//         tp_info = use_take_profit and not na(tp_short) ? "\nTake Profit: @" + str.tostring(tp_short, "#.##") + "$" : ""
//         exit_params = "\n\nstrategy.exit() params:\ntrail_price=" + str.tostring(lowest_price_short, "#.####") + "\ntrail_offset=" + str.tostring(trail_offset_short_atr_cents, "#") + " cents ($" + str.tostring(trail_offset_short_atr, "#.####") + ")"
//         exit_params := exit_params + (use_stop_loss and not na(sl_short) ? "\nstop=" + str.tostring(sl_short, "#.####") : "\nstop=na")
//         exit_params := exit_params + (use_take_profit and not na(tp_short) ? "\nlimit=" + str.tostring(tp_short, "#.####") : "\nlimit=na")
//         label_text = "Setup Trail Stop\nCurrent Price: " + str.tostring(close, "#.##") + "$\nActivation Price: " + str.tostring(lowest_price_short, "#.##") + "$\nTrail Offset: " + str.tostring(trail_offset_short_atr, "#.##") + "$" + trail_offset_display + sl_info + tp_info + exit_params + "\nATR: " + str.tostring(atr_value, "#.####")
//         label_y = high * (1 + label_offset_pct / 200.0)
//         label.new(bar_index, label_y, label_text, color=color.new(#FF69B4, 0), textcolor=color.black, style=label.style_label_down, size=size.normal)

// Update previous state for next bar (trailing stop state commented out)
// prev_trailing_stop_set_long := trailing_stop_set_long
// prev_trailing_stop_set_short := trailing_stop_set_short

// Reset flags when position closes
if strategy.position_size == 0
    // prev_trailing_stop_set_long := false
    // prev_trailing_stop_set_short := false
    sl_tp_set_long := false
    sl_tp_set_short := false

// Regular Stop Loss / Take Profit (trailing stops commented out, so always use SL/TP when enabled)
if (use_stop_loss or use_take_profit)
    if (use_stop_loss and use_take_profit)
        strategy.exit("Long Exit",  "Long",  stop=sl_long,  limit=tp_long, comment="SL/TP")
        strategy.exit("Short Exit", "Short", stop=sl_short, limit=tp_short, comment="SL/TP")
    else if (use_stop_loss)
        strategy.exit("Long Exit",  "Long",  stop=sl_long, comment="Stop Loss")
        strategy.exit("Short Exit", "Short", stop=sl_short, comment="Stop Loss")
    else if (use_take_profit)
        strategy.exit("Long Exit",  "Long",  limit=tp_long, comment="Take Profit")
        strategy.exit("Short Exit", "Short", limit=tp_short, comment="Take Profit")
    
    // Create indicator labels for stop loss/take profit when first set
    pip_size = 0.01
    if strategy.position_size > 0 and not sl_tp_set_long
        sl_info = use_stop_loss and not na(sl_long) ? "Stop Loss: @" + str.tostring(sl_long, "#.##") + "$ (" + str.tostring(math.floor((close - sl_long) / pip_size), "#") + " pips)" : ""
        tp_info = use_take_profit and not na(tp_long) ? "Take Profit: @" + str.tostring(tp_long, "#.##") + "$" : ""
        label_text = "Setup Stop Loss/Take Profit\nCurrent Price: " + str.tostring(close, "#.##") + "$"
        if sl_info != ""
            label_text := label_text + "\n" + sl_info
        if tp_info != ""
            label_text := label_text + "\n" + tp_info
        label_y = high * (1 + label_offset_pct / 200.0)
        label.new(bar_index, label_y, label_text, color=color.new(color.blue, 0), textcolor=color.white, style=label.style_label_down, size=size.normal)
        sl_tp_set_long := true
    
    if strategy.position_size < 0 and not sl_tp_set_short
        sl_info = use_stop_loss and not na(sl_short) ? "Stop Loss: @" + str.tostring(sl_short, "#.##") + "$ (" + str.tostring(math.floor((sl_short - close) / pip_size), "#") + " pips)" : ""
        tp_info = use_take_profit and not na(tp_short) ? "Take Profit: @" + str.tostring(tp_short, "#.##") + "$" : ""
        label_text = "Setup Stop Loss/Take Profit\nCurrent Price: " + str.tostring(close, "#.##") + "$"
        if sl_info != ""
            label_text := label_text + "\n" + sl_info
        if tp_info != ""
            label_text := label_text + "\n" + tp_info
        label_y = high * (1 + label_offset_pct / 200.0)
        label.new(bar_index, label_y, label_text, color=color.new(color.blue, 0), textcolor=color.white, style=label.style_label_down, size=size.normal)
        sl_tp_set_short := true

// Entries (processed after exits)
// Only allow entries if no position was closed today AND price has moved enough from exit price
// Double-check position size right before entry (strategy.position_size check in longCondition should be sufficient with process_orders_on_close=true)

// Debug: Show why entry is blocked if basic condition is met but entry doesn't happen
basic_long_condition_met = longCondition and useLong and within_date_range and not timeframe_too_low
if basic_long_condition_met and strategy.position_size == 0 and not (longOK and can_open_new_position_long and strategy.position_size == 0)
    debug_text = "Entry Blocked"
    if not can_open_new_position_day
        debug_text := debug_text + "\nSame day block"
    if not price_moved_enough_long
        debug_text := debug_text + "\nPrice not moved enough"
    if prevent_same_bar_reentry and exited_with_trailing_stop_long_this_bar
        debug_text := debug_text + "\nSame bar exit"
    label.new(bar_index, low * 0.98, debug_text, color=color.yellow, textcolor=color.black, style=label.style_label_up, size=size.small)

if (longOK and can_open_new_position_long and strategy.position_size == 0)
    // Increment trade ID counter (matches TradingView's sequential trade numbering)
    trade_id_counter += 1
    trade_id_str = "#" + str.tostring(trade_id_counter)
    // Calculate position size based on equity and long position size percentage
    equity_to_use = strategy.equity * (position_size_pct_long / 100.0)
    qty = math.floor(equity_to_use / close)
    strategy.entry("Long", strategy.long, qty=qty, comment=" ") // comment empty string is to remove the dupplicate "Long" that we have in the signal indicator.
    // Use percentage-based offset that scales with price (consistent across zoom levels)
    label_y_long = low * (1 - label_offset_pct / 100.0)
    // Add debug info: threshold and last exit price (always calculate, even if filter is disabled)
    // Calculate threshold prices (always calculate if we have exit price and ATR, regardless of filter settings)
    // Since we use absolute value, show both upper and lower thresholds
    float threshold_lower = na
    float threshold_upper = na
    if not na(last_exit_price_long) and not na(atr_value)
        // Calculate threshold offset using current multiplier value (even if 0 or filter disabled)
        threshold_offset = atr_value * reentry_price_move_atr_multiplier
        threshold_lower := last_exit_price_long - threshold_offset
        threshold_upper := last_exit_price_long + threshold_offset
    // Build label text - always show buy price, exit and threshold values
    buy_price_str = str.tostring(close, "#.##")
    exit_price_str = na(last_exit_price_long) ? "N/A" : str.tostring(last_exit_price_long, "#.##")
    threshold_str = na(threshold_lower) or na(threshold_upper) ? "N/A" : str.tostring(threshold_lower, "#.##") + " / " + str.tostring(threshold_upper, "#.##")
    label_text = "Long\n" + trade_id_str + "\nBuy @" + buy_price_str + "$\nLast Exit: " + exit_price_str
    label.new(bar_index, label_y_long, label_text, color=color.green, style=label.style_label_up)
    // Reset exit price tracking when entering new position
    last_exit_price_long := na

// Double-check position size right before entry (strategy.position_size check in shortCondition should be sufficient with process_orders_on_close=true)
if (shortOK and can_open_new_position_short and strategy.position_size == 0)
    // Increment trade ID counter (matches TradingView's sequential trade numbering)
    trade_id_counter += 1
    trade_id_str = "#" + str.tostring(trade_id_counter)
    // Calculate position size based on equity and short position size percentage
    equity_to_use = strategy.equity * (position_size_pct_short / 100.0)
    qty = math.floor(equity_to_use / close)
    strategy.entry("Short", strategy.short, qty=qty, comment=" ")
    // Use percentage-based offset that scales with price (consistent across zoom levels)
    label_y_short = high * (1 + label_offset_pct / 100.0)
    label.new(bar_index, label_y_short, "Short\n" + trade_id_str, color=color.red, style=label.style_label_down)
    // Reset exit price tracking when entering new position
    last_exit_price_short := na

//─────────────────────────────────────────────
// ALERTS
//─────────────────────────────────────────────
alertcondition(longCondition,  "Long Signal",  "10 EMA crossed over 20 EMA and price > 50 EMA")
alertcondition(shortCondition, "Short Signal", "10 EMA crossed under 20 EMA and price < 50 EMA")

//─────────────────────────────────────────────
// PLOTS
//─────────────────────────────────────────────
// Plot daily EMAs (blocky appearance is correct - they only update once per day)
plot(ema10, "10 EMA (1D)", color=color.new(#CCCCCC, 0), linewidth=2)
plot(ema20, "20 EMA (1D)", color=color.new(#666666, 0), linewidth=2)
plot(ema50, "50 EMA (1D)", color=color.black, linewidth=3)

// Those are the real daily EMA in staircases
//plot(ema10_daily, "10 EMA (1D)", color=color.new(#00EE00, 0), linewidth=2)
//plot(ema20_daily, "20 EMA (1D)", color=color.new(#66EE66, 0), linewidth=2)
