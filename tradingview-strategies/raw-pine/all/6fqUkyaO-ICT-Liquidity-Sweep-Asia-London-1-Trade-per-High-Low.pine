//@version=5
strategy("ICT Liquidity Sweep Asia/London 1 Trade per High & Low", overlay=true, initial_capital=100000,default_qty_type=strategy.fixed,default_qty_value=1,pyramiding=0)


// === INPUTS ===
rrTarget = input.float(2.0, "Risk/Reward Target")
contracts = input.int(1, "Nombre de contrats par trade", minval=1)

// === SESSIONS ===
isAsia   = time(timeframe.period, "2000-2359:1234567", "America/New_York")
isLondon = time(timeframe.period, "0200-0500:1234567", "America/New_York")

// === VARIABLES ===
var float asiaHigh = na
var float asiaLow = na
var float londonHigh = na
var float londonLow = na
var bool asiaTradedHigh = false
var bool asiaTradedLow = false
var bool londonTradedHigh = false
var bool londonTradedLow = false
var float slPrice = na
var float tpPrice = na

// === RESET DAILY ===
if ta.change(time("D"))
    asiaHigh := na
    asiaLow := na
    londonHigh := na
    londonLow := na
    asiaTradedHigh := false
    asiaTradedLow := false
    londonTradedHigh := false
    londonTradedLow := false

// === CALCUL DES RANGES ===
if isAsia
    asiaHigh := na(asiaHigh) ? high : math.max(asiaHigh, high)
    asiaLow := na(asiaLow) ? low : math.min(asiaLow, low)

if isLondon
    londonHigh := na(londonHigh) ? high : math.max(londonHigh, high)
    londonLow := na(londonLow) ? low : math.min(londonLow, low)

// === TRACE LES LIGNES ===
plot(asiaHigh, "Asia High", color=color.new(color.aqua, 0))
plot(asiaLow, "Asia Low", color=color.new(color.aqua, 0))
plot(londonHigh, "London High", color=color.new(color.orange, 0))
plot(londonLow, "London Low", color=color.new(color.orange, 0))

// === COLORATION DES ZONES ===
bgcolor(isAsia ? color.new(color.aqua, 85) : na)
bgcolor(isLondon ? color.new(color.orange, 85) : na)

// === DETECTION DES SWEEPS ===
asiaSweepLow = not asiaTradedLow and not na(asiaLow) and low < asiaLow
asiaSweepHigh = not asiaTradedHigh and not na(asiaHigh) and high > asiaHigh
londonSweepLow = not londonTradedLow and not na(londonLow) and low < londonLow
londonSweepHigh = not londonTradedHigh and not na(londonHigh) and high > londonHigh

// === VISUALISATION ===
plotshape(asiaSweepHigh or londonSweepHigh, title="High Sweep", style=shape.triangleup, location=location.abovebar, color=color.red, size=size.tiny)
plotshape(asiaSweepLow or londonSweepLow, title="Low Sweep", style=shape.triangledown, location=location.belowbar, color=color.green, size=size.tiny)

// === ENTRÉE DE TRADE ===
enterLong = false
enterShort = false

// === CONDITIONS ASIA ===
// Sweep du low → LONG (même bougie OU bougie suivante)
if asiaSweepLow and close > open
    enterLong := true
    slPrice := low
    tpPrice := close + (close - slPrice) * rrTarget
    asiaTradedLow := true
else if asiaSweepLow[1] and close > open and not asiaTradedLow
    enterLong := true
    slPrice := low[1]
    tpPrice := close + (close - slPrice) * rrTarget
    asiaTradedLow := true

// Sweep du high → SHORT (même bougie OU bougie suivante)
if asiaSweepHigh and close < open
    enterShort := true
    slPrice := high
    tpPrice := close - (slPrice - close) * rrTarget
    asiaTradedHigh := true
else if asiaSweepHigh[1] and close < open and not asiaTradedHigh
    enterShort := true
    slPrice := high[1]
    tpPrice := close - (slPrice - close) * rrTarget
    asiaTradedHigh := true

// === CONDITIONS LONDON ===
// Sweep du low → LONG
if londonSweepLow and close > open
    enterLong := true
    slPrice := low
    tpPrice := close + (close - slPrice) * rrTarget
    londonTradedLow := true
else if londonSweepLow[1] and close > open and not londonTradedLow
    enterLong := true
    slPrice := low[1]
    tpPrice := close + (close - slPrice) * rrTarget
    londonTradedLow := true

// Sweep du high → SHORT
if londonSweepHigh and close < open
    enterShort := true
    slPrice := high
    tpPrice := close - (slPrice - close) * rrTarget
    londonTradedHigh := true
else if londonSweepHigh[1] and close < open and not londonTradedHigh
    enterShort := true
    slPrice := high[1]
    tpPrice := close - (slPrice - close) * rrTarget
    londonTradedHigh := true


// === EXECUTION ===
if barstate.isconfirmed
    // Empêche les entrées multiples
    if strategy.position_size == 0
        // LONG
        if enterLong
            idLong = "Long_" + str.tostring(time)
            strategy.entry(idLong, strategy.long, qty=contracts)
            strategy.exit("TP/SL_" + idLong, from_entry=idLong, limit=tpPrice, stop=slPrice)
            label.new(bar_index, close,"LONG\nSL: " + str.tostring(slPrice) + "\nTP: " + str.tostring(tpPrice) +"\nContrats: " + str.tostring(contracts),style=label.style_label_up, color=color.new(color.green, 0))

        // SHORT
        if enterShort
            idShort = "Short_" + str.tostring(time)
            strategy.entry(idShort, strategy.short, qty=contracts)
            strategy.exit("TP/SL_" + idShort, from_entry=idShort, limit=tpPrice, stop=slPrice)
            label.new(bar_index, close,"SHORT\nSL: " + str.tostring(slPrice) + "\nTP: " + str.tostring(tpPrice) +"\nContrats: " + str.tostring(contracts),style=label.style_label_down, color=color.new(color.red, 0))

