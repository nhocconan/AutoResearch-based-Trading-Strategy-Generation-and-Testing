//@version=5
strategy("3 Candle Down/Up + Indecision + 500 EMA Breakout", overlay=true)

// 500 EMA
ema_500 = ta.ema(close, 500)
plot(ema_500, title="500 EMA", color=color.orange)

// Helper functions: check consecutive candles direction
consecutiveDown(n) =>
    count = 0
    for i = 1 to n
        count += close[i] < open[i] ? 1 : 0
    count == n

consecutiveUp(n) =>
    count = 0
    for i = 1 to n
        count += close[i] > open[i] ? 1 : 0
    count == n

// Identify indecision candle - previous bar
body_prev = math.abs(close[1] - open[1])
range_prev = high[1] - low[1]
upper_wick = high[1] - math.max(close[1], open[1])
lower_wick = math.min(close[1], open[1]) - low[1]
is_indecision = (body_prev <= range_prev * 0.25) and (upper_wick > body_prev) and (lower_wick > body_prev)

// Buy condition
buy_cond = consecutiveDown(3) and is_indecision and close > high[1] and close > ema_500

// Sell condition
sell_cond = consecutiveUp(3) and is_indecision and close < low[1] and close < ema_500

// Entries
if buy_cond and strategy.position_size <= 0
    strategy.entry("Long", strategy.long)
if sell_cond and strategy.position_size >= 0
    strategy.entry("Short", strategy.short)

// Plot signals
plotshape(buy_cond, location=location.belowbar, color=color.green, style=shape.triangleup, title="Buy Signal")
//plotshape(sell_cond, location=location.abovebar, color=color.red, style=shape.triangledown, title="Sell Signal")

