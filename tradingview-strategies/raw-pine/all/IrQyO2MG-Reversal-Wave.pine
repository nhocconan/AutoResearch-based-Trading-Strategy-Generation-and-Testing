//@version=5
strategy("Reversal Wave", overlay=true, initial_capital=10000, default_qty_type=strategy.percent_of_equity, default_qty_value=10, commission_type=strategy.commission.percent, commission_value=0.1)

// --- LOGIC DEFINITION ---

// 1. Identify previous bearish candle
// Define the midpoint of the previous candle's BODY ((Open + Close) / 2)
prevOpen = open[1]
prevClose = close[1]
isPrevBearish = prevClose < prevOpen
prevBodyMidpoint = (prevOpen + prevClose) / 2

// 2. Identify current bullish candle
isCurrBullish = close > open

// 3. Entry Condition
// The current candle is bullish AND closes above the midpoint of the previous bearish one
longCondition = isPrevBearish and isCurrBullish and (close > prevBodyMidpoint)

// --- POSITION MANAGEMENT (SL and TP) ---

// Variables to store SL and TP prices for the current trade
var float entryPrice = na
var float slPrice = na
var float tpPrice = na

if (longCondition and strategy.position_size == 0)
    // Set SL at the low of the current candle (the signal candle)
    slPrice := low
    // Estimated entry price is the close of this candle (or open of the next)
    entryPrice := close
    
    // Calculate risk distance
    float risk = entryPrice - slPrice
    
    // TP with 1:1 Ratio
    tpPrice := entryPrice + (risk * 1)
    
    // Execute the order
    strategy.entry("Long", strategy.long)

// If we are currently in a position, send conditional exit orders
if (strategy.position_size > 0)
    strategy.exit("Long Exit", "Long", stop=slPrice, limit=tpPrice)

// --- VISUALIZATION ---

// Paint the background green when there is an entry signal
bgcolor(longCondition ? color.new(color.green, 90) : na)

// Plot SL and TP lines when a position is open
plot(strategy.position_size > 0 ? slPrice : na, "Stop Loss", color=color.red, style=plot.style_linebr)
plot(strategy.position_size > 0 ? tpPrice : na, "Take Profit", color=color.green, style=plot.style_linebr)

