//@version=5
strategy("Delta Volume EMA Strategy", "Delta Volume EMA Strategy", overlay=false, default_qty_type=strategy.fixed, default_qty_value=200)

lenth = input.int(10, 'MA Length')
malenth = input.int(20, 'EMA Length')

risk_dollars = input.float(50, "Fixed Risk in $", minval=1, step=1)
lot_size = input.float(0.01, "Lot Size", minval=0.01, step=0.01)
position_size_mode = input.string("Risk Value", "Position Size Mode", options=["Risk Value", "Lots Size"])

tp_mode = input.string("%", "Take Profit Mode", options=["%", "Currency", "Pips"])
sl_mode = input.string("%", "Stop Loss Mode", options=["%", "Currency", "Pips"])

tp_percent = input.float(2.0, "Take Profit (%)", minval=0.01, step=0.1) / 100
sl_percent = input.float(1.0, "Stop Loss (%)", minval=0.01, step=0.1) / 100

tp_currency = input.float(100, "Take Profit (Currency)", minval=0.01, step=0.01)
sl_currency = input.float(50, "Stop Loss (Currency)", minval=0.01, step=0.01)

tp_pips = input.float(20, "Take Profit (Pips)", minval=0.1, step=0.1)
sl_pips = input.float(10, "Stop Loss (Pips)", minval=0.1, step=0.1)

lookback_period = input.int(20, "Volume Lookback Period", minval=1)
percentile_threshold = input.int(80, "Percentile Threshold (%)", minval=0, maxval=100)

v = volume / volume[1]
mac = ta.ema(close, lenth)
vmac = mac * v
mao = ta.ema(open, lenth)
vmao = mao * v
vd = vmac - vmao

plot(math.abs(vd), color = vd < 0 ? color.red : color.green, style = plot.style_columns, title = "Volume Delta")
vdma = ta.ema(vd, malenth)
plot(vdma, color=color.rgb(0, 0, 0, 52), linewidth=2, style = plot.style_area, title = "Volume Delta MA Area 1")
plot(vdma, color=vdma > 0 ? color.rgb(23, 235, 4, 81) : color.rgb(133, 4, 4, 75), linewidth=2, style = plot.style_area, title = "Volume Delta MA Area 2")
hline(0)

buyer_volumes_only = vd > 0 ? vd : na
seller_volumes_only = vd < 0 ? math.abs(vd) : na

threshold_long_entry = ta.percentile_nearest_rank(seller_volumes_only, lookback_period, percentile_threshold)
threshold_short_entry = ta.percentile_nearest_rank(buyer_volumes_only, lookback_period, percentile_threshold)

long_entry_condition = vd > 0 and vd > threshold_long_entry and not na(threshold_long_entry)
short_entry_condition = vd < 0 and math.abs(vd) > threshold_short_entry and not na(threshold_short_entry)

pip_value = syminfo.mintick * 10

long_size = position_size_mode == "Risk Value" ? risk_dollars / (close * sl_percent) : lot_size
short_size = position_size_mode == "Risk Value" ? risk_dollars / (close * sl_percent) : lot_size

long_size_rounded = math.round(long_size * 100) / 100
short_size_rounded = math.round(short_size * 100) / 100

calc_tp_price(is_long, entry_price) =>
    float tp_price = na
    if tp_mode == "%"
        tp_price := is_long ? entry_price * (1 + tp_percent) : entry_price * (1 - tp_percent)
    else if tp_mode == "Currency"
        tp_price := is_long ? entry_price + tp_currency : entry_price - tp_currency
    else if tp_mode == "Pips"
        tp_price := is_long ? entry_price + (tp_pips * pip_value) : entry_price - (tp_pips * pip_value)
    tp_price

calc_sl_price(is_long, entry_price) =>
    float sl_price = na
    if sl_mode == "%"
        sl_price := is_long ? entry_price * (1 - sl_percent) : entry_price * (1 + sl_percent)
    else if sl_mode == "Currency"
        sl_price := is_long ? entry_price - sl_currency : entry_price + sl_currency
    else if sl_mode == "Pips"
        sl_price := is_long ? entry_price - (sl_pips * pip_value) : entry_price + (sl_pips * pip_value)
    sl_price

if long_entry_condition and strategy.position_size == 0
    entry_price = close
    tp_price = calc_tp_price(true, entry_price)
    sl_price = calc_sl_price(true, entry_price)
    
    strategy.entry("Long", strategy.long, qty=long_size_rounded)
    strategy.exit("TP/SL Long", from_entry="Long", limit=tp_price, stop=sl_price)
    
    alert_message = "Buy | Entry: " + str.tostring(entry_price) + " | TP: " + str.tostring(tp_price) + " | SL: " + str.tostring(sl_price)
    alert(alert_message, alert.freq_once_per_bar_close)

if short_entry_condition and strategy.position_size == 0
    entry_price = close
    tp_price = calc_tp_price(false, entry_price)
    sl_price = calc_sl_price(false, entry_price)
    
    strategy.entry("Short", strategy.short, qty=short_size_rounded)
    strategy.exit("TP/SL Short", from_entry="Short", limit=tp_price, stop=sl_price)
    
    alert_message = "Sell | Entry: " + str.tostring(entry_price) + " | TP: " + str.tostring(tp_price) + " | SL: " + str.tostring(sl_price)
    alert(alert_message, alert.freq_once_per_bar_close)

View in Pine Editor・96 lines
Use on chart
