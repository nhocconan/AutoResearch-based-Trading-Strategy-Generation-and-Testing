//@version=5
strategy("golden cross", overlay=true)

// DeathCross ist ein sinnloser Crash-Indikator, weil viele Signale (v.a. zuletzt) sehr spät kommen und sogar bullish sind
// Idee daher: SL von 10% und PT von 10% und schon ist mal profitabel :-)))

// === Inputs für Stop-Loss und Kursziel ===
stopLossPercent = input.float(title="Stop-Loss in %", defval=10.0, minval=0.1, step=0.1)
takeProfitPercent = input.float(title="Kursziel in %", defval=10.0, minval=0.1, step=0.1)

// SMA-Berechnungen
sma50 = ta.sma(close, 50)
sma200 = ta.sma(close, 200)

// Kreuzungsbedingungen
deathCross = ta.crossover(sma200, sma50) // SMA50 fällt unter SMA200
goldenCross = ta.crossover(sma50, sma200) // SMA50 steigt über SMA200

// Variablen für Einstiegspreis und Bar-Index
var float entryPrice = na
var int entryBar = na

// Kaufregel: 
if (goldenCross)
    strategy.entry("Long", strategy.long)
    entryPrice := close
    entryBar := bar_index

// Stop-Loss- und Take-Profit-Berechnung (dynamisch nach Input)
stopLossPrice = entryPrice * (1 - stopLossPercent / 100)
takeProfitPrice = entryPrice * (1 + takeProfitPercent / 100)

// Verkaufsregel: Death Cross, Stop-Loss oder Take-Profit
exitCondition = deathCross or (strategy.position_size > 0 and (close <= stopLossPrice or close >= takeProfitPrice))

if (exitCondition)
    strategy.close("Long")
    // Linie vom Einstieg zum Ausstieg zeichnen, Farbe je nach Gewinn/Verlust
    if not na(entryPrice) and not na(entryBar)
        lineColor = close > entryPrice ? color.green : color.red
        line.new(x1=entryBar, y1=entryPrice, x2=bar_index, y2=close, color=lineColor, width=2)
    entryPrice := na
    entryBar := na


// Visualisierung der SMAs
plot(sma50, color=color.blue, title="SMA 50")
plot(sma200, color=color.orange, title="SMA 200")

// Hintergrund grün färben, wenn Long-Position aktiv ist
bgcolor(strategy.position_size > 0 ? color.new(color.green, 85) : na)

