//@version=6
strategy("PA System (V1.1) - MultiMarket + Trendlines",
     overlay=true,
     initial_capital=10000,
     default_qty_type=strategy.fixed,
     commission_type=strategy.commission.percent,
     commission_value=0.05,
     slippage=2,
     max_bars_back=500,
     max_lines_count=500)

// =====================================================
// Inputs
// =====================================================
// --- Structure
swingLength   = input.int(5,  "Swing Length（摆动长度）", minval=2, group="结构 Structure")
trendBars     = input.int(3,  "Trend Confirm Bars（趋势确认根数）", minval=2, group="结构 Structure")
stateDebounce = input.int(2,  "State Debounce（状态防抖根数）", minval=1, group="结构 Structure")
channelATR    = input.float(2.0,"Channel ATR Mult（通道阈值 ATR倍数）", group="结构 Structure")

// --- BoS / CHoCH
useBosChoch        = input.bool(true,  "Enable BoS/CHoCH（启用结构突破）", group="结构 BoS/CHoCH")
bosUseCloseOnly    = input.bool(true,  "Break uses Close（仅收盘确认破位）", group="结构 BoS/CHoCH")
showBosChochLines  = input.bool(true,  "Show BoS/CHoCH Lines（画破位线）", group="结构 BoS/CHoCH")
showBosChochLabels = input.bool(true,  "Show BoS/CHoCH Labels（标注BoS/CHoCH）", group="结构 BoS/CHoCH")
breakLookbackBars  = input.int(40,     "Break Valid Lookback（破位有效窗口bars）", minval=5, maxval=300, group="结构 BoS/CHoCH")
useBreakFilter     = input.bool(false, "Use Break Filter for Entries（入场需近期同向破位）", group="结构 BoS/CHoCH")

// --- Signals
enableH2        = input.bool(true, "Enable H2 Longs（启用H2做多）", group="信号 Signals")
enableL2        = input.bool(true, "Enable L2 Shorts（启用L2做空）", group="信号 Signals")
requirePullback = input.bool(true, "Require HH/HL or LH/LL（必须结构回调）", group="信号 Signals")

// --- Signals V2
useMicroBreakout    = input.bool(true, "Use Micro Range Breakout（微平台突破触发）", group="信号 V2")
microLen            = input.int(3, "Micro Range Length（微平台长度）", minval=2, maxval=10, group="信号 V2")
minWaitAfterH1L1    = input.int(2, "Min Bars After H1/L1（H1/L1后等待bars）", minval=1, maxval=10, group="信号 V2")
signalCloseStrength = input.float(0.6, "Close Strength（收盘强度0-1）", minval=0.3, maxval=0.9, step=0.05, group="信号 V2")

// --- Filters
useEMAFilter = input.bool(true, "Use EMA Filter（EMA趋势过滤）", group="过滤 Filters")
emaFast      = input.int(20, "Fast EMA（快EMA）", group="过滤 Filters")
emaSlow      = input.int(50, "Slow EMA（慢EMA）", group="过滤 Filters")
cooldownBars = input.int(5,  "Cooldown After Exit（出场冷却bars）", minval=0, group="过滤 Filters")

// --- Risk
riskPerTrade   = input.float(1.0, "Risk %（每笔风险%）", minval=0.1, maxval=10, group="风控 Risk")
rewardRatio    = input.float(2.0, "R:R（盈亏比）", minval=1, group="风控 Risk")
maxRiskATR     = input.float(2.5, "Max SL ATR（止损最大ATR倍）", minval=0.5, group="风控 Risk")
partialExitR   = input.float(1.0, "Partial at R（部分止盈R）", minval=0.5, group="风控 Risk")
partialExitPct = input.float(50, "Partial %（部分止盈百分比）", minval=10, maxval=90, group="风控 Risk")
breakevenR     = input.float(0.8, "Move to BE at R（保本触发R）", minval=0.3, group="风控 Risk")

// --- Trend Lines (New)
showTrendLines  = input.bool(true, 'Show Trend Lines（显示趋势线）', group = '可视化 Trendlines')
trendLineLength = input.int(20, 'Trend Line Sensitivity（趋势线灵敏度）', group = '可视化 Trendlines', minval = 10)
upTlColor       = input.color(color.new(color.teal, 15), title = 'Bullish Color', group = '可视化 Trendlines', inline = 'tl')
downTlColor     = input.color(color.new(color.red, 15), title = 'Bearish Color', group = '可视化 Trendlines', inline = 'tl')

// --- Visual
showSignals          = input.bool(true, "Show H1/H2/L1/L2（显示信号点）", group="可视化 Signals")
showQtyDebug         = input.bool(true, "Show qty=0 Debug（显示qty=0原因）", group="可视化 Signals")
showStruct           = input.bool(true, "Show HH/HL/LH/LL（显示结构点）", group="可视化 Structure")
structPadATR         = input.float(0.18, "Marker Padding ATR", minval=0.0, step=0.02, group="可视化 Structure")
maxLabels            = input.int(120, "Max Labels", minval=10, group="性能 Performance")

// =====================================================
// Globals / helpers
// =====================================================
var label[] allLabels = array.new<label>()
addLabel(x, y, txt, s, col, tcol=color.white, size=size.normal) =>
    lbl = label.new(x, y, txt, style=s, color=col, textcolor=tcol, size=size)
    array.push(allLabels, lbl)
    if array.size(allLabels) > maxLabels
        label.delete(array.shift(allLabels))
    lbl

calcPositionSize(entryPrice, stopPrice) =>
    riskAmount = strategy.equity * (riskPerTrade / 100.0)
    riskPerPoint = math.abs(entryPrice - stopPrice)
    riskPerUnit = riskPerPoint * syminfo.pointvalue
    qty = riskPerUnit > 0 ? math.floor(riskAmount / riskPerUnit) : 0
    qty

closePos() =>
    rng = (high - low)
    rng > 0 ? (close - low) / rng : 0.5

// Trendline Helpers
extendTrendline(lineId, startIndex, startValue, endIndex, endValue) =>
    slope = (endValue - startValue) / (endIndex - startIndex)
    newEndIndex = bar_index
    newEndValue = startValue + slope * (newEndIndex - startIndex)
    line.set_x2(lineId, newEndIndex)
    line.set_y2(lineId, newEndValue)

getSlope(startIndex, startValue, endIndex, endValue) =>
    (endValue - startValue) / (endIndex - startIndex)

// =====================================================
// Core calcs
// =====================================================
atr   = ta.atr(14)
ema20 = ta.ema(close, emaFast)
ema50 = ta.ema(close, emaSlow)
rangeSize20 = ta.highest(high, 20) - ta.lowest(low, 20)

phVal = ta.pivothigh(high, swingLength, swingLength)
plVal = ta.pivotlow(low,  swingLength, swingLength)

// =====================================================
// Structure HH/HL/LH/LL
// =====================================================
var float lastHH = na
var float lastHL = na
var float lastLH = na
var float lastLL = na
var float swingHigh = na
var float swingLow  = na
var int   swingHighBar = na
var int   swingLowBar  = na

pad = atr * structPadATR

if not na(phVal)
    pivotBar = bar_index - swingLength
    if not na(swingHigh)
        if phVal > swingHigh
            lastHH := phVal
            if showStruct
                addLabel(pivotBar, phVal + pad, "HH", label.style_label_down, color.lime, size=size.tiny)
        else
            lastLH := phVal
            if showStruct
                addLabel(pivotBar, phVal + pad, "LH", label.style_label_down, color.red, size=size.tiny)
    swingHigh := phVal
    swingHighBar := pivotBar

if not na(plVal)
    pivotBar = bar_index - swingLength
    if not na(swingLow)
        if plVal < swingLow
            lastLL := plVal
            if showStruct
                addLabel(pivotBar, plVal - pad, "LL", label.style_label_up, color.maroon, size=size.tiny)
        else
            lastHL := plVal
            if showStruct
                addLabel(pivotBar, plVal - pad, "HL", label.style_label_up, color.green, size=size.tiny)
    swingLow := plVal
    swingLowBar := pivotBar

// =====================================================
// BoS/CHoCH
// =====================================================
var int lastBreakDir = 0
var int lastBreakBar = na

if useBosChoch
    upRef = swingHigh
    dnRef = swingLow
    breakUp = (bosUseCloseOnly ? close > upRef : high > upRef) and (bosUseCloseOnly ? close[1] <= upRef : high[1] <= upRef)
    breakDn = (bosUseCloseOnly ? close < dnRef : low < dnRef) and (bosUseCloseOnly ? close[1] >= dnRef : low[1] >= dnRef)

    if breakUp
        prev = lastBreakDir
        lastBreakDir := 1
        lastBreakBar := bar_index
        if showBosChochLines and not na(swingHighBar)
            line.new(swingHighBar, upRef, bar_index, upRef, color=color.new(color.teal, 50))
        if showBosChochLabels
            addLabel(bar_index, high + atr*0.2, prev == -1 ? "CHoCH" : "BoS", label.style_label_down, color.teal, size=size.tiny)

    if breakDn
        prev = lastBreakDir
        lastBreakDir := -1
        lastBreakBar := bar_index
        if showBosChochLines and not na(swingLowBar)
            line.new(swingLowBar, dnRef, bar_index, dnRef, color=color.new(color.red, 50))
        if showBosChochLabels
            addLabel(bar_index, low - atr*0.2, prev == 1 ? "CHoCH" : "BoS", label.style_label_up, color.red, size=size.tiny)

breakOkLong  = not useBreakFilter or (not na(lastBreakBar) and (bar_index - lastBreakBar <= breakLookbackBars) and lastBreakDir == 1)
breakOkShort = not useBreakFilter or (not na(lastBreakBar) and (bar_index - lastBreakBar <= breakLookbackBars) and lastBreakDir == -1)

// =====================================================
// Trend Lines Logic (Merged from UAlgo)
// =====================================================
var line newBearishTrendline = na
var line newBullishTrendline = na

if showTrendLines
    phTrend = ta.pivothigh(high, trendLineLength, trendLineLength)
    plTrend = ta.pivotlow(low, trendLineLength, trendLineLength)

    bullishTrendLineStart = ta.valuewhen(not na(plTrend), bar_index[trendLineLength], 1)
    bullishTrendLineEnd = ta.valuewhen(not na(plTrend), bar_index[trendLineLength], 0)
    bearishTrendLineStart = ta.valuewhen(not na(phTrend), bar_index[trendLineLength], 1)
    bearishTrendLineEnd = ta.valuewhen(not na(phTrend), bar_index[trendLineLength], 0)

    bullishTrendLineStartVal = ta.valuewhen(not na(plTrend), low[trendLineLength], 1)
    bullishTrendLineEndVal = ta.valuewhen(not na(plTrend), low[trendLineLength], 0)
    bearishTrendLineStartVal = ta.valuewhen(not na(phTrend), high[trendLineLength], 1)
    bearishTrendLineEndVal = ta.valuewhen(not na(phTrend), high[trendLineLength], 0)

    line.delete(newBearishTrendline)
    line.delete(newBullishTrendline)

    slopeBearish = getSlope(bearishTrendLineStart, bearishTrendLineStartVal, bearishTrendLineEnd, bearishTrendLineEndVal)
    slopeBullish = getSlope(bullishTrendLineStart, bullishTrendLineStartVal, bullishTrendLineEnd, bullishTrendLineEndVal)

    if slopeBearish < 0
        newBearishTrendline := line.new(x1 = bearishTrendLineStart, y1 = bearishTrendLineStartVal, x2 = bar_index, y2 = bearishTrendLineEndVal, xloc = xloc.bar_index, color = downTlColor, width = 2)
        extendTrendline(newBearishTrendline, bearishTrendLineStart, bearishTrendLineStartVal, bearishTrendLineEnd, bearishTrendLineEndVal)
        
    if slopeBullish > 0
        newBullishTrendline := line.new(x1 = bullishTrendLineStart, y1 = bullishTrendLineStartVal, x2 = bar_index, y2 = bullishTrendLineEndVal, xloc = xloc.bar_index, color = upTlColor, width = 2)
        extendTrendline(newBullishTrendline, bullishTrendLineStart, bullishTrendLineStartVal, bullishTrendLineEnd, bullishTrendLineEndVal)

// =====================================================
// State machine (Market Context)
// =====================================================
var string marketState = "CHANNEL"
var string alwaysIn    = "NONE"

isBullBar = close > open and (close - open) > atr * 0.4
isBearBar = close < open and (open - close) > atr * 0.4

var int bullStreak = 0
var int bearStreak = 0
bullStreak := isBullBar ? bullStreak + 1 : 0
bearStreak := isBearBar ? bearStreak + 1 : 0

if bullStreak >= trendBars
    marketState := "BREAKOUT", alwaysIn := "BULL"
else if bearStreak >= trendBars
    marketState := "BREAKOUT", alwaysIn := "BEAR"
else if rangeSize20 < atr * channelATR
    marketState := "RANGE", alwaysIn := "NONE"
else
    marketState := "CHANNEL"
    alwaysIn := (close > ema20 and ema20 > ema50) ? "BULL" : (close < ema20 and ema20 < ema50) ? "BEAR" : "NONE"

// =====================================================
// Signals H1/H2/L1/L2
// =====================================================
var bool h1Seen = false
var bool l1Seen = false
var int  h1Bar  = na
var int  l1Bar  = na

if h1Seen and bar_index > h1Bar + 8
    h1Seen := false
if l1Seen and bar_index > l1Bar + 8
    l1Seen := false

isH1 = alwaysIn == "BULL" and low <= ta.highest(high, 5) and close > open
if isH1 and not h1Seen
    h1Seen := true, h1Bar := bar_index

isL1 = alwaysIn == "BEAR" and high >= ta.lowest(low, 5) and close < open
if isL1 and not l1Seen
    l1Seen := true, l1Bar := bar_index

h2Trigger = useMicroBreakout ? (high > ta.highest(high[1], microLen) and closePos() > signalCloseStrength) : (high > high[1] and closePos() > signalCloseStrength)
l2Trigger = useMicroBreakout ? (low < ta.lowest(low[1], microLen) and closePos() < (1-signalCloseStrength)) : (low < low[1] and closePos() < (1-signalCloseStrength))

isH2 = h1Seen and bar_index > h1Bar and h2Trigger and breakOkLong and enableH2
isL2 = l1Seen and bar_index > l1Bar and l2Trigger and breakOkShort and enableL2

plotshape(showSignals and isH1, "H1", shape.circle, location.belowbar, color.lime, size=size.tiny)
plotshape(showSignals and isH2, "H2", shape.triangleup, location.belowbar, color.green, size=size.small)
plotshape(showSignals and isL1, "L1", shape.circle, location.abovebar, color.red, size=size.tiny)
plotshape(showSignals and isL2, "L2", shape.triangledown, location.abovebar, color.maroon, size=size.small)

// =====================================================
// Execution & Risk Management
// =====================================================
var float entrySL = na
var float entryTP = na
var int lastExitBar = 0
inCooldown = (bar_index - lastExitBar) < cooldownBars

if (isH2 or isL2) and strategy.position_size == 0 and not inCooldown
    float slDist = math.min(atr * maxRiskATR, math.abs(close - (isH2 ? ta.lowest(low, 3) : ta.highest(high, 3))))
    entrySL := isH2 ? close - slDist : close + slDist
    entryTP := isH2 ? close + (slDist * rewardRatio) : close - (slDist * rewardRatio)
    
    int qty = calcPositionSize(close, entrySL)
    if qty > 0
        strategy.entry(isH2 ? "Long" : "Short", isH2 ? strategy.long : strategy.short, qty=qty)
        h1Seen := false, l1Seen := false
    else if showQtyDebug
        addLabel(bar_index, high + atr, "Qty=0\nRisk Too High", label.style_label_down, color.orange, size=size.tiny)

if strategy.position_size != 0
    if partialExitPct > 0
        float pTarget = strategy.position_avg_price + (strategy.position_size > 0 ? (math.abs(strategy.position_avg_price - entrySL) * partialExitR) : -(math.abs(strategy.position_avg_price - entrySL) * partialExitR))
        strategy.exit("Partial", qty_percent=partialExitPct, limit=pTarget, comment="Part")
    
    float beLevel = strategy.position_avg_price + (strategy.position_size > 0 ? (math.abs(strategy.position_avg_price - entrySL) * breakevenR) : -(math.abs(strategy.position_avg_price - entrySL) * breakevenR))
    bool reachBE = strategy.position_size > 0 ? high >= beLevel : low <= beLevel
    strategy.exit("Exit", stop=reachBE ? strategy.position_avg_price : entrySL, limit=entryTP, comment="Full/SL")

if strategy.position_size[1] != 0 and strategy.position_size == 0
    lastExitBar := bar_index

View in Pine Editor・306 lines
