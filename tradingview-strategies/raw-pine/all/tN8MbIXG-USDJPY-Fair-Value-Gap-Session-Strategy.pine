//@version=6
strategy("USDJPY FVG + Session Strategy", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=100)

// ============================================================================
// USDJPY Fair Value Gap + Session-Based Trading Strategy
// Combines order flow imbalances (FVGs) with session-specific volatility patterns
// Optimized for short-term trading with 2:1 risk/reward ratio
// ============================================================================

// ===========================
// INPUT PARAMETERS
// ===========================

showTokyoSession = input.bool(true, "Trade Tokyo Session", group="Session Settings")
showLondonNYOverlap = input.bool(true, "Trade London/NY Overlap", group="Session Settings")

fvgThreshold = input.float(0.0, "FVG Minimum Size", group="FVG Settings")
maxFVGAge = input.int(20, "Maximum FVG Age (bars)", group="FVG Settings")
showFVG = input.bool(true, "Show FVG Markers", group="FVG Settings")

useVolumeFilter = input.bool(true, "Use Volume Filter", group="Volume Settings")
volumeMultiplier = input.float(1.5, "Volume Multiplier vs Average", group="Volume Settings")
volumePeriod = input.int(20, "Volume Average Period", group="Volume Settings")

useTrendFilter = input.bool(true, "Use Trend Filter", group="Trend Settings")
trendEMA = input.int(50, "Trend EMA Period", group="Trend Settings")

riskRewardRatio = input.float(2.0, "Risk/Reward Ratio", group="Risk Management")
stopLossPercent = input.float(0.3, "Stop Loss % from Entry", group="Risk Management")

// ===========================
// SESSION DETECTION
// ===========================

tokyoSession = hour >= 0 and hour < 9
tokyoOpen = hour == 0 and minute < 60
londonSession = hour >= 8 and hour < 16
nySession = hour >= 13 and hour < 21
londonNYOverlap = hour >= 13 and hour < 16

tradingSession = (showTokyoSession and (tokyoSession or tokyoOpen)) or (showLondonNYOverlap and londonNYOverlap)

// ===========================
// FAIR VALUE GAP DETECTION
// ===========================

bullishFVG = low > high[2] and high[1] > high[2]
bullishFVGHigh = bullishFVG ? low : na
bullishFVGLow = bullishFVG ? high[2] : na
bullishFVGSize = bullishFVG ? (bullishFVGHigh - bullishFVGLow) : 0.0

bearishFVG = high < low[2] and low[1] < low[2]
bearishFVGHigh = bearishFVG ? low[2] : na
bearishFVGLow = bearishFVG ? high : na
bearishFVGSize = bearishFVG ? (bearishFVGHigh - bearishFVGLow) : 0.0

// Track active FVGs using arrays for Pine Script v6
var activeBullFVGLow = float(na)
var activeBullFVGHigh = float(na)
var bullFVGBar = int(na)

var activeBearFVGLow = float(na)
var activeBearFVGHigh = float(na)
var bearFVGBar = int(na)

// Update bullish FVG
if bullishFVG and bullishFVGSize >= fvgThreshold
    activeBullFVGLow := bullishFVGLow
    activeBullFVGHigh := bullishFVGHigh
    bullFVGBar := bar_index

// Update bearish FVG
if bearishFVG and bearishFVGSize >= fvgThreshold
    activeBearFVGLow := bearishFVGLow
    activeBearFVGHigh := bearishFVGHigh
    bearFVGBar := bar_index

// Check if FVG has been filled
bullFVGFilled = not na(activeBullFVGLow) and low <= activeBullFVGLow
bearFVGFilled = not na(activeBearFVGHigh) and high >= activeBearFVGHigh

// Check if FVG is too old
bullFVGTooOld = not na(bullFVGBar) and (bar_index - bullFVGBar) > maxFVGAge
bearFVGTooOld = not na(bearFVGBar) and (bar_index - bearFVGBar) > maxFVGAge

// Reset FVG if filled or too old
if bullFVGFilled or bullFVGTooOld
    activeBullFVGLow := na
    activeBullFVGHigh := na
    bullFVGBar := na

if bearFVGFilled or bearFVGTooOld
    activeBearFVGLow := na
    activeBearFVGHigh := na
    bearFVGBar := na

// ===========================
// VOLUME ANALYSIS
// ===========================

avgVolume = ta.sma(volume, volumePeriod)
volumeConfirm = not useVolumeFilter or volume > (avgVolume * volumeMultiplier)

// ===========================
// TREND FILTER
// ===========================

ema = ta.ema(close, trendEMA)
uptrend = close > ema
downtrend = close < ema

trendConfirmLong = not useTrendFilter or uptrend
trendConfirmShort = not useTrendFilter or downtrend

plot(useTrendFilter ? ema : na, "Trend EMA", color=color.yellow, linewidth=2)

// ===========================
// ENTRY CONDITIONS
// ===========================

priceInBullFVG = not na(activeBullFVGLow) and low <= activeBullFVGHigh and low >= activeBullFVGLow
priceInBearFVG = not na(activeBearFVGLow) and high >= activeBearFVGLow and high <= activeBearFVGHigh

bullishCandle = close > open
bearishCandle = close < open

longCondition = priceInBullFVG and bullishCandle and volumeConfirm and trendConfirmLong and tradingSession
shortCondition = priceInBearFVG and bearishCandle and volumeConfirm and trendConfirmShort and tradingSession

// ===========================
// RISK MANAGEMENT
// ===========================

var longStopLoss = float(na)
var longTakeProfit = float(na)
var shortStopLoss = float(na)
var shortTakeProfit = float(na)

if longCondition and strategy.position_size == 0
    longStopLoss := close * (1.0 - stopLossPercent / 100.0)
    longTakeProfit := close * (1.0 + (stopLossPercent * riskRewardRatio) / 100.0)

if shortCondition and strategy.position_size == 0
    shortStopLoss := close * (1.0 + stopLossPercent / 100.0)
    shortTakeProfit := close * (1.0 - (stopLossPercent * riskRewardRatio) / 100.0)

// ===========================
// STRATEGY EXECUTION
// ===========================

if longCondition and strategy.position_size == 0
    strategy.entry("Long", strategy.long)
    strategy.exit("Exit Long", "Long", stop=longStopLoss, limit=longTakeProfit)
    activeBullFVGLow := na
    activeBullFVGHigh := na

if shortCondition and strategy.position_size == 0
    strategy.entry("Short", strategy.short)
    strategy.exit("Exit Short", "Short", stop=shortStopLoss, limit=shortTakeProfit)
    activeBearFVGLow := na
    activeBearFVGHigh := na

// ===========================
// VISUALIZATION
// ===========================

plotshape(showFVG and not na(activeBullFVGLow) ? activeBullFVGHigh : na, "Bull FVG High", style=shape.square, location=location.absolute, color=color.new(color.green, 80), size=size.tiny)
plotshape(showFVG and not na(activeBullFVGLow) ? activeBullFVGLow : na, "Bull FVG Low", style=shape.square, location=location.absolute, color=color.new(color.green, 80), size=size.tiny)
plotshape(showFVG and not na(activeBearFVGLow) ? activeBearFVGHigh : na, "Bear FVG High", style=shape.square, location=location.absolute, color=color.new(color.red, 80), size=size.tiny)
plotshape(showFVG and not na(activeBearFVGLow) ? activeBearFVGLow : na, "Bear FVG Low", style=shape.square, location=location.absolute, color=color.new(color.red, 80), size=size.tiny)

bgcolor(tokyoOpen ? color.new(color.blue, 95) : na, title="Tokyo Open")
bgcolor(londonNYOverlap ? color.new(color.orange, 95) : na, title="London/NY Overlap")

plotshape(longCondition, "Long Signal", shape.triangleup, location.belowbar, color.green, size=size.small)
plotshape(shortCondition, "Short Signal", shape.triangledown, location.abovebar, color.red, size=size.small)

