//@version=5
strategy("EMA Cross Strategy v5 (30 lots) - safe flip",
     overlay = true,
     calc_on_every_tick = true,
     initial_capital = 10000)

// INPUTS
emaFast = input.int(title="Fast EMA", defval=10, minval=1)
emaSlow = input.int(title="Slow EMA", defval=20, minval=1)
tradeDirection = input.string(title="Trade Direction", defval="Both", options=["Long","Short","Both"])

// CALCS
fastEMA = ta.ema(close, emaFast)
slowEMA = ta.ema(close, emaSlow)

plot(fastEMA, color=color.orange, linewidth=2)
plot(slowEMA, color=color.blue, linewidth=2)

// SIGNALS
longOK  = (tradeDirection == "Long") or (tradeDirection == "Both")
shortOK = (tradeDirection == "Short") or (tradeDirection == "Both")

longSignal  = ta.crossover(fastEMA, slowEMA)
shortSignal = ta.crossunder(fastEMA, slowEMA)

// SAFE ORDER LOGIC (no doubling)
qty = 30

if longSignal and longOK
    // If currently short, close first and then enter long
    if strategy.position_size < 0
        strategy.close("short")
        strategy.entry("long", strategy.long, qty=qty)
    // If currently flat, enter long
    else if strategy.position_size == 0
        strategy.entry("long", strategy.long, qty=qty)
    // If already long, do nothing (prevents doubling)

if shortSignal and shortOK
    // If currently long, close first and then enter short
    if strategy.position_size > 0
        strategy.close("long")
        strategy.entry("short", strategy.short, qty=qty)
    // If currently flat, enter short
    else if strategy.position_size == 0
        strategy.entry("short", strategy.short, qty=qty)
    // If already short, do nothing

// EXIT ON OPPOSITE handled above by close()
alertcondition(longSignal, title="LONG Signal", message="LONG")
alertcondition(shortSignal, title="SHORT Signal", message="SHORT")

