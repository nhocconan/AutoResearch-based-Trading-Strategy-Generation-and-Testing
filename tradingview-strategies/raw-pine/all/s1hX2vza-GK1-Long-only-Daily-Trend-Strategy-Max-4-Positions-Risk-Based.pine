//@version=6
strategy(
     "Daily Trend Strategy – Max 4 Positions, Risk-Based",
     overlay = true,
     initial_capital = 100000,
     pyramiding = 0,
     default_qty_type = strategy.fixed,
     commission_type = strategy.commission.percent,
     commission_value = 0.1
)

// =====================
// INPUTS
// =====================
riskPct        = input.float(1.0, "Risk % per Trade", step = 0.25)
maxPositions   = input.int(4, "Max Concurrent Positions", minval = 1)
atrLen         = input.int(14, "ATR Length")
atrMult        = input.float(2.5, "ATR Stop Multiple", step = 0.1)
volLen         = input.int(20, "Volume MA Length")

// =====================
// INDICATORS
// =====================
sma14  = ta.sma(close, 14)
sma50  = ta.sma(close, 50)
sma200 = ta.sma(close, 200)
atr    = ta.atr(atrLen)

volMA = ta.sma(volume, volLen)
normalVolume = volume > volMA * 0.8 and volume < volMA * 2.0

// =====================
// ENTRY CONDITIONS
// =====================
trendUp =
     sma14 > sma50 and
     close > sma200 and
     sma200 > sma200[1] and
     normalVolume

// =====================
// POSITION LIMIT LOGIC
// =====================
canEnter = strategy.opentrades < maxPositions

// =====================
// RISK-BASED POSITION SIZE
// =====================
riskCapital = strategy.equity * (riskPct / 100)
stopDistance = atr * atrMult
positionSize = riskCapital / stopDistance

// =====================
// ENTRY
// =====================
if trendUp and canEnter
    strategy.entry("Long", strategy.long, qty = positionSize)

// =====================
// TRAILING ATR STOP
// =====================
var float highestClose = na

if strategy.position_size > 0
    highestClose := na(highestClose) ? close : math.max(highestClose, close)
    trailStop = highestClose - stopDistance
    strategy.exit("ATR Stop", "Long", stop = trailStop)
else
    highestClose := na

// =====================
// TREND EXIT
// =====================
trendExit = sma14 < sma50

if trendExit
    strategy.close("Long")

// =====================
// PLOTS
// =====================
plot(sma14,  color=color.orange, linewidth=2, title="SMA 14")
plot(sma50,  color=color.blue,   linewidth=2, title="SMA 50")
plot(sma200, color=color.red,    linewidth=2, title="SMA 200")

