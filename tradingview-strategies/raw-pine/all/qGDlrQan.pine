//@version=6
strategy("Sinals 15m - RSI 7 e 9", overlay=true,
     margin_long=100, margin_short=100,
     default_qty_type=strategy.cash, default_qty_value=5)


// =============================
//        PARÂMETROS
// =============================
emaFastLen = input.int(9,  "EMA Rápida")
emaMidLen  = input.int(20, "EMA Intermediária")
emaTrend   = input.int(50, "EMA Tendência")
rsiLen1    = input.int(7,  "RSI Curto")
rsiLen2    = input.int(9,  "RSI Médio")
diLen      = input.int(14, "DI Length")
adxSmooth  = input.int(14, "Suavização ADX")
atrLen     = input.int(14, "ATR Length")
cooldown   = input.int(2, "Candles de espera após sinal")
tpPct      = input.float(0.015, "Take Profit (%)", step=0.001) // 1.5%

// =============================
//        CÁLCULOS
// =============================
emaFast = ta.ema(close, emaFastLen)
emaMid  = ta.ema(close, emaMidLen)
emaTrendLine = ta.ema(close, emaTrend)

rsi1 = ta.rsi(close, rsiLen1)
rsi2 = ta.rsi(close, rsiLen2)

[dmiPlus, dmiMinus, adx] = ta.dmi(diLen, adxSmooth)

bullCross = ta.crossover(emaFast, emaMid)
bearCross = ta.crossunder(emaFast, emaMid)

candleRange = high - low
body        = math.abs(close - open)
strongBull  = close > open and body >= candleRange * 0.5
strongBear  = close < open and body >= candleRange * 0.5

// =============================
//     FILTRO DE TENDÊNCIA
// =============================
trendUp   = emaMid > emaTrendLine
trendDown = emaMid < emaTrendLine

longBase  = bullCross and rsi1 > 55 and rsi2 > 55 and adx > 15 and strongBull and trendUp
shortBase = bearCross and rsi1 < 45 and rsi2 < 45 and adx > 15 and strongBear and trendDown

// =============================
//     CONFIRMAÇÃO DE CANDLE
// =============================
longConfirm = longBase and close > high[1]
shortConfirm = shortBase and close < low[1]

// =============================
//     COOLDOWN
// =============================
var int lastSignalBar = na
barsSinceLast = na(lastSignalBar) ? 1e9 : (bar_index - lastSignalBar)
cooldownOk    = barsSinceLast > cooldown

longSignal  = longConfirm and cooldownOk
shortSignal = shortConfirm and cooldownOk

// =============================
//     ENTRADAS E TP/SL DINÂMICOS
// =============================
lastLow  = ta.lowest(low, 10)   
lastHigh = ta.highest(high, 10)

if (longSignal)
    sl = lastLow * 0.99
    tp = close * (1 + tpPct)
    strategy.entry("Long", strategy.long)
    strategy.exit("Long Exit", "Long", stop=sl, limit=tp)
    lastSignalBar := bar_index

if (shortSignal)
    sl = lastHigh * 1.01
    tp = close * (1 - tpPct)
    strategy.entry("Short", strategy.short)
    strategy.exit("Short Exit", "Short", stop=sl, limit=tp)
    lastSignalBar := bar_index



// =============================
//           PLOTS
// =============================
plot(emaFast, "EMA 9",  color=color.new(color.green, 0))
plot(emaMid,  "EMA 20", color=color.new(color.orange, 0))
plot(emaTrendLine, "EMA 50", color=color.new(#f50398, 0))

