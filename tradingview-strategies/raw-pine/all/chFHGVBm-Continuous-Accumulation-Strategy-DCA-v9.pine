//@version=5
strategy("Sürekli Parçalı Alım Stratejisi v9.4 (Yayınlanabilir Final)", 
          shorttitle="Sürekli Strateji v9.4", 
          overlay=true, 
          
          default_qty_type=strategy.cash,
          default_qty_value=100,
          
          initial_capital=50000,
          pyramiding=500,
          commission_value=0.05)

// ----- Kullanıcı Ayarları (Inputs) -----
lookbackPeriod = input.int(5, title="Zirve Arama Periyodu")
dropPercent1 = input.float(5.0, title="1. Alım için Düşüş %")
dropPercent2 = input.float(8.0, title="2. Alım için Düşüş %")

// --- YAYINLAMA İÇİN GEÇİCİ AL-SAT (DUMMY TRADE) ---
// Bu blok, raporun boş kalmasını engellemek için testin en başında sadece 1 tane al-sat işlemi yapar.
// Stratejinin ana mantığını ve genel performansını ETKİLEMEZ.
if bar_index == 1 // Testin ikinci barında (en başlarda)
    strategy.entry("GeciciAlim", strategy.long, qty=1, comment="Yayınlama için geçici alım")

if bar_index == 2 // Üçüncü barda, yani hemen sonra
    strategy.close("GeciciAlim", comment="Yayınlama için geçici satış")


// ----- Strateji Ana Mantığı -----
float dynamicHigh = ta.highest(high, lookbackPeriod)
float dropFromDynamicHigh = (dynamicHigh - close) / dynamicHigh * 100

bool trigger1 = dropFromDynamicHigh >= dropPercent1
bool trigger2 = dropFromDynamicHigh >= dropPercent2

bool buySignal1 = trigger1 and not trigger1[1]
bool buySignal2 = trigger2 and not trigger2[1]

// ----- Ana Alım Koşulları -----
if buySignal1
    strategy.entry("Alim S1", strategy.long, comment="Alım %-" + str.tostring(dropPercent1))

if buySignal2
    strategy.entry("Alim S2", strategy.long, comment="Alım %-" + str.tostring(dropPercent2))

// --- Test sonundaki pozisyonları kapatma (iyi bir pratiktir) ---
if barstate.islast
    strategy.close_all(comment="Test Sonu Kapanış")

// ----- Grafik Üzerinde Gösterim -----
plot(dynamicHigh, title="Dinamik Referans Zirvesi", color=color.new(color.orange, 0), style=plot.style_cross, linewidth=2)

