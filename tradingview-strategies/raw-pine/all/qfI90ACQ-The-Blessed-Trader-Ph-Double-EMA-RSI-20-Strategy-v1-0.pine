//@version=5
// ==================================================
// Strategy : Double EMA + RSI (20)
// Author   : The Blessed Trader Ph.
// Version  : v1.0
// ==================================================
strategy("The Blessed Trader Ph. | Double EMA + RSI (20) Strategy v1.0", overlay=true, initial_capital=10000, calc_on_every_tick=false)

// === Inputs ===
emaLength  = input.int(20, "EMA Length")
rsiLength  = input.int(20, "RSI Length")
rsiLevel   = input.int(50, "RSI Level")

atrLength = input.int(14, "ATR Length")
slMult    = input.float(1.5, "Stop Loss ATR Multiplier")
tpMult    = input.float(3.0, "Take Profit ATR Multiplier")

// === Calculations ===
emaHigh = ta.ema(high, emaLength)
emaLow  = ta.ema(low, emaLength)
rsiVal  = ta.rsi(close, rsiLength)
atrVal  = ta.atr(atrLength)

// === Plot EMAs ===
plot(emaHigh, title="EMA 20 High", color=color.green, linewidth=2)
plot(emaLow, title="EMA 20 Low", color=color.red, linewidth=2)

// === Conditions (Bar Close Confirmed) ===
buyCondition  = close > emaHigh and rsiVal > rsiLevel and barstate.isconfirmed
sellCondition = close < emaLow and rsiVal < rsiLevel and barstate.isconfirmed

// === Entry ===
if buyCondition
    strategy.entry("Buy", strategy.long)

// === Stop Loss & Take Profit ===
if strategy.position_size > 0
    stopLoss   = strategy.position_avg_price - atrVal * slMult
    takeProfit = strategy.position_avg_price + atrVal * tpMult
    strategy.exit("Exit Buy", "Buy", stop=stopLoss, limit=takeProfit)

// === Exit on Opposite Signal ===
if sellCondition
    strategy.close("Buy")

// === Alerts ===
alertcondition(buyCondition, title="BUY Alert", message="BUY Signal: EMA High Break + RSI > 50")
alertcondition(sellCondition, title="SELL Alert", message="SELL Signal: EMA Low Break + RSI < 50")

// === Watermark (FAIL-SAFE VERSION) ===
var table wm = table.new(position.bottom_right, 1, 1)
if barstate.islast
    table.cell(wm, 0, 0, "The Blessed Trader Ph.\nDouble EMA + RSI (20)\nv1.0", text_color=color.gray, text_size=size.large)

