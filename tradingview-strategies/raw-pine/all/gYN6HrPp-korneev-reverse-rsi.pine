//@version=5
strategy("Korneev Reverse RSI", shorttitle = "KRRSI", overlay = true, default_qty_type = strategy.percent_of_equity, default_qty_value = 100, pyramiding = 0, commission_value = 0.01, initial_capital = 10000)

rsperiod = input(defval = 14, title = "RSI Period")
rs = ta.rsi(length = rsperiod, source = ohlc4)
ma = ta.ema(source = rs, length = 14)
sh = input(defval = false, title = "Include Shorts (Not recommended)")

if (ma>80)
    strategy.entry(id = "Long", comment= "Open Long", direction=strategy.long)

if (ma<40)
    strategy.close(id = "Long", comment= "Close Long")

if (sh)
    if (ma<20)
        strategy.entry(id = "Short", comment= "Open Short", direction=strategy.short)
    if (ma>60)
        strategy.close(id = "Short", comment= "Close Short")


// in memory John Welles Wilder Jr.

