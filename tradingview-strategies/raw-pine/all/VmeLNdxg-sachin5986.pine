//@version=4
strategy("sachin5986")
ema3 = ema(close,3)
ema21 = ema(close,21)
long = ema3>ema21
short = ema3<ema21
start = timestamp(2022,19,7,0)
end = timestamp(2022,12,12,0)
strategy.entry("buy",strategy.long,when = long)
strategy.close("buy",when = short)
plot(close)

