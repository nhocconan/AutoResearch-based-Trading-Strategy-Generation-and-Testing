//@version=6
// Creator: K@lTony
strategy("SuperBreak Elite ORB Gold Lon & NY Intelligent Pro Filters", overlay=true,
         default_qty_type = strategy.percent_of_equity,
         default_qty_value = 1)

// ── INPUTS ─────────────────────────────────────
useStrategy = input.bool(true, "Attiva Test Strategia")
tpPoints = input.int(1500, "Take Profit (punti)", minval=500)
slMultiplier = input.float(3.0, "SL Multiplicatore (triplo)", minval=1.5)
useTrendFilter = input.bool(true, "Usa Filtro Trend EMA (per win rate alto)")
useBBFilter = input.bool(false, "Usa Filtro Bande di Bollinger (per volatilità e win rate alto)")
bbLength = input.int(20, "Lunghezza BB", minval=1)
bbStdDev = input.float(2.0, "Deviazione Std BB", minval=0.1)
minBBWidth = input.float(1.0, "Larghezza Minima BB (%)", minval=0.1)
orbMinutes = input.int(15, "ORB Durata (minuti)", minval=5, maxval=30)

// ── SESSIONI (orari in formato HHMM – adattati per ora italiana CET/UTC+1) ──────
londonSession = input.session("0900-1000", "Sessione Londra (09:00-10:00 IT)")
nySession = input.session("1430-1530", "Sessione NY (14:30-15:30 IT)")

// Calcola numero di barre per ORB
tfMin = str.tonumber(timeframe.period)
orbBars = math.round(orbMinutes / tfMin)
sessionBars = math.round(60 / tfMin)

// Rileva sessioni
inLondon = not na(time(timeframe.period, londonSession))
inNY = not na(time(timeframe.period, nySession))
newLondonBar = inLondon and not inLondon[1]
newNYBar = inNY and not inNY[1]

// ── VARIABILI PER ORB ───────────────────────────
var int londonBarCount = 0
var float londonORBHigh = na
var float londonORBLow = na
var bool londonSignalGiven = false

var int nyBarCount = 0
var float nyORBHigh = na
var float nyORBLow = na
var bool nySignalGiven = false

// Reset e aggiornamento ORB London
if newLondonBar
    londonBarCount := 1
    londonORBHigh := high
    londonORBLow := low
    londonSignalGiven := false
else if inLondon
    londonBarCount := londonBarCount[1] + 1
    if londonBarCount <= orbBars
        londonORBHigh := math.max(londonORBHigh, high)
        londonORBLow := math.min(londonORBLow, low)

// Reset e aggiornamento ORB NY
if newNYBar
    nyBarCount := 1
    nyORBHigh := high
    nyORBLow := low
    nySignalGiven := false
else if inNY
    nyBarCount := nyBarCount[1] + 1
    if nyBarCount <= orbBars
        nyORBHigh := math.max(nyORBHigh, high)
        nyORBLow := math.min(nyORBLow, low)

// ── INDICATORI BASE ────────────────────────────
ema50 = ta.ema(close, 50)
ema200 = ta.ema(close, 200)

// Bande di Bollinger
bbMiddle = ta.sma(close, bbLength)
bbStd = ta.stdev(close, bbLength)
bbUpper = bbMiddle + bbStdDev * bbStd
bbLower = bbMiddle - bbStdDev * bbStd
bbWidth = ((bbUpper - bbLower) / bbMiddle) * 100

// Bias esterni (DXY, VIX, US10Y)
dxy_close = request.security("TVC:DXY", "", close, ignore_invalid_symbol=true)
dxy_ema50 = ta.ema(dxy_close, 50)
vix_close = request.security("CBOE:VIX", "", close, ignore_invalid_symbol=true)
vix_ema = ta.ema(vix_close, 50)
us10y_close = request.security("TVC:US10Y", "", close, ignore_invalid_symbol=true)
us10y_ema = ta.ema(us10y_close, 50)

// ── SCORES PER BIAS ────────────────────────────
trendScore = ema50 > ema200 ? 1 : -1
dxyScore = dxy_close < dxy_ema50 ? 1 : dxy_close > dxy_ema50 ? -1 : 0
vixScore = vix_close > vix_ema ? 1 : vix_close < vix_ema ? -1 : 0
us10yScore = us10y_close < us10y_ema ? 1 : us10y_close > us10y_ema ? -1 : 0
totalScore = trendScore + dxyScore + vixScore + us10yScore
bullBias = totalScore >= 0
bearBias = totalScore < 0

bullTrend = ema50 > ema200
bearTrend = ema50 < ema200

volOk = not useBBFilter or bbWidth > minBBWidth

// ── DETEZIONE ULTIMI 5 MINUTI DELLA SESSIONE (PER FORZARE SEMPRE) ──────
// Parse session times for London and NY on first bar
var int london_start_h = na
var int london_start_m = na
var int london_end_h = na
var int london_end_m = na

var int ny_start_h = na
var int ny_start_m = na
var int ny_end_h = na
var int ny_end_m = na

if barstate.isfirst
    array<string> london_parts = str.split(londonSession, "-")
    string london_start_str = array.get(london_parts, 0)
    string london_end_str = array.get(london_parts, 1)
    london_start_h := int(str.tonumber(str.substring(london_start_str, 0, 2)))
    london_start_m := int(str.tonumber(str.substring(london_start_str, 2, 4)))
    london_end_h := int(str.tonumber(str.substring(london_end_str, 0, 2)))
    london_end_m := int(str.tonumber(str.substring(london_end_str, 2, 4)))
    
    array<string> ny_parts = str.split(nySession, "-")
    string ny_start_str = array.get(ny_parts, 0)
    string ny_end_str = array.get(ny_parts, 1)
    ny_start_h := int(str.tonumber(str.substring(ny_start_str, 0, 2)))
    ny_start_m := int(str.tonumber(str.substring(ny_start_str, 2, 4)))
    ny_end_h := int(str.tonumber(str.substring(ny_end_str, 0, 2)))
    ny_end_m := int(str.tonumber(str.substring(ny_end_str, 2, 4)))

// Session timestamps
var float london_start_timestamp = na
var float london_end_timestamp = na
if newLondonBar
    london_start_timestamp := time
    london_end_timestamp := timestamp(year(time), month(time), dayofmonth(time), london_end_h, london_end_m, 0)

var float ny_start_timestamp = na
var float ny_end_timestamp = na
if newNYBar
    ny_start_timestamp := time
    ny_end_timestamp := timestamp(year(time), month(time), dayofmonth(time), ny_end_h, ny_end_m, 0)

// Force period
int force_min = 5
float london_force_start = london_end_timestamp - (force_min * 60 * 1000)
float ny_force_start = ny_end_timestamp - (force_min * 60 * 1000)
float bar_close = time + (timeframe.in_seconds() * 1000)

// End phase detection (bar overlaps last 5 minutes)
londonEndPhase = inLondon and not na(london_end_timestamp) and bar_close > london_force_start and time < london_end_timestamp
nyEndPhase = inNY and not na(ny_end_timestamp) and bar_close > ny_force_start and time < ny_end_timestamp

// ── SEGNALI BREAKOUT (ora senza limite superiore di barre → possibilità fino all'ultimo minuto) ──
buyLondon = false
sellLondon = false
if inLondon and londonBarCount > orbBars and not londonSignalGiven
    if close > londonORBHigh and (not useTrendFilter or bullTrend) and volOk
        buyLondon := true
        londonSignalGiven := true
    else if close < londonORBLow and (not useTrendFilter or bearTrend) and volOk
        sellLondon := true
        londonSignalGiven := true

// ── FORZA SEGNALE (sempre negli ultimi 5 minuti se non è uscito niente) ──────
if londonEndPhase and not londonSignalGiven
    if bullBias
        buyLondon := true
        londonSignalGiven := true
    else if bearBias
        sellLondon := true
        londonSignalGiven := true

buyNY = false
sellNY = false
if inNY and nyBarCount > orbBars and not nySignalGiven
    if close > nyORBHigh and (not useTrendFilter or bullTrend) and volOk
        buyNY := true
        nySignalGiven := true
    else if close < nyORBLow and (not useTrendFilter or bearTrend) and volOk
        sellNY := true
        nySignalGiven := true

if nyEndPhase and not nySignalGiven
    if bullBias
        buyNY := true
        nySignalGiven := true
    else if bearBias
        sellNY := true
        nySignalGiven := true

buySignal = buyLondon or buyNY
sellSignal = sellLondon or sellNY

// ── ESECUZIONE ─────────────────────────────────
if buySignal and strategy.position_size <= 0 and useStrategy
    strategy.entry("BUY", strategy.long)
    strategy.exit("TP/SL BUY", from_entry="BUY", profit=tpPoints, loss=tpPoints * slMultiplier)

if sellSignal and strategy.position_size >= 0 and useStrategy
    strategy.entry("SELL", strategy.short)
    strategy.exit("TP/SL SELL", from_entry="SELL", profit=tpPoints, loss=tpPoints * slMultiplier)

// ── VISUALI ────────────────────────────────────
plot(ema50, "EMA 50", color=color.blue, linewidth=2)
plot(ema200, "EMA 200", color=color.orange, linewidth=2)

plot(bbUpper, "BB Upper", color=color.purple, linewidth=1)
plot(bbMiddle, "BB Middle", color=color.gray, linewidth=1)
plot(bbLower, "BB Lower", color=color.purple, linewidth=1)

plot(inLondon ? londonORBHigh : na, "London ORB High", color=color.green, style=plot.style_linebr)
plot(inLondon ? londonORBLow : na, "London ORB Low", color=color.red, style=plot.style_linebr)
plot(inNY ? nyORBHigh : na, "NY ORB High", color=color.green, style=plot.style_linebr)
plot(inNY ? nyORBLow : na, "NY ORB Low", color=color.red, style=plot.style_linebr)

plotshape(buySignal, title="BUY", location=location.belowbar, color=color.green, style=shape.triangleup, size=size.large, text="BUY")
plotshape(sellSignal, title="SELL", location=location.abovebar, color=color.red, style=shape.triangledown, size=size.large, text="SELL")

bgcolor(newLondonBar ? color.new(color.blue, 85) : na, title="London Open")
bgcolor(newNYBar ? color.new(color.orange, 85) : na, title="NY Open")

// ── ALERT ──────────────────────────────────────
alertcondition(buySignal, title="BUY ORB/Forced", message="🚀 BUY XAUUSD – Sessione Open (ORB/Forced)")
alertcondition(sellSignal, title="SELL ORB/Forced", message="🔻 SELL XAUUSD – Sessione Open (ORB/Forced)")

