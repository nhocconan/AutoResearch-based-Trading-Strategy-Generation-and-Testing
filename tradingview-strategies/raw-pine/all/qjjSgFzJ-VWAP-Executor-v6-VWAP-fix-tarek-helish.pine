//@version=6
strategy("XAUUSD VWAP Executor — v6 (VWAP fix)",
     overlay=true,
     process_orders_on_close=true,
     calc_on_every_tick=false)

// ===== الإعدادات =====
enableTrading = input.bool(true, "تنفيذ أوامر (تشغيل/إيقاف)")
showSignals   = input.bool(true, "إظهار أسهم الإشارات")
showHint      = input.bool(true, "إظهار تنبيه عند غياب الـ Volume")

tfTrend       = input.timeframe("5", "إطار فلتر الاتجاه (EMA/ADX)")
emaLen        = input.int(50,  "طول EMA على إطار الاتجاه", minval=1)

atrLen        = input.int(14, "ATR Length", minval=1)
atrStopMult   = input.float(0.60, "وقف: ×ATR", step=0.05)
atrTPMult     = input.float(0.50, "هدف: ×ATR", step=0.05)
bandATRmult   = input.float(0.20, "أقصى بُعد عن VWAP: ×ATR", step=0.05)

useRSI        = input.bool(true, "فلتر RSI(2)")
rsiLen        = input.int(2, "RSI Length", minval=1)
rsiBuyMax     = input.int(5,  "RSI(2) ≤ (للشراء)", minval=1, maxval=50)
rsiSellMin    = input.int(95, "RSI(2) ≥ (للبيع)",  minval=50, maxval=100)

useADX        = input.bool(true, "فلتر ADX (على إطار الاتجاه)")
adxLen        = input.int(14, "DI Length", minval=1)
adxSmoothLen  = input.int(14, "ADX Smoothing", minval=1)
adxMin        = input.float(18, "ADX ≥", step=0.5)

session1      = input.session("1000-1200", "جلسة 1 (بتوقيت بورصة الرمز)")
session2      = input.session("1630-1800", "جلسة 2 (بتوقيت بورصة الرمز)")

// ===== المؤشرات =====
atr   = ta.atr(atrLen)
rsi2  = ta.rsi(close, rsiLen)
emaTrend  = request.security(syminfo.tickerid, tfTrend, ta.ema(close, emaLen))

// فحص وجود Volume (بعض رموز الذهب/الفوركس لا تُعيد حجماً)
hasVol = not na(volume) and volume > 0
vwapVal = hasVol ? ta.vwap(hlc3) : na

// ADX عبر DMI على إطار الاتجاه
f_adx(_diLen, _smoothLen) =>
    [_, _, _adx] = ta.dmi(_diLen, _smoothLen)
    _adx
adxTF = request.security(syminfo.tickerid, tfTrend, f_adx(adxLen, adxSmoothLen))

// ===== فلاتر وإشارات =====
inSess    = not na(time(timeframe.period, session1)) or not na(time(timeframe.period, session2))
adxOK     = not useADX or adxTF >= adxMin
nearVWAP  = math.abs(close - vwapVal) <= atr * bandATRmult
longTrend  = close >  emaTrend
shortTrend = close <  emaTrend
longRSIok  = (not useRSI) or (rsi2 <= rsiBuyMax)
shortRSIok = (not useRSI) or (rsi2 >= rsiSellMin)

longSigRaw  = hasVol and inSess and adxOK and longTrend  and nearVWAP and close > vwapVal and longRSIok
shortSigRaw = hasVol and inSess and adxOK and shortTrend and nearVWAP and close < vwapVal and shortRSIok
longSig  = longSigRaw  and barstate.isconfirmed
shortSig = shortSigRaw and barstate.isconfirmed

// ===== تنفيذ الأوامر =====
flat = strategy.position_size == 0
if enableTrading and flat and longSig and not shortSig
    strategy.entry("L", strategy.long)
if enableTrading and flat and shortSig and not longSig
    strategy.entry("S", strategy.short)

if strategy.position_size > 0
    longStop = strategy.position_avg_price - atr * atrStopMult
    longTP   = strategy.position_avg_price + atr * atrTPMult
    strategy.exit("L-Exit", from_entry="L", stop=longStop, limit=longTP)
if strategy.position_size < 0
    shortStop = strategy.position_avg_price + atr * atrStopMult
    shortTP   = strategy.position_avg_price - atr * atrTPMult
    strategy.exit("S-Exit", from_entry="S", stop=shortStop, limit=shortTP)

// ===== رسومات/تنبيهات =====
plot(emaTrend, "EMA(Trend TF)", color=color.orange, linewidth=2)
plot(vwapVal,  "VWAP",          color=color.new(color.blue, 0), linewidth=2)

plotshape(series=showSignals and longSig,  title="VWAP Long",
     style=shape.triangleup,   location=location.belowbar, size=size.tiny,
     text="BUY",  color=color.new(color.green,0))
plotshape(series=showSignals and shortSig, title="VWAP Short",
     style=shape.triangledown, location=location.abovebar, size=size.tiny,
     text="SELL", color=color.new(color.red,0))

// تلميح في حال عدم توفر الـ Volume (بدون if محلّي)
plotshape(series=showHint and not hasVol and barstate.islast, title="VWAP Hint",
     style=shape.labeldown, location=location.abovebar, size=size.small,
     text="VWAP يحتاج Volume\nجرّب OANDA/FOREXCOM\nواستخدم فريم داخل اليوم",
     color=color.new(color.orange, 0), textcolor=color.black)

alertcondition(longSig,  title="VWAP Long",  message="VWAP Long on {{ticker}} {{interval}}")
alertcondition(shortSig, title="VWAP Short", message="VWAP Short on {{ticker}} {{interval}}")

