//@version=5
strategy("Estratégia - CCI + PVT", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=100)

// Parâmetros
cciShort = input.int(14, title="CCI Curto")
cciLong  = input.int(50, title="CCI Longo")
pvtMaLen = input.int(50, title="Período da Média PVT")

// Cálculo dos CCIs
cci14 = ta.cci(close, cciShort)
cci50 = ta.cci(close, cciLong)

// Cálculo do PVT
var float pvt = na
pvt := nz(pvt[1]) + ((close - close[1]) / close[1]) * volume
pvt_ma = ta.sma(pvt, pvtMaLen)

// Condições
cond_compra = cci14 > 0 and cci50 > 0 and pvt > pvt_ma
cond_venda  = cci14 < 0 and cci50 < 0 and pvt < pvt_ma

// Entradas e saídas
if (cond_compra and strategy.position_size <= 0)
    strategy.entry("Compra", strategy.long)

if (cond_venda and strategy.position_size >= 0)
    strategy.entry("Venda", strategy.short)

// Visual (opcional)
barcolor(cond_compra ? color.green : cond_venda ? color.red : na)
plotshape(cond_compra, title="Sinal de Compra", location=location.belowbar, color=color.green, style=shape.labelup, text="BUY")
plotshape(cond_venda, title="Sinal de Venda", location=location.abovebar, color=color.red, style=shape.labeldown, text="SELL")

