//@version=5
strategy("Rare SMC BOS/CHoCH 5M 1:3 with Labels", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=1)


lookback = input.int(5, "Swing Lookback")
rr = input.float(3.0, "Risk Reward")  // יחס סיכון-תמורה 1:3

// === י Swing High / Low ===
swingHigh = ta.highest(high, lookback)[1]
swingLow  = ta.lowest(low, lookback)[1]

// =י BOS / CHoCH ===
bullBOS = close > swingHigh
bearBOS = close < swingLow

// === + TP/SL ===

// 🔹 
if bullBOS
    entryPrice = close
    stopPrice  = swingLow
    risk       = entryPrice - stopPrice
    takeProfit = entryPrice + risk * rr
    strategy.entry("BOS Long", strategy.long)
    strategy.exit("TP/SL Long", "BOS Long", stop=stopPrice, limit=takeProfit)
    label.new(bar_index, low, "BUY", color=color.green, style=label.style_label_up, textcolor=color.white, size=size.normal)

// 🔹
if bearBOS
    entryPrice = close
    stopPrice  = swingHigh
    risk       = stopPrice - entryPrice
    takeProfit = entryPrice - risk * rr
    strategy.entry("BOS Short", strategy.short)
    strategy.exit("TP/SL Short", "BOS Short", stop=stopPrice, limit=takeProfit)
    label.new(bar_index, high, "SELL", color=color.red, style=label.style_label_down, textcolor=color.white, size=size.normal)

// swig High / Low ===
plot(swingHigh, color=color.red, title="Swing High")
plot(swingLow, color=color.green, title="Swing Low")

