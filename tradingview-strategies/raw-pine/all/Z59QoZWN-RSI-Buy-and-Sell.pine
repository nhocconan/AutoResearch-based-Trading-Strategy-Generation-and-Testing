//@version=3
///buy when rsi is above 70 and don't sell until rsi is below 30.
strategy("RSI Buy and Sell", overlay=true)
a = rsi(close,14)
OB = input(70)
OS = input(30)
os = a > OB
ob = a < OS
strategy.entry("RSI", strategy.long, when = os)
strategy.close_all(when = ob)

