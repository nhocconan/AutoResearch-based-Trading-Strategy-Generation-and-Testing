//@version=6
strategy("EQL/EQH Reversal System", overlay=true, default_qty_type=strategy.fixed, default_qty_value=1)

// === INPUTS ===
i_look = input.int(30, "Lookback Bars")
i_tol = input.float(5.0, "Tolerance (pts)")
i_sess = input.session("0945-1400", "Session")

// ATR Settings
i_atrLen = input.int(14, "ATR Length")
i_atrStopMult = input.float(1.5, "ATR Stop Multiplier")
i_atrTargetMult = input.float(2.5, "ATR Target Multiplier")

// === SESSION ===
inSess = not na(time(timeframe.period, i_sess))

// === ATR ===
atr = ta.atr(i_atrLen)
stopDist = atr * i_atrStopMult
targetDist = atr * i_atrTargetMult

// === FIND HIGHEST/LOWEST ===
hh = ta.highest(high, i_look)
ll = ta.lowest(low, i_look)

// === COUNT TOUCHES ===
eqhCount = 0
eqlCount = 0
for i = 1 to i_look
    if high[i] >= hh - i_tol
        eqhCount += 1
    if low[i] <= ll + i_tol
        eqlCount += 1

// === ENTRY CONDITIONS ===
shortCond = eqhCount >= 2 and high >= hh - i_tol
longCond = eqlCount >= 2 and low <= ll + i_tol

shortSig = inSess and strategy.position_size == 0 and shortCond
longSig = inSess and strategy.position_size == 0 and longCond and not shortSig

// === TRADES ===
if shortSig
    strategy.entry("Short", strategy.short)
    strategy.exit("SX", "Short", limit=close - targetDist, stop=close + stopDist)

if longSig
    strategy.entry("Long", strategy.long)
    strategy.exit("LX", "Long", limit=close + targetDist, stop=close - stopDist)

// === PLOTS ===
plot(eqhCount >= 2 ? hh : na, "EQH", color.red, 2)
plot(eqlCount >= 2 ? ll : na, "EQL", color.green, 2)
plotshape(shortSig, "Short", style=shape.triangledown, location=location.abovebar, color=color.red)
plotshape(longSig, "Long", style=shape.triangleup, location=location.belowbar, color=color.green)

