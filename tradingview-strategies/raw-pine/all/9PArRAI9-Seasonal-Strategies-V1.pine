//@version=6
// Seasonal Strategies V1 (PUBLIC) — baseline version WITHOUT on-chart season table
// cot-trader.com

strategy("Seasonal Strategies V1", overlay=true,
     default_qty_type=strategy.fixed, default_qty_value=1,
     initial_capital=10000,
     commission_type=strategy.commission.cash_per_contract, commission_value=3,
     pyramiding=0, margin_long=0, margin_short=0)

isInSeason(startMMDD, endMMDD) =>
    mmdd = month * 100 + dayofmonth
    if startMMDD <= endMMDD
        mmdd >= startMMDD and mmdd <= endMMDD
    else
        mmdd >= startMMDD or mmdd <= endMMDD

var int[] longZones  = array.new_int()
var int[] shortZones = array.new_int()

if bar_index == 0
    asset = syminfo.root

    // ── Original set
    if asset == "CC"
        array.push(longZones, 129),  array.push(longZones, 421)
        array.push(longZones, 814),  array.push(longZones, 914)
        array.push(longZones, 1006), array.push(longZones, 1213)

