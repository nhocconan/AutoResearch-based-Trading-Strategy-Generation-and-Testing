        array.push(longZones, 914),  array.push(longZones, 1110)

    if asset == "ZM"
        array.push(longZones, 901),  array.push(longZones, 1121)

    if asset == "ZR"
        array.push(longZones, 102),  array.push(longZones, 128)
        array.push(longZones, 309),  array.push(longZones, 603)
        array.push(longZones, 810),  array.push(longZones, 917)
        array.push(longZones, 1029), array.push(longZones, 1129)

zoneColorLong  = color.new(color.green, 85)
zoneColorShort = color.new(color.red, 85)

longActive  = false
shortActive = false

if array.size(longZones) > 0
    for i = 0 to array.size(longZones) / 2 - 1
        s = array.get(longZones, i * 2)
        e = array.get(longZones, i * 2 + 1)
        if isInSeason(s, e)
            longActive := true

if array.size(shortZones) > 0
    for i = 0 to array.size(shortZones) / 2 - 1
        s = array.get(shortZones, i * 2)
        e = array.get(shortZones, i * 2 + 1)
        if isInSeason(s, e)
            shortActive := true

var bool lastLong  = false
var bool lastShort = false

if not lastLong and longActive and strategy.position_size == 0
    strategy.entry("Long", strategy.long)

if lastLong and not longActive and strategy.position_size > 0 and strategy.opentrades.entry_id(0) == "Long"
    strategy.close("Long")

if not lastShort and shortActive and strategy.position_size == 0
    strategy.entry("Short", strategy.short)

if lastShort and not shortActive and strategy.position_size < 0 and strategy.opentrades.entry_id(0) == "Short"
    strategy.close("Short")

lastLong  := longActive
lastShort := shortActive

bgcolor(longActive ? zoneColorLong : na)
bgcolor(shortActive ? zoneColorShort : na)

