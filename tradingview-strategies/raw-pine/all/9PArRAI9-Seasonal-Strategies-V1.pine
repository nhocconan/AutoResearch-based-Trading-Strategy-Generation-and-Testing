        array.push(longZones, 930),  array.push(longZones, 1226)

    if asset == "SB"
        array.push(longZones, 503),  array.push(longZones, 608)
        array.push(longZones, 820),  array.push(longZones, 1115)

    if asset == "SI"
        array.push(longZones, 108),  array.push(longZones, 221)
        array.push(longZones, 321),  array.push(longZones, 601)
        array.push(longZones, 929),  array.push(longZones, 1024)
