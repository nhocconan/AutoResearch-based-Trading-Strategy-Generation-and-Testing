//@version=6
strategy("阳光电源 | Regime Guard + Turtle Breakout + MFE 2-Stage Trail | Long-only | v6 (Offline-Tuned)",
     overlay=true,
     pyramiding=2,
     initial_capital=100000,
     commission_type=strategy.commission.percent,
     commission_value=0.03,
     slippage=1,
     process_orders_on_close=true)

lotShares = input.int(100, "A-share lot shares (每手股数)", minval=1)
roundToLot(shares) =>
    s = math.floor(shares)
    math.floor(s / lotShares) * lotShares

useChiNextDynamicLimit = input.bool(true, "ChiNext dynamic limit (10% before 2020-08-24, 20% after)")
fixedLimitPct = input.float(0.20, "Fixed limit (%) if not using dynamic", minval=0.05, maxval=0.30, step=0.01)
chiNextStartMs = 1598227200000  // 2020-08-24 00:00:00 UTC
limitPct = useChiNextDynamicLimit ? (time < chiNextStartMs ? 0.10 : 0.20) : fixedLimitPct

blockEntryOnLimitUp  = input.bool(true,  "Block entry on limit-up (涨停不追)")
blockExitOnLimitDown = input.bool(false, "Conservative: block exits on limit-down (跌停可能卖不出)")
isLimitUp   = not na(close[1]) and close >= close[1] * (1 + limitPct - 0.001)
isLimitDown = not na(close[1]) and close <= close[1] * (1 - limitPct + 0.001)
canEnterBar = not (blockEntryOnLimitUp and isLimitUp)
canExitBar  = not (blockExitOnLimitDown and isLimitDown)

atr = ta.atr(14)
atrPct = atr / close * 100.0
ema200 = ta.ema(close, 200)

// slope
slopeBars    = input.int(67, "EMA slope lookback", minval=5, maxval=120)
requireSlope = input.bool(false, "Require EMA slope up")
emaUp        = ema200 > ema200[slopeBars]

// ADX (dmi)
diLen = input.int(14, "DMI length", minval=5, maxval=50)
adxSmooth = input.int(14, "ADX smoothing", minval=5, maxval=50)
[pdi, mdi, adx] = ta.dmi(diLen, adxSmooth)
useAdxFilter = input.bool(false, "Use ADX filter")
adxMin       = input.float(18.24, "ADX min", minval=5, step=0.5)

// guards
useAtrGuard = input.bool(true, "ATR% guard")
atrPctGuard = input.float(13.49, "Block entry/add if ATR% > x", minval=3.0, step=0.1)
atrOk = (not useAtrGuard) or (atrPct <= atrPctGuard)

bullRegime = close > ema200 and (not requireSlope or emaUp) and (not useAdxFilter or adx >= adxMin)

// DD scaling + vol targeting
var float peakEq = na
peakEq := na(peakEq) ? strategy.equity : math.max(peakEq, strategy.equity)
ddPct = peakEq > 0 ? (peakEq - strategy.equity) / peakEq * 100.0 : 0.0

ddStart = input.float(4.38, "DD scale start %", minval=0.5, step=0.5)
ddEnd   = input.float(12.04, "DD scale end %", minval=1.0, step=0.5)
ddMinScale = input.float(0.56, "Min scale", minval=0.1, maxval=1.0, step=0.01)
scaleDD = ddPct <= ddStart ? 1.0 : ddPct >= ddEnd ? ddMinScale : (1.0 - (ddPct - ddStart)/(ddEnd - ddStart) * (1.0 - ddMinScale))

useVolTarget = input.bool(true, "Volatility targeting")
volTargetPct = input.float(5.68, "Target ATR%", minval=0.5, step=0.1)
volMinLev = input.float(0.81, "Min lev", minval=0.1, maxval=3.0, step=0.01)
volMaxLev = input.float(1.26, "Max lev", minval=0.5, maxval=5.0, step=0.01)
lev = (useVolTarget and atrPct > 0) ? math.min(volMaxLev, math.max(volMinLev, volTargetPct / atrPct)) : 1.0
scale = scaleDD * lev

maxExposurePct = input.float(75.1, "Max exposure cap (% equity)", minval=10, maxval=120, step=1)
entryPct       = input.float(53.1, "Entry exposure (% equity)", minval=1, maxval=120, step=1)
addPct         = input.float(79.3, "Add exposure (% equity)", minval=0, maxval=120, step=1)

useRiskCap = input.bool(true, "Risk cap sizing")
riskCapPct = input.float(3.00, "Max loss at stop (% equity)", minval=0.1, step=0.1)

qtyFromPct(pct) =>
    desiredValue  = strategy.equity * (pct / 100.0)
    desiredShares = desiredValue / close
    capValue      = strategy.equity * (maxExposurePct / 100.0)
    capShares     = capValue / close
    curShares     = math.max(strategy.position_size, 0)
    remainShares  = math.max(0.0, capShares - curShares)
    roundToLot(math.min(desiredShares, remainShares))

riskCapShares(stopDist) =>
    raw = (useRiskCap and stopDist > 0) ? (strategy.equity * (riskCapPct/100.0) / stopDist) : 1e18
    roundToLot(raw)

// anti-chop
breakBufPct  = input.float(0.13, "Breakout buffer %", minval=0.0, step=0.05)
cooldownBars = input.int(3, "Cooldown bars after exit", minval=0, maxval=200)
minHoldBars  = input.int(4, "Min hold bars before Donchian exit", minval=0, maxval=100)

var int lastExitBar = na
exitPos = (strategy.position_size==0) and (strategy.position_size[1]>0)
if exitPos
    lastExitBar := bar_index
coolOk = cooldownBars==0 ? true : (na(lastExitBar) or (bar_index-lastExitBar>=cooldownBars))

// donchian
entryLen = input.int(73, "Entry breakout len", minval=10, maxval=200)
exitLen  = input.int(24,  "Exit breakout len", minval=5, maxval=120)
addLen   = input.int(12,   "Add breakout len", minval=5, maxval=120)

hiEntry = ta.highest(high, entryLen)[1]
loExit  = ta.lowest(low,  exitLen)[1]
hiAdd   = ta.highest(high, addLen)[1]

breakLevel = not na(hiEntry) ? hiEntry * (1 + breakBufPct/100.0) : na
addLevel   = not na(hiAdd)   ? hiAdd   * (1 + breakBufPct/100.0) : na

entrySignal = bullRegime and atrOk and coolOk and canEnterBar and not na(breakLevel) and ta.crossover(close, breakLevel)
exitSignal  = not na(loExit) and ta.crossunder(close, loExit)
addSignal   = bullRegime and atrOk and canEnterBar and not na(addLevel) and ta.crossover(close, addLevel)

// stops
initStopATR = input.float(2.43, "Init stop ATR mult", minval=0.5, step=0.1)
trailBase   = input.float(4.16, "Trail ATR mult (base)", minval=1.0, step=0.1)
trailTight  = input.float(3.00, "Trail ATR mult (tight)", minval=1.0, step=0.1)
tightenAtR  = input.float(3.79, "Tighten after MFE >= R", minval=0.5, step=0.1)

useBE = input.bool(true, "Breakeven after +R")
beR   = input.float(1.28, "BE trigger (R)", minval=0.2, step=0.1)

useRegimeExit = input.bool(true, "Regime exit (close < EMA200)")

// adds
maxAdds     = input.int(1, "Max adds", minval=0, maxval=5)
addCooldown = input.int(2, "Add cooldown (bars)", minval=0, maxval=200)
addAfterR   = input.float(0.83, "Add after profit >= R", minval=0.0, step=0.05)

// state
inPos = strategy.position_size > 0
avg   = strategy.position_avg_price

var float entryStopDist = na
var float hhSince = na
var float trailMono = na
var int addCount = 0
var int lastAddBar = na
var int entryBar = na
var float effStopPlot = na

newPos = (strategy.position_size>0) and (strategy.position_size[1]<=0)
if newPos
    entryBar := bar_index
    hhSince := high
    trailMono := na
    addCount := 0
    lastAddBar := na

if not inPos
    entryStopDist := na
    hhSince := na
    trailMono := na
    addCount := 0
    lastAddBar := na
    entryBar := na
    effStopPlot := na

// entry
if (not inPos) and entrySignal
    stopDistNow = initStopATR * atr
    entryStopDist := stopDistNow
    q = math.min(qtyFromPct(entryPct * scale), riskCapShares(stopDistNow))
    if q >= lotShares
        strategy.entry("L", strategy.long, qty=q)

// adds
profitR_now = (inPos and not na(entryStopDist) and entryStopDist>0) ? ((close-avg)/entryStopDist) : 0.0
addCoolOk = addCooldown==0 ? true : (na(lastAddBar) or (bar_index-lastAddBar>=addCooldown))
canAdd = inPos and addSignal and (close>avg) and addCoolOk and (addCount<maxAdds) and (profitR_now>=addAfterR)

if canAdd
    stopDistNow = initStopATR * atr
    qA = math.min(qtyFromPct(addPct * scale), riskCapShares(stopDistNow))
    if qA >= lotShares
        strategy.entry("L", strategy.long, qty=qA)
        addCount += 1
        lastAddBar := bar_index

// exits
if inPos and not na(entryStopDist)
    hhSince := na(hhSince) ? high : math.max(hhSince, high)
    profitR_mfe = (hhSince - avg) / entryStopDist
    tMult = (profitR_mfe >= tightenAtR) ? trailTight : trailBase
    trailRaw = hhSince - tMult * atr
    trailMono := na(trailMono[1]) ? trailRaw : math.max(trailMono[1], trailRaw)

    initStop = avg - entryStopDist
    effStop  = math.max(initStop, trailMono)
    if useBE and (close-avg >= beR * entryStopDist)
        effStop := math.max(effStop, avg)

    effStopPlot := effStop
    if canExitBar
        strategy.exit("STOP", from_entry="L", stop=effStop)

    holdOk = (minHoldBars==0) ? true : (not na(entryBar) and (bar_index-entryBar>=minHoldBars))
    if canExitBar and holdOk and exitSignal
        strategy.close("L", comment="DonchianExit")
    if canExitBar and useRegimeExit and close < ema200
        strategy.close("L", comment="RegimeExit")
else
    effStopPlot := na

plot(ema200, "EMA200", linewidth=2)
plot(effStopPlot, "Stop", style=plot.style_linebr, linewidth=2)

