//@version=5
strategy("Hyper Insight MA Strategy [Universal]", overlay=true, initial_capital=10000, default_qty_type=strategy.percent_of_equity, default_qty_value=100)

// =============================================================================
// 1. INPUTS & CONFIGURATION
// =============================================================================
grp_ma = "Moving Average Settings"

// MA Types Options
ma_options = input.string("SMA", "MA Type Options", options=["SMA", "EMA", "WMA", "HMA", "RMA", "T3", "ALMA", "VWMA", "LSMA", "SWMA", "DEMA", "TEMA", "ZLEMA"], group=grp_ma, tooltip="Select the type of Moving Average calculation")

// Fast MA Inputs (Default: 5)
fastType = input.string("SMA", "Fast MA Type", options=["SMA", "EMA", "WMA", "HMA", "RMA", "T3", "ALMA", "VWMA", "LSMA", "SWMA", "DEMA", "TEMA", "ZLEMA"], group=grp_ma)
fastLen  = input.int(5, "Fast MA Length", minval=1, group=grp_ma)

// Slow MA Inputs (Default: 10)
slowType = input.string("HMA", "Slow MA Type", options=["SMA", "EMA", "WMA", "HMA", "RMA", "T3", "ALMA", "VWMA", "LSMA", "SWMA", "DEMA", "TEMA", "ZLEMA"], group=grp_ma)
slowLen  = input.int(10, "Slow MA Length", minval=1, group=grp_ma)

// =============================================================================
// 2. HELPER FUNCTIONS
// =============================================================================

// T3 Moving Average
t3(src, len) =>
    v = 0.7
    e1 = ta.ema(src, len)
    e2 = ta.ema(e1, len)
    e3 = ta.ema(e2, len)
    c1 = -math.pow(v, 3)
    c2 = 3*math.pow(v, 2) + 3*math.pow(v, 3)
    c3 = -6*math.pow(v, 2) - 3*v - 3*math.pow(v, 3)
    c4 = 1 + 3*v + math.pow(v, 3) + 3*math.pow(v, 2)
    c1*e3 + c2*e2 + c3*e1 + c4*src

// DEMA (Double Exponential Moving Average)
dema(src, len) =>
    e1 = ta.ema(src, len)
    e2 = ta.ema(e1, len)
    2 * e1 - e2

// TEMA (Triple Exponential Moving Average)
tema(src, len) =>
    e1 = ta.ema(src, len)
    e2 = ta.ema(e1, len)
    e3 = ta.ema(e2, len)
    3 * e1 - 3 * e2 + e3

// ZLEMA (Zero Lag Exponential Moving Average)
zlema(src, len) =>
    lag = math.floor((len - 1) / 2)
    ema_data = src + (src - src[lag])
    ta.ema(ema_data, len)

// Universal MA Switcher
get_ma(type, len) =>
    float res = na
    if type == "SMA"
        res := ta.sma(close, len)
    else if type == "EMA"
        res := ta.ema(close, len)
    else if type == "WMA"
        res := ta.wma(close, len)
    else if type == "HMA"
        res := ta.hma(close, len)
    else if type == "RMA"
        res := ta.rma(close, len)
    else if type == "T3"
        res := t3(close, len)
    else if type == "ALMA"
        res := ta.alma(close, len, 0.85, 6)
    else if type == "VWMA"
        res := ta.vwma(close, len)
    else if type == "LSMA"
        res := ta.linreg(close, len, 0)
    else if type == "SWMA"
        res := ta.swma(close) // Note: SWMA usually has fixed length 4 in Pine, but we keep structure
    else if type == "DEMA"
        res := dema(close, len)
    else if type == "TEMA"
        res := tema(close, len)
    else if type == "ZLEMA"
        res := zlema(close, len)
    res

// =============================================================================
// 3. LOGIC CALCULATION
// =============================================================================
// Get MAs
fastMA = get_ma(fastType, fastLen)
slowMA = get_ma(slowType, slowLen)

// =============================================================================
// 4. STRATEGY EXECUTION
// =============================================================================
// Conditions
crossover_bull = ta.crossover(fastMA, slowMA)
crossunder_bear = ta.crossunder(fastMA, slowMA)

// Entry/Exit
if crossover_bull
    strategy.entry("Long", strategy.long)

if crossunder_bear
    strategy.close("Long")
    // Uncomment below to enable Shorting
    // strategy.entry("Short", strategy.short)

// =============================================================================
// 5. VISUALIZATION
// =============================================================================
plot(fastMA, color=color.rgb(0, 255, 0), title="Fast MA", linewidth=2)
plot(slowMA, color=color.rgb(255, 0, 0), title="Slow MA", linewidth=2)

// Fill background between MAs for visual trend
fill(plot(fastMA, display=display.none), plot(slowMA, display=display.none), color = fastMA > slowMA ? color.new(color.green, 90) : color.new(color.red, 90), title="Trend Cloud")

