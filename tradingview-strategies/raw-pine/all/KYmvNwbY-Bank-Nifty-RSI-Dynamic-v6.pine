//@version=6
strategy("Bank Nifty RSI Dynamic v6", 
     overlay=true, 
     initial_capital=500000, 
     pyramiding=0, 
     margin_long=0, 
     margin_short=0)

// --- Inputs ---
int rsiLength      = input.int(14, "RSI Length")
int rsiUpperEntry  = input.int(68, "RSI Put Entry (>68)")
int rsiLowerEntry  = input.int(30, "RSI Call Entry (<30)")
int rsiPutExit     = input.int(56, "RSI Put Exit (<56)")
int rsiCallExit    = input.int(45, "RSI Call Exit (>45)")

// --- Math for 3 Lots (90 Units) ---
int totalUnits     = 90 

// --- Indicators ---
float rsiValue = ta.rsi(close, rsiLength)

// --- Strategy Logic ---
// 1. ENTRY CONDITIONS (On Candle Close)
bool buyCall = ta.crossunder(rsiValue, rsiLowerEntry) 
bool buyPut  = ta.crossover(rsiValue, rsiUpperEntry)

// 2. EXIT CONDITIONS (On Candle Close)
// If we hold a Call, exit when RSI rises above 45
bool exitCall = strategy.position_size > 0 and rsiValue > rsiCallExit
// If we hold a Put, exit when RSI drops below 56
bool exitPut  = strategy.position_size < 0 and rsiValue < rsiPutExit

// --- Execution ---

// Enter Trades
if buyCall
    strategy.entry("Call", strategy.long, qty=totalUnits, comment="RSI < 30")

if buyPut
    strategy.entry("Put", strategy.short, qty=totalUnits, comment="RSI > 68")

// Exit Trades based on your RSI levels
if exitCall
    strategy.close("Call", comment="RSI > 45 Exit")

if exitPut
    strategy.close("Put", comment="RSI < 56 Exit")

// --- Visuals ---
plot(rsiValue, "RSI", color=color.purple, display=display.none)
hline(rsiUpperEntry, "Put Entry", color=color.red)
hline(rsiPutExit, "Put Exit", color=color.orange, linestyle=hline.style_dotted)
hline(rsiCallExit, "Call Exit", color=color.blue, linestyle=hline.style_dotted)
hline(rsiLowerEntry, "Call Entry", color=color.green)

// Mark entries/exits on chart
plotshape(buyCall, "Call Buy", shape.triangleup, location.belowbar, color.green, size=size.small)
plotshape(buyPut, "Put Buy", shape.triangledown, location.abovebar, color.red, size=size.small)

