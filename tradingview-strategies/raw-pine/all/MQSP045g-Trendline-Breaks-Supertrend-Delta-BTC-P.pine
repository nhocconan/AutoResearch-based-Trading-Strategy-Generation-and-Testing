//@version=5
strategy("Trendline Breaks + Supertrend [Delta BTC-P]", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=100)

//-----------------------------------------------------------------------------
//Inputs
//-----------------------------------------------------------------------------
length = input.int(14, 'Swing Detection Lookback')
mult = input.float(1.0, 'Slope Multiplier', minval=0)
calcMethod = input.string('Atr', 'Slope Calculation Method', options=['Atr', 'Stdev', 'Linreg'])
supertrendFactor = input.float(3.0, 'Supertrend ATR Mult')
supertrendPeriod = input.int(10, 'Supertrend ATR Period')
slPerc = input.float(1.0, 'Stop Loss % (if manual disabled)', minval=0.1)
tpPerc = input.float(2.0, 'Take Profit % (if manual disabled)', minval=0.1)
manualTP = input.float(0.0, 'Manual Take Profit Price (0 = disabled)', minval=0)
manualSL = input.float(0.0, 'Manual Stop Loss Price (0 = disabled)', minval=0)

//-----------------------------------------------------------------------------
//Trendline Calculations
//-----------------------------------------------------------------------------
var float upper = na
var float lower = na
var float slope_ph = na
var float slope_pl = na
src = close
n = bar_index

ph = ta.pivothigh(length, length)
pl = ta.pivotlow(length, length)

slope = switch calcMethod
    'Atr'    => ta.atr(length) / length * mult
    'Stdev'  => ta.stdev(src,length) / length * mult
    'Linreg' => math.abs(ta.sma(src * n, length) - ta.sma(src, length) * ta.sma(n, length)) / ta.variance(n, length) / 2 * mult

slope_ph := ph ? slope : slope_ph
slope_pl := pl ? slope : slope_pl

upper := ph ? ph : upper - slope_ph
lower := pl ? pl : lower + slope_pl

upos = ph ? 0 : close > upper - slope_ph * length ? 1 : 0
dnos = pl ? 0 : close < lower + slope_pl * length ? 1 : 0

//-----------------------------------------------------------------------------
//Supertrend Calculation
//-----------------------------------------------------------------------------
atr = ta.atr(supertrendPeriod)
hl2 = (high + low) / 2
upperBand = hl2 + supertrendFactor * atr
lowerBand = hl2 - supertrendFactor * atr
inUpTrend = true
inUpTrend := close[1] > upperBand[1] ? true : close[1] < lowerBand[1] ? false : inUpTrend[1]
supertrendDir = inUpTrend ? 1 : -1

//-----------------------------------------------------------------------------
//Trade Conditions
//-----------------------------------------------------------------------------
longCondition = (supertrendDir == 1 and upos > upos[1])
shortCondition = (supertrendDir == -1 and dnos > dnos[1])

longExitCondition = (supertrendDir == -1 or dnos > dnos[1])
shortExitCondition = (supertrendDir == 1 or upos > upos[1])

//-----------------------------------------------------------------------------
//Manual TP/SL or fallback to percentage
//-----------------------------------------------------------------------------
slLong = manualSL > 0 ? manualSL : close * (1 - slPerc / 100)
tpLong = manualTP > 0 ? manualTP : close * (1 + tpPerc / 100)

slShort = manualSL > 0 ? manualSL : close * (1 + slPerc / 100)
tpShort = manualTP > 0 ? manualTP : close * (1 - tpPerc / 100)

//-----------------------------------------------------------------------------
//Trade Execution
//-----------------------------------------------------------------------------
if (longCondition)
    strategy.entry("Long", strategy.long)
    strategy.exit("TP/SL Long", from_entry="Long", stop=slLong, limit=tpLong)

if (shortCondition)
    strategy.entry("Short", strategy.short)
    strategy.exit("TP/SL Short", from_entry="Short", stop=slShort, limit=tpShort)

// Exit on signal reversal
if (strategy.position_size > 0 and longExitCondition)
    strategy.close("Long", comment="Reversal Exit")

if (strategy.position_size < 0 and shortExitCondition)
    strategy.close("Short", comment="Reversal Exit")

//-----------------------------------------------------------------------------
//Plots for Debug
//-----------------------------------------------------------------------------
plotshape(longCondition, location=location.belowbar, color=color.green, style=shape.labelup, text="Buy")
plotshape(shortCondition, location=location.abovebar, color=color.red, style=shape.labeldown, text="Sell")
plotshape(longExitCondition and strategy.position_size > 0, location=location.abovebar, color=color.orange, style=shape.xcross, text="Exit L")
plotshape(shortExitCondition and strategy.position_size < 0, location=location.belowbar, color=color.orange, style=shape.xcross, text="Exit S")

