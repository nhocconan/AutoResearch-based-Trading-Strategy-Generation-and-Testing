//@version=5
strategy("Elliott Wave Auto + Fib Targets + Scalper Strategy (Fixed Signals)",
     overlay=true,
     default_qty_type=strategy.percent_of_equity,
     default_qty_value=100.0,
     pyramiding=4,
     max_labels_count=500)

// Inputs
leftBars         = input.int(5, "Pivot Left Bars", minval=1, maxval=20)
rightBars        = input.int(5, "Pivot Right Bars", minval=1, maxval=20)
maxPivots        = input.int(20, "Max stored pivots", minval=8)
showPivShapes    = input.bool(true, "Show pivot shapes")
showScalpSignals = input.bool(true, "Show scalping signals")
showFibTargets   = input.bool(true, "Show Fibonacci Targets")
chartBars        = input.int(50, "Bars for signal table", minval=10, maxval=100)
ema_short_len    = input.int(8, "EMA short", minval=1)
ema_long_len     = input.int(21, "EMA long", minval=1)
rsi_len          = input.int(14, "RSI length", minval=1)
rsi_long_max     = input.int(70, "RSI max for longs", minval=50, maxval=90)
rsi_short_min    = input.int(30, "RSI min for shorts", minval=10, maxval=50)
atr_len          = input.int(14, "ATR length", minval=1)
atr_mult         = input.float(1.0, "ATR SL multiplier", step=0.1)
tp1_rr           = input.float(1.5, "TP1 R:R", step=0.1)
tp2_rr           = input.float(3.0, "TP2 R:R", step=0.1)
enable_scalps    = input.bool(true, "Enable scalp signals")
use_trailing     = input.bool(true, "Use trailing stop for winners (TP2)")
trail_atr_mult   = input.float(0.75, "Trailing ATR multiplier", step=0.05)
entry_size_pct   = input.float(1.0, "Entry size (% equity)", minval=0.1, step=0.1)
allow_pyramiding = input.int(1, "Pyramiding (max same-direction entries)", minval=0, maxval=10)
show_predictions  = input.bool(true, "Show predicted entry/exit points")
min_wave_move    = input.float(1.5, "Min wave move (% ATR)", minval=0.5, step=0.1)
trend_ema_len    = input.int(200, "Trend EMA length", minval=50)
volume_confirm   = input.bool(true, "Require volume confirmation")
breakout_window  = input.int(5, "Breakout confirmation window", minval=1, maxval=20)
debug_pivots     = input.bool(false, "Debug pivot detection")
debug_scalp      = input.bool(false, "Debug scalp signals")

// Custom function to sum array elements in a range
f_sum_array_range(array, start, end) =>
    var sum = 0
    size = array.size(array)
    start_idx = math.max(0, math.min(start, size - 1))
    end_idx = math.max(start_idx, math.min(end, size - 1))
    for i = start_idx to end_idx
        sum := sum + array.get(array, i)
    sum

// Track open entries
var int long_entries_count = 0
var int short_entries_count = 0
if strategy.position_size == 0
    long_entries_count := 0
    short_entries_count := 0

// Signal arrays
var int[] buy_signals = array.new_int(chartBars, 0)
var int[] sell_signals = array.new_int(chartBars, 0)
var int signal_index = 0
if true
    array.shift(buy_signals)
    array.shift(sell_signals)
    array.push(buy_signals, 0)
    array.push(sell_signals, 0)
    signal_index := math.min(signal_index + 1, chartBars - 1)

// Pivot detection
pivH = ta.pivothigh(high, leftBars, rightBars)
pivL = ta.pivotlow(low, leftBars, rightBars)
var float[] piv_price = array.new_float(0)
var int[] piv_bar = array.new_int(0)
var string[] piv_type = array.new_string(0)
var label[] waveLabels = array.new_label(0)
var line[] waveLines = array.new_line(0)
var line[] fibLines = array.new_line(0)

// Store historical patterns
var float[] pattern_starts = array.new_float(0)
var float[] pattern_ends = array.new_float(0)
var int[] pattern_start_bars = array.new_int(0)
var int[] pattern_end_bars = array.new_int(0)
var string[] pattern_types = array.new_string(0)
var bool[] pattern_success = array.new_bool(0)
var float[] pattern_magnitudes = array.new_float(0)

// Initialize wave magnitude variables
var float w1_magnitude = na
var float w3_magnitude = na
var float w5_magnitude = na
var float abc_magnitude = na

if not na(pivH)
    array.push(piv_price, pivH)
    array.push(piv_bar, bar_index - rightBars)
    array.push(piv_type, "H")
    if debug_pivots
        label.new(bar_index - rightBars, pivH, "PivH", style=label.style_label_down, color=color.red, size=size.tiny)
if not na(pivL)
    array.push(piv_price, pivL)
    array.push(piv_bar, bar_index - rightBars)
    array.push(piv_type, "L")
    if debug_pivots
        label.new(bar_index - rightBars, pivL, "PivL", style=label.style_label_up, color=color.green, size=size.tiny)
while array.size(piv_price) > maxPivots
    array.shift(piv_price)
    array.shift(piv_bar)
    array.shift(piv_type)

// Clear drawings (only when pattern changes)
f_clear_drawings() =>
    if array.size(waveLabels) > 0
        for i = 0 to array.size(waveLabels) - 1
            label.delete(array.get(waveLabels, i))
        array.clear(waveLabels)
    if array.size(waveLines) > 0
        for i = 0 to array.size(waveLines) - 1
            line.delete(array.get(waveLines, i))
        array.clear(waveLines)
    if array.size(fibLines) > 0
        for i = 0 to array.size(fibLines) - 1
            line.delete(array.get(fibLines, i))
        array.clear(fibLines)

// Additional indicators
ema_trend = ta.ema(close, trend_ema_len)
volume_sma = ta.sma(volume, 20)
volume_confirm_signal = volume_confirm ? volume > volume_sma * 1.5 : true
atr_val = ta.atr(atr_len)

// Elliott Wave detection with stricter validation
var int last_drawn_piv_count = 0
pattern_complete = false
var bool is_current_bullish = false
var bool is_current_bearish = false
var bool valid_pattern = false

if array.size(piv_price) >= 8
    alt_ok = true
    for i = 1 to 7
        idx1 = array.size(piv_type) - i
        idx0 = array.size(piv_type) - i - 1
        if array.get(piv_type, idx1) == array.get(piv_type, idx0)
            alt_ok := false
    // Calculate wave magnitudes
    base = array.size(piv_price) - 8
    w1 = array.get(piv_price, base)
    w2 = array.get(piv_price, base + 1)
    w3 = array.get(piv_price, base + 2)
    w4 = array.get(piv_price, base + 3)
    w5 = array.get(piv_price, base + 4)
    a = array.get(piv_price, base + 5)
    b = array.get(piv_price, base + 6)
    c = array.get(piv_price, base + 7)
    w1_magnitude := math.abs(w2 - w1)
    w3_magnitude := math.abs(w3 - w2)
    w5_magnitude := math.abs(w5 - w4)
    abc_magnitude := math.abs(c - a)
    min_move = atr_val * min_wave_move
    valid_pattern := alt_ok and w3_magnitude > w1_magnitude and w3_magnitude > w5_magnitude and w3_magnitude >= min_move and abc_magnitude >= min_move
    if valid_pattern
        pattern_complete := true
        is_current_bullish := array.get(piv_type, base) == "L"
        is_current_bearish := array.get(piv_type, base) == "H"
        if last_drawn_piv_count != array.size(piv_price)
            f_clear_drawings()
            // Draw impulse 1-5
            for i = 0 to 4
                idx = base + i
                price_i = array.get(piv_price, idx)
                bar_i = array.get(piv_bar, idx)
                txt = str.tostring(i + 1)
                isImpulse = (i % 2 == 0)
                lbl_style = isImpulse ? label.style_label_up : label.style_label_down
                lbl_col = isImpulse ? color.new(color.green, 0) : color.new(color.red, 0)
                lab = label.new(bar_i, price_i, text=txt, style=lbl_style, color=lbl_col, textcolor=color.white, size=size.small)
                array.push(waveLabels, lab)
                if i > 0
                    prev_idx = base + i - 1
                    prev_price = array.get(piv_price, prev_idx)
                    prev_bar = array.get(piv_bar, prev_idx)
                    ln = line.new(prev_bar, prev_price, bar_i, price_i, width=2, color=color.new(color.blue, 0))
                    array.push(waveLines, ln)
            // Correction A-B-C
            abc_base = array.size(piv_price) - 3
            var string[] abc_labels = array.from("A", "B", "C")
            for j = 0 to 2
                idx = abc_base + j
                price_j = array.get(piv_price, idx)
                bar_j = array.get(piv_bar, idx)
                txt = array.get(abc_labels, j)
                ptype = array.get(piv_type, idx)
                lbl_style = ptype == "H" ? label.style_label_down : label.style_label_up
                lbl_col = color.new(color.orange, 0)
                lab = label.new(bar_j, price_j, text=txt, style=lbl_style, color=lbl_col, textcolor=color.white, size=size.small)
                array.push(waveLabels, lab)
                if j > 0
                    prev_idx = abc_base + j - 1
                    prev_price = array.get(piv_price, prev_idx)
                    prev_bar = array.get(piv_bar, prev_idx)
                    ln = line.new(prev_bar, prev_price, bar_j, price_j, width=2, color=color.new(color.orange, 0))
                    array.push(waveLines, ln)
            // Store pattern
            w1_price = array.get(piv_price, base)
            w5_price = array.get(piv_price, base + 4)
            c_price = array.get(piv_price, abc_base + 2)
            w1_bar = array.get(piv_bar, base)
            w5_bar = array.get(piv_bar, base + 4)
            c_bar = array.get(piv_bar, abc_base + 2)
            w5_target = w1_price + (w3 - w1_price) * 1.618
            c_target = a + (a - b) * 1.0
            w5_hit = is_current_bullish ? high >= w5_target : low <= w5_target
            c_hit = is_current_bullish ? low <= c_target : high >= c_target
            array.push(pattern_starts, w1_price)
            array.push(pattern_ends, is_current_bullish ? w5_price : c_price)
            array.push(pattern_start_bars, w1_bar)
            array.push(pattern_end_bars, is_current_bullish ? w5_bar : c_bar)
            array.push(pattern_types, is_current_bullish ? "12345" : "ABC")
            array.push(pattern_success, is_current_bullish ? w5_hit : c_hit)
            array.push(pattern_magnitudes, is_current_bullish ? math.abs(w5_price - w1_price) : math.abs(c_price - a))
            // Fibonacci targets
            if showFibTargets
                bar4 = array.get(piv_bar, base + 3)
                ln = line.new(bar4, w4, bar_index, w5_target, width=1, color=color.new(color.green, 50), style=line.style_dotted)
                array.push(fibLines, ln)
                bar_b = array.get(piv_bar, abc_base + 1)
                ln2 = line.new(bar_b, b, bar_index, c_target, width=1, color=color.new(color.orange, 50), style=line.style_dotted)
                array.push(fibLines, ln2)
                label.new(bar_index, w5_target, text="Wave 5 Target\n" + str.tostring(w5_target), style=label.style_label_down, color=color.new(color.green, 0), textcolor=color.white, size=size.small)
                label.new(bar_index, c_target, text="Wave C Target\n" + str.tostring(c_target), style=label.style_label_up, color=color.new(color.orange, 0), textcolor=color.white, size=size.small)
            last_drawn_piv_count := array.size(piv_price)
    else
        if last_drawn_piv_count != 0
            f_clear_drawings()
            last_drawn_piv_count := 0
else
    if last_drawn_piv_count != 0
        f_clear_drawings()
        last_drawn_piv_count := 0

// Predict entry/exit with enhanced logic
var float predicted_entry = na
var float predicted_exit = na
var string prediction_type = ""
var float confidence_score = na
var float avg_pattern_length = na
var float success_rate = na
var float weighted_magnitude = na
if array.size(pattern_starts) > 0
    successes = 0.0
    total_length = 0
    total_magnitude = 0.0
    weight_sum = 0.0
    for i = 0 to array.size(pattern_starts) - 1
        weight = 1.0 - (bar_index - array.get(pattern_end_bars, i)) / 1000.0
        weight := math.max(0.1, weight)
        if array.get(pattern_success, i)
            successes := successes + weight
        total_length := total_length + (array.get(pattern_end_bars, i) - array.get(pattern_start_bars, i))
        total_magnitude := total_magnitude + array.get(pattern_magnitudes, i) * weight
        weight_sum := weight_sum + weight
    success_rate := successes / weight_sum
    avg_pattern_length := total_length / array.size(pattern_starts)
    weighted_magnitude := total_magnitude / weight_sum
    confidence_score := success_rate * (close > ema_trend ? 1.0 : 0.8) * (volume_confirm_signal ? 1.0 : 0.9)
    // Dynamic Fibonacci levels
    fib_levels = array.new_float(3, 0)
    array.set(fib_levels, 0, 1.0)
    array.set(fib_levels, 1, 1.618)
    array.set(fib_levels, 2, 2.618)
    selected_fib = 1.618
    if success_rate > 0.75
        selected_fib := 2.618
    else if success_rate < 0.5
        selected_fib := 1.0
    // Predict entry
    if pattern_complete and array.size(piv_price) >= 8
        c_price = array.get(piv_price, array.size(piv_price) - 1)
        c_bar = array.get(piv_bar, array.size(piv_price) - 1)
        b_price = array.get(piv_price, array.size(piv_price) - 2)
        if is_current_bullish and close > c_price and bar_index - c_bar <= breakout_window and close > ema_trend and volume_confirm_signal
            predicted_entry := close
            predicted_exit := close + math.abs(close - b_price) * selected_fib
            prediction_type := "Long (New Wave 1)"
        else if is_current_bearish and close < c_price and bar_index - c_bar <= breakout_window and close < ema_trend and volume_confirm_signal
            predicted_entry := close
            predicted_exit := close - math.abs(b_price - close) * selected_fib
            prediction_type := "Short (New Wave 1)"

// Display predictions
if show_predictions and not na(predicted_entry)
    label.new(bar_index, predicted_entry, text="Predicted Entry: " + str.tostring(predicted_entry) + "\nExit: " + str.tostring(predicted_exit) + "\nType: " + prediction_type + "\nConfidence: " + str.tostring(confidence_score * 100, "#.##") + "%\nSuccess Rate: " + str.tostring(success_rate * 100, "#.##") + "%", style=label.style_label_down, color=color.new(color.purple, 0), textcolor=color.white, size=size.small)

// Scalper indicators
ema_short = ta.ema(close, ema_short_len)
ema_long = ta.ema(close, ema_long_len)
rsi_val = ta.rsi(close, rsi_len)
var float w4_val = na
if array.size(piv_price) >= 8
    w4_val := array.get(piv_price, array.size(piv_price) - 5)
long_breakout = not na(w4_val) and ta.crossover(close, w4_val)
short_breakout = not na(w4_val) and ta.crossunder(close, w4_val)
long_ok = enable_scalps and is_current_bullish and ema_short > ema_long and rsi_val <= rsi_long_max and long_breakout and long_entries_count < allow_pyramiding and close > ema_trend and volume_confirm_signal
short_ok = enable_scalps and is_current_bearish and ema_short < ema_long and rsi_val >= rsi_short_min and short_breakout and short_entries_count < allow_pyramiding and close < ema_trend and volume_confirm_signal

// Debug scalping signals
if long_ok and debug_scalp
    label.new(bar_index, low, "Scalp Buy", style=label.style_label_up, color=color.green, textcolor=color.white, size=size.tiny)
if short_ok and debug_scalp
    label.new(bar_index, high, "Scalp Sell", style=label.style_label_down, color=color.red, textcolor=color.white, size=size.tiny)

// Dynamic SL & TP
risk_dist_long = math.max(atr_val * atr_mult, math.abs(w4_val - close))
risk_dist_short = math.max(atr_val * atr_mult, math.abs(w4_val - close))
long_sl = long_ok ? math.min(close - risk_dist_long, w4_val) : na
short_sl = short_ok ? math.max(close + risk_dist_short, w4_val) : na
long_tp1 = long_ok ? close + risk_dist_long * tp1_rr : na
long_tp2 = long_ok ? predicted_exit : na
short_tp1 = short_ok ? close - risk_dist_short * tp1_rr : na
short_tp2 = short_ok ? predicted_exit : na
if long_ok
    label.new(bar_index, close, "SL: " + str.tostring(long_sl) + "\nTP1: " + str.tostring(long_tp1) + "\nTP2: " + (use_trailing ? "Trailing" : str.tostring(long_tp2)), style=label.style_label_down, color=color.green, textcolor=color.white, size=size.tiny)
if short_ok
    label.new(bar_index, close, "SL: " + str.tostring(short_sl) + "\nTP1: " + str.tostring(short_tp1) + "\nTP2: " + (use_trailing ? "Trailing" : str.tostring(short_tp2)), style=label.style_label_up, color=color.red, textcolor=color.white, size=size.tiny)

// Scalping signal triangles (global scope)
plotshape(long_ok and showScalpSignals, style=shape.triangleup, location=location.belowbar, color=color.green, size=size.normal, title="Scalp Buy")
plotshape(short_ok and showScalpSignals, style=shape.triangledown, location=location.abovebar, color=color.red, size=size.normal, title="Scalp Sell")

// Signal count display
var label signal_label_header = na
var label signal_label_50_40 = na
var label signal_label_40_30 = na
var label signal_label_30_20 = na
var label signal_label_20_10 = na
var label signal_label_10_0 = na
var label signal_label_current = na
var float label_y_base = ta.highest(high, chartBars)
var float label_y_offset = label_y_base * 0.01
if true
    label.delete(signal_label_header[1])
    label.delete(signal_label_50_40[1])
    label.delete(signal_label_40_30[1])
    label.delete(signal_label_30_20[1])
    label.delete(signal_label_20_10[1])
    label.delete(signal_label_10_0[1])
    label.delete(signal_label_current[1])
    signal_label_header := label.new(bar_index, label_y_base + 6 * label_y_offset, "Period: Buy | Sell", style=label.style_label_down, color=color.new(color.blue, 50), textcolor=color.white, size=size.small, textalign=text.align_right)
    signal_label_50_40 := label.new(bar_index, label_y_base + 5 * label_y_offset, "-50 to -40: " + str.tostring(f_sum_array_range(buy_signals, math.max(0, signal_index - 50), math.max(0, signal_index - 40))) + " | " + str.tostring(f_sum_array_range(sell_signals, math.max(0, signal_index - 50), math.max(0, signal_index - 40))), style=label.style_label_down, color=color.new(color.gray, 80), textcolor=color.white, size=size.small, textalign=text.align_right)
    signal_label_40_30 := label.new(bar_index, label_y_base + 4 * label_y_offset, "-40 to -30: " + str.tostring(f_sum_array_range(buy_signals, math.max(0, signal_index - 40), math.max(0, signal_index - 30))) + " | " + str.tostring(f_sum_array_range(sell_signals, math.max(0, signal_index - 40), math.max(0, signal_index - 30))), style=label.style_label_down, color=color.new(color.gray, 80), textcolor=color.white, size=size.small, textalign=text.align_right)
    signal_label_30_20 := label.new(bar_index, label_y_base + 3 * label_y_offset, "-30 to -20: " + str.tostring(f_sum_array_range(buy_signals, math.max(0, signal_index - 30), math.max(0, signal_index - 20))) + " | " + str.tostring(f_sum_array_range(sell_signals, math.max(0, signal_index - 30), math.max(0, signal_index - 20))), style=label.style_label_down, color=color.new(color.gray, 80), textcolor=color.white, size=size.small, textalign=text.align_right)
    signal_label_20_10 := label.new(bar_index, label_y_base + 2 * label_y_offset, "-20 to -10: " + str.tostring(f_sum_array_range(buy_signals, math.max(0, signal_index - 20), math.max(0, signal_index - 10))) + " | " + str.tostring(f_sum_array_range(sell_signals, math.max(0, signal_index - 20), math.max(0, signal_index - 10))), style=label.style_label_down, color=color.new(color.gray, 80), textcolor=color.white, size=size.small, textalign=text.align_right)
    signal_label_10_0 := label.new(bar_index, label_y_base + 1 * label_y_offset, "-10 to 0: " + str.tostring(f_sum_array_range(buy_signals, math.max(0, signal_index - 10), signal_index)) + " | " + str.tostring(f_sum_array_range(sell_signals, math.max(0, signal_index - 10), signal_index)), style=label.style_label_down, color=color.new(color.gray, 80), textcolor=color.white, size=size.small, textalign=text.align_right)
    signal_label_current := label.new(bar_index, label_y_base, "Current: " + str.tostring(array.get(buy_signals, signal_index)) + " | " + str.tostring(array.get(sell_signals, signal_index)), style=label.style_label_down, color=color.new(color.gray, 80), textcolor=color.white, size=size.small, textalign=text.align_right)

// Strategy execution
long_entry_id = "ElliottScalpLong"
short_entry_id = "ElliottScalpShort"
qty_long = math.floor(strategy.equity * entry_size_pct / 100 / close)
qty_short = math.floor(strategy.equity * entry_size_pct / 100 / close)
if long_ok
    array.set(buy_signals, signal_index, array.get(buy_signals, signal_index) + 1)
    strategy.entry(id=long_entry_id, direction=strategy.long, qty=qty_long)
    long_entries_count := long_entries_count + 1
    label.new(bar_index, low, "BUY", style=label.style_label_up, color=color.new(color.green, 0), textcolor=color.white, size=size.normal)
if short_ok
    array.set(sell_signals, signal_index, array.get(sell_signals, signal_index) + 1)
    strategy.entry(id=short_entry_id, direction=strategy.short, qty=qty_short)
    short_entries_count := short_entries_count + 1
    label.new(bar_index, high, "SELL", style=label.style_label_down, color=color.new(color.red, 0), textcolor=color.white, size=size.normal)

// Visuals
plotshape(not na(pivH) and showPivShapes, style=shape.triangledown, location=location.abovebar, color=color.red, size=size.tiny, title="Pivot High")
plotshape(not na(pivL) and showPivShapes, style=shape.triangleup, location=location.belowbar, color=color.green, size=size.tiny, title="Pivot Low")
plot(long_ok ? long_sl : na, title="Long SL (visual)", linewidth=1, style=plot.style_linebr, color=color.red)
plot(long_ok ? long_tp1 : na, title="Long TP1 (visual)", linewidth=1, style=plot.style_linebr, color=color.green)
plot(short_ok ? short_sl : na, title="Short SL (visual)", linewidth=1, style=plot.style_linebr, color=color.green)
plot(short_ok ? short_tp1 : na, title="Short TP1 (visual)", linewidth=1, style=plot.style_linebr, color=color.red)
plot(ema_short, title="EMA Short", color=color.green)
plot(ema_long, title="EMA Long", color=color.red)
plot(ema_trend, title="Trend EMA", color=color.purple )

