//@version=6
strategy('EMA and SR', overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=100, initial_capital=100000, process_orders_on_close=true, close_entries_rule="ANY", use_bar_magnifier=false)

// === Inputs ===
rr_multiplier     = input.float(3.0, title="Risk Reward Ratio")
show_dynamic_sr   = input.bool(true,  title="Show Support/Resistance")
swing_lookback    = input.int(20,     title="Swing Detection Bars")
one_trade_per_day = input.bool(true,  title="One Trade Per Day Per Type (CE/PE)?")

// Trailing Stop Loss
use_trailing_sl        = input.bool(false, title="Use Trailing Stop Loss?")
trailing_sl_activation = input.float(1.0,  title="Trailing Activation % (profit before trailing starts)", minval=0.5, step=0.1)
trailing_sl_distance   = input.float(0.5,  title="Trailing Distance % (distance from peak)",              minval=0.1, step=0.1)

// === EMAs ===
ema20  = ta.ema(close, 20)
ema50  = ta.ema(close, 50)
ema100 = ta.ema(close, 100)
ema200 = ta.ema(close, 200)

plot(ema20,  color=color.yellow, title="EMA 20",  linewidth=2)
plot(ema50,  color=color.blue,   title="EMA 50",  linewidth=2)
plot(ema100, color=color.white,  title="EMA 100", linewidth=2)
plot(ema200, color=color.green,  title="EMA 200", linewidth=2)

// === Daily Trade Tracking ===
var int  last_traded_day = na
var bool ce_traded_today = false
var bool pe_traded_today = false

is_new_day = na(last_traded_day) or dayofmonth != last_traded_day
if is_new_day
    last_traded_day  := dayofmonth
    ce_traded_today  := false
    pe_traded_today  := false

// === Open Trade Checks ===
ce_is_open = false
pe_is_open = false
for i = 0 to strategy.opentrades - 1
    if strategy.opentrades.entry_id(i) == 'Buy CE'
        ce_is_open := true
    if strategy.opentrades.entry_id(i) == 'Buy PE'
        pe_is_open := true

// === Persistent SL / Target ===
var float ce_sl     = na
var float ce_target = na
var float pe_sl     = na
var float pe_target = na

// === Previous Bar ===
prev_high  = high[1]
prev_low   = low[1]
prev_close = close[1]
prev_valid = not na(prev_high) and not na(prev_low) and not na(prev_close)

// === EMA Conditions ===
emas_valid = not na(ema20) and not na(ema50) and not na(ema100) and not na(ema200)

// CE: price closes above all 4 EMAs + breaks above previous bar high (breakout)
ce_ema_filter  = emas_valid and close > ema20 and close > ema50 and close > ema100 and close > ema200
ce_breakout    = prev_valid and close > prev_high

// PE: price closes below all 4 EMAs + breaks below previous bar low (breakdown)
pe_ema_filter  = emas_valid and close < ema20 and close < ema50 and close < ema100 and close < ema200
pe_breakdown   = prev_valid and close < prev_low

// === CE Entry ===
ce_can_trade = not one_trade_per_day or not ce_traded_today

ce_entry = ce_ema_filter and
           ce_breakout   and
           ce_can_trade  and
           not ce_is_open and
           not pe_is_open

if ce_entry
    risk = close - prev_low
    if risk > 0
        ce_sl       := prev_low
        ce_target   := close + rr_multiplier * risk
        strategy.entry('Buy CE', strategy.long, comment='CE Entry', alert_message='pe_signal_4hDZCAZz7ovi')
        ce_traded_today := true

// CE Exit: fixed SL/Target OR tighten stop if price drops below EMA20 or EMA50
if ce_is_open and not na(ce_sl) and not na(ce_target)
    effective_sl = (close < ema20 or close < ema50) ? math.min(ce_sl, low) : ce_sl
    if use_trailing_sl
        act_price = strategy.opentrades.entry_price(0) * (1 + trailing_sl_activation / 100)
        strategy.exit('Exit CE', from_entry='Buy CE', stop=effective_sl, limit=ce_target, trail_price=act_price, trail_offset=trailing_sl_distance, comment='exit', alert_message='pe_signal_4hDZCAZz7ovi')
    else
        strategy.exit('Exit CE', from_entry='Buy CE', stop=effective_sl, limit=ce_target, comment='exit', alert_message='pe_signal_4hDZCAZz7ovi')

if not ce_is_open
    ce_sl     := na
    ce_target := na

plotshape(ce_entry, location=location.belowbar, color=color.green, style=shape.arrowup, size=size.small, title="CE Entry")

// === PE Entry ===
pe_can_trade = not one_trade_per_day or not pe_traded_today

pe_entry = pe_ema_filter and
           pe_breakdown   and
           pe_can_trade   and
           not pe_is_open and
           not ce_is_open

if pe_entry
    risk = prev_high - close
    if risk > 0
        pe_sl       := prev_high
        pe_target   := close - rr_multiplier * risk
        strategy.entry('Buy PE', strategy.short, comment='PE Entry', alert_message='ce_signal_XavTqkmtJGQu')
        pe_traded_today := true

// PE Exit: fixed SL/Target OR tighten stop if price rises above EMA20 or EMA50
if pe_is_open and not na(pe_sl) and not na(pe_target)
    effective_sl = (close > ema20 or close > ema50) ? math.max(pe_sl, high) : pe_sl
    if use_trailing_sl
        act_price = strategy.opentrades.entry_price(0) * (1 - trailing_sl_activation / 100)
        strategy.exit('Exit PE', from_entry='Buy PE', stop=effective_sl, limit=pe_target, trail_price=act_price, trail_offset=trailing_sl_distance, comment='exit', alert_message='ce_signal_XavTqkmtJGQu')
    else
        strategy.exit('Exit PE', from_entry='Buy PE', stop=effective_sl, limit=pe_target, comment='exit', alert_message='ce_signal_XavTqkmtJGQu')

if not pe_is_open
    pe_sl     := na
    pe_target := na

plotshape(pe_entry, location=location.abovebar, color=color.red, style=shape.arrowdown, size=size.small, title="PE Entry")

// === Support & Resistance ===
swing_high = ta.pivothigh(high, swing_lookback, swing_lookback)
swing_low  = ta.pivotlow(low,  swing_lookback, swing_lookback)

var float resistance_level = na
var float support_level    = na

if not na(swing_high)
    resistance_level := swing_high
if not na(swing_low)
    support_level := swing_low

plot(show_dynamic_sr ? resistance_level : na, color=color.orange, linewidth=1, style=plot.style_circles, title="Resistance")
plot(show_dynamic_sr ? support_level    : na, color=color.blue,   linewidth=1, style=plot.style_circles, title="Support")

