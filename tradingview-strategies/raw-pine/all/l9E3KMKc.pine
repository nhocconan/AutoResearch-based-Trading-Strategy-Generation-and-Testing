//@version=4
strategy(title='Cross Strategy', shorttitle='Cross', overlay=true, commission_value=0.075, pyramiding=0, initial_capital=1000, default_qty_type=strategy.cash, default_qty_value=1000, currency=currency.USD )

LongPeriod=input('240')
ShortPeriod=input('60')
start_year = input(2019, "start year", input.integer)
start_month = input(6, "start month", input.integer, minval=1, maxval=12)
start_day = input(1, "start day", input.integer, minval=1, maxval=31)
start = timestamp(start_year, start_month, start_day, 00, 00)

ch_long = security(syminfo.tickerid, LongPeriod, open)
ch_short = security(syminfo.tickerid, ShortPeriod, close)

p1=plot(ch_long,color=color.blue, linewidth=1, title='open')
p2=plot(ch_short,color=color.orange, linewidth=1, title='close')

longCondition = crossover(ch_short, ch_long)

strategy.entry("long", strategy.long, when=time > start and longCondition)

shortCondition = crossunder(ch_short, ch_long)
if (time > start and shortCondition)
    strategy.close("long")

