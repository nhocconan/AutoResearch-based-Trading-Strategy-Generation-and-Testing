//@version=6
strategy("Master Multi-Asset Confluence Strategy", "Master Strat", overlay = true, initial_capital = 100000, default_qty_type = strategy.fixed, default_qty_value = 1, precision = 2)

// --- User-Defined Types ---
type OBZone
    float top
    float bottom
    bool  mitigated

// --- Inputs ---
grpStrat     = "Strategy & Confluence Logic"
tradeLong    = input.bool(true, "Allow Long Trades", group = grpStrat)
tradeShort   = input.bool(true, "Allow Short Trades", group = grpStrat)
exitOpposite = input.bool(true, "Exit on Opposite Signal", group = grpStrat)

grpToggle    = "Active Confirmations (Checkboxes)"
useRsiBbConf = input.bool(true, "Require RSI/BB Extension", group = grpToggle)
useObConf    = input.bool(true, "Require Order Block Hit", group = grpToggle)
useCvdConf   = input.bool(false, "Require CVD Divergence", group = grpToggle)
useSfpConf   = input.bool(false, "Require SFP Confirmation", group = grpToggle)

grpRisk      = "Risk Management"
useTPSL      = input.bool(true, "Use Take Profit / Stop Loss", group = grpRisk)
exitType     = input.string("Percentage", "Exit Type", options = ["Percentage", "Ticks"], group = grpRisk)
tpPct        = input.float(2.0, "Take Profit %", minval = 0.1, group = grpRisk)
slPct        = input.float(1.0, "Stop Loss %", minval = 0.1, group = grpRisk)
tpTicks      = input.int(200, "Take Profit (Ticks)", group = grpRisk)
slTicks      = input.int(100, "Stop Loss (Ticks)", group = grpRisk)

grpAssets    = "Asset Settings"
vixTicker    = input.symbol("CBOE:VIX", "VIX Ticker", group = grpAssets)
vixTF        = input.timeframe("", "VIX Timeframe", group = grpAssets)
pccTicker    = input.symbol("CBOE:PCCE", "PCC Ticker", group = grpAssets)
pccTF        = input.timeframe("", "PCC Timeframe", group = grpAssets)
compTicker   = input.symbol("CME_MINI:ES1!", "Comp Ticker", group = grpAssets)
compTF       = input.timeframe("", "Comp Timeframe", group = grpAssets)

grpParams    = "Technical Parameters"
htfOB        = input.timeframe("60", "HTF for Order Blocks", group = grpParams)
swingLook    = input.int(10, "Swing Lookback", minval = 2, group = grpParams)
rsiLen       = input.int(7, "RSI Period", group = grpParams)
bbLen        = input.int(20, "BB Length", group = grpParams)
bbMult       = input.float(2.0, "BB StdDev", group = grpParams)

grpDelta     = "Delta & SFP Parameters"
deltaMethod  = input.string("Intrabar", "Delta Method", options = ["Intrabar", "Bar Direction"], group = grpDelta)
ltfDelta     = input.timeframe("1", "LTF for Intrabar Delta", group = grpDelta)
sfpTF        = input.timeframe("60", "SFP Reference TF", group = grpDelta)

bullColor    = input.color(#089981, "Bullish Color", group = "Style")
bearColor    = input.color(#f23645, "Bearish Color", group = "Style")
goldColor    = input.color(#f1c40f, "Confirmed Signal (Gold)", group = "Style")

// --- Functions ---
findActiveOBs(len) =>
    float ph = ta.pivothigh(high, len, len)
    float pl = ta.pivotlow(low, len, len)
    var bullOBs = array.new<OBZone>(0)
    var bearOBs = array.new<OBZone>(0)
    if not na(pl)
        array.unshift(bullOBs, OBZone.new(high[len], low[len], false))
    if not na(ph)
        array.unshift(bearOBs, OBZone.new(high[len], low[len], false))
    float aBullT = float(na), aBullB = float(na), aBearT = float(na), aBearB = float(na)
    if array.size(bullOBs) > 0
        for i = 0 to array.size(bullOBs) - 1
            OBZone ob = array.get(bullOBs, i)
            if not ob.mitigated
                if close < ob.bottom 
                    ob.mitigated := true
                else
                    aBullT := ob.top, aBullB := ob.bottom
                    break
    if array.size(bearOBs) > 0
        for i = 0 to array.size(bearOBs) - 1
            OBZone ob = array.get(bearOBs, i)
            if not ob.mitigated
                if close > ob.top
                    ob.mitigated := true
                else
                    aBearT := ob.top, aBearB := ob.bottom
                    break
    [aBullT, aBullB, aBearT, aBearB]

calcDelta(method, ltf) =>
    float d = close >= open ? volume : -volume
    if method == "Intrabar"
        [ltfO, ltfC, ltfV] = request.security_lower_tf(syminfo.tickerid, ltf, [open, close, volume], ignore_invalid_timeframe = true)
        if not na(ltfC) and array.size(ltfC) > 0
            float td = 0.0
            for i = 0 to array.size(ltfC) - 1
                td += (array.get(ltfC, i) >= array.get(ltfO, i) ? array.get(ltfV, i) : -array.get(ltfV, i))
            d := td
    d

// --- Logic ---
[vixO, vixH, vixL, vixC] = request.security(vixTicker, vixTF, [open, high, low, close])
[pccO, pccH, pccL, pccC] = request.security(pccTicker, pccTF, [open, high, low, close])
[compO, compH, compL, compC] = request.security(compTicker, compTF, [open, high, low, close])
[htfH, htfL] = request.security(syminfo.tickerid, sfpTF, [high[1], low[1]], lookahead = barmerge.lookahead_on)

rsiVal = ta.rsi(close, rsiLen)
[bbBasis, bbUpper, bbLower] = ta.bb(close, bbLen, bbMult)
[lBullT, lBullB, lBearT, lBearB] = findActiveOBs(swingLook)
[hBullT, hBullB, hBearT, hBearB] = request.security(syminfo.tickerid, htfOB, findActiveOBs(swingLook))

deltaVal = calcDelta(deltaMethod, ltfDelta)
var float cvd = 0.0
cvd += nz(deltaVal)

// Divergence Logic
v_L = ta.lowest(vixL, 10)[1], v_H = ta.highest(vixH, 10)[1]
p_L = ta.lowest(pccL, 10)[1], p_H = ta.highest(pccH, 10)[1]
c_L = ta.lowest(compL, 10)[1], c_H = ta.highest(compH, 10)[1]
pr_L = ta.lowest(low, 10)[1], pr_H = ta.highest(high, 10)[1]

cvd_L = ta.lowest(cvd, 5)[1], cvd_H = ta.highest(cvd, 5)[1]
low_L = ta.lowest(low, 5)[1], high_H = ta.highest(high, 5)[1]

divBull = (low < pr_L and vixH < v_H) or (low < pr_L and pccH < p_H) or (low < pr_L and compL > c_L)
divBear = (high > pr_H and vixL > v_L) or (high > pr_H and pccL > p_L) or (high > pr_H and compH < c_H)

cvdBull = low < low_L and cvd > cvd_L
cvdBear = high > high_H and cvd < cvd_H
sfpBull = low < htfL and close > htfL
sfpBear = high > htfH and close < htfH

// --- Confluence Check ---
cRsiBbLong = not useRsiBbConf or (rsiVal < 30 and low < bbLower)
cRsiBbShort = not useRsiBbConf or (rsiVal > 70 and high > bbUpper)
cObLong = not useObConf or (not na(lBullB) and low <= lBullT and high >= lBullB)
cObShort = not useObConf or (not na(lBearT) and low <= lBearT and high >= lBearB)
cCvdLong = not useCvdConf or cvdBull
cCvdShort = not useCvdConf or cvdBear
cSfpLong = not useSfpConf or sfpBull
cSfpShort = not useSfpConf or sfpBear

finalLong = divBull and cRsiBbLong and cObLong and cCvdLong and cSfpLong
finalShort = divBear and cRsiBbShort and cObShort and cCvdShort and cSfpShort

// --- Execution ---
if finalLong and tradeLong
    strategy.entry("Long", strategy.long)
if finalShort and tradeShort
    strategy.entry("Short", strategy.short)

if exitOpposite
    if finalShort and strategy.position_size > 0 
        strategy.close("Long")
    if finalLong and strategy.position_size < 0 
        strategy.close("Short")

var float tP = na, var float sP = na
if strategy.position_size != 0
    float ep = strategy.position_avg_price
    if exitType == "Percentage"
        tP := strategy.position_size > 0 ? ep * (1 + tpPct/100) : ep * (1 - tpPct/100)
        sP := strategy.position_size > 0 ? ep * (1 - slPct/100) : ep * (1 + slPct/100)
        strategy.exit("Exit", limit = tP, stop = sP)
    else
        strategy.exit("Exit", profit = tpTicks, loss = slTicks)
else
    tP := na, sP := na

// --- Visuals ---
isNestedBull = not na(hBullB) and lBullT <= hBullT and lBullB >= hBullB
isNestedBear = not na(hBearT) and lBearT <= hBearT and lBearB >= hBearB

plotshape(finalLong and isNestedBull ? low : na, "Gold Bull", shape.diamond, location.belowbar, goldColor, 0, "GOLD", chart.fg_color, size = size.small)
plotshape(finalShort and isNestedBear ? high : na, "Gold Bear", shape.diamond, location.abovebar, goldColor, 0, "GOLD", chart.fg_color, size = size.small)
plotshape(finalLong and not isNestedBull ? low : na, "White Bull", shape.diamond, location.belowbar, color.white, 0, "CONF", chart.fg_color, size = size.small)
plotshape(finalShort and not isNestedBear ? high : na, "White Bear", shape.diamond, location.abovebar, color.white, 0, "CONF", chart.fg_color, size = size.small)

plot(tP, "Take Profit", color = color.new(bullColor, 40), style = plot.style_linebr, linewidth = 2)
plot(sP, "Stop Loss", color = color.new(bearColor, 40), style = plot.style_linebr, linewidth = 2)

