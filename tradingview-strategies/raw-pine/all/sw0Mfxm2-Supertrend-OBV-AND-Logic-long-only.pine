//@version=6
strategy(
    "Supertrend + OBV AND Logic (FINAL – NO ta.obv)",
    overlay = true,
    initial_capital = 100000,
    default_qty_type = strategy.percent_of_equity,
    default_qty_value = 100,
    commission_type = strategy.commission.percent,
    commission_value = 0.04
)

// =====================
// INPUTS
// =====================
atrPeriod  = input.int(10, "Supertrend ATR Period")
atrMult    = input.float(3.0, "Supertrend Multiplier")

obvLen     = input.int(20, "OBV EMA Length")
signalLen  = input.int(20, "OBV Signal Length")

// =====================
// SUPERTREND (OFFICIAL POLARITY)
// =====================
[st, dir] = ta.supertrend(atrMult, atrPeriod)

// TradingView built-in Supertrend:
// dir ==  1 → Bullish
// dir == -1 → Bearish
supertrendBull = dir == 1
supertrendBear = dir == -1

// =====================
// OBV (MANUAL – NO ta.obv)
// =====================
var float obv = na
if bar_index == 0
    obv := volume
else
    obv := close > close[1] ? nz(obv[1]) + volume :
           close < close[1] ? nz(obv[1]) - volume :
           nz(obv[1])

obvEMA   = ta.ema(obv, obvLen)
signal   = ta.ema(obvEMA, signalLen)

obvCrossUp   = ta.crossover(obvEMA, signal)
obvCrossDown = ta.crossunder(obvEMA, signal)

// =====================
// ENTRY / EXIT CONDITIONS
// =====================

// ENTRY:
// OBV crosses UP while Supertrend is bullish
ENTER = obvCrossUp and supertrendBull and strategy.position_size == 0

// EXIT:
// Supertrend flips bearish
EXIT = supertrendBear and strategy.position_size > 0

// =====================
// STRATEGY EXECUTION
// =====================
if ENTER
    strategy.entry("LONG", strategy.long)

if EXIT
    strategy.close("LONG")

// =====================
// VISUALS
// =====================
plot(st, color = supertrendBull ? color.green : color.red, linewidth = 2, title="Supertrend")

plotshape(
    ENTER,
    title="ENTRY",
    location=location.belowbar,
    style=shape.labelup,
    color=color.green,
    text="ENTER",
    textcolor=color.white
)

plotshape(
    obvCrossDown,
    title="PROTECT (Visual)",
    location=location.abovebar,
    style=shape.labeldown,
    color=color.orange,
    text="OBV ↓",
    textcolor=color.white
)

plotshape(
    EXIT,
    title="EXIT",
    location=location.abovebar,
    style=shape.labeldown,
    color=color.red,
    text="EXIT",
    textcolor=color.white
)

