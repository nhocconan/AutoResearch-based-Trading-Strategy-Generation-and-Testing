//@version=5
strategy("Rasta",
     overlay=true, max_lines_count=500,

     // --- Defaults to match your screenshots
     initial_capital = 100,
     currency        = currency.USD,
     default_qty_type= strategy.cash,     // order size in USD
     default_qty_value=100,
     pyramiding      = 0,
     commission_type = strategy.commission.percent,
     commission_value= 0.25,
     slippage        = 0,
     calc_on_every_tick = true,
     calc_on_order_fills = true)

/// ========= Inputs (same as indicator)
groupInp   = "Inputs"
emaLen     = input.int(5, "Length", minval=1, group=groupInp)
src        = input.source(close, "Source", group=groupInp)
offsetBars = input.int(0, "Offset", group=groupInp)

groupSm    = "Smoothing"
smType     = input.string("SMA", "Type",
              options=["SMA","EMA","RMA","WMA","None"], group=groupSm)
smLen      = input.int(5, "Length", minval=1, group=groupSm)

groupViz   = "Visualization"
showLabels = input.bool(true,  "Show Buy/Sell Labels", group=groupViz)
showFog    = input.bool(true,  "Show Colored Fog Between Lines", group=groupViz)
fogTransp  = input.int(55,     "Fog Opacity (0=solid, 100=hidden)", minval=0, maxval=100, group=groupViz)

groupRung  = "DNA Rungs"
showRungs  = input.bool(true,  "Show DNA Rungs (EMA ↔ Smoothed)", group=groupRung)
rungWidth  = input.int(3,      "Rung Width", minval=1, maxval=5, group=groupRung)
maxKeep    = input.int(420,    "Max Rungs to Keep (<= 450)", minval=100, maxval=450, step=10, group=groupRung)
rungColorMode = input.string("Direction", "Rung Color",
     options=["Fixed Green","Direction"], group=groupRung)
rungFixedCol  = input.color(color.lime, "Fixed Rung Color", group=groupRung)

/// ========== EMA 8/21 Filter (same behavior; exits never blocked)
groupFilt        = "EMA 8/21 Filter"
useEmaFilter     = input.bool(true,  "Enable EMA 8/21 Filter", group=groupFilt)
emaFastLenSw     = input.int(8,      "Fast EMA",  minval=1, group=groupFilt)
emaSlowLenSw     = input.int(21,     "Slow EMA",  minval=1, group=groupFilt)
plotFilterEMAs   = input.bool(false, "Plot Filter EMAs", group=groupFilt)
adaptiveOnFlip   = input.bool(true,  "Adaptive entry when filter flips ON", group=groupFilt)

ema8  = ta.ema(close, emaFastLenSw)
ema21 = ta.ema(close, emaSlowLenSw)
upTrend       = ema8 > ema21
filterFlipOn  = ta.crossover(ema8, ema21)

/// ========== Fixed Stop-Loss (adjustable; default 13%)
groupRisk   = "Risk"
slPctInp    = input.float(13.0, "Fixed Stop Loss (%)", minval=0.1, step=0.1, group=groupRisk) / 100.0

/// ========== Core calc
emaLine = ta.ema(src, emaLen)
f_smooth(series float s, string t, int l) =>
    float out = switch t
        "SMA"  => ta.sma(s, l)
        "EMA"  => ta.ema(s, l)
        "RMA"  => ta.rma(s, l)
        "WMA"  => ta.wma(s, l)
        => s
    out
smoothed = f_smooth(emaLine, smType, smLen)
dirUp   = emaLine > smoothed

/// ========== Tick-by-tick signals with per-bar lock (mirrors your indicator)
var bool barLock = false
if barstate.isnew
    barLock := false

buyRaw  = ta.crossover(emaLine, smoothed)
sellRaw = ta.crossunder(emaLine, smoothed)

buyFireBase  = buyRaw  and not barLock and strategy.position_size == 0
sellFireBase = sellRaw and not barLock and strategy.position_size > 0

// EMA 8/21 gating
buyAllowed  = (not useEmaFilter) or upTrend
sellAllowed = true

// Adaptive entry
adaptiveBuy = useEmaFilter and adaptiveOnFlip and filterFlipOn and strategy.position_size == 0 and not barLock and (emaLine > smoothed)

// Final realtime fires
buyFire  = ((buyFireBase and buyAllowed) or adaptiveBuy)
sellFire =  (sellFireBase and sellAllowed)

// Close-only backup (ungated)
buyFireClose  = barstate.isconfirmed and ta.crossover(emaLine, smoothed) and strategy.position_size == 0 and buyAllowed
sellFireClose = barstate.isconfirmed and ta.crossunder(emaLine, smoothed)  and strategy.position_size > 0

// Lock for this bar when a realtime fire happens
if buyFire or sellFire
    barLock := true

/// ========== Strategy orders
// Entries (one position at a time)
if (buyFire or buyFireClose) and strategy.position_size == 0
    strategy.entry("LONG", strategy.long)

// Manage fixed stop-loss every tick while in position
if strategy.position_size > 0
    stopPrice = strategy.position_avg_price * (1.0 - slPctInp)
    // Re-issue/refresh the exit each bar so SL tracks avg fill
    strategy.exit("SL", from_entry="LONG", stop=stopPrice)

// Exit on SELL signals (market close of position)
if (sellFire or sellFireClose) and strategy.position_size > 0
    strategy.close("LONG")

/// ========== Plots & labels (unchanged visuals)
pEMA = plot(emaLine,  "EMA",      color=color.new(color.red,   0), offset=offsetBars, linewidth=2)
pSM  = plot(smoothed, "Smoothed", color=color.new(color.yellow,0), offset=offsetBars, linewidth=2)

plot(plotFilterEMAs ? ema8  : na, "EMA 8 (Filter)",  color=color.new(color.teal,  0), linewidth=1)
plot(plotFilterEMAs ? ema21 : na, "EMA 21 (Filter)", color=color.new(color.orange,0), linewidth=1)

if showLabels and buyFire
    label.new(bar_index, low,  "Enter",  style=label.style_label_up,   textcolor=color.white, color=color.new(color.teal, 0))
if showLabels and sellFire
    label.new(bar_index, high, "Exit", style=label.style_label_down, textcolor=color.white, color=color.new(color.red,  0))
if showLabels and buyFireClose
    label.new(bar_index, low,  "Enter",  style=label.style_label_up,   textcolor=color.white, color=color.new(color.teal, 0))
if showLabels and sellFireClose
    label.new(bar_index, high, "Exit", style=label.style_label_down, textcolor=color.white, color=color.new(color.red,  0))

// Directional fog
colFog = showFog ? (dirUp ? color.new(color.lime, fogTransp) : color.new(color.red, fogTransp)) : na
fill(pEMA, pSM, color=colFog)

// FAT DNA rungs
topR = math.max(emaLine, smoothed)
botR = math.min(emaLine, smoothed)
rungCol = rungColorMode == "Direction" ? (dirUp ? color.lime : color.red) : rungFixedCol
var line   curRung = na
var line[] rungBuf = array.new_line()
if showRungs
    if barstate.isnew
        curRung := line.new(bar_index, botR, bar_index, topR,
                             xloc=xloc.bar_index, extend=extend.none,
                             color=rungCol, width=rungWidth)
        array.push(rungBuf, curRung)
        if array.size(rungBuf) > maxKeep
            line.delete(array.shift(rungBuf))
    if not na(curRung)
        line.set_y1(curRung, botR)
        line.set_y2(curRung, topR)
        line.set_width(curRung, rungWidth)
        line.set_color(curRung, rungCol)

