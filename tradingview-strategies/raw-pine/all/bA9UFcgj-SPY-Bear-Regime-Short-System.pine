//@version=5
strategy("SPY Bear Regime Short System",
     overlay    = true,
     shorttitle = "BRSM",
     initial_capital      = 10000,
     default_qty_type     = strategy.percent_of_equity,
     default_qty_value    = 100,
     commission_type      = strategy.commission.percent,
     commission_value     = 0.05,
     slippage             = 1,
     process_orders_on_close = false,
     calc_on_every_tick   = false)

// ── Inputs ───────────────────────────────────────────────────
ma_long_len  = input.int(250,   "Long MA length",      minval = 1)
ma_short_len = input.int(5,     "Short MA length",     minval = 1)
rsi_len      = input.int(3,     "RSI length",          minval = 1)
rsi_thresh   = input.float(70.0, "RSI overbought",     minval = 50, maxval = 100)
gap_pct      = input.float(2.0,  "Min % below long MA", minval = 0, step = 0.1)

// ── Indicators ───────────────────────────────────────────────
ma_long  = ta.sma(close, ma_long_len)
ma_short = ta.sma(close, ma_short_len)
rsi      = ta.rsi(close, rsi_len)

// ── Conditions ───────────────────────────────────────────────
below_long_ma  = close < ma_long
above_short_ma = close > ma_short
rsi_cross_ob   = ta.crossover(rsi, rsi_thresh)
gap_ok         = close <= ma_long * (1 - gap_pct / 100)

entry_signal = below_long_ma and above_short_ma and rsi_cross_ob and gap_ok

exit_below_short = close < ma_short
exit_above_long  = close > ma_long
exit_signal      = exit_below_short or exit_above_long

// ── Strategy orders (execute at next bar open) ────────────────
if entry_signal and strategy.position_size == 0
    strategy.entry("Short", strategy.short, comment = "SHORT")

if exit_signal and strategy.position_size < 0
    strategy.close("Short", comment = "EXIT")

// ── Plot MAs on price pane ────────────────────────────────────
plot(ma_long,  "250 MA", color = color.yellow, linewidth = 2)
plot(ma_short, "5 MA",   color = color.white,  linewidth = 2)

// ── RSI in separate pane ──────────────────────────────────────
rsiPlot = plot(rsi, "3-period RSI",
     color     = color.white,
     linewidth = 3,
     display   = display.pane)

hline(70, "Overbought 70",
     color     = color.new(#ff4444, 30),
     linestyle = hline.style_dashed,
     linewidth = 1)

hline(50, "Midline",
     color     = color.new(color.gray, 60),
     linestyle = hline.style_dotted,
     linewidth = 1)

hline(30, "Oversold 30",
     color     = color.new(#00e676, 50),
     linestyle = hline.style_dashed,
     linewidth = 1)

// ── Entry arrow ──────────────────────────────────────────────
plotshape(
     entry_signal and strategy.position_size == 0,
     title     = "Short entry",
     style     = shape.triangledown,
     location  = location.abovebar,
     color     = color.new(#ff4444, 0),
     size      = size.small,
     text      = "SHORT",
     textcolor = color.new(#ff4444, 0))

// ── Exit arrow ───────────────────────────────────────────────
plotshape(
     exit_signal and strategy.position_size < 0,
     title     = "Exit short",
     style     = shape.triangleup,
     location  = location.belowbar,
     color     = color.new(#00e676, 0),
     size      = size.small,
     text      = "EXIT",
     textcolor = color.new(#00e676, 0))

