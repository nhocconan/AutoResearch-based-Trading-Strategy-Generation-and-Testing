//@version=5
strategy("Trend Surge with Pullback Filter", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=25, commission_type=strategy.commission.percent, commission_value=0.05, slippage=1)

// === INPUTS ===
rocLen      = input.int(10, title="ROC Length")
rocThresh   = input.float(2.0, title="ROC Threshold (%)")
pullbackBars = input.int(3, title="Pullback Lookback")
pullbackDrop = input.float(1.0, title="Minimum Pullback %")
atrLen      = input.int(14, title="ATR Length")
volFactor   = input.float(1.2, title="Low Volatility Filter Multiplier")
riskReward  = input.float(2.0, title="Risk-Reward Ratio")
maxBars     = input.int(30, title="Max Holding Bars")

// === CALCULATIONS ===
roc = ta.roc(close, rocLen)
atr = ta.atr(atrLen)
atrMA = ta.sma(atr, 20)

volLow = atr < atrMA * volFactor

// === Pullback Logic ===
pullbackCond = close < ta.highest(close, pullbackBars) * (1 - pullbackDrop / 100)

// === LONG Condition ===
longCond = roc > rocThresh and pullbackCond and volLow

if (longCond)
    strategy.entry("Long", strategy.long)

// === SL/TP and Time Exit ===
longSL = strategy.position_avg_price - atr
longTP = strategy.position_avg_price + atr * riskReward

strategy.exit("Long Exit", from_entry="Long", stop=longSL, limit=longTP, when=bar_index - strategy.opentrades.entry_bar_index(0) >= maxBars)

