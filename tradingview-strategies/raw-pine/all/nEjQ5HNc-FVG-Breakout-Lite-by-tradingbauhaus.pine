//@version=6
strategy("FVG Breakout Lite by tradingbauhaus", overlay = true, max_boxes_count = 500, max_lines_count = 500)

// === Inputs ===
length = input.int(25, "Trend Period", minval = 5, group = "Core Settings")
volumeLookback = input.int(20, "Volume Lookback", minval = 5, group = "Core Settings")
volumeThreshold = input.float(1.2, "Volume Threshold (x Avg)", minval = 1.0, step = 0.1, group = "Core Settings")
showMitigation = input(true, "Display Mitigation Zones", group = "Mitigation Settings")
maxDuration = input(75, "Max Zone Life", group = "Mitigation Settings")

// === Style Customization ===
bullBreakColor = input(color.new(#00cc88, 35), "Bullish Breakout FVG Color", inline = "bullStyle", group = "Visuals")
bullFVGColor  = input(color.new(#66ffcc, 50), "Bullish FVG Color", inline = "bullStyle", group = "Visuals")
bearBreakColor = input(color.new(#ff3366, 35), "Bearish Breakout FVG Color", inline = "bearStyle", group = "Visuals")
bearFVGColor  = input(color.new(#ff9999, 50), "Bearish FVG Color", inline = "bearStyle", group = "Visuals")

// === Risk Management ===
stopLossPerc = input.float(1.5, "Stop Loss %", minval = 0.2, step = 0.1, group = "Trading Rules")
takeProfitPerc = input.float(3.0, "Take Profit %", minval = 0.5, step = 0.1, group = "Trading Rules")
marginRate = input.float(8.74, "Margin Rate % (Webull Default)", minval = 4.74, maxval = 8.74, group = "Trading Rules")

// === Webull Fee Structure ===
var float secFeeRate = 0.0000278  // SEC fee per $1 of trade value (sell only)
var float finraFeeRate = 0.000166 // FINRA TAF per share (sell only)
var float finraFeeMin = 0.01      // Minimum FINRA fee
var float finraFeeMax = 8.30      // Maximum FINRA fee per trade

// === FVG Detection Logic ===
var bullBreakLines = array.new<line>(0)
var bearBreakLines = array.new<line>(0)
var bullBreakLabels = array.new<label>(0)
var bearBreakLabels = array.new<label>(0)

upperBand = ta.highest(length)
lowerBand = ta.lowest(length)
midLevel = math.avg(upperBand, lowerBand)

currentBar = bar_index
isBullFVG = low > high[2] and close[1] > high[2]
isBearFVG = high < low[2] and close[1] < low[2]

var bool isBullBroken = false
var bool isBearBroken = false
var float bullTriggerLevel = 0
var float bearTriggerLevel = 0

// === Volume Filter ===
avgVolume = ta.sma(volume, volumeLookback)
isHighVolume = volume > avgVolume * volumeThreshold

// === Fee Calculation Functions ===
calcSECFee(float tradeValue) =>
    float fee = tradeValue * secFeeRate
    math.max(fee, 0.01)

calcFINRAFee(float shares) =>
    float fee = shares * finraFeeRate
    math.min(math.max(fee, finraFeeMin), finraFeeMax)

calcMarginCost(float positionSize) =>
    float cost = positionSize * (marginRate / 100) / 252  // Daily cost assuming 252 trading days
    cost

// === Bullish Breakout FVG ===
if low > upperBand[2] and isBullFVG
    box.new(currentBar-2, high[2], currentBar, low, na, bgcolor = bullBreakColor)
    isBullBroken := false
    bullTriggerLevel := high[2]
    if showMitigation
        bullBreakLines.unshift(line.new(currentBar-2, high[2], currentBar, high[2], color = bullBreakColor))
        bullBreakLabels.unshift(label.new(bar_index, high[2], color = color.rgb(0,0,0,90), text = "B", textcolor = bullBreakColor, style = label.style_label_left))

// === Bearish Breakout FVG ===
if high < lowerBand[2] and isBearFVG
    box.new(currentBar-2, low[2], currentBar, high, na, bgcolor = bearBreakColor)
    isBearBroken := false
    bearTriggerLevel := low[2]
    if showMitigation
        bearBreakLines.unshift(line.new(currentBar-2, low[2], currentBar, low[2], color = bearBreakColor))
        bearBreakLabels.unshift(label.new(bar_index, low[2], color = color.rgb(0,0,0,90), text = "B", textcolor = bearBreakColor, style = label.style_label_left))

bullTriggerLevel := math.max(bullTriggerLevel, midLevel)
bearTriggerLevel := math.min(bearTriggerLevel, midLevel)

if high > bearTriggerLevel
    isBearBroken := true
if low < bullTriggerLevel
    isBullBroken := true

// === Trading Logic with Fees and Volume Filter ===
var float entryPrice = 0.0
var float positionSize = 0.0
var float marginCost = 0.0
var float secFee = 0.0
var float finraFee = 0.0

if (isBullFVG and not isBullBroken and isHighVolume)
    entryPrice := close
    positionSize := strategy.position_size * entryPrice
    marginCost := calcMarginCost(positionSize)
    strategy.entry("Long", strategy.long)
    strategy.exit("TP/SL Long", "Long", stop = entryPrice * (1 - stopLossPerc / 100), limit = entryPrice * (1 + takeProfitPerc / 100))

if (isBearFVG and not isBearBroken and isHighVolume)
    entryPrice := close
    positionSize := strategy.position_size * entryPrice
    marginCost := calcMarginCost(positionSize)
    sellValue = entryPrice * strategy.position_size
    secFee := calcSECFee(sellValue)
    finraFee := calcFINRAFee(strategy.position_size)
    strategy.entry("Short", strategy.short)
    strategy.exit("TP/SL Short", "Short", stop = entryPrice * (1 + stopLossPerc / 100), limit = entryPrice * (1 - takeProfitPerc / 100))

