//@version=6
strategy("PSAR with ATR Trailing Stop + SMA Filter", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=0.5)

start     = input(0.003, title="PSAR Start")
increment = input(0.001, title="PSAR Increment")
maximum   = input(0.1,  title="PSAR Maximum")
atrLength = input(14,   title="ATR Length")
atrMult   = input(6.0,  title="ATR Multiplier")
smaLength = input(100,  title="Trend SMA Length")

psar     = ta.sar(start, increment, maximum)
atr      = ta.atr(atrLength)
smaTrend = ta.sma(close, smaLength)

// PSAR flip signals
longSignal  = psar < low and psar[1] > high[1]
shortSignal = psar > high and psar[1] < low[1]

// Dynamic trailing stops
longStop  = close - atrMult * atr
shortStop = close + atrMult * atr

// Entry conditions with SMA trend filter
if longSignal and close > smaTrend
    strategy.entry("Long", strategy.long)
if shortSignal and close < smaTrend
    strategy.entry("Short", strategy.short)

// Trailing stop exits
if strategy.position_size > 0
    strategy.exit("Long Exit", from_entry="Long", stop=longStop)
if strategy.position_size < 0
    strategy.exit("Short Exit", from_entry="Short", stop=shortStop)

// Plots
plot(psar,       "PSAR",       style=plot.style_cross, color=color.orange)
plot(smaTrend,   "SMA Trend",  color=color.blue, linewidth=2)
plot(longStop,   "Long Stop",  style=plot.style_cross, color=color.new(color.green, 50))
plot(shortStop,  "Short Stop", style=plot.style_cross, color=color.new(color.red,   50))

