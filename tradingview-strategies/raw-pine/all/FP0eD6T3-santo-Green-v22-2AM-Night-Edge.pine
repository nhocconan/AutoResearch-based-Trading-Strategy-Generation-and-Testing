//@version=5
strategy("Yoona Green v22 - 2AM Night Edge", shorttitle="santo V02 2AM", overlay=true, initial_capital=500000, default_qty_type=strategy.fixed, default_qty_value=1, commission_type=strategy.commission.cash_per_contract, commission_value=5, slippage=1, calc_on_every_tick=false)

// -----------------------------------------------
// INPUTS
// -----------------------------------------------

// Session
i_start_hour  = input.int(2,   "Session Start Hour (ET)",  minval=0, maxval=23, group="Session")
i_start_min   = input.int(0,   "Session Start Minute",     minval=0, maxval=59, group="Session")
i_end_hour    = input.int(3,   "Session End Hour (ET)",    minval=0, maxval=23, group="Session")
i_end_min     = input.int(0,   "Session End Minute",       minval=0, maxval=59, group="Session")

// Days
i_mon = input.bool(true, "Monday",    group="Days")
i_tue = input.bool(true, "Tuesday",   group="Days")
i_wed = input.bool(true, "Wednesday", group="Days")
i_thu = input.bool(true, "Thursday",  group="Days")
i_fri = input.bool(true, "Friday",    group="Days")

// Entry
i_ema_fast  = input.int(5,    "Fast EMA",      minval=1,             group="Entry")
i_ema_slow  = input.int(13,   "Slow EMA",      minval=1,             group="Entry")
i_rsi_len   = input.int(14,   "RSI Length",    minval=1,             group="Entry")
i_rsi_ob    = input.float(60, "RSI OB level",  minval=50, maxval=90, group="Entry")
i_rsi_os    = input.float(40, "RSI OS level",  minval=10, maxval=50, group="Entry")
i_short_bias= input.bool(true, "Prefer Short bias (aligns with overnight drift)", group="Entry")

// Risk
i_tp_usd    = input.float(30,  "Take Profit ($)",    minval=5,   step=5,  group="Risk")
i_sl_usd    = input.float(150, "Stop Loss ($)",      minval=25,  step=25, group="Risk")
i_trail_usd = input.float(75,  "Trailing Stop ($)",  minval=25,  step=25, group="Risk")
i_use_trail = input.bool(false, "Use Trailing Stop",              group="Risk")
i_max_trades= input.int(3,     "Max Trades Per Day", minval=1, maxval=10, group="Risk")
i_daily_loss= input.float(300, "Daily Loss Limit ($)",minval=50, step=50, group="Risk")

// -----------------------------------------------
// TICK / POINT MATH
// -----------------------------------------------

pt_val     = syminfo.pointvalue
tick_val   = syminfo.mintick
tp_ticks   = math.round(i_tp_usd    / pt_val / tick_val)
sl_ticks   = math.round(i_sl_usd    / pt_val / tick_val)
trail_ticks= math.round(i_trail_usd / pt_val / tick_val)

// -----------------------------------------------
// TIME  (Eastern Time)
// -----------------------------------------------

t_hr  = hour(time,      "America/New_York")
t_mn  = minute(time,    "America/New_York")
t_dow = dayofweek(time, "America/New_York")
t_now = t_hr * 60 + t_mn

sess_open  = i_start_hour * 60 + i_start_min
sess_close = i_end_hour   * 60 + i_end_min

in_session = (t_now >= sess_open) and (t_now <= sess_close)
at_close   = (t_now >= sess_close)

day_ok = ((t_dow == dayofweek.monday) and i_mon) or ((t_dow == dayofweek.tuesday) and i_tue) or ((t_dow == dayofweek.wednesday) and i_wed) or ((t_dow == dayofweek.thursday) and i_thu) or ((t_dow == dayofweek.friday) and i_fri)

// -----------------------------------------------
// DAILY COUNTERS
// -----------------------------------------------

var int   trades_today = 0
var float day_open_pnl = 0.0
var int   last_day     = 0

cur_day    = dayofmonth(time, "America/New_York")
is_new_day = cur_day != last_day

if is_new_day
    trades_today := 0
    day_open_pnl := strategy.netprofit
    last_day     := cur_day

daily_pnl      = strategy.netprofit - day_open_pnl
trade_limit_ok = trades_today < i_max_trades
loss_limit_ok  = daily_pnl    > -math.abs(i_daily_loss)

// -----------------------------------------------
// INDICATORS
// -----------------------------------------------

ema_f  = ta.ema(close, i_ema_fast)
ema_s  = ta.ema(close, i_ema_slow)
rsi    = ta.rsi(close, i_rsi_len)

// -----------------------------------------------
// SIGNALS
// Key insight from backtest:
//   Short bias = 73.3% WR  (overnight drift plays)
//   Long  bias = 60.0% WR
//   TP = $30 = just 15 NQ points = closes in 1-2 min
// -----------------------------------------------

cross_up = ta.crossover(ema_f,  ema_s)
cross_dn = ta.crossunder(ema_f, ema_s)

// Long: EMA cross up + RSI not overbought
long_sig = cross_up and (rsi < i_rsi_ob) and (rsi > 40)

// Short: EMA cross down + RSI not oversold
// Apply short bias multiplier - only take shorts when RSI is weaker
short_sig = cross_dn and (rsi > i_rsi_os) and (rsi < 60)

// Reduce long signals when short bias is on (overnight drift is bearish)
long_allowed  = (not i_short_bias) or (rsi < 50)
short_allowed = true

// -----------------------------------------------
// MASTER GATE
// -----------------------------------------------

can_trade = in_session and day_ok and trade_limit_ok and loss_limit_ok and (strategy.position_size == 0) and (not at_close)

// -----------------------------------------------
// ENTRIES
// -----------------------------------------------

if can_trade and long_sig and long_allowed
    strategy.entry("Long",  strategy.long,  comment="LONG 2AM")
    trades_today := trades_today + 1

if can_trade and short_sig and short_allowed
    strategy.entry("Short", strategy.short, comment="SHORT 2AM")
    trades_today := trades_today + 1

// -----------------------------------------------
// EXITS
// -----------------------------------------------

if strategy.position_size > 0
    strategy.exit("Long Exit", from_entry="Long",
         loss         = sl_ticks,
         profit       = tp_ticks,
         trail_points = i_use_trail ? trail_ticks           : na,
         trail_offset = i_use_trail ? math.round(trail_ticks / 2) : na)

if strategy.position_size < 0
    strategy.exit("Short Exit", from_entry="Short",
         loss         = sl_ticks,
         profit       = tp_ticks,
         trail_points = i_use_trail ? trail_ticks           : na,
         trail_offset = i_use_trail ? math.round(trail_ticks / 2) : na)

// Force close at session end
if at_close and (strategy.position_size != 0)
    strategy.close_all(comment="Session End")

// -----------------------------------------------
// PLOTS
// -----------------------------------------------

plot(ema_f, "EMA Fast", color=color.new(color.teal,   0), linewidth=1)
plot(ema_s, "EMA Slow", color=color.new(color.orange, 0), linewidth=2)

// Session highlight
bgcolor(in_session and day_ok    ? color.new(color.blue,  92) : na, title="2AM Session")
bgcolor(not loss_limit_ok        ? color.new(color.red,   85) : na, title="Loss Limit Hit")

// Signal arrows
plotshape(can_trade and long_sig  and long_allowed,  title="Long",  style=shape.triangleup,   location=location.belowbar, color=color.new(color.teal, 0), size=size.small, text="L")
plotshape(can_trade and short_sig and short_allowed, title="Short", style=shape.triangledown, location=location.abovebar, color=color.new(color.red,  0), size=size.small, text="S")

// -----------------------------------------------
// DASHBOARD
// -----------------------------------------------

var table dash = table.new(position.top_right, 2, 10, bgcolor=color.new(color.black, 55), border_color=color.new(color.gray, 50), border_width=1, frame_color=color.new(color.blue, 50), frame_width=2)

if barstate.islast
    pnl_c  = strategy.netprofit >= 0 ? color.teal : color.red
    wp     = strategy.closedtrades > 0 ? math.round(strategy.wintrades / strategy.closedtrades * 100, 1) : 0.0
    wr_c   = wp >= 70 ? color.teal : wp >= 55 ? color.orange : color.red
    dp_c   = daily_pnl >= 0 ? color.teal : color.red
    dl_c   = loss_limit_ok ? color.teal : color.red
    tc     = trades_today >= i_max_trades ? color.red : color.white
    aw     = strategy.wintrades  > 0 ? math.round(strategy.grossprofit  / strategy.wintrades,  0) : 0
    al     = strategy.losstrades > 0 ? math.round(strategy.grossloss    / strategy.losstrades, 0) : 0
    ss     = in_session and day_ok ? "ACTIVE" : day_ok ? "WAITING" : "OFF DAY"
    sc     = in_session and day_ok ? color.teal : color.gray
    table.cell(dash, 0, 0, "YG v22 - 2AM",   bgcolor=color.new(color.blue, 25), text_color=color.white,  text_size=size.small)
    table.cell(dash, 1, 0, "Night Edge",      bgcolor=color.new(color.blue, 25), text_color=color.white,  text_size=size.small)
    table.cell(dash, 0, 1, "Net P&L",         text_color=color.silver, text_size=size.tiny)
    table.cell(dash, 1, 1, str.tostring(math.round(strategy.netprofit, 0), "$#,##0"), text_color=pnl_c,  text_size=size.tiny)
    table.cell(dash, 0, 2, "Win Rate",        text_color=color.silver, text_size=size.tiny)
    table.cell(dash, 1, 2, str.tostring(wp) + "%", text_color=wr_c, text_size=size.tiny)
    table.cell(dash, 0, 3, "Trades",          text_color=color.silver, text_size=size.tiny)
    table.cell(dash, 1, 3, str.tostring(strategy.closedtrades), text_color=color.white, text_size=size.tiny)
    table.cell(dash, 0, 4, "Avg Win",         text_color=color.silver, text_size=size.tiny)
    table.cell(dash, 1, 4, str.tostring(aw, "$#,##0"), text_color=color.teal, text_size=size.tiny)
    table.cell(dash, 0, 5, "Avg Loss",        text_color=color.silver, text_size=size.tiny)
    table.cell(dash, 1, 5, str.tostring(al, "$#,##0"), text_color=color.red,  text_size=size.tiny)
    table.cell(dash, 0, 6, "Today Trades",    text_color=color.silver, text_size=size.tiny)
    table.cell(dash, 1, 6, str.tostring(trades_today) + "/" + str.tostring(i_max_trades), text_color=tc, text_size=size.tiny)
    table.cell(dash, 0, 7, "Today P&L",       text_color=color.silver, text_size=size.tiny)
    table.cell(dash, 1, 7, str.tostring(math.round(daily_pnl, 0), "$#,##0"), text_color=dp_c, text_size=size.tiny)
    table.cell(dash, 0, 8, "Loss Guard",      text_color=color.silver, text_size=size.tiny)
    table.cell(dash, 1, 8, loss_limit_ok ? "OK" : "HALTED", text_color=dl_c, text_size=size.tiny)
    table.cell(dash, 0, 9, "Session",         text_color=color.silver, text_size=size.tiny)
    table.cell(dash, 1, 9, ss, text_color=sc, text_size=size.tiny)


