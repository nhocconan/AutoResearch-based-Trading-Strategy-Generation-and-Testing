//@version=5
strategy("Keltner Trend Follower (20, 100)", overlay=true, initial_capital=10000, default_qty_type=strategy.percent_of_equity, default_qty_value=100)

// ============================================================================
// INPUTS
// ============================================================================

// Keltner Channel 20 Settings
kc20_length = input.int(20, "KC 20 - EMA Length", group="Keltner Channel 20")
kc20_mult = input.float(2.0, "KC 20 - ATR Multiplier", step=0.1, group="Keltner Channel 20")
kc20_atr_length = input.int(10, "KC 20 - ATR Length", group="Keltner Channel 20")

// Keltner Channel 100 Settings
kc100_length = input.int(100, "KC 100 - EMA Length", group="Keltner Channel 100")
kc100_mult = input.float(2.0, "KC 100 - ATR Multiplier", step=0.1, group="Keltner Channel 100")
kc100_atr_length = input.int(10, "KC 100 - ATR Length", group="Keltner Channel 100")

// Moving Average Settings
ma_length = input.int(100, "MA Length", group="Moving Average")

// ============================================================================
// CALCULATIONS
// ============================================================================

// Keltner Channel 20
kc20_basis = ta.ema(close, kc20_length)
kc20_range = ta.atr(kc20_atr_length) * kc20_mult
kc20_upper = kc20_basis + kc20_range
kc20_lower = kc20_basis - kc20_range

// Keltner Channel 100
kc100_basis = ta.ema(close, kc100_length)
kc100_range = ta.atr(kc100_atr_length) * kc100_mult
kc100_upper = kc100_basis + kc100_range
kc100_lower = kc100_basis - kc100_range

// Moving Average 100
ma100 = ta.sma(close, ma_length)

// ============================================================================
// STRATEGY LOGIC
// ============================================================================

// Long Conditions: Price > KC100 Upper AND Price breaks above KC20 Upper
longCondition = (close > kc100_upper) and ta.crossover(close, kc20_upper)
if (longCondition)
    strategy.entry("Long", strategy.long)

// Long Exit: Price breaks below MA 100
if (ta.crossunder(close, ma100))
    strategy.close("Long", comment="MA 100 Exit")

// Short Conditions: Price < KC100 Lower AND Price breaks below KC20 Lower
shortCondition = (close < kc100_lower) and ta.crossunder(close, kc20_lower)
if (shortCondition)
    strategy.entry("Short", strategy.short)

// Short Exit: Price breaks above MA 100
if (ta.crossover(close, ma100))
    strategy.close("Short", comment="MA 100 Exit")

// ============================================================================
// PLOTTING
// ============================================================================

// Keltner Channel 20 (Blue)
p20_u = plot(kc20_upper, "KC 20 Upper", color=color.blue, linewidth=1)
plot(kc20_basis, "KC 20 Basis", color=color.blue, linewidth=1, style=plot.style_circles, display=display.none)
p20_l = plot(kc20_lower, "KC 20 Lower", color=color.blue, linewidth=1)
fill(p20_u, p20_l, color=color.new(color.blue, 90), title="KC 20 Fill")

// Keltner Channel 100 (Purple)
p100_u = plot(kc100_upper, "KC 100 Upper", color=color.purple, linewidth=2)
p100_l = plot(kc100_lower, "KC 100 Lower", color=color.purple, linewidth=2)
fill(p100_u, p100_l, color=color.new(color.purple, 95), title="KC 100 Fill")

// Moving Average 100 (Yellow/Orange)
plot(ma100, "MA 100", color=color.orange, linewidth=2)

