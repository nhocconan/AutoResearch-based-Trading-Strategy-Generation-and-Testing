//@version=6
strategy("UT Bot + Hull MA Close-Cross Confirm (Futures v6)",
     overlay=true,
     pyramiding=0,
     process_orders_on_close=true,
     calc_on_every_tick=false)

// ─────────────────────────────────────────────────────────────────────────────
// Futures sizing (fixed contracts)
contracts = input.int(1, "Contracts", minval=1)

// UT Bot inputs
a         = input.float(1.0,  "Key Value (Sensitivity)", step=0.1)
c         = input.int(10,     "ATR Period", minval=1)
useHeikin = input.bool(false, "Signals from Heikin Ashi Candles")

// Hull inputs
hullLen = input.int(55, "Hull MA Length", minval=1)
mode    = input.string("Hma", "Hull Type", options=["Hma","Thma","Ehma"])

// Direction
tradeDir = input.string("Both", "Trade Direction", options=["Both","Long Only","Short Only"])

// TP/SL in ticks (futures-native)
useTPSL = input.bool(true, "Enable TP/SL")
tpTicks = input.int(80, "Take Profit (Ticks)", minval=1)
slTicks = input.int(40, "Stop Loss (Ticks)",  minval=1)

tick     = syminfo.mintick
tpOffset = tpTicks * tick
slOffset = slTicks * tick

// ─────────────────────────────────────────────────────────────────────────────
// Source (no repaint)
src = useHeikin
     ? request.security(ticker.heikinashi(syminfo.tickerid), timeframe.period, close,
         lookahead=barmerge.lookahead_off)
     : close

xATR  = ta.atr(c)
nLoss = a * xATR

// ─────────────────────────────────────────────────────────────────────────────
// UT Bot trailing stop (v4-faithful)
var float stop = 0.0
prevStop = nz(stop[1], 0.0)

if src > prevStop and src[1] > prevStop
    stop := math.max(prevStop, src - nLoss)
else if src < prevStop and src[1] < prevStop
    stop := math.min(prevStop, src + nLoss)
else
    stop := src > prevStop ? src - nLoss : src + nLoss

// UT signals
ema1  = ta.ema(src, 1)
above = ta.crossover(ema1, stop)
below = ta.crossover(stop, ema1)

utBuy  = src > stop and above
utSell = src < stop and below

// ─────────────────────────────────────────────────────────────────────────────
// Hull Suite (v6-safe)
HMA(_src, _len) =>
    ta.wma(
        2 * ta.wma(_src, _len / 2) - ta.wma(_src, _len),
        math.round(math.sqrt(_len))
    )

EHMA(_src, _len) =>
    ta.ema(
        2 * ta.ema(_src, _len / 2) - ta.ema(_src, _len),
        math.round(math.sqrt(_len))
    )

THMA(_src, _len) =>
    ta.wma(
        ta.wma(_src, _len / 3) * 3 - ta.wma(_src, _len / 2) - ta.wma(_src, _len),
        _len
    )

thLen = math.max(1, int(math.round(hullLen / 2.0)))

HULL = mode == "Hma"  ? HMA(close, hullLen) :
       mode == "Ehma" ? EHMA(close, hullLen) :
       THMA(close, thLen)

plot(HULL, "Hull MA", color=color.new(color.orange, 0))

// ─────────────────────────────────────────────────────────────────────────────
// Close-cross confirm delay
var int  signalState = 0
var bool buySignal   = false
var bool sellSignal  = false

buySignal  := utBuy and close > HULL ? true :
              signalState == 1 and ta.crossover(close, HULL) ? true : false

sellSignal := utSell and close < HULL ? true :
              signalState == -1 and ta.crossunder(close, HULL) ? true : false

signalState := utBuy  and close <= HULL ? 1 :
               utSell and close >= HULL ? -1 :
               buySignal or sellSignal ? 0 :
               signalState

plotshape(buySignal,  "Buy",  shape.labelup,   location.belowbar, color=color.new(color.green,0), text="Buy",  textcolor=color.white, size=size.tiny)
plotshape(sellSignal, "Sell", shape.labeldown, location.abovebar, color=color.new(color.red,0),   text="Sell", textcolor=color.white, size=size.tiny)

// ─────────────────────────────────────────────────────────────────────────────
// Entries
allowLong  = tradeDir == "Both" or tradeDir == "Long Only"
allowShort = tradeDir == "Both" or tradeDir == "Short Only"

// Build webhook JSON messages
longEntryMsg = '{"symbol":"' + syminfo.ticker + '","action":"buy","price":' + str.tostring(close) + ',"contracts":' + str.tostring(contracts) + ',"position":"long","time":"{{timenow}}"}'
shortEntryMsg = '{"symbol":"' + syminfo.ticker + '","action":"sell","price":' + str.tostring(close) + ',"contracts":' + str.tostring(contracts) + ',"position":"short","time":"{{timenow}}"}'
closeMsg = '{"symbol":"' + syminfo.ticker + '","action":"close","price":' + str.tostring(close) + ',"contracts":' + str.tostring(contracts) + ',"position":"flat","time":"{{timenow}}"}'

if buySignal and allowLong
    strategy.entry("Long", strategy.long, qty=contracts, alert_message=longEntryMsg)

if sellSignal and allowShort
    strategy.entry("Short", strategy.short, qty=contracts, alert_message=shortEntryMsg)

// Exits with webhook alerts
if useTPSL
    if strategy.position_size > 0
        strategy.exit("Long TP/SL", from_entry="Long",
            limit = strategy.position_avg_price + tpOffset,
            stop  = strategy.position_avg_price - slOffset,
            alert_message=closeMsg)

    if strategy.position_size < 0
        strategy.exit("Short TP/SL", from_entry="Short",
            limit = strategy.position_avg_price - tpOffset,
            stop  = strategy.position_avg_price + slOffset,
            alert_message=closeMsg)

