strategy("EMA12/26 buy spot only", overlay=true)

longCondition = ta.crossover(ta.ema(close, 12), ta.ema(close, 26))
if (longCondition)
    strategy.entry("buy", strategy.long)

if ta.crossunder(ta.ema(close, 12), ta.ema(close, 26))
    strategy.close("buy")

