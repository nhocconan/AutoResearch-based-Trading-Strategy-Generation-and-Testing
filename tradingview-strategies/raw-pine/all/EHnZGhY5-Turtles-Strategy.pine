//@version=6
strategy("Turtles Strategy (Fast System - Intrabar Entries, Realized Cash Only)", shorttitle="Turtle EA", overlay=true, pyramiding=0, default_qty_type=strategy.fixed, default_qty_value=1, process_orders_on_close=false, initial_capital=100000)

// Inputs
enter_fast = input.int(20, title="Entry Period", minval=1)
exit_fast = input.int(10, title="Exit Period", minval=1)
atr_length = input.int(20, title="ATR Length", minval=1)
atr_mult = input.float(2.0, title="ATR Stop Multiplier", minval=0.1, step=0.1)
risk_percent = input.float(1.0, title="Risk % of Equity", minval=0.1, maxval=100) // Default risk = 1%

// Turtle Risk Management Variables (adapted for realized cash)
var float peak_equity = na
var int reduction_count = 0
var float current_risk_multiplier = 1.0
var float recovery_threshold = na
var bool reductions_active = false

// Realized equity: initial + net realized PnL (excludes open unrealized)
realized_equity = strategy.initial_capital + strategy.netprofit

// Update peak equity based on realized only
if na(peak_equity)
    peak_equity := realized_equity
else
    peak_equity := math.max(peak_equity, realized_equity)

// Risk Management Logic (using realized equity only)
if not reductions_active
    if realized_equity < peak_equity * 0.9 and reduction_count < 3
        reductions_active := true
        recovery_threshold := peak_equity
        current_risk_multiplier := 0.8
        reduction_count := 1
else if reductions_active
    // Check for further reductions (at 20%, 30% drawdown from original peak)
    dd_level = 1.0 - (0.1 * reduction_count)
    if realized_equity < peak_equity * dd_level and reduction_count < 3
        current_risk_multiplier *= 0.8
        reduction_count += 1
    // Check for recovery
    if not na(recovery_threshold) and realized_equity > recovery_threshold
        reductions_active := false
        reduction_count := 0
        current_risk_multiplier := 1.0
        recovery_threshold := na

// Calculations
fastL = ta.highest(high, enter_fast)
fastLC = ta.lowest(low, exit_fast)
fastS = ta.lowest(low, enter_fast)
fastSC = ta.highest(high, exit_fast)
atr = ta.atr(atr_length)
stop_distance = atr * atr_mult

// Position Sizing (effective risk % of realized equity, adjusted for point value)
pointvalue = syminfo.pointvalue // e.g., 1 for spot/forex/CFD, varies for futures contracts
effective_risk = risk_percent * current_risk_multiplier
position_size = pointvalue > 0 ? (realized_equity * (effective_risk / 100.0)) / (stop_distance * pointvalue) : 0

// Persistent variable for initial stop distance
var float initial_stop_distance = na

// Entry stops with 1 tick slippage for confirmation
tick = syminfo.mintick
if strategy.position_size == 0 and not na(position_size) and position_size > 0
    strategy.cancel_all()
    strategy.entry("Long", strategy.long, stop=fastL[1] + tick, qty=position_size, oca_name="Breakout", oca_type=strategy.oca.cancel)
    strategy.entry("Short", strategy.short, stop=fastS[1] - tick, qty=position_size, oca_name="Breakout", oca_type=strategy.oca.cancel)

// Set initial stop distance on entry bar close
if strategy.position_size != 0 and strategy.position_size[1] == 0
    initial_stop_distance := atr * atr_mult

// Manage exits: tighter of initial ATR stop or trailing stop (with tick slippage for confirmation)
if strategy.position_size > 0 and not na(initial_stop_distance)
    trail_stop = fastLC[1] - tick
    init_stop = strategy.position_avg_price - initial_stop_distance
    effective_stop = math.max(init_stop, trail_stop)
    strategy.exit("Exit Long", "Long", stop=effective_stop)

if strategy.position_size < 0 and not na(initial_stop_distance)
    trail_stop = fastSC[1] + tick
    init_stop = strategy.position_avg_price + initial_stop_distance
    effective_stop = math.min(init_stop, trail_stop)
    strategy.exit("Exit Short", "Short", stop=effective_stop)

