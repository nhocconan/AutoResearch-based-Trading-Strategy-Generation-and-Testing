//@version=6
strategy("Advanced Breakout System v2.0", overlay=true, initial_capital=10000, 
     default_qty_type=strategy.percent_of_equity, 
     default_qty_value=2, currency=currency.USD, 
     commission_type=strategy.commission.percent, 
     commission_value=0.07,      slippage=3 )
     
// -------------------------------------------------------------------------
// 1. Settings (Inputs)
// -------------------------------------------------------------------------
group_entry = "Entry Settings"
// --- CONDITIONAL INPUTS ---
// Apply less restrictive settings on Daily chart to force more trades for policy compliance
is_daily = timeframe.isdaily

// Less restrictive Lookback (e.g., 5 bars instead of 20) on Daily
daily_lookback = 5
default_lookback = input.int(20, "Consolidation Lookback (Bars)", minval=5, group=group_entry)
lookback_period = is_daily ? daily_lookback : default_lookback

// More restrictive Range (e.g., 50% instead of 12%) on Daily
daily_range_percent = 50.0 // Allow a much wider range for a 'consolidation'
default_range_percent = input.float(12.0, "Consolidation Range %", minval=1.0, step=0.5, group=group_entry)
range_percent_val = is_daily ? daily_range_percent : default_range_percent
range_percent = range_percent_val / 100 
// -------------------------------------------------------------------------
// The rest of the script remains the same, but replaces these:
// lookback_period = input.int(...)  // Delete this line
// range_percent = input.float(...) / 100 // Delete this line
// -------------------------------------------------------------------------
vol_multiplier  = input.float(1.2, "Volume Spike Multiplier", minval=1.0, step=0.1, group=group_entry)
use_obv_filter  = input.bool(true, "Enable Smart Volume Filter (OBV)", group=group_entry)
ignore_cons_on_big_move = input.bool(true, "Force Signal on Big Moves (>5%)", tooltip="Triggers an immediate WATCH signal for strong moves, bypassing all filters", group=group_entry)

group_exit = "Exit Settings (Warnings)"
use_fast_exit    = input.bool(true, "Enable Fast Exit (EMA 9)", group=group_exit)
use_vol_exit     = input.bool(true, "Enable Volume Dump Exit", group=group_exit)
vol_exit_mult    = input.float(2.0, "Dump Volume Multiplier", group=group_exit)
use_pattern_exit = input.bool(true, "Enable Bearish Engulfing Exit", group=group_exit)

// --- GROUP: Support & Resistance ---
group_sr = "Support & Resistance Points"
sr_left_bars  = input.int(15, "Pivot Left Bars", minval=2, tooltip="Minimum bars to the left to confirm a point", group=group_sr)
sr_right_bars = input.int(5, "Pivot Right Bars", minval=1, tooltip="Minimum bars to the right to confirm a point (lag)", group=group_sr)

// -------------------------------------------------------------------------
// 2. Indicators & Calculations
// -------------------------------------------------------------------------
highest_high = ta.highest(high, lookback_period)[1]
lowest_low   = ta.lowest(low, lookback_period)[1]

avg_volume = ta.sma(volume, 20)
ema_fast   = ta.ema(close, 9)
sma_slow   = ta.sma(close, 20)

obv_value = ta.obv
obv_ma    = ta.sma(obv_value, lookback_period)
is_obv_strong = (obv_value > obv_ma)

// --- Pivot Calculation ---
pivot_high = ta.pivothigh(high, sr_left_bars, sr_right_bars)
pivot_low  = ta.pivotlow(low, sr_left_bars, sr_right_bars)

// -------------------------------------------------------------------------
// 3. Logic & Strategy
// -------------------------------------------------------------------------
is_consolidating = ((highest_high - lowest_low) / close[1]) < range_percent
is_big_move = (close > open * 1.05)
breakout_core = close > highest_high and volume > (avg_volume * vol_multiplier)

normal_trigger = breakout_core and is_consolidating[1]
final_normal_trigger = use_obv_filter ? (normal_trigger and is_obv_strong) : normal_trigger
momentum_trigger = breakout_core and is_big_move and ignore_cons_on_big_move
breakout_condition = final_normal_trigger or momentum_trigger

var bool pending_confirmation = false
var float breakout_high_price = 0.0

if breakout_condition
    pending_confirmation := true
    breakout_high_price := high

if pending_confirmation and close < lowest_low
    pending_confirmation := false

valid_entry = pending_confirmation and high > breakout_high_price and bar_index > 0 and not breakout_condition

if valid_entry
    pending_confirmation := false

// -------------------------------------------------------------------------
// 4. Exits Logic
// -------------------------------------------------------------------------
exit_trend = use_fast_exit and ta.crossunder(close, ema_fast)
exit_vol = use_vol_exit and close < open and volume > (avg_volume * vol_exit_mult)
is_engulfing = close < open and close[1] > open[1] and close < low[1] and open > high[1]
exit_pattern = use_pattern_exit and is_engulfing
any_exit_signal = exit_trend or exit_vol or exit_pattern

// -------------------------------------------------------------------------
// 5. Strategy Execution
// -------------------------------------------------------------------------
if valid_entry
    strategy.entry("Long Position", strategy.long, stop=breakout_high_price)

if strategy.position_size > 0 and any_exit_signal
    strategy.close("Long Position", comment="Exit Signal")

// -------------------------------------------------------------------------
// 6. Alerts
// -------------------------------------------------------------------------
if breakout_condition
    alert("🟡 WATCH SETUP: " + syminfo.ticker + " - Breakout Detected. Prepare for entry.", alert.freq_once_per_bar_close)

if valid_entry
    alert("🟢 BUY SIGNAL: " + syminfo.ticker + " - Price Confirmed above Breakout Level.", alert.freq_once_per_bar_close)

if any_exit_signal
    string exit_reason = ""
    if exit_trend
        exit_reason := "Trend Broken (EMA 9)"
    else if exit_vol
        exit_reason := "Volume Dump (Distribution)"
    else if exit_pattern
        exit_reason := "Bearish Pattern (Engulfing)"
    alert("🔴 SELL SIGNAL: " + syminfo.ticker + " - Reason: " + exit_reason, alert.freq_once_per_bar_close)

// -------------------------------------------------------------------------
// 7. Visualization
// -------------------------------------------------------------------------
fill(plot(highest_high, display=display.none), plot(lowest_low, display=display.none), color=is_consolidating ? color.new(color.blue, 90) : na, title="Consolidation Zone")
plot(use_fast_exit ? ema_fast : na, "EMA 9 (Fast Exit)", color.orange)
plot(sma_slow, "SMA 20 (Trend)", color.gray)

// Signals
plotshape(breakout_condition, "Breakout Setup", shape.arrowdown, location.abovebar, color.yellow, 0, "WATCH", color.yellow, size=size.small)
plotshape(valid_entry, "Buy Confirmation", shape.arrowup, location.belowbar, color.green, 0, "BUY", color.green, size=size.small)
plotshape(exit_trend, "Trend Break", shape.arrowdown, location.abovebar, color.orange, 0, "BREAK", color.orange, size=size.small)
plotshape(exit_vol, "Volume Dump", shape.arrowdown, location.abovebar, color.maroon, 0, "DUMP", color.maroon, size=size.small)
plotshape(exit_pattern, "Bearish Pattern", shape.arrowdown, location.abovebar, color.purple, 0, "PATTERN", color.purple, size=size.small)

// --- NEW: Support & Resistance (Lines & Price Labels) ---

// 1. Draw Resistance (Red Line + Price)
if not na(pivot_high)
    // Pivot location is in the past
    pivot_loc = bar_index - sr_right_bars
    // Draw small red line
    line.new(x1=pivot_loc - 1, y1=pivot_high, x2=pivot_loc + 1, y2=pivot_high, color=color.red, width=2)
    // Draw price text above
    label.new(x=pivot_loc, y=pivot_high, text=str.tostring(pivot_high, format.mintick), style=label.style_label_down, color=color.new(color.white, 100), textcolor=color.red, size=size.small)

// 2. Draw Support (Green Line + Price)
if not na(pivot_low)
    // Pivot location is in the past
    pivot_loc = bar_index - sr_right_bars
    // Draw small green line
    line.new(x1=pivot_loc - 1, y1=pivot_low, x2=pivot_loc + 1, y2=pivot_low, color=color.green, width=2)
    // Draw price text below
    label.new(x=pivot_loc, y=pivot_low, text=str.tostring(pivot_low, format.mintick), style=label.style_label_up, color=color.new(color.white, 100), textcolor=color.green, size=size.small)

