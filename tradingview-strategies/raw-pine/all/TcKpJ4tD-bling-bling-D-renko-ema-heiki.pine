trendD0 := (heikinashi_Dopen0<heikinashi_Dclose0) ? 0:1

trend600 := (heikinashi_60open0<heikinashi_60close0) ? 0:1

heikinashi_Wclose1 = security(heikinashi(tickerid), 'W', open)
heikinashi_Wclose2 = security(heikinashi(tickerid), 'W', close[1])

heikinashi_short = security(heikinashi(tickerid), 'D', close)
sma=sma(open,20)
ema= ema(close,7)
highest = highest(close[1],1)
lowest = lowest(close[1],20)
mid = (highest + lowest)/2

//if (rsi <= rsi_low and sma >= mid and close < heikinashi_close)

