//DEFINE ARROWS
buy=     trend_240_renko==0 and ema( renko_240close,14) < close//and trend_3_renko==0 and trend_W_renko==0//  ///    ha_open1 <= ha_close1 and sma  <= close and heikinashi_short > heikinashi_close
sell = trend_240_renko==1 //and ema( renko_240close,2) > close//and sma > hl2 //and trend_240_renko==1//trend_3_renko==1 and    ///ha_open1 >= ha_close1 and sma >= close and heikinashi_close < heikinashi_short
neutral = buy == 0 and sell == 0

//PREVENT REPETITIVE ARROWS
timetobuy = buy==1
timetosell = sell==1
tup = barssince(timetobuy[1])
tdn = barssince(timetosell[1])
long    = tup>tdn?1:na
short   = tdn>tup?1:na

plotshape(sell, color=red, location=location.abovebar, style=shape.arrowdown, size=size.huge, title="Sell Arrow", transp=0)
plotshape(buy, color=green, location=location.abovebar, style=shape.arrowup, size=size.huge,title=" Buy Arrow", transp=0)

trend1 = green
futur =sma(hl2,1)

futur := (sma(close[1],1)-sma(open,1))+sma(close,1)
if futur > hl2 
    trend1 := green
if futur < hl2 
    trend := red


plot(futur, title='futur', color=yellow, linewidth=2, style=stepline, offset=1,transp=20, trackprice=true)
newarrow = timetobuy == 1 or timetosell == 1
alertcondition(sell, title='Sell Alert', message = 'Down Arrow')
alertcondition(buy, title='Buy Alert', message = 'Up Arrow')
alertcondition(newarrow, title='New Arrow', message = 'New Arrow')

 
 
  
