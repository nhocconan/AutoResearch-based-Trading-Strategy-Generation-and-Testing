//@version=6
strategy("[Outperforms Bitcoin Since 2011] Professional MA Strategy", "BTC Professional MA Strategy", true, 
  initial_capital = 1000000, default_qty_value = 100,  default_qty_type = strategy.percent_of_equity, 
  margin_long = 10, margin_short = 10, currency = currency.USD)

fast = ta.wma(hlc3, input.int(30, "fast")) 
slow = ta.wma(hlc3, input.int(360, 'slow'))

plot(fast, 'fast', color.blue, 2)
plot(slow, 'slow', color.black, 2)

buy = hlc3 > fast and (hlc3 < fast)[1] 
sell = hlc3 < fast and (hlc3 > fast)[1]

if buy and hlc3 > slow 
    strategy.entry('long', strategy.long)

if sell and hlc3 < slow 
    strategy.entry('short', strategy.short)

if hlc3 < fast 
    strategy.close('long')

if hlc3 > fast 
    strategy.close('short')

