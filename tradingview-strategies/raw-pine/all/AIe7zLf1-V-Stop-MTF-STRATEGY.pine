//@version=5
strategy("Volatility Stop MTF → STRATEGY [Fixed - No Errors]", 
         overlay = true,
         default_qty_type = strategy.fixed,
         default_qty_value = 1,
         initial_capital = 100000,
         commission_value = 0,
         slippage = 0,
         pyramiding = 1,
         calc_on_every_tick = false,
         process_orders_on_close = true,   // Critical for exact match with indicator
         max_bars_back = 5000)

// ──────────────────────────────────────────────────────────────
// IMPORTS & INPUTS (100% identical to your indicator)
// ──────────────────────────────────────────────────────────────
import PineCoders/Time/1 as pcTimeLib

// Colors
color GREEN1     = #00FF00FF
color DARKLIME   = #00FF0080
color RED1       = #FF0000FF
color DARKRED    = #FF0000b0
color DEEPSKY    = #00C0FFFF
color DEEPBLUE   = #00C0FF80
color DEEPPINK   = #FF0080FF
color DARKPINK   = #FF008080
color ORANGE     = #FF8000FF
color DARKORANGE = #FF8000d0
color CLEARBLACK = #00000000

// Inputs - exactly as in your indicator
string GRP1 = "═════════ Stop Calculations ═════════"
srcInput   = input.source(close,  "Source",          group = GRP1)
lenInput   = input.int(20,        "Length",          group = GRP1, minval = 2)
atrInput   = input.float(2.0,     "ATR Factor",      group = GRP1, minval = 0.25, step = 0.25)

string GRP2 = "══════════  HTF Selection  ══════════"
typeInput  = input.string("Multiple Of Current TF", "Higher Timeframe Selection", options = ["None", "Discrete Steps (60min, 1D, 3D, 1W, 1M, 12M)", "Multiple Of Current TF", "Fixed TF"], group = GRP2)
type2Input = input.float(3.0, "  Multiple of Current TF", minval = 1, group = GRP2)
type3Input = input.timeframe("D", "  Fixed TF", group = GRP2)

detectBreachesInput = input.bool(true,  "Detect Breaches By Chart Bars", group = GRP2)
repaintsInput       = input.bool(false, "Repainting HTF", group = GRP2)
breachesMrkrInput   = input.bool(true,  "  Show Chart Breaches", group = GRP2)
breachedBarsInput   = input.bool(false, "  Color Bars in Limbo", group = GRP2)
breachedBgInput     = input.bool(false, "  Highlight Background in Limbo", group = GRP2)

string GRP4 = "════════════  Visuals  ═══════════"
colSchemeInput = input.string("Aqua/Pink", "Color Scheme", options = ["Lime/Red", "Aqua/Pink"], group = GRP4)
thicknessInput = input.int(2, "Line Thickness", options = [0,1,2,3], group = GRP4)
colorBarsInput = input.bool(false, "Color Bars on Trend State (continuous)", group = GRP4)
colorCandlesOnReversal = input.bool(true, "Color Candles on Trend Reversal", group = GRP4)   // ← Your favorite feature

string GRP5 = "═══════════  Display HTF  ══════════"
showHTFInput = input.bool(false, "Show HTF Used", group = GRP5)
string textSizeInput = input.string("large", "Text Size", group = GRP5, options = ["tiny","small","normal","large","huge","auto"])
string tableYposInput = input.string("bottom", "Position  ", group = GRP5, options = ["top","middle","bottom"], inline = "41")
string tableXposInput = input.string("right", "", group = GRP5, options = ["left","center","right"], inline = "41")

bool defaultScheme = colSchemeInput == "Lime/Red"
bool htfOn = typeInput != "None"

// ──────────────────────────────────────────────────────────────
// Volatility Stop Function (exact copy from your indicator)
// ──────────────────────────────────────────────────────────────
vStop(series float source, simple int atrLength, series float atrMult, series int offset = 0) =>
    float src = nz(source, close)
    var bool  trendUp = true
    var float max     = src
    var float min     = src
    var float stop    = 0.0
    float atrM = nz(ta.atr(atrLength) * atrMult, ta.tr)
    max := math.max(max, src)
    min := math.min(min, src)
    stop := nz(trendUp ? math.max(stop, max - atrM) : math.min(stop, min + atrM), src)
    trendUp := src - stop >= 0.0
    if trendUp != nz(trendUp[1], true)
        max := src
        min := src
        stop := trendUp ? max - atrM : min + atrM
    [stop[offset], trendUp[offset]]

// HTF Logic
tfNextStep(simple int tf) =>
    switch
        tf <= 1    => "60"
        tf <= 60   => "1D"
        tf <= 360  => "3D"
        tf <= 1440 => "1W"
        tf <= 10080=> "1M"
        => "12M"

int tfInSec = timeframe.in_seconds()
string htf = switch typeInput
    "Discrete Steps (60min, 1D, 3D, 1W, 1M, 12M)" => tfNextStep(tfInSec / 60)
    "Multiple Of Current TF"                     => pcTimeLib.secondsToTfString(tfInSec, type2Input)
    "Fixed TF"                                   => type3Input
    => ""

int offset = not htfOn ? 0 : (not repaintsInput and barstate.isrealtime ? 1 : 0)

[stopChartTf, trendUpChartTf] = vStop(srcInput, lenInput, atrInput, offset)

// FIXED: Separate request.security calls for lookahead (cannot be conditional)
[stopSec_repaint, trendUpSec_repaint] = request.security(syminfo.tickerid, htf, [stopChartTf, trendUpChartTf], lookahead = barmerge.lookahead_on)
[stopSec_norepaint, trendUpSec_norepaint] = request.security(syminfo.tickerid, htf, [stopChartTf, trendUpChartTf], lookahead = barmerge.lookahead_off)

float stopSec     = repaintsInput ? stopSec_repaint : stopSec_norepaint
bool  trendUpSec  = repaintsInput ? trendUpSec_repaint : trendUpSec_norepaint

float stopHTF     = stopSec[repaintsInput or barstate.isrealtime ? 0 : 1]
bool  trendUpHTF  = trendUpSec[repaintsInput or barstate.isrealtime ? 0 : 1]

float stop    = htfOn ? stopHTF : stopChartTf
bool  trendUp = htfOn ? trendUpHTF : trendUpChartTf

// Limbo state (breach detection) - exact from your indicator
var bool inLimbo = false
bool trendReversal = trendUp != trendUp[1]
bool trendChangeToUp = trendUp and not trendUp[1]
bool trendChangeToDn = not trendUp and trendUp[1]
bool htfBreach = htfOn and detectBreachesInput and not inLimbo and ta.cross(close, stop)
bool earlyBreachUp = htfBreach and not trendReversal and trendUp
bool earlyBreachDn = htfBreach and not trendReversal and not trendUp
inLimbo := (inLimbo or htfBreach) and trendUp == trendUp[1]

// Trading signals (only when not in limbo)
bool goLongSignal  = trendChangeToUp and not inLimbo
bool goShortSignal = trendChangeToDn and not inLimbo

// ──────────────────────────────────────────────────────────────
// STRATEGY EXECUTION – Reversing System
// ──────────────────────────────────────────────────────────────
if goLongSignal
    strategy.entry("Long", strategy.long)
if goShortSignal
    strategy.entry("Short", strategy.short)

// Close opposite on reversal (always in market)
if goLongSignal
    strategy.close("Short")
if goShortSignal
    strategy.close("Long")

// ──────────────────────────────────────────────────────────────
// VISUALS – Exact replica of your indicator
// ──────────────────────────────────────────────────────────────
color colorUp   = inLimbo ? (defaultScheme ? DARKLIME : DEEPBLUE) : (defaultScheme ? GREEN1 : DEEPSKY)
color colorDown = inLimbo ? (defaultScheme ? DARKRED  : DARKPINK) : (defaultScheme ? RED1   : DEEPPINK)
color schemeColor = inLimbo
     ? (defaultScheme ? (trendUp ? DARKLIME : DARKRED) : (trendUp ? DEEPBLUE : DARKPINK))
     : (defaultScheme ? (trendUp ? GREEN1 : RED1)       : (trendUp ? DEEPSKY : DEEPPINK))
color lineColor = trendReversal or htfBreach ? CLEARBLACK : schemeColor

// NEW: Candle colors on reversal (your feature)
color candleBull = defaultScheme ? GREEN1 : DEEPSKY
color candleBear = defaultScheme ? RED1   : DEEPPINK

plot(thicknessInput != 0 ? stop : na, "V-Stop", lineColor, thicknessInput)
plot(trendReversal ? stop : na, "Beg. Circle", schemeColor, math.max(thicknessInput,1)+2, plot.style_circles)
plot(trendReversal ? stop : na, "Beg. Small circle", #000000ff, math.max(thicknessInput,1), plot.style_circles)

// Entry shapes
plotshape(goLongSignal,  title="Long Signal",  location=location.belowbar, color=color.lime, style=shape.triangleup,   size=size.small)
plotshape(goShortSignal, title="Short Signal", location=location.abovebar, color=color.red,  style=shape.triangledown, size=size.small)

// Breach markers
plotshape(breachesMrkrInput and earlyBreachUp, "Breach of HTF Uptrend", shape.triangledown, location.abovebar, RED1, size = size.tiny)
plotshape(breachesMrkrInput and earlyBreachDn, "Breach of HTF Downtrend", shape.triangleup,   location.belowbar, RED1, size = size.tiny)

// ————— Bar coloring ————— (exact from your indicator)
// 1. Original continuous coloring (optional)
barcolor(colorBarsInput ? (trendUp ? colorUp : colorDown) : na)
// 2. Color candles instantly on every trend reversal
barcolor(colorCandlesOnReversal and trendReversal ? (trendUp ? candleBull : candleBear) : na)
// 3. Limbo coloring (orange)
barcolor(breachedBarsInput and inLimbo ? (close > open ? ORANGE : DARKORANGE) : na)

bgcolor(breachedBgInput and inLimbo ? color.new(color.silver, 90) : na)

// Error check (from your indicator)
if htfOn and tfInSec >= timeframe.in_seconds(htf)
    runtime.error("Chart timeframe must be < " + htf)

// HTF display table (from your indicator)
if barstate.islastconfirmedhistory and htfOn and showHTFInput
    var table tfDisplay = table.new(tableYposInput + "_" + tableXposInput, 1, 1)
    table.cell(tfDisplay, 0, 0, htf, text_color = color.silver, text_size = textSizeInput)

// ──────────────────────────────────────────────────────────────
// ALERTS (same as your indicator)
// ──────────────────────────────────────────────────────────────
string A1 = alert.freq_once_per_bar
string A2 = alert.freq_once_per_bar_close
string freqInput = input.string(A1, "Alert Frequency", options = [A1, A2])

float delayInput = input.float(0.0, "Delay in Minutes", minval = 0.0, step = 0.5)
float secondsUp = pcTimeLib.secondsSince(trendChangeToUp, false)
float secondsDn = pcTimeLib.secondsSince(trendChangeToDn, false)
bool alertUp = secondsUp >= delayInput * 60
bool alertDn = secondsDn >= delayInput * 60
bool alertRev = alertUp or alertDn

bool timed = delayInput != 0
float duration = trendChangeToUp ? secondsUp : secondsDn

if alertRev
    alert("Trend Reversal. " + (timed ? "Close crossed stop for " + str.tostring(duration/60,"#.##m") : ""), freqInput)
if alertUp
    alert("Change to uptrend. " + (timed ? "Close was above stop for " + str.tostring(secondsUp/60,"#.##m") : ""), freqInput)
if alertDn
    alert("Change to downtrend. " + (timed ? "Close was below stop for " + str.tostring(secondsDn/60,"#.##m") : ""), freqInput)

