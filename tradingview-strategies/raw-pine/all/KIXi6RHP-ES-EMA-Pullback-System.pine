//@version=5
strategy("ES EMA Pullback System", overlay=true,
     initial_capital=50000,
     default_qty_type=strategy.fixed,
     default_qty_value=1)

// ===== INPUTS =====
fastEMA = input.int(9)
midEMA  = input.int(21)
slowEMA = input.int(50)

atrLen = input.int(14)
stopATR = input.float(1.6)
targetATR = input.float(3.2)

// ===== SESSION =====
sessionInput = input.session("0930-1130,1330-1600")
inSession = not na(time(timeframe.period, sessionInput))

// ===== EMAs =====
ema9  = ta.ema(close, fastEMA)
ema21 = ta.ema(close, midEMA)
ema50 = ta.ema(close, slowEMA)

plot(ema9, color=color.blue)
plot(ema21, color=color.orange)
plot(ema50, color=color.red)

// ===== TREND =====
bearTrend = ema9 < ema21 and ema21 < ema50

// ===== PULLBACK =====
pullback = high >= ema9

// ===== MOMENTUM =====
bearMomentum = close < open

// ===== ENTRY =====
sellSignal =
     bearTrend and
     pullback and
     bearMomentum

// ===== ATR =====
atr = ta.atr(atrLen)

shortStop = close + atr * stopATR
shortTarget = close - atr * targetATR

// ===== EXECUTE =====
if sellSignal and inSession
    strategy.entry("SELL", strategy.short)

strategy.exit("EXIT", "SELL",
     stop=shortStop,
     limit=shortTarget)

// ===== LABEL =====
if sellSignal and inSession
    label.new(bar_index, high, "SELL",
         style=label.style_label_down,
         color=color.red,
         textcolor=color.white,
         size=size.tiny)

