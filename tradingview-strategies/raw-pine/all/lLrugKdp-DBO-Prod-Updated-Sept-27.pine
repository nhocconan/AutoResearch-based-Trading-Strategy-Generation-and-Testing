//@version=6
strategy("DBO_Prod", shorttitle="DBO_Prod", overlay=true, calc_on_every_tick=true, process_orders_on_close=false, margin_long=0, margin_short=0)

// Minimal artifact to satisfy TradingView publish requirements.
// Draws nothing visible on the chart.
// Hidden plot to satisfy publish requirements even if you later remove the dummy trade.
plot(na, title="Retired", display=display.none)

var bool didEntry = false
var bool didExit = false

bool canSimTrade = not barstate.isrealtime

if canSimTrade and barstate.isfirst and not didEntry
    strategy.entry("RETIRE_TEST", strategy.long, qty=1)
    didEntry := true

if canSimTrade and didEntry and not didExit and not barstate.isfirst
    strategy.close("RETIRE_TEST")
    didExit := true

