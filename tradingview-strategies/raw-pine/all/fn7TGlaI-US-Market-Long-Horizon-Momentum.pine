//@version=6
strategy(    "US Long Horizon Momentum",    overlay = false,    initial_capital = 100000,    commission_type = strategy.commission.percent,    commission_value = 0.03,    pyramiding = 0,    process_orders_on_close = true,    calc_on_every_tick = false)

// === CONFIG ===
group_momentum = "Momentum"
lookback_months = input.int(18, "Momentum Lookback (months)", minval = 3, maxval = 24, group = group_momentum)

group_risk = "Risk & Sizing"
use_vol_target   = false//input.bool(false, "Use Volatility Targeting", group = group_risk)
target_vol_annual = 0.2//input.float(0.15, "Target Vol (annual)", minval = 0.05, maxval = 0.5, step = 0.01, group = group_risk)
vol_lookback_days = 63//input.int(63, "Vol Lookback (days)", minval = 20, maxval = 252, group = group_risk)
max_leverage      = 2.0//input.float(2.0, "Max Leverage", minval = 0.1, maxval = 5.0, group = group_risk)

group_exec = "Execution"
allow_shorts = input.bool(false, "Allow Shorts", group = group_exec)

symbol = input.symbol("SPY")
// === CONSTANTS ===
bars_per_year  = 252.0
bars_per_month = math.round(bars_per_year / 12.0)
mom_lookback   = int(lookback_months * bars_per_month)

// === HELPER FUNCTIONS ===

//** * Annualized volatility of daily log returns. */
f_annualized_vol(daily_log_ret, lookback) =>
    float vol_daily  = ta.stdev(daily_log_ret, lookback)
    float vol_annual = vol_daily * math.sqrt(bars_per_year)
    vol_annual

//** * Target position leverage from annual vol. */
f_target_leverage(target_vol, realized_vol, max_lev) =>
    float lev_raw = realized_vol > 0 ? target_vol / realized_vol : 0.0
    float lev     = math.min(max_lev, lev_raw)
    lev

// === CALC SECTION ===

// 1) 12‑month log momentum
have_history = bar_index >= mom_lookback

float mom_log = na
if have_history
    mom_log := request.security(symbol, timeframe.period, math.log(close / close[mom_lookback]),lookahead = barmerge.lookahead_off)

float signal_dir = 0.0
if have_history and not na(mom_log)
    if mom_log > 0
        signal_dir := 1.0
    else if mom_log < 0 and allow_shorts
        signal_dir := -1.0
    else
        signal_dir := 0.0

// 2) Volatility (optional sizing)
daily_log_ret = math.log(close / close[1])
realized_vol  = f_annualized_vol(daily_log_ret, vol_lookback_days)

float leverage = 1.0
if use_vol_target
    leverage := f_target_leverage(target_vol_annual, realized_vol, max_leverage)

// === RISK / EXECUTION SECTION ===

// Current position direction
pos_dir = strategy.position_size > 0 ? 1.0 : strategy.position_size < 0 ? -1.0 : 0.0

// Target notional and quantity (rebalance only when direction changes)
float equity          = strategy.equity
float target_notional = equity * leverage * signal_dir
float target_qty      = target_notional / close

bool new_signal = have_history and barstate.isconfirmed and (signal_dir != pos_dir)

// Flip or open positions on new signal
if new_signal
    // Close any open position first
    if pos_dir != 0
        strategy.close_all(comment = "Flip")

    // Open new position if non‑flat signal
    if signal_dir == 1
        strategy.entry("Long", strategy.long)
    else if signal_dir == -1
        strategy.entry("Short", strategy.short, qty = math.abs(target_qty))

// === PLOTS / UI SECTION ===
plot(mom_log, title = "12M Log Momentum", color = mom_log >= 0 ? color.new(color.green, 0) : color.new(color.red, 0))
hline(0.0, "Momentum Zero", color = color.gray)

bgcolor(signal_dir == 1 ? color.new(color.green, 90) : signal_dir == -1 ? color.new(color.red, 90) : na)

