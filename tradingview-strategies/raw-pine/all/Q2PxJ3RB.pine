//@version=5
// ============================================================
// XAUUSD GoldScalper Pro v8.0
//
// [데이터 기반 결론]
// 15분봉 v7: 승률48% / PF1.99 / 37회 → 수익지수 목표 달성
// 5분봉  v7: 승률36% / PF1.45 / 96회 → 노이즈 과다
//
// [v8 목표]
// 15분봉: 승률 55%+ / PF 2.0+ / 월 25~35회
// 5분봉:  승률 50%+ / PF 1.8+ / 월 40~60회
//
// [개선 포인트]
// 1. MACD 크로스 → MACD 크로스 + 0선 위치 추가 확인
//    (0선 위에서 골든크로스 = 강한 상승추세 확인)
// 2. EMA55 방향 필터 강화 → 5봉 → 10봉 기울기로 변경
// 3. RSI 진입 구간 타이트하게 (45~65 → 50~68)
// 4. 캔들 확인 추가: 진입봉이 추세 방향 양봉/음봉인지 확인
// 5. 부분청산 구조 유지 (v7 성공 요인)
// 6. TP2를 5.0으로 확대 (추세 강한 경우 극대화)
// ============================================================
strategy("XAUUSD GoldScalper Pro v8+Session", shorttitle="Gold v8+S",
     overlay=true,
     default_qty_type=strategy.fixed,
     default_qty_value=2,
     initial_capital=10000,
     commission_type=strategy.commission.cash_per_contract,
     commission_value=0.07,
     slippage=2,
     calc_on_every_tick=false)

// ============================================================
// INPUTS
// ============================================================
g1 = "EMA"
e1 = input.int(8,   "EMA Fast",  minval=3,  maxval=20,  group=g1)
e2 = input.int(21,  "EMA Mid",   minval=10, maxval=50,  group=g1)
e3 = input.int(55,  "EMA Slow",  minval=30, maxval=200, group=g1)
e3_slope_bars = input.int(10, "EMA55 Slope Bars", minval=3, maxval=20, group=g1,
     tooltip="EMA55 기울기 판단 기준봉 수. 클수록 강한 추세만 허용")

g2 = "MACD"
m1 = input.int(12, "Fast",   minval=5,  maxval=30, group=g2)
m2 = input.int(26, "Slow",   minval=15, maxval=60, group=g2)
m3 = input.int(9,  "Signal", minval=3,  maxval=20, group=g2)
use_macd_zero = input.bool(true, "MACD Zero Line Filter",  group=g2,
     tooltip="롱: 크로스 후 MACD가 0선 위 or 0선 위에서 크로스. 숏: 반대")

g3 = "RSI"
r_len       = input.int(14, "Length",         minval=5,  maxval=30, group=g3)
r_long_min  = input.int(50, "Long RSI Min",   minval=40, maxval=60, group=g3)
r_long_max  = input.int(68, "Long RSI Max",   minval=60, maxval=80, group=g3)
r_short_max = input.int(50, "Short RSI Max",  minval=40, maxval=60, group=g3)
r_short_min = input.int(32, "Short RSI Min",  minval=20, maxval=40, group=g3)

g4 = "ATR Risk"
a_len  = input.int(14,    "ATR Length", minval=7,  maxval=30,  group=g4)
sl_m   = input.float(1.0, "SL Mult",   minval=0.5, maxval=2.0, step=0.1, group=g4)
tp1_m  = input.float(2.0, "TP1 Mult",  minval=1.0, maxval=4.0, step=0.1, group=g4)
tp2_m  = input.float(5.0, "TP2 Mult",  minval=3.0, maxval=10.0, step=0.1, group=g4)
use_be = input.bool(true,  "Breakeven Stop", group=g4)

g5 = "ADX"
adx_min = input.int(20, "ADX Min", minval=12, maxval=35, group=g5)

g6 = "Candle Filter"
use_candle = input.bool(true, "Candle Direction Filter", group=g6,
     tooltip="롱: 진입봉이 양봉 (close>open). 숏: 음봉. 역방향 캔들 진입 차단")

g_sess = "KST Session Filter"
use_session     = input.bool(true, "Enable Session Filter", group=g_sess,
     tooltip="한국시간 지정 시간대 신호 차단. 보유 포지션은 유지됨")
kst_block_start = input.int(0, "Block Start (KST hour 0~23)", minval=0, maxval=23, group=g_sess,
     tooltip="차단 시작 한국시간. 기본값 0 = 자정")
kst_block_end   = input.int(6, "Block End   (KST hour 0~23)", minval=0, maxval=23, group=g_sess,
     tooltip="차단 종료 한국시간. 기본값 6 = 오전6시")

g7 = "Display"
show_ema = input.bool(true, "Show EMA",    group=g7)
show_tbl = input.bool(true, "Show Table",  group=g7)
show_lbl = input.bool(true, "Show Labels", group=g7)

// ============================================================
// INDICATORS
// ============================================================
// ── KST 세션 필터
// 한국시간(UTC+9) 기준 지정 시간대 신호 차단
// 포지션 보유 중에는 청산 조건 정상 작동 (강제청산 없음)
kst_hour   = hour(time, "Asia/Seoul")
in_block   = kst_hour >= kst_block_start and kst_hour < kst_block_end
session_ok = not use_session or not in_block

ema1 = ta.ema(close, e1)
ema2 = ta.ema(close, e2)
ema3 = ta.ema(close, e3)

[ml, sl_, hist] = ta.macd(close, m1, m2, m3)
[dip, dim, adx] = ta.dmi(14, 14)
rsi             = ta.rsi(close, r_len)
atr             = ta.atr(a_len)

// ── EMA 정배열
bull_align = ema1 > ema2 and ema2 > ema3
bear_align = ema1 < ema2 and ema2 < ema3

// ── EMA55 기울기 (강화: 10봉)
ema3_up   = ema3 > ema3[e3_slope_bars]
ema3_down = ema3 < ema3[e3_slope_bars]

// ── MACD 크로스
macd_up   = ta.crossover(ml, sl_)
macd_down = ta.crossunder(ml, sl_)

// ── MACD 0선 위치 필터
macd_zero_long  = not use_macd_zero or ml > 0 or (ml > ml[1] and ml > -math.abs(ta.sma(ml, 20)))
macd_zero_short = not use_macd_zero or ml < 0 or (ml < ml[1] and ml < math.abs(ta.sma(ml, 20)))

// ── RSI 구간
rsi_long_ok  = rsi >= r_long_min  and rsi <= r_long_max
rsi_short_ok = rsi <= r_short_max and rsi >= r_short_min

// ── ADX
adx_ok = adx >= adx_min

// ── 캔들 방향
bull_candle = not use_candle or close > open
bear_candle = not use_candle or close < open

// ============================================================
// 최종 진입 신호
// ============================================================
long_sig = macd_up
         and bull_align
         and ema3_up
         and rsi_long_ok
         and adx_ok
         and macd_zero_long
         and bull_candle
         and session_ok
         and strategy.position_size == 0

short_sig = macd_down
          and bear_align
          and ema3_down
          and rsi_short_ok
          and adx_ok
          and macd_zero_short
          and bear_candle
          and session_ok
          and strategy.position_size == 0

// ============================================================
// 청산 조건
// ============================================================
long_exit  = ta.crossunder(ema1, ema2) or rsi > r_long_max + 5
short_exit = ta.crossover(ema1, ema2)  or rsi < r_short_min - 5

// ============================================================
// SL / TP / BE 추적
// ============================================================
var float entry_px   = na
var bool  be_active  = false

if long_sig or short_sig
    entry_px  := close
    be_active := false

tp1_hit_l = strategy.position_size > 0 and high  >= entry_px + atr * tp1_m
tp1_hit_s = strategy.position_size < 0 and low   <= entry_px - atr * tp1_m

if (tp1_hit_l or tp1_hit_s) and not be_active
    be_active := true

var float l_sl  = na
var float l_tp1 = na
var float l_tp2 = na
var float s_sl  = na
var float s_tp1 = na
var float s_tp2 = na

if long_sig
    l_sl  := close - atr * sl_m
    l_tp1 := close + atr * tp1_m
    l_tp2 := close + atr * tp2_m

if short_sig
    s_sl  := close + atr * sl_m
    s_tp1 := close - atr * tp1_m
    s_tp2 := close - atr * tp2_m

// 브레이크이븐 적용 SL
cur_l_sl = strategy.position_size > 0 ? (be_active and use_be ? entry_px + atr * 0.1 : l_sl) : na
cur_s_sl = strategy.position_size < 0 ? (be_active and use_be ? entry_px - atr * 0.1 : s_sl) : na

// ============================================================
// STRATEGY EXECUTION
// ============================================================
if long_sig
    strategy.entry("Long", strategy.long, qty=2, comment="BUY")
    strategy.exit("L_TP1", "Long", qty=1, limit=close + atr * tp1_m, stop=close - atr * sl_m, comment="TP1")
    strategy.exit("L_TP2", "Long", qty=1, limit=close + atr * tp2_m, stop=close - atr * sl_m, comment="TP2")

if short_sig
    strategy.entry("Short", strategy.short, qty=2, comment="SELL")
    strategy.exit("S_TP1", "Short", qty=1, limit=close - atr * tp1_m, stop=close + atr * sl_m, comment="TP1")
    strategy.exit("S_TP2", "Short", qty=1, limit=close - atr * tp2_m, stop=close + atr * sl_m, comment="TP2")

if use_be and be_active
    if strategy.position_size > 0 and low  < entry_px + atr * 0.1
        strategy.close("Long",  comment="BE")
    if strategy.position_size < 0 and high > entry_px - atr * 0.1
        strategy.close("Short", comment="BE")

if long_exit  and strategy.position_size > 0
    strategy.close("Long",  comment="EXIT")
if short_exit and strategy.position_size < 0
    strategy.close("Short", comment="EXIT")

// ============================================================
// VISUALS
// ============================================================
ema1_p = plot(show_ema ? ema1 : na, "EMA8",  color=color.new(#FFD700, 0), linewidth=1)
ema2_p = plot(show_ema ? ema2 : na, "EMA21", color=color.new(#FF9800, 0), linewidth=2)
plot(show_ema ? ema3 : na,          "EMA55", color=color.new(#FF5722, 0), linewidth=3)
fill(ema1_p, ema2_p, color = ema1 > ema2 ? color.new(#00E676, 88) : color.new(#FF1744, 88))

plot(strategy.position_size > 0 ? cur_l_sl : na, "L SL",  color=color.new(#F44336, 0),  linewidth=2, style=plot.style_linebr)
plot(strategy.position_size > 0 ? l_tp1    : na, "L TP1", color=color.new(#81C784, 20), linewidth=1, style=plot.style_linebr)
plot(strategy.position_size > 0 ? l_tp2    : na, "L TP2", color=color.new(#4CAF50, 0),  linewidth=2, style=plot.style_linebr)
plot(strategy.position_size < 0 ? cur_s_sl : na, "S SL",  color=color.new(#F44336, 0),  linewidth=2, style=plot.style_linebr)
plot(strategy.position_size < 0 ? s_tp1    : na, "S TP1", color=color.new(#81C784, 20), linewidth=1, style=plot.style_linebr)
plot(strategy.position_size < 0 ? s_tp2    : na, "S TP2", color=color.new(#4CAF50, 0),  linewidth=2, style=plot.style_linebr)

plotshape(long_sig,  title="BUY",  location=location.belowbar, style=shape.triangleup,   size=size.normal, color=color.new(#00E676, 0), text="BUY",  textcolor=color.new(#00E676, 0))
plotshape(short_sig, title="SELL", location=location.abovebar, style=shape.triangledown, size=size.normal, color=color.new(#FF1744, 0), text="SELL", textcolor=color.new(#FF1744, 0))
plotshape(long_exit  and strategy.position_size > 0, title="L Exit", location=location.abovebar, style=shape.xcross, size=size.small, color=color.new(#FF9800, 0), text="EXIT")
plotshape(short_exit and strategy.position_size < 0, title="S Exit", location=location.belowbar, style=shape.xcross, size=size.small, color=color.new(#FF9800, 0), text="EXIT")

bgcolor(be_active and strategy.position_size != 0 ? color.new(#FFD700, 96) : na, title="BE Active BG")
bgcolor(use_session and in_block ? color.new(#333355, 85) : na, title="Session Block BG")
bgcolor(bull_align and ema3_up   ? color.new(#00E676, 97) : na, title="Bull BG")
bgcolor(bear_align and ema3_down ? color.new(#FF1744, 97) : na, title="Bear BG")

var string lbl_b = ""
var string lbl_s = ""
if show_lbl and long_sig
    lbl_b := "BUY\nTP1: " + str.tostring(math.round(close + atr * tp1_m, 2)) + "\nTP2: " + str.tostring(math.round(close + atr * tp2_m, 2)) + "\nSL:  " + str.tostring(math.round(close - atr * sl_m, 2))
    label.new(bar_index, low - atr * 0.8, text=lbl_b, style=label.style_label_up, color=color.new(#00C853, 5), textcolor=color.white, size=size.small)
if show_lbl and short_sig
    lbl_s := "SELL\nTP1: " + str.tostring(math.round(close - atr * tp1_m, 2)) + "\nTP2: " + str.tostring(math.round(close - atr * tp2_m, 2)) + "\nSL:  " + str.tostring(math.round(close + atr * sl_m, 2))
    label.new(bar_index, high + atr * 0.8, text=lbl_s, style=label.style_label_down, color=color.new(#D50000, 5), textcolor=color.white, size=size.small)

// ============================================================
// INFO TABLE
// ============================================================
var table tb = table.new(position.top_right, 2, 13, bgcolor=color.new(#0A0A18, 8), border_color=color.new(#FFD700, 45), border_width=1, frame_color=color.new(#FFD700, 30), frame_width=2)

if barstate.islast and show_tbl
    table.cell(tb, 0, 0, "Gold v8+Session", text_color=color.new(#FFD700, 0), text_size=size.small, bgcolor=color.new(#0D0D1A, 0))
    table.cell(tb, 1, 0, "XAUUSD",      text_color=color.new(#FFD700, 0), text_size=size.small, bgcolor=color.new(#0D0D1A, 0))

    t_col = bull_align ? color.new(#00E676, 0) : bear_align ? color.new(#FF1744, 0) : color.new(#888888, 0)
    table.cell(tb, 0, 1, "EMA Align",  text_color=color.new(#777799, 0), text_size=size.tiny)
    table.cell(tb, 1, 1, bull_align ? "BULL" : bear_align ? "BEAR" : "FLAT", text_color=t_col, text_size=size.tiny)

    e3c = ema3_up ? color.new(#00E676, 0) : color.new(#FF1744, 0)
    table.cell(tb, 0, 2, "EMA55 Dir", text_color=color.new(#777799, 0), text_size=size.tiny)
    table.cell(tb, 1, 2, ema3_up ? "UP" : "DOWN", text_color=e3c, text_size=size.tiny)

    mc = macd_up ? color.new(#00E676, 0) : macd_down ? color.new(#FF1744, 0) : color.new(#888888, 0)
    table.cell(tb, 0, 3, "MACD Cross", text_color=color.new(#777799, 0), text_size=size.tiny)
    table.cell(tb, 1, 3, macd_up ? "UP" : macd_down ? "DOWN" : "-", text_color=mc, text_size=size.tiny)

    mzc = ml > 0 ? color.new(#00E676, 0) : color.new(#FF1744, 0)
    table.cell(tb, 0, 4, "MACD Line",  text_color=color.new(#777799, 0), text_size=size.tiny)
    table.cell(tb, 1, 4, ml > 0 ? "Above 0" : "Below 0", text_color=mzc, text_size=size.tiny)

    rc = rsi > r_long_max ? color.new(#FF1744, 0) : rsi < r_short_min ? color.new(#00E676, 0) : rsi_long_ok ? color.new(#00E676, 0) : rsi_short_ok ? color.new(#FF1744, 0) : color.new(#FFFFFF, 0)
    table.cell(tb, 0, 5, "RSI",  text_color=color.new(#777799, 0), text_size=size.tiny)
    table.cell(tb, 1, 5, str.tostring(math.round(rsi, 1)), text_color=rc, text_size=size.tiny)

    ac = adx >= adx_min ? color.new(#00E676, 0) : color.new(#FF5722, 0)
    table.cell(tb, 0, 6, "ADX",  text_color=color.new(#777799, 0), text_size=size.tiny)
    table.cell(tb, 1, 6, str.tostring(math.round(adx, 1)) + (adx >= adx_min ? " OK" : " LOW"), text_color=ac, text_size=size.tiny)

    table.cell(tb, 0, 7, "ATR",  text_color=color.new(#777799, 0), text_size=size.tiny)
    table.cell(tb, 1, 7, str.tostring(math.round(atr, 2)), text_color=color.new(#FFFFFF, 0), text_size=size.tiny)

    bec = be_active ? color.new(#FFD700, 0) : color.new(#888888, 0)
    table.cell(tb, 0, 8, "BE Stop",  text_color=color.new(#777799, 0), text_size=size.tiny)
    table.cell(tb, 1, 8, be_active ? "ACTIVE" : "READY", text_color=bec, text_size=size.tiny)

    table.cell(tb, 0, 9, "TP1 / TP2",  text_color=color.new(#777799, 0), text_size=size.tiny)
    table.cell(tb, 1, 9, "1:" + str.tostring(tp1_m/sl_m, "#.#") + " / 1:" + str.tostring(tp2_m/sl_m, "#.#"), text_color=color.new(#FFD700, 0), text_size=size.tiny)

    pos_txt = strategy.position_size > 0 ? "LONG" : strategy.position_size < 0 ? "SHORT" : "FLAT"
    pos_col = strategy.position_size > 0 ? color.new(#00E676, 0) : strategy.position_size < 0 ? color.new(#FF1744, 0) : color.new(#888888, 0)
    table.cell(tb, 0, 10, "Position", text_color=color.new(#777799, 0), text_size=size.tiny)
    table.cell(tb, 1, 10, pos_txt,    text_color=pos_col, text_size=size.tiny)

    sess_lbl = not use_session ? "OFF" : in_block ? "BLOCKED " + str.tostring(kst_block_start) + "-" + str.tostring(kst_block_end) + "h" : "OPEN"
    sess_col = not use_session ? color.new(#888888, 0) : in_block ? color.new(#FF1744, 0) : color.new(#00E676, 0)
    table.cell(tb, 0, 11, "KST Session", text_color=color.new(#777799, 0), text_size=size.tiny)
    table.cell(tb, 1, 11, sess_lbl,      text_color=sess_col, text_size=size.tiny)

    table.cell(tb, 0, 12, "KST Time", text_color=color.new(#777799, 0), text_size=size.tiny)
    table.cell(tb, 1, 12, str.tostring(kst_hour) + ":xx", text_color=color.new(#AAAAAA, 0), text_size=size.tiny)

// ============================================================
// ALERTS
// ============================================================
alertcondition(long_sig,  title="BUY",  message="XAUUSD v8+S BUY!")
alertcondition(short_sig, title="SELL", message="XAUUSD v8+S SELL!")
alertcondition(be_active and strategy.position_size > 0, title="BE Long",  message="XAUUSD v8+S TP1 hit - Breakeven ON!")
alertcondition(be_active and strategy.position_size < 0, title="BE Short", message="XAUUSD v8+S TP1 hit - Breakeven ON!")

