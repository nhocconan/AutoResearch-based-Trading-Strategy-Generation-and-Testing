//@version=6
strategy("Advanced Crypto Day Trading - Bybit Optimized", 
         shorttitle="ACDT-Bybit",
         overlay=true, 
         initial_capital=10000,
         default_qty_type=strategy.percent_of_equity,
         default_qty_value=10,
         commission_type=strategy.commission.percent,
         commission_value=0.075,
         pyramiding=1,
         calc_on_every_tick=false,
         calc_on_order_fills=false,
         close_entries_rule="ANY",
         max_bars_back=500)

// ═══════════════════════════════════════════════════════════════════
// 📊 INPUT PARAMETERS - ORIGINALI
// ═══════════════════════════════════════════════════════════════════

leverage = input.float(5.0, "Leva Finanziaria", minval=1.0, maxval=10.0, step=0.1, group="🔧 Impostazioni Base")
enable_long = input.bool(true, "Abilita Long", group="🔧 Impostazioni Base")
enable_short = input.bool(true, "Abilita Short", group="🔧 Impostazioni Base")
only_weekdays = input.bool(true, "Solo Giorni Lavorativi (Lun-Ven)", group="🔧 Impostazioni Base")

risk_reward_ratio = input.string("1:2", "Risk/Reward Ratio", options=["1:2", "1:3"], group="💰 Risk Management")
risk_percent = input.float(2.0, "Risk Per Trade (%)", minval=0.5, maxval=5.0, step=0.1, group="💰 Risk Management")
atr_stop_multiplier = input.float(1.8, "ATR Stop Loss Moltiplicatore", minval=1.0, maxval=3.0, step=0.1, group="💰 Risk Management")
use_trailing_stop = input.bool(true, "Trailing Stop Attivo", group="💰 Risk Management")
trailing_trigger_ratio = input.float(0.6, "Trigger Trailing (ratio del TP)", minval=0.3, maxval=0.9, step=0.1, group="💰 Risk Management")

ema_fast = input.int(8, "EMA Veloce", minval=5, maxval=15, group="📈 Indicatori Tecnici")
ema_slow = input.int(21, "EMA Lenta", minval=15, maxval=35, group="📈 Indicatori Tecnici")
rsi_period = input.int(9, "Periodo RSI", minval=7, maxval=14, group="📈 Indicatori Tecnici")
rsi_entry_long = input.int(45, "RSI Entry Long (sopra)", minval=35, maxval=55, group="📈 Indicatori Tecnici")
rsi_entry_short = input.int(55, "RSI Entry Short (sotto)", minval=45, maxval=65, group="📈 Indicatori Tecnici")
macd_fast = input.int(5, "MACD Veloce", minval=3, maxval=8, group="📈 Indicatori Tecnici")
macd_slow = input.int(13, "MACD Lenta", minval=10, maxval=20, group="📈 Indicatori Tecnici")
macd_signal = input.int(9, "MACD Signal", minval=5, maxval=15, group="📈 Indicatori Tecnici")
atr_period = input.int(14, "Periodo ATR", minval=10, maxval=20, group="📈 Indicatori Tecnici")
volume_threshold = input.float(1.2, "Moltiplicatore Volume Minimo", minval=0.8, maxval=2.0, step=0.1, group="📈 Indicatori Tecnici")

min_price_change = input.float(0.3, "Variazione Minima Prezzo % (filtro rumore)", minval=0.1, maxval=1.0, step=0.1, group="🔍 Filtri Mercato")
avoid_high_volatility = input.bool(true, "Evita Alta Volatilità (>3x ATR media)", group="🔍 Filtri Mercato")

webhook_key = input.string("BYBIT_WEBHOOK_2024", "Chiave Webhook Bybit", group="🚨 Alert & Webhook")

// ═══════════════════════════════════════════════════════════════════
// 🔧 CALCOLI INDICATORI TECNICI - ORIGINALI
// ═══════════════════════════════════════════════════════════════════

f_security_no_repaint(_symbol, _timeframe, _expression) =>
    request.security(_symbol, _timeframe, _expression[barstate.isconfirmed ? 0 : 1])

is_weekday = not only_weekdays or (dayofweek != dayofweek.saturday and dayofweek != dayofweek.sunday)

ema_fast_val = ta.ema(close, ema_fast)
ema_slow_val = ta.ema(close, ema_slow)
trend_bullish = ema_fast_val > ema_slow_val and close > ema_fast_val
trend_bearish = ema_fast_val < ema_slow_val and close < ema_fast_val

rsi_val = ta.rsi(close, rsi_period)
rsi_bullish = rsi_val > rsi_entry_long and rsi_val < 85
rsi_bearish = rsi_val < rsi_entry_short and rsi_val > 15

[macd_line, signal_line, _] = ta.macd(close, macd_fast, macd_slow, macd_signal)
macd_bullish = macd_line > signal_line and macd_line > macd_line[1]
macd_bearish = macd_line < signal_line and macd_line < macd_line[1]

atr_val = ta.atr(atr_period)
atr_avg = ta.sma(atr_val, 50)
high_volatility = avoid_high_volatility and atr_val > atr_avg * 3

volume_avg = ta.sma(volume, 20)
volume_condition = volume > volume_avg * volume_threshold

price_change_pct = math.abs(close - close[1]) / close[1] * 100
sufficient_movement = price_change_pct >= min_price_change

htf_timeframe = timeframe.multiplier <= 5 ? "15" : timeframe.multiplier <= 15 ? "60" : "240"
htf_ema = f_security_no_repaint(syminfo.tickerid, htf_timeframe, ta.ema(close, 50))
htf_trend_bull = close > htf_ema
htf_trend_bear = close < htf_ema

// ═══════════════════════════════════════════════════════════════════
// 📈 ENTRY CONDITIONS - ORIGINALI ESATTE
// ═══════════════════════════════════════════════════════════════════

long_condition_1 = trend_bullish
long_condition_2 = rsi_bullish
long_condition_3 = macd_bullish
long_condition_4 = volume_condition
long_condition_5 = sufficient_movement
long_condition_6 = htf_trend_bull
long_condition_7 = is_weekday
long_condition_8 = not high_volatility
long_condition_9 = barstate.isconfirmed

long_condition = long_condition_1 and long_condition_2 and long_condition_3 and long_condition_4 and long_condition_5 and long_condition_6 and long_condition_7 and long_condition_8 and long_condition_9

short_condition_1 = trend_bearish
short_condition_2 = rsi_bearish
short_condition_3 = macd_bearish
short_condition_4 = volume_condition
short_condition_5 = sufficient_movement
short_condition_6 = htf_trend_bear
short_condition_7 = is_weekday
short_condition_8 = not high_volatility
short_condition_9 = barstate.isconfirmed

short_condition = short_condition_1 and short_condition_2 and short_condition_3 and short_condition_4 and short_condition_5 and short_condition_6 and short_condition_7 and short_condition_8 and short_condition_9

// ═══════════════════════════════════════════════════════════════════
// 📤 EXIT CONDITIONS - NUOVE, SEPARATE
// ═══════════════════════════════════════════════════════════════════

// EXIT PER CAMBIO TREND
long_trend_exit = not trend_bullish or not htf_trend_bull
short_trend_exit = not trend_bearish or not htf_trend_bear

// EXIT PER RSI ESTREMO
long_rsi_exit = rsi_val > 85
short_rsi_exit = rsi_val < 15

// EXIT PER MACD REVERSAL
long_macd_exit = macd_line < signal_line
short_macd_exit = macd_line > signal_line

// CONDIZIONI EXIT COMBINATE
long_exit_condition = long_trend_exit or long_rsi_exit or long_macd_exit
short_exit_condition = short_trend_exit or short_rsi_exit or short_macd_exit

// ═══════════════════════════════════════════════════════════════════
// 💰 RISK MANAGEMENT - SEMPLIFICATO
// ═══════════════════════════════════════════════════════════════════

tp_multiplier = risk_reward_ratio == "1:2" ? 2.0 : 3.0
account_balance = strategy.initial_capital + strategy.netprofit
risk_amount = account_balance * (risk_percent / 100)

var float long_entry_price = na
var float long_stop_loss = na
var float long_take_profit = na
var float short_entry_price = na
var float short_stop_loss = na  
var float short_take_profit = na

var float long_trailing_stop = na
var float short_trailing_stop = na
var bool long_trailing_active = false
var bool short_trailing_active = false

// ═══════════════════════════════════════════════════════════════════
// 🎯 ESECUZIONE STRATEGIA - CORRETTA
// ═══════════════════════════════════════════════════════════════════

// LONG ENTRY - FIXATO
if long_condition and enable_long and strategy.position_size == 0
    entry_price = close
    stop_distance = atr_val * atr_stop_multiplier
    stop_price = entry_price - stop_distance
    tp_distance = stop_distance * tp_multiplier
    tp_price = entry_price + tp_distance
    
    long_entry_price := entry_price
    long_stop_loss := stop_price
    long_take_profit := tp_price
    long_trailing_stop := stop_price
    long_trailing_active := false
    
    // POSITION SIZE SEMPLIFICATO
    risk_per_unit = stop_distance
    pos_size_pct = (risk_percent / 100) * leverage / (risk_per_unit / entry_price)
    
    // ENTRY CON PERCENTUALE INVECE CHE QTY
    strategy.entry("LONG", strategy.long, qty=pos_size_pct, comment="Long Entry")
    strategy.exit("LONG_SL_TP", from_entry="LONG", stop=stop_price, limit=tp_price, comment="SL/TP")

// SHORT ENTRY - FIXATO  
if short_condition and enable_short and strategy.position_size == 0
    entry_price = close
    stop_distance = atr_val * atr_stop_multiplier  
    stop_price = entry_price + stop_distance
    tp_distance = stop_distance * tp_multiplier
    tp_price = entry_price - tp_distance
    
    short_entry_price := entry_price
    short_stop_loss := stop_price
    short_take_profit := tp_price
    short_trailing_stop := stop_price
    short_trailing_active := false
    
    // POSITION SIZE SEMPLIFICATO
    risk_per_unit = stop_distance
    pos_size_pct = (risk_percent / 100) * leverage / (risk_per_unit / entry_price)
    
    // ENTRY CON PERCENTUALE INVECE CHE QTY
    strategy.entry("SHORT", strategy.short, qty=pos_size_pct, comment="Short Entry")
    strategy.exit("SHORT_SL_TP", from_entry="SHORT", stop=stop_price, limit=tp_price, comment="SL/TP")

// EXIT PER CAMBIO TREND
if strategy.position_size > 0 and long_exit_condition
    strategy.close("LONG", comment="Trend Exit")
    long_trailing_active := false

if strategy.position_size < 0 and short_exit_condition
    strategy.close("SHORT", comment="Trend Exit")
    short_trailing_active := false

// TRAILING STOP
if use_trailing_stop and strategy.position_size > 0
    trigger_price = long_entry_price + ((long_take_profit - long_entry_price) * trailing_trigger_ratio)
    
    if not long_trailing_active and close >= trigger_price
        long_trailing_active := true
    
    if long_trailing_active
        trail_distance = atr_val * atr_stop_multiplier * 0.8
        new_trail = close - trail_distance
        long_trailing_stop := math.max(long_trailing_stop, new_trail)
        strategy.exit("LONG_TRAIL", from_entry="LONG", stop=long_trailing_stop, comment="Trailing")

if use_trailing_stop and strategy.position_size < 0
    trigger_price = short_entry_price - ((short_entry_price - short_take_profit) * trailing_trigger_ratio)
    
    if not short_trailing_active and close <= trigger_price
        short_trailing_active := true
    
    if short_trailing_active
        trail_distance = atr_val * atr_stop_multiplier * 0.8
        new_trail = close + trail_distance
        short_trailing_stop := math.min(short_trailing_stop, new_trail)
        strategy.exit("SHORT_TRAIL", from_entry="SHORT", stop=short_trailing_stop, comment="Trailing")

// ═══════════════════════════════════════════════════════════════════
// 🚨 ALERT SYSTEM
// ═══════════════════════════════════════════════════════════════════

if long_condition and enable_long and strategy.position_size == 0
    alert_msg = '{"action":"buy","symbol":"' + syminfo.ticker + '","price":' + str.tostring(close, "#.####") + ',"stopLoss":' + str.tostring(long_stop_loss, "#.####") + ',"takeProfit":' + str.tostring(long_take_profit, "#.####") + ',"leverage":' + str.tostring(leverage, "#") + ',"key":"' + webhook_key + '"}'
    alert(alert_msg, alert.freq_once_per_bar_close)

if short_condition and enable_short and strategy.position_size == 0
    alert_msg = '{"action":"sell","symbol":"' + syminfo.ticker + '","price":' + str.tostring(close, "#.####") + ',"stopLoss":' + str.tostring(short_stop_loss, "#.####") + ',"takeProfit":' + str.tostring(short_take_profit, "#.####") + ',"leverage":' + str.tostring(leverage, "#") + ',"key":"' + webhook_key + '"}'
    alert(alert_msg, alert.freq_once_per_bar_close)

// ═══════════════════════════════════════════════════════════════════
// 🎨 VISUALIZZAZIONE GRAFICA COMPLETA
// ═══════════════════════════════════════════════════════════════════

plot(ema_fast_val, "EMA Veloce", color=color.new(color.blue, 0), linewidth=2)
plot(ema_slow_val, "EMA Lenta", color=color.new(color.orange, 0), linewidth=2)

plot(strategy.position_size > 0 ? long_stop_loss : na, "Long SL", color=color.new(color.red, 0), style=plot.style_linebr, linewidth=2)
plot(strategy.position_size > 0 ? long_take_profit : na, "Long TP", color=color.new(color.green, 0), style=plot.style_linebr, linewidth=2)
plot(strategy.position_size > 0 and long_trailing_active ? long_trailing_stop : na, "Long Trail", color=color.new(color.yellow, 0), style=plot.style_circles, linewidth=1)

plot(strategy.position_size < 0 ? short_stop_loss : na, "Short SL", color=color.new(color.red, 0), style=plot.style_linebr, linewidth=2)
plot(strategy.position_size < 0 ? short_take_profit : na, "Short TP", color=color.new(color.green, 0), style=plot.style_linebr, linewidth=2)
plot(strategy.position_size < 0 and short_trailing_active ? short_trailing_stop : na, "Short Trail", color=color.new(color.yellow, 0), style=plot.style_circles, linewidth=1)

bgcolor(high_volatility ? color.new(color.red, 90) : na, title="Alta Volatilità")
bgcolor(not is_weekday ? color.new(color.gray, 95) : na, title="Weekend")

// SEGNALI ENTRY
plotshape(long_condition, title="Long Signal", location=location.belowbar, style=shape.triangleup, size=size.normal, color=color.new(color.lime, 0))
plotshape(short_condition, title="Short Signal", location=location.abovebar, style=shape.triangledown, size=size.normal, color=color.new(color.red, 0))

// SEGNALI EXIT - AGGIUNTI
plotshape(long_exit_condition and strategy.position_size > 0, title="Long Trend Exit", location=location.abovebar, style=shape.xcross, size=size.small, color=color.new(color.blue, 0))
plotshape(short_exit_condition and strategy.position_size < 0, title="Short Trend Exit", location=location.belowbar, style=shape.xcross, size=size.small, color=color.new(color.purple, 0))

plotshape(strategy.position_size[1] > 0 and strategy.position_size == 0, title="Long Exit Complete", location=location.abovebar, style=shape.circle, size=size.tiny, color=color.new(color.gray, 0))
plotshape(strategy.position_size[1] < 0 and strategy.position_size == 0, title="Short Exit Complete", location=location.belowbar, style=shape.circle, size=size.tiny, color=color.new(color.gray, 0))

// ═══════════════════════════════════════════════════════════════════
// 📊 TABELLA INFORMAZIONI COMPLETA - ORIGINALE
// ═══════════════════════════════════════════════════════════════════

var table info_table = table.new(position.top_right, 3, 12, bgcolor=color.new(color.white, 80), border_width=1, frame_color=color.gray, frame_width=1)

if barstate.islast
    table.cell(info_table, 0, 0, "PARAMETRO", bgcolor=color.new(color.blue, 70), text_color=color.white, text_size=size.small)
    table.cell(info_table, 1, 0, "VALORE", bgcolor=color.new(color.blue, 70), text_color=color.white, text_size=size.small)
    table.cell(info_table, 2, 0, "STATUS", bgcolor=color.new(color.blue, 70), text_color=color.white, text_size=size.small)
    
    position_text = strategy.position_size > 0 ? "LONG " + str.tostring(math.abs(strategy.position_size), "#.##") : strategy.position_size < 0 ? "SHORT " + str.tostring(math.abs(strategy.position_size), "#.##") : "FLAT"
    position_emoji = strategy.position_size > 0 ? "📈" : strategy.position_size < 0 ? "📉" : "⚪"
    table.cell(info_table, 0, 1, "Posizione", text_color=color.black, text_size=size.small)
    table.cell(info_table, 1, 1, position_text, text_color=color.black, text_size=size.small)
    table.cell(info_table, 2, 1, position_emoji, text_size=size.small)
    
    unrealized_pnl = strategy.position_size != 0 ? (close - strategy.position_avg_price) * strategy.position_size : 0
    pnl_color = unrealized_pnl > 0 ? color.green : unrealized_pnl < 0 ? color.red : color.gray
    table.cell(info_table, 0, 2, "P&L Non Real.", text_color=color.black, text_size=size.small)
    table.cell(info_table, 1, 2, str.tostring(unrealized_pnl, "#.##") + "$", text_color=pnl_color, text_size=size.small)
    table.cell(info_table, 2, 2, unrealized_pnl > 0 ? "💰" : unrealized_pnl < 0 ? "💸" : "💤", text_size=size.small)
    
    risk_amount_display = account_balance * (risk_percent / 100)
    table.cell(info_table, 0, 3, "Risk x Trade", text_color=color.black, text_size=size.small)
    table.cell(info_table, 1, 3, str.tostring(risk_amount_display, "#.##") + "$", text_color=color.black, text_size=size.small)
    table.cell(info_table, 2, 3, "⚖️", text_size=size.small)
    
    table.cell(info_table, 0, 4, "R/R Ratio", text_color=color.black, text_size=size.small)
    table.cell(info_table, 1, 4, risk_reward_ratio, text_color=color.black, text_size=size.small)
    table.cell(info_table, 2, 4, "🎯", text_size=size.small)
    
    rsi_status_color = rsi_val > 70 ? color.red : rsi_val < 30 ? color.blue : color.black
    rsi_emoji = rsi_val > 70 ? "🔥" : rsi_val < 30 ? "🧊" : rsi_val > 50 ? "📈" : "📉"
    table.cell(info_table, 0, 5, "RSI", text_color=color.black, text_size=size.small)
    table.cell(info_table, 1, 5, str.tostring(rsi_val, "#.#"), text_color=rsi_status_color, text_size=size.small)
    table.cell(info_table, 2, 5, rsi_emoji, text_size=size.small)
    
    volatility_status = high_volatility ? "ALTA" : "NORMALE"
    volatility_emoji = high_volatility ? "⚠️" : "✅"
    table.cell(info_table, 0, 6, "Volatilità", text_color=color.black, text_size=size.small)
    table.cell(info_table, 1, 6, volatility_status, text_color=color.black, text_size=size.small)
    table.cell(info_table, 2, 6, volatility_emoji, text_size=size.small)
    
    day_status = is_weekday ? "ATTIVO" : "WEEKEND"
    day_emoji = is_weekday ? "🟢" : "🔴"
    table.cell(info_table, 0, 7, "Giorno Trading", text_color=color.black, text_size=size.small)
    table.cell(info_table, 1, 7, day_status, text_color=color.black, text_size=size.small)
    table.cell(info_table, 2, 7, day_emoji, text_size=size.small)
    
    trend_status = trend_bullish ? "RIALZISTA" : trend_bearish ? "RIBASSISTA" : "LATERALE"
    trend_emoji = trend_bullish ? "🚀" : trend_bearish ? "🐻" : "😴"
    table.cell(info_table, 0, 8, "Trend", text_color=color.black, text_size=size.small)
    table.cell(info_table, 1, 8, trend_status, text_color=color.black, text_size=size.small)
    table.cell(info_table, 2, 8, trend_emoji, text_size=size.small)
    
    trailing_status = strategy.position_size > 0 and long_trailing_active ? "ATTIVO LONG" : strategy.position_size < 0 and short_trailing_active ? "ATTIVO SHORT" : "INATTIVO"
    trailing_emoji = (long_trailing_active or short_trailing_active) ? "🔄" : "⏸️"
    table.cell(info_table, 0, 9, "Trailing Stop", text_color=color.black, text_size=size.small)
    table.cell(info_table, 1, 9, trailing_status, text_color=color.black, text_size=size.small)
    table.cell(info_table, 2, 9, trailing_emoji, text_size=size.small)
    
    table.cell(info_table, 0, 10, "Trade Totali", text_color=color.black, text_size=size.small)
    table.cell(info_table, 1, 10, str.tostring(strategy.closedtrades), text_color=color.black, text_size=size.small)
    table.cell(info_table, 2, 10, "📊", text_size=size.small)
    
    win_rate = strategy.closedtrades > 0 ? (strategy.wintrades / strategy.closedtrades * 100) : 0
    win_color = win_rate >= 50 ? color.green : color.red
    win_emoji = win_rate >= 60 ? "🏆" : win_rate >= 50 ? "👍" : "👎"
    table.cell(info_table, 0, 11, "Win Rate", text_color=color.black, text_size=size.small)
    table.cell(info_table, 1, 11, str.tostring(win_rate, "#.#") + "%", text_color=win_color, text_size=size.small)
    table.cell(info_table, 2, 11, win_emoji, text_size=size.small)

// ═══════════════════════════════════════════════════════════════════
// 🏷️ ETICHETTE INFORMATIVE
// ═══════════════════════════════════════════════════════════════════

if long_condition and barstate.isconfirmed
    label.new(bar_index, low - atr_val, "🚀 LONG ENTRY\n💰 Entry: " + str.tostring(close, "#.####") + "\n🛑 SL: " + str.tostring(close - (atr_val * atr_stop_multiplier), "#.####") + "\n🎯 TP: " + str.tostring(close + (atr_val * atr_stop_multiplier * tp_multiplier), "#.####") + "\n⚖️ R/R: " + risk_reward_ratio, style=label.style_label_up, color=color.new(color.green, 20), textcolor=color.white, size=size.normal)

if short_condition and barstate.isconfirmed
    label.new(bar_index, high + atr_val, "🐻 SHORT ENTRY\n💰 Entry: " + str.tostring(close, "#.####") + "\n🛑 SL: " + str.tostring(close + (atr_val * atr_stop_multiplier), "#.####") + "\n🎯 TP: " + str.tostring(close - (atr_val * atr_stop_multiplier * tp_multiplier), "#.####") + "\n⚖️ R/R: " + risk_reward_ratio, style=label.style_label_down, color=color.new(color.red, 20), textcolor=color.white, size=size.normal)

