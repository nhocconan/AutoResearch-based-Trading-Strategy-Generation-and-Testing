//@version=6
strategy("Multi-TF Renko Strategy", overlay=true, max_labels_count=500, 
     default_qty_type=strategy.percent_of_equity, default_qty_value=10, 
     pyramiding=5, commission_type=strategy.commission.percent, commission_value=0.04, 
     calc_on_every_tick=true)

// === НАСТРОЙКИ ТАЙМФРЕЙМОВ ===
tf1 = input.timeframe("5",   "M5")
tf2 = input.timeframe("15",  "M15")
tf3 = input.timeframe("60",  "H1")
tf4 = input.timeframe("240", "H4")

emaPeriod = input.int(14, "EMA Period", minval=1)

w1 = input.float(1.0, "Weight M5",  minval=0)
w2 = input.float(2.0, "Weight M15", minval=0)
w3 = input.float(3.0, "Weight H1",  minval=0)
w4 = input.float(4.0, "Weight H4",  minval=0)

useAtr = input.bool(true, "Use ATR for brick size")
brickFixed = input.float(0.0010, "Fixed Brick Size", minval=0.0001, step=0.0001)
atrPeriod = input.int(14, "ATR Period")
atrMultiplier = input.float(0.5, "ATR Multiplier", minval=0.1)

methodAgg = input.string("Weighted", "Aggregation Method", options=["Simple", "Weighted", "Consensus"])

// === НАСТРОЙКИ РИСК-МЕНЕДЖМЕНТА ===
grpRisk = "Управление риском"
stopLossPct = input.float(0.3, "Стоп-лосс, %", minval=0.1, step=0.1, group=grpRisk) / 100
takeProfitPct = input.float(0.8, "Тейк-профит, %", minval=0.1, step=0.1, group=grpRisk) / 100
useTrailing = input.bool(false, "Трейлинг-стоп", group=grpRisk)
trailOffsetPct = input.float(0.5, "Сдвиг трейлинг-стопа, %", minval=0.1, step=0.1, group=grpRisk) / 100
trailActivationPct = input.float(0.5, "Активация трейлинг-стопа, %", minval=0.1, step=0.1, group=grpRisk) / 100

// === НАСТРОЙКИ ЛИМИТНЫХ ОРДЕРОВ ===
useLimitOrders = input.bool(true, "Использовать лимитные ордера", group=grpRisk)
limitOffsetPct = input.float(0.1, "Отступ лимита от цены, %", minval=0.0, step=0.05, group=grpRisk) / 100

// === ЗАПРОС ДАННЫХ С ДРУГИХ ТАЙМФРЕЙМОВ ===
getEma(tf) => ta.ema(close, emaPeriod)

ema1 = request.security(syminfo.tickerid, tf1, getEma(tf1))
ema2 = request.security(syminfo.tickerid, tf2, getEma(tf2))
ema3 = request.security(syminfo.tickerid, tf3, getEma(tf3))
ema4 = request.security(syminfo.tickerid, tf4, getEma(tf4))

// === РАЗМЕР КИРПИЧА ===
atrSource = useAtr ? request.security(syminfo.tickerid, "240", ta.atr(atrPeriod)) : na
brickSize = useAtr ? atrSource * atrMultiplier : brickFixed

// === АГРЕГАЦИЯ СИГНАЛОВ ===
compositeSignal() =>
    float comp = na
    if methodAgg == "Simple"
        comp := (ema1 + ema2 + ema3 + ema4) / 4
    else if methodAgg == "Weighted"
        totalW = w1 + w2 + w3 + w4
        comp := (ema1 * w1 + ema2 * w2 + ema3 * w3 + ema4 * w4) / totalW
    else
        dir1 = ema1 >= ema1[1] ? 1 : -1
        dir2 = ema2 >= ema2[1] ? 1 : -1
        dir3 = ema3 >= ema3[1] ? 1 : -1
        dir4 = ema4 >= ema4[1] ? 1 : -1
        sumDir = dir1 + dir2 + dir3 + dir4
        if math.abs(sumDir) >= 3
            comp := (ema1 + ema2 + ema3 + ema4) / 4
        else
            totalW = w1 + w2 + w3 + w4
            comp := (ema1 * w1 + ema2 * w2 + ema3 * w3 + ema4 * w4) / totalW
    comp

signal = compositeSignal()

// === ЛОГИКА РЕНКО ===
var float realRenko = na
var float prevClose = na
var int direction = 0

if na(realRenko)
    realRenko := signal
    prevClose := signal
    direction := 0
else
    green = realRenko > prevClose
    priceDiff = signal - realRenko

    if green and priceDiff >= brickSize
        bricksUp = math.floor(priceDiff / brickSize)
        realRenko += bricksUp * brickSize
        prevClose := realRenko
        direction := 1
    else if not green and priceDiff <= -brickSize
        bricksDown = math.floor(-priceDiff / brickSize)
        realRenko -= bricksDown * brickSize
        prevClose := realRenko
        direction := -1
    else if not green and priceDiff >= brickSize * 2
        bricksUp = math.floor(priceDiff / brickSize)
        realRenko += bricksUp * brickSize
        prevClose := realRenko
        direction := 1
    else if green and priceDiff <= -brickSize * 2
        bricksDown = math.floor(-priceDiff / brickSize)
        realRenko -= bricksDown * brickSize
        prevClose := realRenko
        direction := -1

// === СИГНАЛЫ ===
buySignal = direction == 1 and direction[1] != 1
sellSignal = direction == -1 and direction[1] != -1

// === ПЕРЕМЕННЫЕ ДЛЯ СТОПОВ И ТРЕЙЛИНГА ===
var float longStopLevel = na
var float shortStopLevel = na
var float highestSinceLong = na
var float lowestSinceShort = na
var bool trailingActiveLong = false
var bool trailingActiveShort = false

// === ТОРГОВЛЯ ===
inLongPosition = strategy.position_size > 0
inShortPosition = strategy.position_size < 0

limitPriceLong = close * (1 - limitOffsetPct)
limitPriceShort = close * (1 + limitOffsetPct)

// === ЗАКРЫТИЕ ПО ПРОТИВОПОЛОЖНОМУ СИГНАЛУ ===
if buySignal and inShortPosition
    strategy.close_all(comment="Close Short (Renko Reverse)", 
                     alert_message="CLOSE SHORT | Renko Reverse | Entry: {{strategy.position_avg_price}} | Exit: {{close}} | Size: {{strategy.position_size}}")
    shortStopLevel := na
    lowestSinceShort := na
    trailingActiveShort := false

if sellSignal and inLongPosition
    strategy.close_all(comment="Close Long (Renko Reverse)", 
                     alert_message="CLOSE LONG | Renko Reverse | Entry: {{strategy.position_avg_price}} | Exit: {{close}} | Size: {{strategy.position_size}}")
    longStopLevel := na
    highestSinceLong := na
    trailingActiveLong := false

// === ОПРЕДЕЛЕНИЕ ВХОДОВ ===
inLongPositionAfterClose = strategy.position_size > 0
inShortPositionAfterClose = strategy.position_size < 0

isFirstLongEntry = buySignal and not inLongPositionAfterClose and not inShortPositionAfterClose
isLongAdd = buySignal and inLongPositionAfterClose and not inShortPositionAfterClose

isFirstShortEntry = sellSignal and not inShortPositionAfterClose and not inLongPositionAfterClose
isShortAdd = sellSignal and inShortPositionAfterClose and not inLongPositionAfterClose

// === ВХОДЫ В ПОЗИЦИИ ===
if isFirstLongEntry
    stop = close * (1 - stopLossPct)
    tp = close * (1 + takeProfitPct)
    
    if useLimitOrders
        strategy.entry("Long", strategy.long, limit=limitPriceLong, comment="Long #1 Limit", 
                     alert_message="ENTRY LONG | Renko | Price: " + str.tostring(limitPriceLong) + " | Stop: " + str.tostring(stop) + " | TP: " + str.tostring(tp))
    else
        strategy.entry("Long", strategy.long, comment="Long #1 Market", 
                     alert_message="ENTRY LONG | Renko | Price: {{close}} | Stop: " + str.tostring(stop) + " | TP: " + str.tostring(tp))
    trailingActiveLong := false
    longStopLevel := stop

if isLongAdd
    if useLimitOrders
        strategy.entry("Long", strategy.long, limit=limitPriceLong, comment="Long Add Limit", 
                     alert_message="ADD LONG | Renko | Price: " + str.tostring(limitPriceLong) + " | Avg: {{strategy.position_avg_price}} | Size: {{strategy.position_size}}")
    else
        strategy.entry("Long", strategy.long, comment="Long Add Market", 
                     alert_message="ADD LONG | Renko | Price: {{close}} | Avg: {{strategy.position_avg_price}} | Size: {{strategy.position_size}}")

if isFirstShortEntry
    stop = close * (1 + stopLossPct)
    tp = close * (1 - takeProfitPct)
    
    if useLimitOrders
        strategy.entry("Short", strategy.short, limit=limitPriceShort, comment="Short #1 Limit", 
                     alert_message="ENTRY SHORT | Renko | Price: " + str.tostring(limitPriceShort) + " | Stop: " + str.tostring(stop) + " | TP: " + str.tostring(tp))
    else
        strategy.entry("Short", strategy.short, comment="Short #1 Market", 
                     alert_message="ENTRY SHORT | Renko | Price: {{close}} | Stop: " + str.tostring(stop) + " | TP: " + str.tostring(tp))
    trailingActiveShort := false
    shortStopLevel := stop

if isShortAdd
    if useLimitOrders
        strategy.entry("Short", strategy.short, limit=limitPriceShort, comment="Short Add Limit", 
                     alert_message="ADD SHORT | Renko | Price: " + str.tostring(limitPriceShort) + " | Avg: {{strategy.position_avg_price}} | Size: {{strategy.position_size}}")
    else
        strategy.entry("Short", strategy.short, comment="Short Add Market", 
                     alert_message="ADD SHORT | Renko | Price: {{close}} | Avg: {{strategy.position_avg_price}} | Size: {{strategy.position_size}}")

// === ОБНОВЛЕНИЕ СТОП-УРОВНЕЙ ===
var isLongSignal = false
var isShortSignal = false
if isLongSignal
    newStop = close * (1 - stopLossPct)
    if na(longStopLevel) or newStop > longStopLevel
        longStopLevel := newStop
    
    if na(highestSinceLong)
        highestSinceLong := high
    else
        highestSinceLong := math.max(highestSinceLong, high)

if isShortSignal
    newStop = close * (1 + stopLossPct)
    if na(shortStopLevel) or newStop < shortStopLevel
        shortStopLevel := newStop
    
    if na(lowestSinceShort)
        lowestSinceShort := low
    else
        lowestSinceShort := math.min(lowestSinceShort, low)

// === ОБНОВЛЕНИЕ ЭКСТРЕМУМОВ ===
if inLongPosition
    if na(highestSinceLong)
        highestSinceLong := high
    else
        highestSinceLong := math.max(highestSinceLong, high)
    
if inShortPosition
    if na(lowestSinceShort)
        lowestSinceShort := low
    else
        lowestSinceShort := math.min(lowestSinceShort, low)

// === ВЫХОДЫ ===

// ЛОНГ
if inLongPosition and not sellSignal
    avgPrice = strategy.position_avg_price
    
    activationPriceLong = avgPrice * (1 + trailActivationPct)
    if not trailingActiveLong and close >= activationPriceLong
        trailingActiveLong := true
    
    var float trailingLevelLong = na
    if useTrailing and not na(highestSinceLong)
        trailingLevelLong := highestSinceLong * (1 - trailOffsetPct)
    
    // Стоп-лосс
    if not na(longStopLevel) and close <= longStopLevel
        strategy.close("Long", comment="SL Long", 
                     alert_message="EXIT LONG | STOP LOSS | Entry: {{strategy.position_avg_price}} | Exit: {{close}} | Size: {{strategy.position_size}}")
        longStopLevel := na
        highestSinceLong := na
        trailingActiveLong := false
    
    // Трейлинг-стоп
    else if useTrailing and trailingActiveLong and not na(trailingLevelLong) and close <= trailingLevelLong
        strategy.close("Long", comment="Trail Long", 
                     alert_message="EXIT LONG | TRAILING STOP | Entry: {{strategy.position_avg_price}} | Exit: {{close}} | Size: {{strategy.position_size}}")
        longStopLevel := na
        highestSinceLong := na
        trailingActiveLong := false
    
    // Тейк-профит
    else if not useTrailing
        tpLevel = avgPrice * (1 + takeProfitPct)
        if close >= tpLevel
            strategy.close("Long", comment="TP Long", 
                         alert_message="EXIT LONG | TAKE PROFIT | Entry: {{strategy.position_avg_price}} | Exit: {{close}} | Size: {{strategy.position_size}}")
            longStopLevel := na
            highestSinceLong := na
            trailingActiveLong := false

// ШОРТ
if inShortPosition and not buySignal
    avgPrice = strategy.position_avg_price
    
    activationPriceShort = avgPrice * (1 - trailActivationPct)
    if not trailingActiveShort and close <= activationPriceShort
        trailingActiveShort := true
    
    var float trailingLevelShort = na
    if useTrailing and not na(lowestSinceShort)
        trailingLevelShort := lowestSinceShort * (1 + trailOffsetPct)
    
    // Стоп-лосс
    if not na(shortStopLevel) and close >= shortStopLevel
        strategy.close("Short", comment="SL Short", 
                     alert_message="EXIT SHORT | STOP LOSS | Entry: {{strategy.position_avg_price}} | Exit: {{close}} | Size: {{strategy.position_size}}")
        shortStopLevel := na
        lowestSinceShort := na
        trailingActiveShort := false
    
    // Трейлинг-стоп
    else if useTrailing and trailingActiveShort and not na(trailingLevelShort) and close >= trailingLevelShort
        strategy.close("Short", comment="Trail Short", 
                     alert_message="EXIT SHORT | TRAILING STOP | Entry: {{strategy.position_avg_price}} | Exit: {{close}} | Size: {{strategy.position_size}}")
        shortStopLevel := na
        lowestSinceShort := na
        trailingActiveShort := false
    
    // Тейк-профит
    else if not useTrailing
        tpLevel = avgPrice * (1 - takeProfitPct)
        if close <= tpLevel
            strategy.close("Short", comment="TP Short", 
                         alert_message="EXIT SHORT | TAKE PROFIT | Entry: {{strategy.position_avg_price}} | Exit: {{close}} | Size: {{strategy.position_size}}")
            shortStopLevel := na
            lowestSinceShort := na
            trailingActiveShort := false

if not inLongPosition and inLongPosition[1]
    longStopLevel := na
    highestSinceLong := na
    trailingActiveLong := false
    
if not inShortPosition and inShortPosition[1]
    shortStopLevel := na
    lowestSinceShort := na
    trailingActiveShort := false

// === ТАБЛИЦА ===
var table infoTable = table.new(position.top_right, 2, 10, bgcolor=color.black, border_width=1, border_color=color.gray)

if barstate.islast
    table.cell(infoTable, 0, 0, "ПАРАМЕТР", text_color=color.white, text_size=size.small)
    table.cell(infoTable, 1, 0, "ЗНАЧЕНИЕ", text_color=color.white, text_size=size.small)
    
    table.cell(infoTable, 0, 1, "Direction", text_color=color.gray, text_size=size.small)
    dirText = direction == 1 ? "UP" : direction == -1 ? "DOWN" : "FLAT"
    table.cell(infoTable, 1, 1, dirText, text_color=direction == 1 ? color.green : direction == -1 ? color.red : color.gray, text_size=size.small)
    
    table.cell(infoTable, 0, 2, "Brick Size", text_color=color.gray, text_size=size.small)
    table.cell(infoTable, 1, 2, str.tostring(brickSize, format.mintick), text_color=color.yellow, text_size=size.small)
    
    table.cell(infoTable, 0, 3, "Renko Price", text_color=color.gray, text_size=size.small)
    table.cell(infoTable, 1, 3, str.tostring(realRenko, format.mintick), text_color=color.blue, text_size=size.small)
    
    table.cell(infoTable, 0, 4, "Long Stop", text_color=color.gray, text_size=size.small)
    table.cell(infoTable, 1, 4, str.tostring(longStopLevel, format.mintick), text_color=color.red, text_size=size.small)
    
    table.cell(infoTable, 0, 5, "Short Stop", text_color=color.gray, text_size=size.small)
    table.cell(infoTable, 1, 5, str.tostring(shortStopLevel, format.mintick), text_color=color.red, text_size=size.small)
    
    table.cell(infoTable, 0, 6, "Trail Long", text_color=color.gray, text_size=size.small)
    trailStatusLong = useTrailing ? (trailingActiveLong ? "ACTIVE" : "WAITING") : "OFF"
    table.cell(infoTable, 1, 6, trailStatusLong, text_color=trailingActiveLong ? color.orange : color.gray, text_size=size.small)
    
    table.cell(infoTable, 0, 7, "Trail Short", text_color=color.gray, text_size=size.small)
    trailStatusShort = useTrailing ? (trailingActiveShort ? "ACTIVE" : "WAITING") : "OFF"
    table.cell(infoTable, 1, 7, trailStatusShort, text_color=trailingActiveShort ? color.orange : color.gray, text_size=size.small)
    
    if inLongPosition or inShortPosition
        avgPrice = strategy.position_avg_price
        
        directionPos = inLongPosition ? "LONG" : "SHORT"
        table.cell(infoTable, 0, 8, "Позиция", text_color=color.gray, text_size=size.small)
        table.cell(infoTable, 1, 8, directionPos, text_color=inLongPosition ? color.green : color.red, text_size=size.small)
        
        table.cell(infoTable, 0, 9, "Размер поз", text_color=color.gray, text_size=size.small)
        table.cell(infoTable, 1, 9, str.tostring(math.abs(strategy.position_size)), text_color=color.white, text_size=size.small)

// === ВИЗУАЛИЗАЦИЯ ===
plotshape(buySignal, title="Buy Signal", location=location.belowbar, color=color.green, style=shape.triangleup, size=size.small)
plotshape(sellSignal, title="Sell Signal", location=location.abovebar, color=color.red, style=shape.triangledown, size=size.small)

plot(inLongPosition ? longStopLevel : na, "Long Stop", color=color.red, style=plot.style_linebr)
plot(inShortPosition ? shortStopLevel : na, "Short Stop", color=color.red, style=plot.style_linebr)
plot(inLongPosition and trailingActiveLong ? highestSinceLong * (1 - trailOffsetPct) : na, "Long Trailing", color=color.orange, style=plot.style_linebr)
plot(inShortPosition and trailingActiveShort ? lowestSinceShort * (1 + trailOffsetPct) : na, "Short Trailing", color=color.orange, style=plot.style_linebr)

plot(isFirstLongEntry or isLongAdd ? limitPriceLong : na, "Limit Buy", color=color.green, style=plot.style_linebr)
plot(isFirstShortEntry or isShortAdd ? limitPriceShort : na, "Limit Sell", color=color.red, style=plot.style_linebr)

