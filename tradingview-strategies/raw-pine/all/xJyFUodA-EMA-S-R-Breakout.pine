//@version=5
strategy("EMA + S/R Breakout", overlay=true, 
     default_qty_type=strategy.percent_of_equity, 
     default_qty_value=10,
     calc_on_every_tick=false)

// ─── INPUTS ───────────────────────────────────────────────────────────────────
ema9_len    = input.int(9,    "EMA Fast")
ema20_len   = input.int(20,   "EMA Slow")
sr_lookback = input.int(20,   "S/R Lookback Bars")
target_pct  = input.float(12.0, "Target %",    step=0.5) / 100
sl_pct      = input.float(6.0,  "Stop Loss %", step=0.5) / 100

// ─── EMA ──────────────────────────────────────────────────────────────────────
ema9  = ta.ema(close, ema9_len)
ema20 = ta.ema(close, ema20_len)

plot(ema9,  "EMA 9",  color=color.orange, linewidth=2)
plot(ema20, "EMA 20", color=color.blue,   linewidth=2)

// ─── S/R LEVELS (no lag - rolling highest/lowest) ─────────────────────────────
// Use [1] so we reference COMPLETED bars only - no repainting
res = ta.highest(high[1], sr_lookback)  // resistance
sup = ta.lowest(low[1],   sr_lookback)  // support

// ─── DRAW DOTTED S/R SEGMENTS AT PIVOT POINTS ─────────────────────────────────
ph = ta.pivothigh(high, sr_lookback, sr_lookback)
pl = ta.pivotlow(low,   sr_lookback, sr_lookback)

if not na(ph)
    line.new(bar_index[sr_lookback] - 4, ph,
             bar_index[sr_lookback] + 4, ph,
             color=color.red, style=line.style_dotted, width=2)

if not na(pl)
    line.new(bar_index[sr_lookback] - 4, pl,
             bar_index[sr_lookback] + 4, pl,
             color=color.green, style=line.style_dotted, width=2)

// ─── BREAKOUT CONDITIONS ──────────────────────────────────────────────────────
// Long:  price closes above resistance + EMA9 above EMA20
// Short: price closes below support    + EMA9 below EMA20
long_signal  = ta.crossover(close, res)  and ema9 > ema20
short_signal = ta.crossunder(close, sup) and ema9 < ema20

// ─── ENTRIES ──────────────────────────────────────────────────────────────────
if long_signal
    strategy.entry("Long", strategy.long, comment="BUY")

if short_signal
    strategy.entry("Short", strategy.short, comment="SELL")

// ─── EXITS ────────────────────────────────────────────────────────────────────
if strategy.position_size > 0
    strategy.exit("L-Exit", "Long",
         limit = strategy.position_avg_price * (1 + target_pct),
         stop  = strategy.position_avg_price * (1 - sl_pct),
         comment_profit = "TP +12%",
         comment_loss   = "SL -6%")

if strategy.position_size < 0
    strategy.exit("S-Exit", "Short",
         limit = strategy.position_avg_price * (1 - target_pct),
         stop  = strategy.position_avg_price * (1 + sl_pct),
         comment_profit = "TP +12%",
         comment_loss   = "SL -6%")

// ─── VISUAL SIGNALS (plotshape - most reliable, always shows) ─────────────────
plotshape(long_signal,  title="Long Entry",  location=location.belowbar, 
     style=shape.triangleup,   color=color.green, size=size.normal, text="BUY")

plotshape(short_signal, title="Short Entry", location=location.abovebar, 
     style=shape.triangledown, color=color.red,   size=size.normal, text="SELL")

