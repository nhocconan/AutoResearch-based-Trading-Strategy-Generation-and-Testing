//@version=5
strategy('The Best Strategy Template [LuciTech]',
 overlay=true,
 max_bars_back=500,
 max_lines_count=500,
 max_boxes_count=500,
 initial_capital=100000,
 default_qty_type=strategy.percent_of_equity,
 default_qty_value=100)


//---Strategy Settings---
//ToolTips
sltip = 'Defines the stop-loss length based on candles. 0 means 1 candle, 1 means 2 candles, and so on.'
betip = 'Enter the R multiple at which the stop loss moves to breakeven. 0 means breakeven is disabled.'
rrtip = 'The risk-reward ratio determines the relationship between potential reward and risk. For example, 3 means risking 1 unit to gain 3 units.'
risk_percent_tip = 'The percentage of your equity that you are willing to risk per trade.'
sl_type_tip = 'Choose the stop-loss calculation type: ATR-based, Candle-based, or FVG-based (uses FVG boundaries).'
ATRlength_tip = 'The number of periods used to calculate the Average True Range (ATR).'
smoothing_tip = 'Choose the smoothing method for ATR: RMA, SMA, EMA, or WMA.'
ATRlines_tip = 'Enable or disable plotting of ATR-based stop-loss lines.'
fillcolour_tip = 'Select the background color to visually indicate the active time filter range on the chart.'
time_filter_tip = 'Enable or disable the time filter. When disabled, trades can occur at any time.'
day_filter_tip = 'Enable or disable the day filter. When enabled, trades only occur on selected days of the week.'


//Time filter inputs
use_time_filter = input.bool(false, title="Use Time Filter", group = 'Time Filter', tooltip=time_filter_tip)
start_hour = input.int(defval=0, title='Start Hour (24h)', minval=0, maxval=23, group = 'Time Filter')
start_minute = input.int(defval=59, title='Start Minute', minval=0, maxval=59, group = 'Time Filter')
end_hour = input.int(defval=23, title='End Hour (24h)', minval=0, maxval=23, group = 'Time Filter')
end_minute = input.int(defval=59, title='End Minute', minval=0, maxval=59, group = 'Time Filter')
showFill = input.bool(defval=false, title="Fill Background", inline = 'colour1', group = 'Time Filter')
fillColor = input.color(color.rgb(192, 192, 192, 90), title='', inline = 'colour1', group = 'Time Filter')

//Day Filter Inputs
use_day_filter = input.bool(false, title="Use Day Filter", group = 'Day Filter', tooltip=day_filter_tip)
monday = input.bool(true, title="Monday", inline="days1", group = 'Day Filter')
tuesday = input.bool(true, title="Tuesday", inline="days1", group = 'Day Filter')
wednesday = input.bool(true, title="Wednesday", inline="days1", group = 'Day Filter')
thursday = input.bool(true, title="Thursday", inline="days2", group = 'Day Filter')
friday = input.bool(true, title="Friday", inline="days2", group = 'Day Filter')
saturday = input.bool(false, title="Saturday", inline="days3", group = 'Day Filter')
sunday = input.bool(false, title="Sunday", inline="days3", group = 'Day Filter')

//Monthly Filter Inputs
use_month_filter = input.bool(false, title="Use Month Filter", group = 'Month Filter', tooltip="Enable to restrict trading to specific months")
january = input.bool(true, title="January", inline="months1", group = 'Month Filter')
february = input.bool(true, title="February", inline="months1", group = 'Month Filter')
march = input.bool(true, title="March", inline="months1", group = 'Month Filter')
april = input.bool(true, title="April", inline="months2", group = 'Month Filter')
may = input.bool(true, title="May", inline="months2", group = 'Month Filter')
june = input.bool(true, title="June", inline="months2", group = 'Month Filter')
july = input.bool(true, title="July", inline="months3", group = 'Month Filter')
august = input.bool(true, title="August", inline="months3", group = 'Month Filter')
september = input.bool(true, title="September", inline="months3", group = 'Month Filter')
october = input.bool(true, title="October", inline="months4", group = 'Month Filter')
november = input.bool(true, title="November", inline="months4", group = 'Month Filter')
december = input.bool(true, title="December", inline="months4", group = 'Month Filter')

//Position Type Filter Inputs
use_position_filter = input.bool(false, title="Use Position Type Filter", group = 'Position Type', tooltip="Enable to restrict trading to specific position types")
allow_long = input.bool(true, title="Allow Long", inline="positions", group = 'Position Type')
allow_short = input.bool(true, title="Allow Short", inline="positions", group = 'Position Type')

//Risk Management Inputs
risk_percent = input.float(2, title="Risk %", minval=0.1, maxval=100, group = 'Risk Management', tooltip=risk_percent_tip) / 100
Risk_reward = input.float(defval=2, title='Risk:Reward', minval=1, maxval=10, step=0.1, group = 'Risk Management', tooltip=rrtip)
breakeven = input.float(0, title="Breakeven at R", minval=0.0, step=0.1, group = 'Risk Management', tooltip=betip)
// Modified stop loss type options to include second FVG
sl_type = input.string("ATR", title="Stop Loss Type", options=["ATR", "Candle"], group = 'Risk Management', tooltip=sl_type_tip)
SL_length = input(0, title='Candle Length', group = 'Risk Management', tooltip=sltip)
ATRlength = input.int(title='ATR length', defval=14, minval=1, group = 'Risk Management', tooltip=ATRlength_tip)
smoothing = input.string(title='ATR Smoothing/ATR Lines', defval='SMA', options=['RMA', 'SMA', 'EMA', 'WMA'], group = 'Risk Management', tooltip=smoothing_tip)
ATRlines = input(false, 'Show ATR Lines', group = 'Risk Management', tooltip=ATRlines_tip)
ATRmulti = input.float(0, title='ATRMulti', group = 'Risk Management', tooltip=sltip, step=0.1)


//Position Colour Inputs
entrypricecolour = input.color(color.rgb(244, 244, 244, 75), title = 'Entry/SL/TP', group = 'Style', inline = 'peb')
stoplosscolour = input.color(color.rgb(255, 0, 0, 75), title = '',group = 'Style' ,inline = 'peb')
takeprofitcolour = input.color(color.rgb(0, 255, 0, 75), title = '',group = 'Style' ,inline = 'peb')


// Alert Settings Group
group_alert = "Alert Settings"
use_webhook_alerts = input.bool(true, "Use Webhook Alerts", group = group_alert, tooltip="Enable to send webhook alerts with trade information in JSON format")
webhook_format = input.string("Concise Telegram", title="Webhook Format", options=["Standard", "Telegram", "Concise Telegram"], group=group_alert, tooltip="Select the format for webhook alerts")
telegram_chat_id = input.string("tele chatid", title="Telegram Chat ID", group=group_alert, tooltip="Chat ID for Telegram alerts")


// --- ATR Values ---


//ATR SL
ma_function(source, ATRlength) =>
    if smoothing == 'RMA'
        ta.rma(source, ATRlength)
    else
        if smoothing == 'SMA'
            ta.sma(source, ATRlength)
        else
            if smoothing == 'EMA'
                ta.ema(source, ATRlength)
            else
                ta.wma(source, ATRlength)


a = ma_function(ta.tr(true), ATRlength) * (ATRmulti)
x = ma_function(ta.tr(true), ATRlength) * (ATRmulti) + high
x2 = low - ma_function(ta.tr(true), ATRlength) * (ATRmulti)
p1 = plot(ATRlines ? x : na, title='ATR Short Stop Loss', color=stoplosscolour, trackprice=ATRlines)
p2 = plot(ATRlines ? x2 : na, title='ATR Long Stop Loss', color=takeprofitcolour, trackprice=ATRlines)



// Standard time filter function
is_within_time_window() =>
    current_time = time('1', 'America/New_York')
    start_time = timestamp(year(current_time), month(current_time), dayofmonth(current_time), start_hour, start_minute, 0)
    end_time = timestamp(year(current_time), month(current_time), dayofmonth(current_time), end_hour, end_minute, 0)
    current_time >= start_time and current_time <= end_time


// Day filter function
is_valid_trading_day() =>
    current_day = dayofweek(time)
    day_allowed = false
    
    // dayofweek() returns: 1=Sunday, 2=Monday, 3=Tuesday, 4=Wednesday, 5=Thursday, 6=Friday, 7=Saturday
    if current_day == 2 and monday
        day_allowed := true
    else if current_day == 3 and tuesday
        day_allowed := true
    else if current_day == 4 and wednesday
        day_allowed := true
    else if current_day == 5 and thursday
        day_allowed := true
    else if current_day == 6 and friday
        day_allowed := true
    else if current_day == 7 and saturday
        day_allowed := true
    else if current_day == 1 and sunday
        day_allowed := true
    
    day_allowed

// Month filter function
is_valid_trading_month() =>
    current_month = month(time)
    month_allowed = false
    
    // month() returns: 1=January, 2=February, ..., 12=December
    if current_month == 1 and january
        month_allowed := true
    else if current_month == 2 and february
        month_allowed := true
    else if current_month == 3 and march
        month_allowed := true
    else if current_month == 4 and april
        month_allowed := true
    else if current_month == 5 and may
        month_allowed := true
    else if current_month == 6 and june
        month_allowed := true
    else if current_month == 7 and july
        month_allowed := true
    else if current_month == 8 and august
        month_allowed := true
    else if current_month == 9 and september
        month_allowed := true
    else if current_month == 10 and october
        month_allowed := true
    else if current_month == 11 and november
        month_allowed := true
    else if current_month == 12 and december
        month_allowed := true
    
    month_allowed

// Position type filter function
is_valid_position_type(direction) =>
    position_allowed = false
    
    if direction == "LONG" and allow_long
        position_allowed := true
    else if direction == "SHORT" and allow_short
        position_allowed := true
    
    position_allowed

// Combine time, day, month, and position type filters
in_standard_time_range = not use_time_filter or is_within_time_window()
in_valid_day = not use_day_filter or is_valid_trading_day()
in_valid_month = not use_month_filter or is_valid_trading_month()
in_valid_position_long = not use_position_filter or is_valid_position_type("LONG")
in_valid_position_short = not use_position_filter or is_valid_position_type("SHORT")
inTimeRange = in_standard_time_range and in_valid_day and in_valid_month




// Background color for time filter
var color bgColor = na
bgColor := showFill and use_time_filter and is_within_time_window() ? fillColor : na
bgcolor(bgColor)



//Strategy Logic Example:


ma1 = ta.ema(close, 15) 
bull_cross = ta.crossover(close, ma1)
bear_cross = ta.crossunder(close, ma1)


// --- Strategy Signal Integration ---
longCondition = inTimeRange and bull_cross and in_valid_position_long
shortCondition = inTimeRange and bear_cross and in_valid_position_short



// --- Strategy Position Management ---
var float stop_level = na
var float target_level = na
var float entry_price = na
var float initial_stop = na
var bool moved_to_breakeven = false
var box current_bull_box = na
var box current_bear_box = na
var box current_second_bull_box = na
var box current_second_bear_box = na


calculate_position_size(stop_distance) =>
    if stop_distance > 0
        risk_amount = strategy.equity * risk_percent
        position_size = risk_amount / stop_distance
        math.floor(position_size / syminfo.mintick) * syminfo.mintick  // Ensure valid position size
    else
        na


// Function to create standard JSON alert message
create_alert_message(direction, sl_price, tp_price) =>
    // Format the JSON message with proper escaping
    message = '{"type":"' + direction + '","instrument":"' + syminfo.ticker + '","sl":' + str.tostring(sl_price, "#.#####") + ',"tp":' + str.tostring(tp_price, "#.#####") + '}'
    message


// Function to create Telegram JSON alert message
create_telegram_alert_message(direction, sl_price, tp_price) =>
    // Format the header based on direction
    header = direction == "BUY" ? "🟢BUY SIGNAL" : "🔴SELL SIGNAL"
    
    // Format date and time components
    y = str.tostring(year)
    m = str.tostring(month)
    d = str.tostring(dayofmonth)
    h = str.tostring(hour)
    min = str.tostring(minute)
    
    // Add leading zeros to single-digit values
    m := str.length(m) == 1 ? "0" + m : m
    d := str.length(d) == 1 ? "0" + d : d
    h := str.length(h) == 1 ? "0" + h : h
    min := str.length(min) == 1 ? "0" + min : min
    
    // Format the date time string
    datetime_str = y + "-" + m + "-" + d + " " + h + ":" + min
    
    // Format the JSON message for Telegram with proper escaping
    message = '{"chat_id": "' + telegram_chat_id + '", "text": "' + header + '\\n\\n{[' + syminfo.prefix + ']:[' + syminfo.ticker + '], price = [' + str.tostring(close, "#.#####") + ']}\\nDateTime = [' + datetime_str + ']\\nSL: ' + str.tostring(sl_price, "#.#####") + '\\nTP: ' + str.tostring(tp_price, "#.#####") + '"}'
    message


// Function to create concise Telegram JSON alert message
create_concise_telegram_alert_message(direction, sl_price, tp_price) =>
    // Format the header based on direction with emoji
    header = direction == "BUY" ? "🟢BUY " : "🔴SELL "
    
    // Format the JSON message for Telegram with proper escaping and concise format
    message = '{"chat_id": "' + telegram_chat_id + '", "text": "' + header + syminfo.ticker + '\\nPRICE = ' + str.tostring(close, "#.#####") + '\\nSL: ' + str.tostring(sl_price, "#.#####") + '\\nTP: ' + str.tostring(tp_price, "#.#####") + '"}'
    message


if strategy.position_size == 0
    // Reset breakeven flag when entering new trades
    moved_to_breakeven := false


    // Long entry logic
    if longCondition
        // Calculate stop loss level based on selected type (ATR, Candle, FVG, or Second FVG)
        stop_level := switch sl_type
            "ATR" => x2
            "Candle" => low[SL_length]
            => low[SL_length]  // Default to candle-based if unknown type
            
        initial_stop := stop_level  // Store initial stop level for breakeven calculations
        // Calculate distance between entry and stop for position sizing
        stop_distance = close - stop_level
        // Calculate take profit level based on risk:reward ratio
        target_level := close + (Risk_reward * stop_distance)
        // Calculate position size based on risk parameters
        position_size = calculate_position_size(stop_distance)
        
        // Send webhook alert if enabled
        if use_webhook_alerts
            // Choose alert format based on user selection
            alert_message = switch webhook_format
                "Telegram" => create_telegram_alert_message("BUY", stop_level, target_level)
                "Concise Telegram" => create_concise_telegram_alert_message("BUY", stop_level, target_level)
                => create_alert_message("BUY", stop_level, target_level)  // Default to standard format
            alert(alert_message, alert.freq_once_per_bar)
        
        // Enter long position if position size is valid
        if not na(position_size) and position_size > 0
            strategy.entry("Long", strategy.long, qty=position_size)
            // Place stop loss and take profit orders
            strategy.exit("Exit Long", "Long", stop=stop_level, limit=target_level)
            entry_price := close  // Store entry price for breakeven calculations
            
    
    // Short entry logic
    if shortCondition
        // Calculate stop loss level based on selected type (ATR, Candle, FVG, or Second FVG)
        stop_level := switch sl_type
            "ATR" => x
            "Candle" => high[SL_length]
            => high[SL_length]  // Default to candle-based if unknown type
            
        initial_stop := stop_level  // Store initial stop level for breakeven calculations
        // Calculate distance between entry and stop for position sizing
        stop_distance = stop_level - close
        // Calculate take profit level based on risk:reward ratio
        target_level := close - (Risk_reward * stop_distance)
        // Calculate position size based on risk parameters
        position_size = calculate_position_size(stop_distance)
        
        // Send webhook alert if enabled
        if use_webhook_alerts
            // Choose alert format based on user selection
            alert_message = switch webhook_format
                "Telegram" => create_telegram_alert_message("SELL", stop_level, target_level)
                "Concise Telegram" => create_concise_telegram_alert_message("SELL", stop_level, target_level)
                => create_alert_message("SELL", stop_level, target_level)  // Default to standard format
            alert(alert_message, alert.freq_once_per_bar)
        
        // Enter short position if position size is valid
        if not na(position_size) and position_size > 0
            strategy.entry("Short", strategy.short, qty=position_size)
            // Place stop loss and take profit orders
            strategy.exit("Exit Short", "Short", stop=stop_level, limit=target_level)
            entry_price := close  // Store entry price for breakeven calculations
            



// Breakeven logic - moves stop loss to entry price when profit threshold is reached
if breakeven > 0 and strategy.position_size != 0
    // Calculate initial risk in points/pips
    initial_risk = math.abs(entry_price - initial_stop)


    // Long position breakeven logic
    if strategy.position_size > 0  // Long position
        // Calculate current unrealized profit
        current_profit = high - entry_price
        // Check if profit threshold reached and breakeven not already moved
        if current_profit >= (breakeven * initial_risk) and not moved_to_breakeven
            moved_to_breakeven := true
            strategy.cancel("Exit Long")  // Cancel existing exit order
            stop_level := entry_price     // Set new stop at entry price
            // Place new exit order with breakeven stop
            strategy.exit("Exit Long", "Long", stop=entry_price, limit=target_level)
    
    // Short position breakeven logic
    if strategy.position_size < 0  // Short position
        // Calculate current unrealized profit
        current_profit = entry_price - low
        // Check if profit threshold reached and breakeven not already moved
        if current_profit >= (breakeven * initial_risk) and not moved_to_breakeven
            moved_to_breakeven := true
            strategy.cancel("Exit Short")  // Cancel existing exit order
            stop_level := entry_price     // Set new stop at entry price
            // Place new exit order with breakeven stop
            strategy.exit("Exit Short", "Short", stop=entry_price, limit=target_level)


// Plotting Entry, SL, and TP lines
plot(strategy.position_size != 0 ? entry_price : na, title="Entry Price", color=entrypricecolour, style=plot.style_linebr)
plot(strategy.position_size != 0 ? stop_level : na, title="Stop Loss", color=stoplosscolour, style=plot.style_linebr)
plot(strategy.position_size != 0 ? target_level : na, title="Take Profit", color=takeprofitcolour, style=plot.style_linebr)


// Determine fill extension based on user setting
extend_fill_by_bar = false
var int fill_extension = extend_fill_by_bar ? 1 : 0


// Fill between Entry and SL
plot_entry = plot(strategy.position_size != 0 ? entry_price : na, "Entry for SL Fill", display=display.none, offset=fill_extension)
plot_sl = plot(strategy.position_size != 0 ? stop_level : na, "SL for Fill", display=display.none)
fill(plot_entry, plot_sl, color = strategy.position_size != 0 ? stoplosscolour : na)


// Fill between Entry and TP
plot_entry_tp = plot(strategy.position_size != 0 ? entry_price : na, "Entry for TP Fill", display=display.none, offset=fill_extension)
plot_tp = plot(strategy.position_size != 0 ? target_level : na, "TP for Fill", display=display.none)
fill(plot_entry_tp, plot_tp, color = strategy.position_size != 0 ? takeprofitcolour : na)

