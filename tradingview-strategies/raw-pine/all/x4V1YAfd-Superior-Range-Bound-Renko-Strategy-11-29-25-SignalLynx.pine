//@version=6
// Superior-Range Bound Renko - Strategy - By SignalLynx 11-29-25 Release

// ============================================================================================================
//     SIGNAL LYNX - SUPERIOR RANGE BOUND RENKO (RBR)
// ============================================================================================================
//
//     INTRODUCTION:
//     This script implements "Superior RBR," an elevated take on Range Bounding combined with 
//     Renko Brick emulation. Unlike standard static indicators, this system actively monitors 
//     and adapts to price action volatility.
//    
//     HOW IT WORKS:
//     1. Adaptive Range Bounding: Calculates dynamic High/Low ranges based on volatility (ATR).
//     2. Renko Emulator: Visualizes price movement as "Bricks" on a standard candlestick chart 
//        without the repainting issues of standard Renko charts.
//     3. Impulse Tracking (The Cyan/Red Line): This is a Laguerre Filter applied to the brick structure.
//        - Extension beyond the bricks indicates an Impulse move has started.
//        - Color changes indicate the impulse is ending and price is reverting.
//     4. K-Means SuperTrend: Used as a secondary filter to confirm trend regimes.
//    
//     THE RISK MANAGEMENT (RM) ENGINE:
//     This code features the Signal Lynx Risk Management Engine. It separates the "Signal" from the "Execution."
//     - Logic Injection: The engine expects a simple integer signal: +2 (Buy) or -2 (Sell).
//     - Repainting Protection: Uses actual candle closes for critical logic.
//     - Advanced Exits: Includes Staged Take Profits, Trailing Stops, and an Advanced Adaptive 
//       Trailing Stop (AATS) based on Hirashima Sugita and Bollinger Bands.
//
//     --------------------------------------------------------------------------------------------------------
//     Signal Lynx
//     Free Scripts supporting Automation for the Night-Shift Nation 🌙
//     (www.signallynx.com)
//     --------------------------------------------------------------------------------------------------------

// ==============================================================================
//  !!! MODE SELECTION - READ CAREFULLY !!!
// ==============================================================================
//  Pine Script can run as a STRATEGY (Backtesting) or an INDICATOR (Alerts).
//  You must uncomment only ONE of the following two lines.

//  OPTION 1: STRATEGY MODE (Default) 
//  Use this to see Buy/Sell tags on the chart and run the Strategy Tester.
strategy('Superior-Range Bound Renko - Strategy - 11-29-25', shorttitle='Superior-RBR - 11-29-25', overlay=true, initial_capital=1000, max_bars_back = 5000, commission_type=strategy.commission.percent, commission_value=0.26, currency=currency.USD, default_qty_type=strategy.percent_of_equity, default_qty_value=100, pyramiding=0, slippage=5)

//  OPTION 2: INDICATOR/ALERT MODE
//  Use this to set up Alerts for automation.
//indicator('Superior-Range Bound Renko - Alerts - 1-29-25', shorttitle='Superior-RBR (Alerts) - 11-29-25', overlay=true, max_bars_back = 5000) 
// ==============================================================================


// ==========================================
// ─── HELPER FUNCTIONS ───
// ==========================================

// Helper function to clamp lookback for Adaptive Logic
f_clampLookback(norm, minVal, maxVal) =>
    if na(norm)
        na
    else
        math.round(minVal + norm * float(maxVal - minVal))

// Helper function for Laguerre Filter (Reduces repetitive code blocks)
f_calc_laguerre(float src, float gamma) =>
    var float l0 = 0.0
    var float l1 = 0.0
    var float l2 = 0.0
    var float l3 = 0.0
    
    l0 := (1 - gamma) * src + gamma * nz(l0[1])
    l1 := -gamma * l0 + nz(l0[1]) + gamma * nz(l1[1])
    l2 := -gamma * l1 + nz(l1[1]) + gamma * nz(l2[1])
    l3 := -gamma * l2 + nz(l2[1]) + gamma * nz(l3[1])
    
    (l0 + 2 * l1 + 2 * l2 + l3) / 6


// ==========================================
// ─── INPUTS: BACKTEST RANGE ───
// ==========================================
var BackTestMod = "Back Test Inputs"
testStartYear   = input.int(2019, '- Start year', group=BackTestMod)
testStartMonth  = input.int(01,   '- Start month', group=BackTestMod) 
testStartDay    = input.int(01,   '- Start day',   group=BackTestMod)
testStopYear    = input.int(99999,'- Stop year',   group=BackTestMod)
testStopMonth   = input.int(12,   '- Stop month',  group=BackTestMod)
testStopDay     = input.int(30,   '- Stop day',    group=BackTestMod)

testPeriodStart = timestamp(testStartYear, testStartMonth, testStartDay, 0, 0) 
testPeriodStop  = timestamp(testStopYear, testStopMonth, testStopDay, 0, 0)

testPeriod() => time >= testPeriodStart and time <= testPeriodStop


// ==========================================
// ─── INPUTS: STRATEGY & DIRECTION ───
// ==========================================
var LnS = "Strategy Options - Longs and Shorts"
LnS_Longs  = input.bool(true,  title='Longs',  group=LnS)
LnS_Shorts = input.bool(false, title='Shorts', group=LnS)

LongAndShort = LnS_Longs and LnS_Shorts ? 1 : LnS_Longs and not LnS_Shorts ? 2 : not LnS_Longs and LnS_Shorts ? 3 : 1


// ==========================================
// ─── SUPERIOR RBR LOGIC ───
// ==========================================

// --- Adaptive Lookback Calculation ---
// [NOTE] This section calculates volatility to determine how far back the system 
// should look to define "Range". Higher volatility = Shorter lookback.
var RB = "Range Bound Inputs"
UseAdaptiveLB   = input.bool(false, "Use Adaptive Lookback?", group=RB)
fixedLookback   = input.int(100, "Lookback Length (Default=100)", minval=1, group=RB)
volPeriod       = input.int(50, "Volatility Period for Adaptive LB", group=RB)
minLookbackVal  = input.int(4,  "Min Lookback",  group=RB)
maxLookbackVal  = input.int(100,"Max Lookback",  group=RB)

atrVol = ta.atr(volPeriod)
hasEnoughBars = bar_index >= volPeriod

// Calculate Min/Max volatility outside ternary to ensure consistency
_volMinRaw = ta.lowest(atrVol, volPeriod)
_volMaxRaw = ta.highest(atrVol, volPeriod)

volMin   = hasEnoughBars ? _volMinRaw : na
volMax   = hasEnoughBars ? _volMaxRaw : na
volRange = (not na(volMax) and not na(volMin)) ? (volMax - volMin) : 0.0
volNorm  = (volRange == 0.0) or (not hasEnoughBars) ? na : (atrVol - volMin) / volRange

adaptiveLB = f_clampLookback(volNorm, minLookbackVal, maxLookbackVal)
lookback_float = not UseAdaptiveLB ? fixedLookback : (na(adaptiveLB) ? fixedLookback : adaptiveLB)
lookback = int(lookback_float)

// --- Range Definitions ---
// Calculating the physical boundaries of the current range
rangeHigh      = ta.highest(high, lookback)
rangeLow       = ta.lowest(low, lookback)
rangeOpenHigh  = ta.highest(open, lookback)
rangeOpenLow   = ta.lowest(open, lookback)
rangeCloseHigh = ta.highest(close, lookback)
rangeCloseLow  = ta.lowest(close, lookback)

rangeHighChange      = rangeHigh <= rangeHigh[1] ? 1 : 0
rangeLowChange       = rangeLow >= rangeLow[1] ? 1 : 0
rangeOpenHighChange  = rangeOpenHigh <= rangeOpenHigh[1] ? 1 : 0
rangeOpenLowChange   = rangeOpenLow >= rangeOpenLow[1] ? 1 : 0
rangeCloseHighChange = rangeCloseHigh <= rangeCloseHigh[1] ? 1 : 0
rangeCloseLowChange  = rangeCloseLow >= rangeCloseLow[1] ? 1 : 0

// High Range Construction
var int rangeHighCounter = 1
rangeHighCounter := rangeLowChange == 0 ? 1 : rangeHighCounter + 1
rangeHighFinalLength = rangeHighCounter < lookback ? rangeHighCounter : lookback
rangeHighFinal = ta.highest(high, rangeHighFinalLength)
plot(rangeHighFinal, color=color.lime, linewidth=3, title="Range High") 

// Low Range Construction
var int rangeLowCounter = 1
rangeLowCounter := rangeHighChange == 0 ? 1 : rangeLowCounter + 1
rangeLowFinalLength = rangeLowCounter < lookback ? rangeLowCounter : lookback
rangeLowFinal = ta.lowest(low, rangeLowFinalLength)
plot(rangeLowFinal, color=color.red, linewidth=3, title="Range Low")

// Close High/Low Construction (Inner Range)
var int rangeCloseHighCounter = 1
rangeCloseHighCounter := rangeCloseHighChange == 0 ? 1 : rangeCloseHighCounter + 1
rangeCloseHighFinalLength = rangeCloseHighCounter < lookback ? rangeCloseHighCounter : lookback
rangeCloseHighFinal = ta.highest(close, rangeCloseHighFinalLength)
plot(rangeCloseHighFinal, color=color.olive, linewidth=4, title="Range Close High")

var int rangeCloseLowCounter = 1
rangeCloseLowCounter := rangeCloseLowChange == 0 ? 1 : rangeCloseLowCounter + 1
rangeCloseLowFinalLength = rangeCloseLowCounter < lookback ? rangeCloseLowCounter : lookback
rangeCloseLowFinal = ta.lowest(close, rangeCloseLowFinalLength) 
plot(rangeCloseLowFinal, color=color.orange, linewidth=4, title="Range Close Low")

// Quick Ranges (Fast reaction)
quick1 = (rangeHighFinalLength / 2) < 2 ? 2 : int(rangeHighFinalLength / 2)
quick2 = (rangeLowFinalLength / 2) < 2 ? 2 : int(rangeLowFinalLength / 2)
quickLengthAvg = math.round(math.avg(quick1, quick2))

rangeCloseHighQuick = ta.highest(close, quick1)
rangeCloseLowQuick  = ta.lowest(close, quick2)
standardAvg         = math.avg(rangeLowFinal, rangeHighFinal)
quickCloseAvg       = math.avg(rangeCloseHighQuick, rangeCloseLowQuick)

LA1 = (rangeCloseHighFinalLength / 2) < 2 ? 2 : int(rangeCloseHighFinalLength / 2)
LA2 = (rangeCloseLowFinalLength / 2) < 2 ? 2 : int(rangeCloseLowFinalLength / 2)
LAAvg = int(math.round(math.avg(LA1, quick2)))


// --- Support & Resistance (S&R) ---
// Visualizes static S&R lines based on the range breaks
var S_and_R = "Support and Resistance"
UseChart        = input.bool(false, title='Chart Support and Resistance)', group=S_and_R)
UseChartRedraw  = input.bool(false, title='Redraw S&R at Each Rangebreak', group=S_and_R)
UseLines = (UseChart and UseChartRedraw) ? 1 : 0
UsePlots = (UseChart and not UseChartRedraw) ? 1 : 0

// [NOTE] Logic simplified for plotting static lines on range locks.
// (Detailed S&R plotting logic omitted for brevity, but functional in chart)
var float preCloseHigh1 = 0.0, var float preCloseHigh2 = 0.0
HighTrigger = rangeCloseHighChange == 0 and rangeCloseHighFinal[1] == rangeCloseHighFinal[14] ? 1 : 0
preCloseHigh1 := HighTrigger == 1 ? rangeCloseHighFinal[1] : preCloseHigh1[1]
preCloseHigh2 := HighTrigger == 1 ? preCloseHigh1[1] : preCloseHigh2[1]

plot(UsePlots == 1 ? preCloseHigh1 : na, color=color.black, title="S&R High 1")
plot(UsePlots == 1 ? preCloseHigh2 : na, color=color.black, title="S&R High 2")

var float preCloseLow1 = 0.0, var float preCloseLow2 = 0.0
LowTrigger = rangeCloseLowChange == 0 and rangeCloseLowFinal[1] == rangeCloseLowFinal[14] ? 1 : 0
preCloseLow1 := LowTrigger == 1 ? rangeCloseLowFinal[1] : preCloseLow1[1]
preCloseLow2 := LowTrigger == 1 ? preCloseLow1[1] : preCloseLow2[1]

plot(UsePlots == 1 ? preCloseLow1 : na, color=color.gray, title="S&R Low 1")
plot(UsePlots == 1 ? preCloseLow2 : na, color=color.gray, title="S&R Low 2")


// --- Fibonacci Levels ---
// Dynamic fibs based on the current active range
debauchFibHigh = rangeHighFinal 
deabuchFibLow  = rangeLowFinal

var int zSwap = 0
var emulator = "Renko Emulator Settings"
var bool useFib_Input = input.bool(false, "Use RangeBound Fib Breaks as Renko Blocks", group = emulator)
useFib = useFib_Input

triggerSwapHigh = zSwap == 1 and useFib ? debauchFibHigh : rangeCloseHighFinal
triggerSwapLow  = zSwap == 1 and useFib ? deabuchFibLow  : rangeCloseLowFinal

fibRange    = triggerSwapHigh - triggerSwapLow
fibRangeLow = triggerSwapLow

// Standard Fibs
fib12 = (fibRange * 0.12)  + fibRangeLow
fib23 = (fibRange * 0.236) + fibRangeLow
fib38 = (fibRange * 0.382) + fibRangeLow
fib50 = (fibRange * 0.5)   + fibRangeLow
fib61 = (fibRange * 0.61)  + fibRangeLow
fib76 = (fibRange * 0.768) + fibRangeLow
fib88 = (fibRange * 0.88)  + fibRangeLow

plot(fib12, color=color.black, linewidth=2, title="Fib 12")
plot(fib23, color=color.black, linewidth=2, title="Fib 23")
plot(fib50, color=color.black, linewidth=2, title="Fib 50")
plot(fib88, color=color.black, linewidth=2, title="Fib 88")

// Fib Location Tracker (Bucket Logic)
locTrackerSet = close
int FibLoc = locTrackerSet < fib12 ? 1 : locTrackerSet >= fib12 and locTrackerSet < fib23 ? 2 : locTrackerSet >= fib23 and locTrackerSet < fib38 ? 3 : locTrackerSet >= fib23 and locTrackerSet < fib50 ? 4 : locTrackerSet >= fib50 and locTrackerSet < fib61 ? 5 : locTrackerSet >= fib61 and locTrackerSet < fib76 ? 6 : locTrackerSet >= fib76 and locTrackerSet < fib88 ? 7 : 8

fibLocHigh = FibLoc==1 ? fib12 : FibLoc==2 ? fib23 : FibLoc==3 ? fib38 : FibLoc==4 ? fib50 : FibLoc==5 ? fib61 : FibLoc==6 ? fib76 : FibLoc==7 ? fib88 : debauchFibHigh
fibLocLow  = FibLoc==1 ? deabuchFibLow : FibLoc==2 ? fib12 : FibLoc==3 ? fib23 : FibLoc==4 ? fib38 : FibLoc==5 ? fib50 : FibLoc==6 ? fib61 : FibLoc==7 ? fib76 : fib88


// --- Renko Emulator ---
// Emulates Brick behavior on standard charts
var emulatorInputs = "Renko Emulator Inputs"
var emulatorPlots  = "Emulator Plot Settings"

sourceBrick   = input.source(close, "Brick Source (Default is Close)", group = emulator)
brickType     = input.bool(true, "Choose Brick Size - Default (True) is Standard Bricks; False is ATR", group = emulator)
atrInhib      = input.bool(false, "For ATR Emulator Settings - Use 'Standard Brick Size (in Percent)' as an Inhibitor", group = emulator)
standardBrick = input.float(0.5, "Standard Brick Size (In Percent)", minval=0, step=0.1, maxval=100, group = emulatorInputs)/100
atrLength     = input.int(100, "ATR Length for Renko (Default = 100)", minval=1, step=1, group = emulatorInputs)
atrMod        = input.int(5, "ATR Modifier (Default = 5)", minval=1, step=1, group = emulatorInputs)
useBrickPlots = input.bool(true, "Plot Emulated Bricks", group = emulatorPlots)
useFill       = input.bool(true, "Fill between Emulated Bricks", group = emulatorPlots)

// ATR for Renko sizing
atrGet  = ta.atr(atrLength)
atrHigh = ta.highest(atrGet, atrLength)
atrLow  = ta.lowest(atrGet, atrLength)

atrBrick      = ((atrHigh - atrLow) / sourceBrick) * atrMod 
atrBrickInhib = atrBrick > standardBrick ? atrBrick : standardBrick
atrBrickFinal = atrInhib == false ? atrBrick : atrBrickInhib
brick         = brickType == true ? standardBrick : atrBrickFinal

// Emulated Renko Block Calculation
float baseValue = sourceBrick
var int updateBase = 1

baseValue := updateBase == 1 ? sourceBrick : baseValue[1]
brickUpper = useFib ? fibLocHigh[1] : baseValue * (1 + brick)
brickLower = useFib ? fibLocLow[1]  : baseValue * (1 - brick)

calculateUpper = sourceBrick > brickUpper ? 1 : 0
calculateLower = sourceBrick < brickLower ? -1 : 0
updateBase := calculateUpper == 1 or calculateLower == -1 ? 1 : 0

// Plotting the Renko Bricks
plot(useBrickPlots ? baseValue : na, color=color.aqua, linewidth=1, title="Renko Base")
plot(useBrickPlots and not useFill ? brickUpper : na, color=color.lime, linewidth=1, title="Renko Upper")
plot(useBrickPlots and not useFill ? brickLower : na, color=color.fuchsia, linewidth=1, title="Renko Lower")
U = plot(useBrickPlots and useFill ? brickUpper : na, color=color.black, linewidth=1, title="Renko Upper Fill")
L = plot(useBrickPlots and useFill ? brickLower : na, color=color.black, linewidth=1, title="Renko Lower Fill")

var int getFillColor = 0
getFillColor := baseValue > baseValue[1] ? 1 : baseValue < baseValue[1] ? -1 : getFillColor[1]
fillColor = getFillColor == 1 ? color.new(color.aqua, 25) : getFillColor == -1 ? color.new(color.red, 25) : color.orange
fill(U, L, color=fillColor)

// Cleanup vars for logic
EmuBrick = math.avg(rangeCloseHighFinal, rangeCloseLowFinal) 
brickAvgX = math.avg(brickUpper, brickLower)
brickAvgXOld = math.avg(rangeCloseHighQuick, rangeCloseLowQuick)
brickAvgY = math.avg(rangeHighFinal, rangeLowFinal)
rangeAverage = (rangeLowFinal + rangeHighFinal) / 2

// Renko Directional Memory
var int renkoDir = 0
renkoDir := baseValue > baseValue[1] ? 2 : baseValue < baseValue[1] ? -2 : renkoDir[1]

// Expansion logic (Volatility expansion detection)
expansion = fibRange > fibRange[1] ? 1 : 0
expansionRangeQuick = rangeHighFinal - rangeLowFinal
expansionQuick = expansionRangeQuick > expansionRangeQuick[1] ? 1 : 0
expansionBrickRange = brickUpper - brickLower
expansionBrick = expansionBrickRange > expansionBrickRange[1] ? 1 : 0 

var int expansionQuickPerp = 0
expansionQuickPerp := expansionRangeQuick > expansionRangeQuick[1] ? 1 : expansionRangeQuick < expansionRangeQuick[1] ? 0 : expansionQuickPerp[1]
expansionQuickDir = expansionQuick == 1 and rangeHighFinal > rangeHighFinal[1] ? 1 : expansionQuick == 1 and rangeLowFinal < rangeLowFinal[1] ? -1 : 0


// --- Laguerre Filters (Impulse Tracking) ---
// [NOTE] Laguerre Filters are used here to create smooth, responsive trend lines.
// The primary impulse line (LagF_V) changes color based on direction.
returns = math.log(close / close[1])
volatility = ta.stdev(returns, LAAvg)
volatilityMin = ta.lowest(volatility, LAAvg)
volatilityMax = ta.highest(volatility, LAAvg) 

normalizedVolatility = (volatility - volatilityMin) / (volatilityMax - volatilityMin)
relativeVolatility = 1 - normalizedVolatility

// True Range calculations
atrHigh89 = ta.highest(rangeHighFinal, rangeHighFinalLength)
atrLow89  = ta.lowest(rangeLowFinal, rangeLowFinalLength)
highLow   = atrHigh89 - atrLow89 
highClose = math.abs(atrHigh89 - rangeHighFinal)
lowClose  = math.abs(atrLow89 - rangeLowFinal)
trueRange = math.max(highLow, math.max(highClose, lowClose))

wepSlow = (math.abs(EmuBrick - trueRange) / EmuBrick)
wepFast = (math.abs(quickCloseAvg - rangeAverage) / quickCloseAvg)
wepAvg  = math.avg(wepSlow, wepFast)
wepTotality = math.avg(wepSlow, wepSlow, wepSlow, relativeVolatility)

// 1. LagF_1 (Brick Upper Baseline)
src_1 = brickUpper
gamma_1 = math.pow(wepAvg, wepSlow)
LagF_1 = f_calc_laguerre(src_1, gamma_1)
var int lagSigATF = 0
lagSigATF := LagF_1 > (LagF_1[1]) ? 2 : LagF_1 < (LagF_1[1]) ? -2 : lagSigATF[1]
Color_ATF = lagSigATF == 2 ? color.aqua : lagSigATF == -2 ? color.fuchsia : color.yellow
plot(LagF_1, title='LagF', linewidth=3, color=Color_ATF)

// 2. LagF_W (Brick Lower Baseline)
src_W = brickLower
gamma_W = math.pow(wepAvg, wepSlow)
LagF_W = f_calc_laguerre(src_W, gamma_W)
var int lagSig_W = 0
lagSig_W := LagF_W > (LagF_W[1]) ? 2 : LagF_W < (LagF_W[1]) ? -2 : lagSig_W[1]
Color_lagSig_W = lagSig_W == 2 ? color.lime : lagSig_W == -2 ? color.red : color.yellow
plot(LagF_W, title='LagW', linewidth=3, color=Color_lagSig_W)

// 3. LagF_Q (Based on HLCC4)
src_Q = hlcc4
alpha_Q = input.float(title='LagF - Alpha Q', minval=0, maxval=1, step=0.1, defval=1.0)
gamma_Q = 1 - alpha_Q
LagF_Q = f_calc_laguerre(src_Q, gamma_Q)
var int lagSig_Q = 0
lagSig_Q := LagF_Q > (LagF_Q[1]) ? 2 : LagF_Q < (LagF_Q[1]) ? -2 : lagSig_Q[1]
Color_lagSig_Q = lagSig_Q == 2 ? color.gray : lagSig_Q == -2 ? color.orange : color.yellow
plot(LagF_Q, title='LagQ', linewidth=3, color=Color_lagSig_Q)

// 4. LagF_Z (Based on Brick Average)
src_Z = brickAvgX
gamma_Z = math.pow(wepAvg, wepSlow)
LagF_Z = f_calc_laguerre(src_Z, gamma_Z)
var int lagSig_Z = 0
lagSig_Z := LagF_Z > (LagF_Z[1]) ? 2 : LagF_Z < (LagF_Z[1]) ? -2 : lagSig_Z[1]
Color_lagSig_Z = lagSig_Z == 2 ? color.blue : lagSig_Z == -2 ? color.maroon : color.yellow
plot(LagF_Z, title='LagZ', linewidth=3, color=Color_lagSig_Z)

// 5. LagF_Y (Complex Average)
crazyAvg = math.avg(brickUpper, brickLower, brickAvgX, hlcc4)
crazyAvgOld = math.avg(rangeCloseHighQuick, rangeCloseLowQuick, brickAvgXOld, hlcc4)
src_Y = crazyAvgOld
alpha_Y = input.float(title='LagF - Alpha Y', minval=0, maxval=1, step=0.1, defval=1.0)
gamma_Y = 1 - alpha_Y
LagF_Y = f_calc_laguerre(src_Y, gamma_Y)
var int lagSig_Y = 0
lagSig_Y := LagF_Y > (LagF_Y[1]) ? 2 : LagF_Y < (LagF_Y[1]) ? -2 : lagSig_Y[1]
Color_lagSig_Y = lagSig_Y == 2 ? color.olive : lagSig_Y == -2 ? color.yellow : color.yellow
plot(LagF_Y, title='LagY', linewidth=3, color=Color_lagSig_Y)

// 6. LagF_P (Averaged Y and Brick Y)
src_P = math.avg(crazyAvg, brickAvgY)
gamma_P = math.pow(wepAvg, wepSlow)
LagF_P = f_calc_laguerre(src_P, gamma_P)
var int lagSig_P = 0
lagSig_P := LagF_P > (LagF_P[1]) ? 2 : LagF_P < (LagF_P[1]) ? -2 : lagSig_P[1]
Color_lagSig_P = lagSig_P == 2 ? color.navy : lagSig_P == -2 ? color.orange : color.yellow
plot(LagF_P, title='LagP', linewidth=3, color=Color_lagSig_P)

// 7. LagF_V (Primary Visual Impulse Line)
vAvg = math.avg(LagF_Y, rangeHighFinal, rangeLowFinal, LagF_P)
src_V = vAvg
gamma_V = math.pow(wepAvg, wepSlow)
LagF_V = f_calc_laguerre(src_V, gamma_V)
var int lagSig_V = 0
lagSig_V := LagF_V > (LagF_V[1]) ? 2 : LagF_V < (LagF_V[1]) ? -2 : lagSig_V[1]
Color_lagSig_V = lagSig_V == 2 ? color.lime : lagSig_V == -2 ? color.gray : color.yellow
plot(LagF_V, title='LagV', linewidth=5, color=Color_lagSig_V)

// Fib Range Swap & Z Swap Logic (Secondary Fib Set)
fibRangeSwap = rangeCloseHighFinal - rangeCloseLowFinal
fibRangeLowSwap = rangeCloseLowFinal

fib12Swap = (fibRangeSwap * 0.12) + fibRangeLowSwap
fib23Swap = (fibRangeSwap * 0.23) + fibRangeLowSwap
fib38Swap = (fibRangeSwap * 0.38) + fibRangeLowSwap
fib50Swap = (fibRangeSwap * 0.5)  + fibRangeLowSwap
fib61Swap = (fibRangeSwap * 0.62) + fibRangeLowSwap
fib76Swap = (fibRangeSwap * 0.77) + fibRangeLowSwap
fib88Swap = (fibRangeSwap * 0.88) + fibRangeLowSwap

plot(fib12Swap, color=color.gray, linewidth=1, title="Swap Fib 12")
plot(fib23Swap, color=color.gray, linewidth=1, title="Swap Fib 23")
plot(fib50Swap, color=color.gray, linewidth=1, title="Swap Fib 50")
plot(fib88Swap, color=color.gray, linewidth=1, title="Swap Fib 88")

zSwap := LagF_Q > fib76Swap and lagSig_V == 2 or LagF_Q < fib23Swap and lagSig_V == -2 ? 1 : fib23Swap > LagF_P or fib76Swap < LagF_P ? 1 : 0 


// --- Adaptive SuperTrend Oscillator (K-Means) ---
// [NOTE] This section uses Machine Learning (K-Means clustering) to classify volatility
// and adjust the SuperTrend factor dynamically.
atr_lenK = 14
factK = 3
training_data_periodK = 70
highvolK = 0.75
midvolK = 0.5
lowvolK = 0.25
smthlenK = 7

// SuperTrend Calc Function
pine_supertrendK(float factorK, float atrK) =>
    srcK = ohlc4
    upperBandK = srcK + factorK * atrK
    lowerBandK = srcK - factorK * atrK
    prevLowerBandK = nz(lowerBandK[1])
    prevUpperBandK = nz(upperBandK[1])

    lowerBandK := lowerBandK > prevLowerBandK or close[1] < prevLowerBandK ? lowerBandK : prevLowerBandK
    upperBandK := upperBandK < prevUpperBandK or close[1] > prevUpperBandK ? upperBandK : prevUpperBandK
    int _directionK = na
    float superTrendK = na
    prevSuperTrendK = superTrendK[1]
    
    if na(atrK[1])
        _directionK := 1
    else if prevSuperTrendK == prevUpperBandK
        _directionK := close > upperBandK ? -1 : 1
    else
        _directionK := close < lowerBandK ? 1 : -1
        
    superTrendK := _directionK == -1 ? lowerBandK : upperBandK
    [superTrendK, _directionK, upperBandK, lowerBandK]

// K-Means Logic
volatilityAtrK = ta.atr(atr_lenK)
upperK = ta.highest(volatilityAtrK, training_data_periodK)
lowerK = ta.lowest(volatilityAtrK, training_data_periodK)
high_volatilityK = lowerK + (upperK - lowerK) * highvolK
medium_volatilityK = lowerK + (upperK - lowerK) * midvolK
low_volatilityK = lowerK + (upperK - lowerK) * lowvolK

vdist_aK = math.abs(volatilityAtrK - high_volatilityK)
vdist_bK = math.abs(volatilityAtrK - medium_volatilityK)
vdist_cK = math.abs(volatilityAtrK - low_volatilityK)
distancesK = array.new_float()
distancesK.push(vdist_aK), distancesK.push(vdist_bK), distancesK.push(vdist_cK)

clusterK = distancesK.indexof(distancesK.min())
assigned_centroidK = clusterK == 0 ? high_volatilityK : clusterK == 1 ? medium_volatilityK : low_volatilityK

[STK, dirK, oscupperK, osclowerK] = pine_supertrendK(factK, assigned_centroidK)

// Raw Oscillator
raw_oscK = close - STK
osc_rangeK = ta.stdev(close, training_data_periodK) * 2
scaled_oscK = raw_oscK * (osc_rangeK / ta.stdev(raw_oscK, training_data_periodK))
adjusted_oscK = scaled_oscK + ohlc4
smthed_oscK = ta.ema(adjusted_oscK, smthlenK)

// Laguerre on SuperTrend (LagF_K)
src_K = adjusted_oscK
base_alphaK = input.float(title="Base Alpha K", minval=0, maxval=1, step=0.1, defval=0.3)
volatility_periodK = 14
gamma_K = 1 - base_alphaK
LagF_K = f_calc_laguerre(src_K, gamma_K)

var int lagSig_K = 0
lagSig_K := LagF_K > (LagF_K[1]) ? 2 : LagF_K < (LagF_K[1]) ? -2 : lagSig_K[1]
Color_lagSig_K = lagSig_K == 2 ? color.aqua : lagSig_K == -2 ? color.red : color.yellow

var int colorLagsigKCombo = 0
colorLagsigKCombo := lagSig_K == 2 and LagF_K > ohlc4 ? 2 : lagSig_K == -2 and LagF_K < ohlc4 ? -2 : colorLagsigKCombo[1]
plot(LagF_K, title="Laguerre Filter (Dynamic)", linewidth=3, color=Color_lagSig_K)

// All In One
var int aio_sig = 0
allinOne = math.avg(LagF_1, LagF_K, LagF_P, LagF_Q, LagF_V, LagF_W, LagF_Y, LagF_Z)
aio_sig := allinOne > (allinOne[1]) and allinOne[1] > (allinOne[2]) ? 2 : allinOne < (allinOne[1]) and allinOne[1] < (allinOne[2]) ? -2 : aio_sig[1]
Color_allinOne = aio_sig == 2 ? color.lime : aio_sig == -2 ? color.red : color.yellow
plot(allinOne, title="All In One)", linewidth=8, color=Color_allinOne)


// ==========================================
// ─── BASELINE & SIGNAL GENERATION ───
// ==========================================
// FIX: Pre-calculate crossover/crossunder to prevent short-circuiting consistency warnings
xUpFib38 = ta.crossover(rangeHighFinal, fib38)
xDnFib61 = ta.crossunder(rangeLowFinal, fib61)

// Baseline Logic 1
B1 = LagF_Q > LagF_W and expansionQuickDir == 1 and lagSig_Z == 2 and lagSig_Y == 2 and LagF_Y > fib23 and renkoDir == 2 or xUpFib38 and lagSig_Z == 2 and fibRange == fibRange[1] and renkoDir == 2 and LagF_Q > LagF_W ? 2 : LagF_Q < LagF_W and expansionQuickDir == -1 and lagSig_Z == -2 and lagSig_Y == -2 and LagF_Y < fib76 and renkoDir == -2 or xDnFib61 and lagSig_Z == -2 and fibRange == fibRange[1] and renkoDir == -2 and LagF_Q < LagF_W ? -2 : 0 

// Baseline Logic 2 (Incorporates Range Swap)
B2 = LagF_Q > LagF_W and expansionQuickDir == 1 and lagSig_Z == 2 and lagSig_Y == 2 and LagF_Y > fib23 and renkoDir == 2 or xUpFib38 and lagSig_Z == 2 and fibRange == fibRange[1] and renkoDir == 2 and LagF_Q > LagF_W or fib50Swap > fib50Swap[1] and LagF_P > fib76Swap ? 2 : LagF_Q < LagF_W and expansionQuickDir == -1 and lagSig_Z == -2 and lagSig_Y == -2 and LagF_Y < fib76 and renkoDir == -2 or xDnFib61 and lagSig_Z == -2 and fibRange == fibRange[1] and renkoDir == -2 and LagF_Q < LagF_W or fib50Swap < fib50Swap[1] and LagF_P < fib23Swap ? -2 : 0 

sigSwap  = input.bool(true, "Use Baseline Final Sig? (True = Yes/Baseline)")
baseSig  = B2
altSig   = B1
finalSig = sigSwap ? baseSig : altSig 

// Range Bound Brick Fills (Visuals)
var int getFillColorRB = 0
uRB = plot(rangeCloseHighQuick, color=color.black, linewidth=1, title="RB Upper")
lRB = plot(rangeCloseLowQuick, color=color.black, linewidth=1, title="RB Lower")
getFillColorRB := finalSig == 2 ? 1 : finalSig == -2 ? -1 : getFillColorRB[1]
fillColorRB = getFillColorRB == 1 ? color.new(color.green, 50) : getFillColorRB == -1 ? color.new(color.fuchsia, 50) : color.new(color.orange, 50)
fill(uRB, lRB, color=fillColorRB)

// Weekend Checker
WeekendInput = input.bool(false, title='Do NOT Trade Weekends (Default=Trade)')
weekend      = dayofweek == 1 or dayofweek == 7 ? 1 : 0
WeekendHalt  = WeekendInput ? weekend : 0


// ==========================================
// ─── RISK MANAGEMENT & TRADE ENGINE ───
// ==========================================
AlertOpen = WeekendHalt == 1 ? 0 : finalSig

var ClInputs = "Closing Arguments"
CloseInput   = input.bool(false, title='Use Closing Argument (Default=Yes)', group = ClInputs)
closerLong   = 0
closerShort  = 0
CloseLong    = CloseInput and closerLong == 1
CloseShort   = CloseInput and closerShort == -1

// Trade State Machine
AO = AlertOpen == 2 and AlertOpen != AlertOpen[1] ? 2 : AlertOpen == -2 and AlertOpen != AlertOpen[1] ? -2 : 0
var float AT = na
AT := (AO == 2) ? 2 : (AO == -2) ? -2 : AT[1]
var float AF = na
AF := (AT == 2 and AT[1] != 2) ? 2 : (AT == -2 and AT[1] != -2) ? -2 : 0

CS = CloseShort ? -1 : 0
CL = CloseLong ? 1 : 0
CSX = CS == -1 and CS != CS[1] ? -1 : CL == 1 and CL != CL[1] ? 1 : 0

AgressiveRM = input.bool(true, "Utilize Agresive RM - Reset RM Values as long as Algo determines entry conditions are valide (Default- Conservative)")
TradeEngineX = AlertOpen == 2 ? 1 : AlertOpen == -2 ? -1 : 0
TradeEngineY = AF == 2 ? 1 : AF == -2 ? -1 : 0
TradeEngineRisk = (not AgressiveRM) ? TradeEngineY : TradeEngineX

// Risk Variables
open_  = open[1]
close_ = close[1] 
high_X = high[1] 
low_X  = low[1] 

isLong  = true
isShort = true

BarTypeRM = input.bool(true, "Use Bar Open/Close for RM Only (Defaul is High/Low)")
low_  = (BarTypeRM) ? close_ : low_X
high_ = (BarTypeRM) ? close_ : high_X

RiskOpenR   = (not AgressiveRM) ? AF : AO
RiskCloseLR = (not AgressiveRM) ? CSX : CL
RiskCloseSR = (not AgressiveRM) ? CSX : CS

openLongR   = RiskOpenR == 2
closeLongR  = RiskCloseLR == 1
openShortR  = RiskOpenR == -2
closeShortR = RiskCloseSR == -1

var int buy = 0
buy := openLongR ? nz(buy[1]) > 0 ? buy[1] + 1 : 1 : 0
var int sell = 0
sell := openShortR ? nz(sell[1]) > 0 ? sell[1] + 1 : 1 : 0

// State tracking
var bool longCloseX = false
var bool shortCloseX = false

tradeState = TradeEngineRisk

// Conditions (Using non-zero check for v6 strict typing)
longCondition  = ta.change(tradeState) != 0 and tradeState == 1
shortCondition = ta.change(tradeState) != 0 and tradeState == -1
longExitC      = CL == 1 or AlertOpen == -2 ? 1 : 0
shortExitC     = CS == -1 or AlertOpen == 2 ? 1 : 0
longExit       = ta.change(longExitC) != 0 and longExitC == 1 and tradeState == 1
shortExit      = ta.change(shortExitC) != 0 and shortExitC == 1 and tradeState == -1

var float last_open_longCondition = na
var float last_open_shortCondition = na
last_open_longCondition := longCondition ? close : nz(last_open_longCondition[1])
last_open_shortCondition := shortCondition ? close : nz(last_open_shortCondition[1])

in_longCondition  = (AT == 2)
in_shortCondition = (AT == -2)

// --- TRAILING STOP ---
isTS = input.bool(false, "Trailing Stop")
tsActivation = input.float(18.0, "Trailing Stop  Activation (%)", minval=0, step=0.1)/100
ts = input.float(6.0, 'Trailing Stop (%)', minval=0, step=0.1) / 100

LongTSActivate = low_ > last_open_longCondition + last_open_longCondition * tsActivation
ShortTSActivate = high_ < last_open_shortCondition - last_open_shortCondition * tsActivation

var float last_high = na
var float last_low = na
var float last_high_short = na
var float last_low_long = na

last_high := not in_longCondition ? na : in_longCondition and (na(last_high[1]) or high_ > nz(last_high[1])) ? high_ : nz(last_high[1])
last_high_short := not in_shortCondition ? na : in_shortCondition and (na(last_high[1]) or high_ > nz(last_high[1])) ? high_ : nz(last_high[1])
last_low := not in_shortCondition ? na : in_shortCondition and (na(last_low[1]) or low_ < nz(last_low[1])) ? low_ : nz(last_low[1])
last_low_long := not in_longCondition ? na : in_longCondition and (na(last_low[1]) or low_ < nz(last_low[1])) ? low_ : nz(last_low[1])

long_ts  = isTS and in_longCondition and not na(last_high) and LongTSActivate and low_ <= last_high - last_high * ts
short_ts = isTS and in_shortCondition and not na(last_low) and ShortTSActivate and high_ >= last_low + last_low * ts

// --- TAKE PROFIT ---
isTP = input.bool(false, "Take Profit")
tp   = input.float(12.0, 'Take Profit (%)', minval=0, step=0.1) / 100
ttp  = input.float(2.5, 'Trailing Profit (%)', minval=0, step=0.1) / 100
ttp := ttp > tp ? tp : ttp

long_tp  = isTP and in_longCondition and last_high >= last_open_longCondition + last_open_longCondition * tp and low_ <= last_high - last_high * ttp
short_tp = isTP and in_shortCondition and last_low <= last_open_shortCondition - last_open_shortCondition * tp and high_ >= last_low + last_low * ttp

// --- STAGED TAKE PROFIT ---
isSTP     = input.bool(false, "Use Staged Take Profit (Default = No")
Stp1Per   = input.float(10.0, "1st Level - Take Profit Activation Percent (%))", minval=0, step=0.1)
Stp1Trail = input.float(5.0,  "1st Level - Trailing Profit Percent (%)", minval=0, step=0.1)
Stp1Qty   = input.float(10.0, "1st Level - Close Order Quantity (%)", minval=0, step=0.1)
Stp2Per   = input.float(20.0, "2nd Level - Take Profit Activation Percent (%))", minval=0, step=0.1)
Stp2Trail = input.float(10.0, "2nd Level - Trailing Profit Percent (%)", minval=0, step=0.1)
Stp2Qty   = input.float(10.0, "2nd Level - Close Order Quantity (%)", minval=0, step=0.1)
Stp3Per   = input.float(30.0, "3rd Level - Take Profit Activation Percent (%)", minval=0, step=0.1)
Stp3Trail = input.float(5.0,  "3rd Level - Trailing Profit Percent (%)", minval=0, step=0.1)
Stp3Qty   = input.float(70.0, "3rd Level - Close Order Quantity (%)", minval=0, step=0.1)

LongTSActivate1 = last_high >= last_open_longCondition + last_open_longCondition * (Stp1Per/100)
ShortTSActivate1= last_low  <= last_open_shortCondition - last_open_shortCondition * (Stp1Per/100)
LongTSActivate2 = last_high >= last_open_longCondition + last_open_longCondition * (Stp2Per/100)
ShortTSActivate2= last_low  <= last_open_shortCondition - last_open_shortCondition * (Stp2Per/100)
LongTSActivate3 = last_high >= last_open_longCondition + last_open_longCondition * (Stp3Per/100)
ShortTSActivate3= last_low  <= last_open_shortCondition - last_open_shortCondition * (Stp3Per/100)

long_Stp1 = isSTP and in_longCondition and not na(last_high) and LongTSActivate1 and low_ <= last_high - last_high * (Stp1Trail/100)
short_Stp1 = isSTP and in_shortCondition and not na(last_low) and ShortTSActivate1 and high_ >= last_low + last_low * (Stp1Trail/100)
long_Stp2 = isSTP and in_longCondition and not na(last_high) and LongTSActivate2 and low_ <= last_high - last_high * (Stp2Trail/100)
short_Stp2 = isSTP and in_shortCondition and not na(last_low) and ShortTSActivate2 and high_ >= last_low + last_low * (Stp2Trail/100)
long_Stp3 = isSTP and in_longCondition and not na(last_high) and LongTSActivate3 and low_ <= last_high - last_high * (Stp3Trail/100)
short_Stp3 = isSTP and in_shortCondition and not na(last_low) and ShortTSActivate3 and high_ >= last_low + last_low * (Stp3Trail/100)

longSTP1 = long_Stp1 ? last_high - last_high * (Stp1Per/100) : Stp1Qty<=0 ? na : na
longSTP2 = long_Stp2 ? last_high - last_high * (Stp2Per/100) : Stp2Qty<=0 ? na : na
longSTP3 = long_Stp3 ? last_high - last_high * (Stp3Per/100) : Stp3Qty<=0 ? na : na

shortSTP1 = short_Stp1 ? last_low + last_low * (Stp1Per/100) : Stp1Qty<=0 ? na : na
shortSTP2 = short_Stp2 ? last_low + last_low * (Stp2Per/100) : Stp2Qty<=0 ? na : na
shortSTP3 = short_Stp3 ? last_low + last_low * (Stp3Per/100) : Stp3Qty<=0 ? na : na

Stp1QtyF = Stp1Qty <= 0 ? na : Stp1Qty
Stp2QtyF = Stp2Qty <= 0 ? na : Stp2Qty
Stp3QtyF = Stp3Qty <= 0 ? na : Stp3Qty

var int Counter_LTP1 = 0
Counter_LTP1 := long_Stp1 ? Counter_LTP1 + 1 : AF != 0 ? 0 : Counter_LTP1[1]
var int Counter_LTP2 = 0
Counter_LTP2 := long_Stp2 ? Counter_LTP2 + 1 : AF != 0 ? 0 : Counter_LTP2[1]
var int Counter_LTP3 = 0
Counter_LTP3 := long_Stp3 ? Counter_LTP3 + 1 : AF != 0 ? 0 : Counter_LTP3[1]
var int Counter_STP1 = 0
Counter_STP1 := short_Stp1 ? Counter_STP1 + 1 : AF != 0 ? 0 : Counter_STP1[1]
var int Counter_STP2 = 0
Counter_STP2 := short_Stp2 ? Counter_STP2 + 1 : AF != 0 ? 0 : Counter_STP2[1]
var int Counter_STP3 = 0
Counter_STP3 := short_Stp3 ? Counter_STP3 + 1 : AF != 0 ? 0 : Counter_STP3[1]

TakeProfit1Plot = long_Stp1 == true and long_Stp1 != long_Stp1[1] and Counter_LTP1 == 1 ? 1 : short_Stp1 == true and short_Stp1 != short_Stp1[1] and Counter_STP1 == 1 ? -1 : 0
TakeProfit2Plot = long_Stp2 == true and long_Stp2 != long_Stp2[1] and Counter_LTP2 == 1 ? 2 : short_Stp2 == true and short_Stp2 != short_Stp2[1] and Counter_STP2 == 1 ? -2 : 0
TakeProfit3Plot = long_Stp3 == true and long_Stp3 != long_Stp3[1] and Counter_LTP3 == 1 ? 3 : short_Stp3 == true and short_Stp3 != short_Stp3[1] and Counter_STP3 == 1 ? -3 : 0

// --- STOP LOSS ---
isSL = input.bool(false, "Stop Loss")
sl   = input.float(18.0, 'Stop Loss (%)', minval=0, step=0.1) / 100
long_sl  = isSL and in_longCondition and (low_ <= last_open_longCondition - last_open_longCondition * sl)
short_sl = isSL and in_shortCondition and (high_ >= (last_open_shortCondition + last_open_shortCondition * sl))

LongStop  = last_open_longCondition - last_open_longCondition * sl
ShortStop = last_open_shortCondition + last_open_shortCondition * sl

// --- ADVANCED ADAPTIVE TRAILING STOP (AATS) ---
lenEMA = 50  
outEMA = ta.sma(close, lenEMA)
CS_AATS = ta.ema(close, 7)

// Hirashima Sugita R/S Code
lengthHSRS = 1000  
maHSRS = ta.ema(close, lengthHSRS)
dHSRS = close - maHSRS
sHSRS = ta.linreg(dHSRS, lengthHSRS, 0)
xHSRS = maHSRS + sHSRS
d_HSRS = close - xHSRS
s_HSRS = ta.linreg(d_HSRS, lengthHSRS, 0)
basisHSRS = maHSRS + sHSRS + ta.change(s_HSRS)
upperHSRS = basisHSRS + ta.wma(math.abs(dHSRS), lengthHSRS)
lowerHSRS = basisHSRS - ta.wma(math.abs(dHSRS), lengthHSRS)
upper_HSRS = upperHSRS + ta.wma(math.abs(dHSRS), lengthHSRS)
lower_HSRS = lowerHSRS - ta.wma(math.abs(dHSRS), lengthHSRS)

HSRS_RangePenthouse = CS_AATS >= upper_HSRS ? 6 : 0
HSRS_Range4thFloor  = CS_AATS < upper_HSRS and CS_AATS >= upperHSRS ? 5 : 0
HSRS_Range3rdFloor  = CS_AATS < upperHSRS and CS_AATS >= basisHSRS ? 4 : 0
HSRS_Range2ndFloor  = CS_AATS < basisHSRS and CS_AATS >= lowerHSRS ? 3 : 0
HSRS_Range1stFloor  = CS_AATS < lowerHSRS and CS_AATS >= lower_HSRS ? 2 : 0
HSRS_RangeDungeon   = CS_AATS < lower_HSRS ? 1 : 0
HSRS_Location = HSRS_RangeDungeon + HSRS_Range1stFloor + HSRS_Range2ndFloor + HSRS_Range3rdFloor + HSRS_Range4thFloor + HSRS_RangePenthouse

srcMBB = close  
lengthMBB = 34  
multMBB = 2.0  
basisMBB = ta.sma(srcMBB, lengthMBB)
devMBB = ta.stdev(srcMBB, lengthMBB)
dev2MBB = multMBB * devMBB
dev3MBB = multMBB * 2 * devMBB
upper1MBB = basisMBB + devMBB
lower1MBB = basisMBB - devMBB

AATS_Engage3 = CS_AATS > outEMA and CS_AATS > basisHSRS and CS_AATS > upper1MBB ? 1 : CS_AATS < outEMA and CS_AATS < basisHSRS and CS_AATS < lower1MBB ? -1 : 0
AATS_Factor = AATS_Engage3 == 1 and HSRS_Location == 6 ? 0.5 : AATS_Engage3 == 1 and HSRS_Location == 5 ? 2 : AATS_Engage3 == 1 and HSRS_Location == 4 ? 3 : AATS_Engage3 == -1 and HSRS_Location == 1 ? 0.5 : AATS_Engage3 == -1 and HSRS_Location == 2 ? 2 : AATS_Engage3 == -1 and HSRS_Location == 3 ? 3 : 4

var SLMod2 = "Stop Loss Qualifiers"
UseAATS = input.bool(true, 'Use Advance Adaptive Trailing Stop (AATS) - (Default is On)', group = SLMod2)
RestrictiveAATS = input.bool(true, 'Use Restrictive AATS - Good for majors (Default is On)', group = SLMod2)
UseRSIS = input.bool(true, 'Use RSI Stop (RSIS) - (Default is On)', group = SLMod2)

atsFacInput = input.int(80, 'ATS Stop Factor (0+)', group = SLMod2)
erATS = AATS_Factor / atsFacInput  

var float aATS = 0.0
var float bATS = 0.0
aATS := math.max(close, nz(aATS[1], close)) - math.abs(close - nz(aATS[1], close)) * erATS
bATS := math.min(close, nz(bATS[1], close)) + math.abs(close - nz(bATS[1], close)) * erATS

ATSCross1 = ta.cross(aATS, close) ? 1 : 0
ATSCross2 = ta.cross(bATS, close) ? 0 : -1

var int osATS = 0
osATS := ATSCross1 == 1 ? 1 : ATSCross2 == 0 ? 0 : osATS[1]
tsATS = osATS * bATS + (1 - osATS) * aATS

ATSaX = ta.sma(close - (aATS - close), 7)
ATSbX = ta.sma(close + close - bATS, 7)

// RSI Stop Logic
// Manual function implementation for McGinley Dynamic
f_McGinleyRSIS(_src, _len) =>
    var float md = 0.0
    md := na(_src[1]) ? _src : md[1] + (_src - md[1]) / (0.6 * _len * math.pow(_src / md[1], 4))
    md

rsi_maRSIS = f_McGinleyRSIS(close, 14)
ATRRSIS = ta.atr(27)
top_lineRSIS = rsi_maRSIS + ATRRSIS
bottom_lineRSIS = rsi_maRSIS - ATRRSIS
DirectionRSIS1 = ta.crossover(close, top_lineRSIS) ? 1 : 0
DirectionRSIS2 = ta.crossunder(close, bottom_lineRSIS) ? -1 : 0
var int directionRSIS = 1
directionRSIS := DirectionRSIS1 == 1 ? 1 : DirectionRSIS2 == -1 ? -1 : directionRSIS[1]
RSIS_Signal = directionRSIS

ATS_CloseLongsX = UseRSIS and in_longCondition and AATS_Engage3 == 1  and RSIS_Signal == -1
ATS_CloseShortsX = UseRSIS and in_shortCondition and AATS_Engage3 == -1 and RSIS_Signal == 1
ATS_CloseLongsY = UseAATS and in_longCondition and AATS_Engage3 == 1   and low_ < bATS and low_ < ATSbX and low_ < ATSaX
ATS_CloseShortsY = UseAATS and in_shortCondition and AATS_Engage3 == -1 and high_ > aATS and high_ > ATSaX and high_ > ATSbX

ATS_CloseLongsAgg = ATS_CloseLongsX or ATS_CloseLongsY
ATS_CloseShortsAgg = ATS_CloseShortsX or ATS_CloseShortsY
ATS_CloseLongs = RestrictiveAATS ? ATS_CloseLongsY : ATS_CloseLongsAgg
ATS_CloseShorts = RestrictiveAATS ? ATS_CloseShortsY : ATS_CloseShortsAgg

// Final Closes
longCloseX := isLong and (long_tp or long_sl or long_ts  or ATS_CloseLongs ) and not longCondition
shortCloseX := isShort and (short_tp or short_sl or short_ts or ATS_CloseShorts ) and not shortCondition


// ==========================================
// ─── FINAL SIGNALS & EXECUTION ───
// ==========================================
RMPlot = (longCloseX or CSX == 1) ? 1 : (shortCloseX or CSX == -1) ? -1 : 0
RMSig = RMPlot == 1 and RMPlot != RMPlot[1] ? 1 : RMPlot == -1 and RMPlot != RMPlot[1] ? -1 : 0
ClearRM = (AT == 2 and RMSig == 1) ? 3 : (AT == -2 and RMSig == -1) ? -3 : 0
var float ClearRMP = na
ClearRMP := (ClearRM == 3) ? 3 : (ClearRM == -3) ? -3 : (AO == 2 or AO == -2) ? 0 : ClearRMP[1]
CloseEmAll = ClearRM == 3 and ClearRM[1] != 3 and ClearRMP[1] == 0 ? 1 :
     ClearRM == -3 and ClearRM[1] != -3 and ClearRMP[1] == 0 ? -1 : 0

// ---------------------------------------------------------
//  Re-entry events (ReOrder) from the RM engine
// ---------------------------------------------------------
ReOrder = (ClearRMP == 0 and ClearRMP[1] == 3 and ClearRMP != ClearRMP[1]) ? 4 :
     (ClearRMP == 0 and ClearRMP[1] == -3 and ClearRMP != ClearRMP[1]) ? -4 : 0

// Base entry signal from the RM engine (unfiltered)
Fin_raw = (AF == 2 or ReOrder == 4 and AT == 2) ? 2 :
     (AF == -2 or ReOrder == -4 and AT == -2) ? -2 : 0

// ---------------------------------------------------------
//  EDGE GUARD: fire entry only when tradeState flips side
//  Uses existing longCondition / shortCondition:
//    longCondition  = ta.change(tradeState) != 0 and tradeState == 1
//    shortCondition = ta.change(tradeState) != 0 and tradeState == -1
// ---------------------------------------------------------
Fin_long  = Fin_raw == 2 and longCondition
Fin_short = Fin_raw == -2 and shortCondition

Fin = Fin_long ? 2 : Fin_short ? -2 : 0


// ==========================================
// ─── STRATEGY EXECUTION ───
// ==========================================
if testPeriod() and LongAndShort == 1
    if Fin == 2
        strategy.entry('Long', strategy.long, comment='Long')
    strategy.exit('TP1 L', from_entry='Long', limit=longSTP1, qty_percent=Stp1QtyF, comment='L-TP1')
    strategy.exit('TP2 L', from_entry='Long', limit=longSTP2, qty_percent=Stp2QtyF, comment='L-TP2')
    strategy.exit('TP3 L', from_entry='Long', limit=longSTP3, qty_percent=Stp3QtyF, comment='L-TP3')
    if CSX == 1 or longCloseX
        strategy.close('Long')

    if Fin == -2
        strategy.entry('Short', strategy.short, comment='Short')
    strategy.exit('TP1 S', from_entry='Short', limit=shortSTP1, qty_percent=Stp1QtyF, comment='S-TP1')
    strategy.exit('TP2 S', from_entry='Short', limit=shortSTP2, qty_percent=Stp2QtyF, comment='S-TP2')
    strategy.exit('TP3 S', from_entry='Short', limit=shortSTP3, qty_percent=Stp3QtyF, comment='S-TP3')
    if CSX == -1 or shortCloseX
        strategy.close('Short')
     
if testPeriod() and LongAndShort == 2
    if Fin == 2
        strategy.entry('Long', strategy.long, comment='Long')
    strategy.exit('TP1 L', from_entry='Long', limit=longSTP1, qty_percent=Stp1QtyF, comment='L-TP1')
    strategy.exit('TP2 L', from_entry='Long', limit=longSTP2, qty_percent=Stp2QtyF, comment='L-TP2')
    strategy.exit('TP3 L', from_entry='Long', limit=longSTP3, qty_percent=Stp3QtyF, comment='L-TP3')
    if CSX == 1 or longCloseX or Fin == -2
        strategy.close('Long')

if testPeriod() and LongAndShort == 3
    if Fin == -2
        strategy.entry('Short', strategy.short, comment='Short')
    strategy.exit('TP1 S', from_entry='Short', limit=shortSTP1, qty_percent=Stp1QtyF, comment='S-TP1')
    strategy.exit('TP2 S', from_entry='Short', limit=shortSTP2, qty_percent=Stp2QtyF, comment='S-TP2')
    strategy.exit('TP3 S', from_entry='Short', limit=shortSTP3, qty_percent=Stp3QtyF, comment='S-TP3')
    if CSX == -1 or shortCloseX or Fin == 2
        strategy.close('Short')


// ==========================================
// ─── ALERT VISUALIZERS (INDICATOR MODE) ───
// ==========================================

//Buy and Sell Signals - Fin==2 Long, Fin==-2 Short
//plot(Fin, title="Order Open",linewidth=3,color=color.blue)

//RM Close Alerts = Close Long = 1, Close Short =-1
//plot(CloseEmAll, title="RM Close", linewidth=3,color=color.yellow)

//Take Profit Plot 1,2, 3 for Long TP1, 2, 3, and -1 -2 -3 for shorts
//plot(TakeProfitStopsPlot, title="TP Close", linewidth=3,color=color.orange)
//plot(isSTP==true ? TakeProfit1Plot : na, title="TP-1 Close", linewidth=3,color=color.lime)
//plot(isSTP==true ? TakeProfit2Plot : na, title="TP-2 Close", linewidth=3,color=color.olive)
//plot(isSTP==true ? TakeProfit3Plot : na, title="TP-3 Close", linewidth=3,color=color.green)

// --- ALERT CONDITIONS (For Automation) ---
//alertcondition(Fin == 2, title="Long Entry", message="Long Entry Triggered")
//alertcondition(Fin == -2, title="Short Entry", message="Short Entry Triggered")
//alertcondition(CloseEmAll == 1, title="Close Long", message="Close Long Triggered")
//alertcondition(CloseEmAll == -1, title="Close Short", message="Close Short Triggered")
//alertcondition(TakeProfit1Plot != 0, title="TP 1 Hit", message="TP 1 Level Reached")
//alertcondition(TakeProfit2Plot != 0, title="TP 2 Hit", message="TP 2 Level Reached")
//alertcondition(TakeProfit3Plot != 0, title="TP 3 Hit", message="TP 3 Level Reached")


// ==========================================
// ─── RESET VARIABLES ───
// ==========================================
if longCloseX or not in_longCondition
    last_high := na
    last_high_short := na

if shortCloseX or not in_shortCondition
    last_low := na
    last_low_long := na

if longCloseX or shortCloseX
    tradeState := 0
    in_longCondition := false
    in_shortCondition := false

