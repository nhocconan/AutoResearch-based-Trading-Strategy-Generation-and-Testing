//@version=5
strategy("200DMA - Trade based on SMA once every Month - ajh", overlay =true,default_qty_type=strategy.percent_of_equity, default_qty_value=100, initial_capital = 10000)

// Use 100% of  equity always
ma_long = input.int(defval=200, title="SMA (Chart Period) default: 200 days", minval=1, maxval=600)
ma_short = input.int(defval=50, title="SMA shorter eg; 50", minval=1, maxval=600)
offset_days = input.int(defval=0, title="Add some offset days from first trading day of month (0-31)", minval=0, maxval=31)

// backtesting date range
from_day = input.int(defval=3, title="From Day", minval=1, maxval=31)
from_month = input.int(defval=1, title="From Month", minval=1, maxval=12)
from_year = input.int(defval=2000, title="From Year", minval=1900)
to_day = input.int(defval=28, title="To Day", minval=1, maxval=31)
to_month = input.int(defval=6, title="To Month", minval=1, maxval=12)
to_year = input.int(defval=2060, title="To Year", minval=1900)

dateStart = timestamp(syminfo.timezone, from_year, from_month, from_day, 0, 0) // 2000-01-03
dateEnd = timestamp(syminfo.timezone, to_year, to_month, to_day, 0, 0) //2021-06-28

inDateRange = time >= dateStart and time <= dateEnd

// 200 day ma 
dma200 = ta.sma(close, ma_long)
plot(dma200, color=color.red, linewidth = 2)
dma50 = ta.sma(close, ma_short)
plot(dma50, color=color.yellow, linewidth = 1)

// Set trade entry conditions -
enterLong  = close > dma200
enterSale = close < dma200

// Detect the first trading day of a new month
isFirstTradingDayOfMonth = ta.change(time('1M'))[offset_days] !=0 
bgcolor(isFirstTradingDayOfMonth and inDateRange ? color.new(color.green, 80) : na) // colour the FirstTradingDay of Month

xLong = isFirstTradingDayOfMonth and inDateRange and enterLong
xSell = isFirstTradingDayOfMonth and inDateRange and enterSale

plotchar(xLong, "long","L", color=color.green, location=location.abovebar, size=size.tiny)   
plotchar(xSell, "Sell","S", color=color.red, location = location.abovebar, size = size.tiny)   

if xLong
    strategy.entry("long", strategy.long)
if xSell
    strategy.close("long")
// Exit open market position when date range ends
if (not inDateRange)
    strategy.close_all()

