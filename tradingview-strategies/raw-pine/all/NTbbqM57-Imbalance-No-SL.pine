//@version=6
strategy("Imbalance No SL", overlay=true, max_boxes_count=500, max_labels_count=500, pyramiding=1)

var box[] imbalanceBoxes = array.new_box()
var label[] imbalanceLabels = array.new<label>()
qty = input.int(1, "Lot Size (Qty Per Signal)", minval=1)
var float buy_avg = na
var int   buy_count = 0
var float sell_avg = na
var int   sell_count = 0
is_imb_bull = low > high[1]
is_imb_bear = high < low[1]
if is_imb_bull
    newbox = box.new(left=bar_index[1], right=bar_index, top=high, bottom=low[1], bgcolor=color.new(color.green, 80), border_color=color.lime)
    array.unshift(imbalanceBoxes, newbox)
    newlabel = label.new(bar_index, low, "IMB BULL", color=color.lime, textcolor=color.black, style=label.style_label_up, yloc=yloc.belowbar)
    array.unshift(imbalanceLabels, newlabel)
    if strategy.position_size >= 0
        strategy.entry("IMB BUY", strategy.long, qty=qty)
        buy_avg := na(buy_avg) ? close : (buy_avg * buy_count + close) / (buy_count + 1)
        buy_count += 1
        sell_avg := na
        sell_count := 0
if is_imb_bear
    newbox = box.new(left=bar_index[1], right=bar_index, top=high[1], bottom=low, bgcolor=color.new(color.red, 85), border_color=color.red)
    array.unshift(imbalanceBoxes, newbox)
    newlabel = label.new(bar_index, high, "IMB BEAR", color=color.red, textcolor=color.white, style=label.style_label_down, yloc=yloc.abovebar)
    array.unshift(imbalanceLabels, newlabel)
    if strategy.position_size <= 0
        strategy.entry("IMB SELL", strategy.short, qty=qty)
        sell_avg := na(sell_avg) ? close : (sell_avg * sell_count + close) / (sell_count + 1)
        sell_count += 1
        buy_avg := na
        buy_count := 0
if is_imb_bear and strategy.position_size > 0 and close > buy_avg
    strategy.close("IMB BUY", comment="Opposite Signal + Profit")
    buy_avg := na
    buy_count := 0
if is_imb_bull and strategy.position_size < 0 and close < sell_avg
    strategy.close("IMB SELL", comment="Opposite Signal + Profit")
    sell_avg := na
    sell_count := 0
while array.size(imbalanceLabels) > 1
    label.delete(array.pop(imbalanceLabels))
while array.size(imbalanceBoxes) > 1
    box.delete(array.pop(imbalanceBoxes))
alertcondition(is_imb_bull, title="Buy Alert", message="Buy Signal: {{close}}")
alertcondition(is_imb_bear, title="Sell Alert", message="Sell Signal: {{close}}")

