//@version=5
strategy("Bank Nifty 500 Round – SAFE Expectancy Version",
     overlay=true,
     initial_capital=100000,
     pyramiding=0,
     calc_on_every_tick=false)

// ================= INPUTS =================
step        = 500
offset      = 50
slPts       = 80
tgt1        = 60
tgt2        = 160
beTrigger   = 90
emaLen      = 50

// ================= EMA =================
ema = ta.ema(close, emaLen)
plot(ema, "EMA 50", color=color.orange)

// ================= TIME FILTER (IST) =================
startTime = timestamp("Asia/Kolkata", year, month, dayofmonth, 9, 30)
endTime   = timestamp("Asia/Kolkata", year, month, dayofmonth, 15, 10)
inSession = time >= startTime and time <= endTime
sessionEnd = time >= endTime

// ================= ROUND LEVELS =================
roundBase  = math.floor(close / step) * step
upperLevel = roundBase + offset
lowerLevel = roundBase - offset

plot(roundBase, "500 Round", color=color.gray)
plot(upperLevel, "+50", color=color.red)
plot(lowerLevel, "-50", color=color.green)

// ================= MARKET FILTER =================
flatMarket = math.abs(close - ema) < 300

// ================= ENTRY CONDITIONS =================
longCond  = inSession and flatMarket and low <= lowerLevel and close > lowerLevel
shortCond = inSession and flatMarket and high >= upperLevel and close < upperLevel

// ================= ENTRIES =================
if longCond and strategy.position_size == 0
    strategy.entry("LONG", strategy.long)

if shortCond and strategy.position_size == 0
    strategy.entry("SHORT", strategy.short)

// ================= LONG EXIT LOGIC =================
if strategy.position_size > 0
    entry     = strategy.position_avg_price
    hardStop = entry - slPts
    beStop   = high >= entry + beTrigger ? entry : hardStop

    // Partial exit
    strategy.exit("L_TGT1", "LONG", limit=entry + tgt1, qty_percent=50)

    // Runner with HARD stop always active
    strategy.exit("L_RUN", "LONG", limit=entry + tgt2, stop=beStop)

    // Forced session close
    if sessionEnd
        strategy.close("LONG")

// ================= SHORT EXIT LOGIC =================
if strategy.position_size < 0
    entry     = strategy.position_avg_price
    hardStop = entry + slPts
    beStop   = low <= entry - beTrigger ? entry : hardStop

    // Partial exit
    strategy.exit("S_TGT1", "SHORT", limit=entry - tgt1, qty_percent=50)

    // Runner with HARD stop always active
    strategy.exit("S_RUN", "SHORT", limit=entry - tgt2, stop=beStop)

    // Forced session close
    if sessionEnd
        strategy.close("SHORT")

