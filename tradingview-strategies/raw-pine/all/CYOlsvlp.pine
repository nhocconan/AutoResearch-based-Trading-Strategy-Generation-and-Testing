//@version=6
strategy(
     title="Gold Magnet Reversal: Hunt Profitable Trades on XAUUSD with Daily Candle Power!",
     shorttitle="GMR",
     overlay=true,
     calc_on_every_tick=true,
     process_orders_on_close=true   // ← TRUE = entra nella STESSA candela del segnale (alla chiusura)
)

// === Backtest Options ===
GRP_BACKTEST = "Backtest Options"
enable_backtest = input.bool(false, "Enable Backtest", group=GRP_BACKTEST)
tp_points = input.float(100.0, "TP Points", minval=0.0, group=GRP_BACKTEST)
sl_points = input.float(100.0, "SL Points", minval=0.0, group=GRP_BACKTEST)
lookback_days = input.int(60, "Lookback Days", minval=1, group=GRP_BACKTEST)

// === Time Ranges Section ===
GRP_RANGE = "Time Ranges"
timeZoneOffset = input.int(0, title="Time Zone Offset (hours from UTC)", minval=-12, maxval=12, group=GRP_RANGE)
sessionTimeZone = "UTC" + (timeZoneOffset == 0 ? "" : (timeZoneOffset > 0 ? "+" : "") + str.tostring(timeZoneOffset))
enableRange1 = input.bool(true, "Enable Observation Range", group=GRP_RANGE)
range1Start = input.session("0000-2230", "Observation Range (HHMM-HHMM)", group=GRP_RANGE)
range1Color = input.color(color.new(color.blue, 90), "Observation Range Background Color", group=GRP_RANGE)
enableRange2 = input.bool(true, "Enable Signal Range", group=GRP_RANGE)
range2Start = input.session("1630-1700", "Signal Range (HHMM-HHMM)", group=GRP_RANGE)
range2Color = input.color(color.new(color.orange, 90), "Signal Range Background Color", group=GRP_RANGE)

// === Range Detection
inRange1 = not na(time(timeframe.period, range1Start, sessionTimeZone))
firstInRange1 = enableRange1 and inRange1 and not inRange1[1]
endOfRange1 = enableRange1 and not inRange1 and inRange1[1]

inRange2 = not na(time(timeframe.period, range2Start, sessionTimeZone))
firstInRange2 = enableRange2 and inRange2 and not inRange2[1]

// === Background Colors
bgcolor(enableRange1 and inRange1 ? range1Color : na)
bgcolor(enableRange2 and inRange2 ? range2Color : na)

// === DAILY RANGE MEMORY ===
var float curr_start = na
var float curr_end = na
var bool prev_bullish = false
var bool prev_bearish = false

new_day = timeframe.change("D")

if new_day
    if not na(curr_start) and not na(curr_end)
        prev_bullish := curr_end > curr_start
        prev_bearish := curr_end < curr_start
    curr_start := na
    curr_end := na

if firstInRange1
    curr_start := open
if endOfRange1
    curr_end := close

// === SEGNALI ===
buySignal = false
sellSignal = false

if firstInRange2
    if prev_bullish
        sellSignal := true
    else if prev_bearish
        buySignal := true

plotshape(buySignal, title="Buy Signal", style=shape.labelup, location=location.belowbar, color=color.new(color.green, 0), text="BUY", textcolor=color.white, size=size.small)
plotshape(sellSignal, title="Sell Signal", style=shape.labeldown, location=location.abovebar, color=color.new(color.red, 0), text="SELL", textcolor=color.white, size=size.small)

alertcondition(buySignal, title="Range Reversal Buy", message="Range Reversal - BUY in signal range")
alertcondition(sellSignal, title="Range Reversal Sell", message="Range Reversal - SELL in signal range")

// === BACKTEST (stessa candela del segnale) ===
if enable_backtest
    if buySignal
        if strategy.position_size < 0
            strategy.close("Short Close", comment="Reversal")
        strategy.entry("Long Entry", strategy.long)
        strategy.exit("Long Exit", from_entry="Long Entry", profit=tp_points, loss=sl_points, comment_profit="TP", comment_loss="SL")
    if sellSignal
        if strategy.position_size > 0
            strategy.close("Long Close", comment="Reversal")
        strategy.entry("Short Entry", strategy.short)
        strategy.exit("Short Exit", from_entry="Short Entry", profit=tp_points, loss=sl_points, comment_profit="TP", comment_loss="SL")

// === TABELLA RISULTATI (invariata) ===
var table results_table = table.new(position.top_right, columns=2, rows=3, bgcolor=color.new(color.white, 0), border_width=1, frame_color=color.gray, frame_width=1)

if barstate.islastconfirmedhistory and enable_backtest
    int tp_count = 0
    int sl_count = 0
    int lookback_time = timenow - lookback_days * 86400000
    for i = 0 to strategy.closedtrades - 1
        if strategy.closedtrades.exit_time(i) >= lookback_time
            string exit_comment = strategy.closedtrades.exit_comment(i)
            if exit_comment == "TP"
                tp_count += 1
            else if exit_comment == "SL"
                sl_count += 1
    int total_trades = tp_count + sl_count
    float win_rate = total_trades > 0 ? (tp_count * 100.0 / total_trades) : 0.0
    
    table.cell(results_table, 0, 0, "TP Hits (last " + str.tostring(lookback_days) + " days)", text_color=color.black, text_size=size.small)
    table.cell(results_table, 1, 0, str.tostring(tp_count), text_color=color.green)
    table.cell(results_table, 0, 1, "SL Hits (last " + str.tostring(lookback_days) + " days)", text_color=color.black, text_size=size.small)
    table.cell(results_table, 1, 1, str.tostring(sl_count), text_color=color.red)
    table.cell(results_table, 0, 2, "Win Rate", text_color=color.black, text_size=size.small)
    table.cell(results_table, 1, 2, str.tostring(win_rate, "#.##") + "%", text_color = win_rate >= 50 ? color.green : color.red)

