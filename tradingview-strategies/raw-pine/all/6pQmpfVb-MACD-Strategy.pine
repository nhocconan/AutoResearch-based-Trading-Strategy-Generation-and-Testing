//@version=6
strategy('MACD Strategy', overlay = true, margin_long = 100, margin_short = 100)

// --- Input Parameters ---
account_balance = input.float(10000, 'Account Balance', minval = 1000, tooltip = 'Initial account balance for position sizing.')
macd_fast = input.int(12, 'MACD Fast Length', minval = 1, tooltip = 'Fast length for MACD.')
macd_slow = input.int(26, 'MACD Slow Length', minval = 1, tooltip = 'Slow length for MACD.')
macd_signal = input.int(9, 'MACD Signal Length', minval = 1, tooltip = 'Signal smoothing for MACD.')
risk_percent = input.float(3.0, 'Risk Per Trade (%)', minval = 0.1, step = 0.1, tooltip = 'Percentage of balance risked per trade.')
rr_ratio = input.float(3.0, 'Risk:Reward Ratio', minval = 1.0, step = 0.1, tooltip = 'Ratio of potential reward to risk.')
sl_multiplier = input.float(1.0, 'SL Multiplier', minval = 0.1, step = 0.1, tooltip = 'Multiplier for stop loss distance based on ATR.')
tp_multiplier = input.float(3.0, 'TP Multiplier', minval = 0.1, step = 0.1, tooltip = 'Multiplier for take profit distance based on ATR.')
line_length = input.int(25, 'Line Length (bars)', minval = 5, step = 5, tooltip = 'Duration for TP, SL, and entry lines.')
label_position = input.string('left', 'Label Position', options = ['left', 'right'], tooltip = 'Position of labels.')
atr_period = input.int(14, 'ATR Period', minval = 1, tooltip = 'ATR period for volatility measure.')

// --- MACD Calculation ---
[macdLine, signalLine, hist] = ta.macd(close, macd_fast, macd_slow, macd_signal)
macd_hist = macdLine - signalLine

// --- Signals ---
sellSignal = ta.crossunder(macdLine, signalLine) and macd_hist < 0
buySignal = ta.crossover(macdLine, signalLine) and macd_hist > 0

// --- Risk Management ---
float risk_amount = account_balance * (risk_percent / 100)
float stop_distance = ta.atr(atr_period)
float position_size = math.floor(risk_amount / stop_distance)

// --- Entry Logic ---
var float sell_stop_price = na
var float sell_take_profit = na
var float buy_stop_price = na
var float buy_take_profit = na

if sellSignal
    strategy.entry('Sell', strategy.short, qty = position_size)
    sell_stop_price := close + stop_distance * sl_multiplier
    sell_take_profit := close - stop_distance * tp_multiplier * rr_ratio
    strategy.exit('Sell Exit', 'Sell', stop = sell_stop_price, limit = sell_take_profit)
    line.new(bar_index, sell_stop_price, bar_index + line_length, sell_stop_price, color = color.red, style = line.style_solid)
    label.new(bar_index + (label_position == 'left' ? -1 : line_length + 1), sell_stop_price, text = 'SL: ' + str.tostring(sell_stop_price, '#.##'), color = color.red, textcolor = color.white, style = label_position == 'left' ? label.style_label_right : label.style_label_left, size = size.small)
    line.new(bar_index, sell_take_profit, bar_index + line_length, sell_take_profit, color = color.green, style = line.style_solid)
    label.new(bar_index + (label_position == 'left' ? -1 : line_length + 1), sell_take_profit, text = 'TP: ' + str.tostring(sell_take_profit, '#.##'), color = color.green, textcolor = color.white, style = label_position == 'left' ? label.style_label_right : label.style_label_left, size = size.small)
    line.new(bar_index, close, bar_index + line_length, close, color = color.red, style = line.style_solid)
    label.new(bar_index + (label_position == 'left' ? -1 : line_length + 1), close, text = 'Sell', color = color.red, textcolor = color.white, style = label_position == 'left' ? label.style_label_right : label.style_label_left, size = size.small)

if buySignal
    strategy.entry('Buy', strategy.long, qty = position_size)
    buy_stop_price := close - stop_distance * sl_multiplier
    buy_take_profit := close + stop_distance * tp_multiplier * rr_ratio
    strategy.exit('Buy Exit', 'Buy', stop = buy_stop_price, limit = buy_take_profit)
    line.new(bar_index, buy_stop_price, bar_index + line_length, buy_stop_price, color = color.red, style = line.style_solid)
    label.new(bar_index + (label_position == 'left' ? -1 : line_length + 1), buy_stop_price, text = 'SL: ' + str.tostring(buy_stop_price, '#.##'), color = color.red, textcolor = color.white, style = label_position == 'left' ? label.style_label_right : label.style_label_left, size = size.small)
    line.new(bar_index, buy_take_profit, bar_index + line_length, buy_take_profit, color = color.green, style = line.style_solid)
    label.new(bar_index + (label_position == 'left' ? -1 : line_length + 1), buy_take_profit, text = 'TP: ' + str.tostring(buy_take_profit, '#.##'), color = color.green, textcolor = color.white, style = label_position == 'left' ? label.style_label_right : label.style_label_left, size = size.small)
    line.new(bar_index, close, bar_index + line_length, close, color = color.green, style = line.style_solid)
    label.new(bar_index + (label_position == 'left' ? -1 : line_length + 1), close, text = 'Buy', color = color.green, textcolor = color.white, style = label_position == 'left' ? label.style_label_right : label.style_label_left, size = size.small)

// --- Alert Conditions for Bitget Webhook ---
alertcondition(sellSignal, title = 'Sell Signal', message = '{"action":"{{strategy.order.action}}","contracts":"{{strategy.order.contracts}}","marketPosition":"{{strategy.market_position}}","positionSize":"{{strategy.position_size}}","prevMarketPosition":"{{strategy.prev_market_position}}","price":"{{close}}","symbol":"{{ticker}}","time":"{{timenow}}"}')
alertcondition(buySignal, title = 'Buy Signal', message = '{"action":"{{strategy.order.action}}","contracts":"{{strategy.order.contracts}}","marketPosition":"{{strategy.market_position}}","positionSize":"{{strategy.position_size}}","prevMarketPosition":"{{strategy.prev_market_position}}","price":"{{close}}","symbol":"{{ticker}}","time":"{{timenow}}"}')

