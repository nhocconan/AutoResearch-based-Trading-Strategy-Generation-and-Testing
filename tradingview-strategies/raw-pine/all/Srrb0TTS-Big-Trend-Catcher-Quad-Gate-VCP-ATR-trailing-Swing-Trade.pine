//@version=5
strategy("Big Trend Catcher: Quad-Gate & VCP & ATR trailing & Phoenix swing trade", 
     overlay=true, 
     initial_capital=100000, 
     default_qty_type=strategy.percent_of_equity, 
     default_qty_value=50,
     pyramiding=2,         
     process_orders_on_close=true)

// =============================
// INDICATORS & VOLATILITY (VCP)
// =============================
ema20  = ta.ema(close, 20)
ema100 = ta.ema(close, 100)
atrVal = ta.atr(20)
volGate = volume > ta.sma(volume, 20) * 1.3

[bbUpper, bbMid, bbLower] = ta.bb(close, 20, 2)
bbWidth = (bbUpper - bbLower) / bbMid
isQuietZone = bbWidth < ta.sma(bbWidth, 50)

// === NEW: 3 Std Dev Bands from 100 EMA ===
// We calculate standard deviation based on price over 100 periods
dev100 = ta.stdev(close, 100)
ema100Upper = ema100 + (dev100 * 3)
ema100Lower = ema100 - (dev100 * 3)

// =============================
// REGIME FILTERS (100 EMA SLOPE)
// =============================
ema100Slope = ema100 - ema100[3]
regimeIsUp  = ema100Slope >= 0

// =============================
// ROC MOMENTUM FILTER
// =============================
rocLen    = 15
smoothLen = 10
rocRaw    = 100.0 * (close / nz(close[rocLen]) - 1.0)
roc       = ta.ema(rocRaw, smoothLen) 
rocIsPositive = roc >= 0

// =============================
// FIXED EXIT LOGIC (Matches Standalone Indicator)
// =============================
atrPeriod = 20
hhvPeriod = 20
atrMult   = 3.0

highest_val = ta.highest(high - atrMult * ta.atr(atrPeriod), hhvPeriod)

var float TS = na

if na(TS)
    TS := highest_val
else
    TS := (close > TS[1] and close > close[1]) ? highest_val : TS[1]

if close < TS
    TS := highest_val

aboveATR   = close > TS
trendDeath = close < TS or ta.crossunder(close, ema100)

// =============================
// THE PHOENIX WINDOW
// =============================
barsSinceExit = ta.barssince(trendDeath)
isPhoenixWindow = barsSinceExit < 10

// =============================
// SIGNAL LOGIC
// =============================
initialSignal = (ta.crossover(close, ema20) or (close > high[1] and close > ema20)) and volGate and isQuietZone
phoenixSignal = (ta.crossover(close, ema20) or (close > high[1] and close > ema20)) and volGate and isPhoenixWindow

var bool signalPending = false
if initialSignal or phoenixSignal
    signalPending := true

if ta.crossunder(close, ema20) or ta.barssince(initialSignal or phoenixSignal) > 10
    signalPending := false

// =============================
// ENTRY EXECUTION
// =============================
confirmedEntry = signalPending and close > ema100 and close > ema20 and rocIsPositive and regimeIsUp and aboveATR and strategy.position_size == 0

if confirmedEntry
    strategy.entry("Wizard", strategy.long, comment=isPhoenixWindow ? "Phoenix" : "Initial")
    signalPending := false 

// =============================
// PROGRESSIVE PYRAMIDING
// =============================
avgPrice = strategy.position_avg_price
distFromEntry = (close - avgPrice) / avgPrice * 100

runawayScale  = strategy.position_size > 0 and distFromEntry > 10 and close > ema100 and close > ema20 and regimeIsUp and aboveATR and strategy.opentrades < 3
pullbackScale = ta.crossunder(low, ema20) and close > ema20 and close > ema100 and regimeIsUp and aboveATR and strategy.position_size > 0

if (runawayScale or pullbackScale)
    strategy.entry("Wizard", strategy.long, comment=runawayScale ? "Velocity" : "Pullback")

if trendDeath
    strategy.close_all(comment="Trend Death")

// =============================
// VISUALS
// =============================
plot(ema20, "20 EMA", color=color.yellow)
plot(ema100, "100 EMA", color=regimeIsUp ? color.blue : color.gray, linewidth=2)

// Plotting the 3 Std Dev Bands
plot(ema100Upper, "EMA 100 Upper Band (3SD)", color=color.new(color.gray, 50), linewidth=1)
plot(ema100Lower, "EMA 100 Lower Band (3SD)", color=color.new(color.gray, 50), linewidth=1)

tsColor = close > TS ? color.green : color.red
plot(TS, "ATR Stop", color=tsColor, style=plot.style_stepline, linewidth=1)

bgcolor(isQuietZone ? color.new(color.blue, 95) : na)

plotshape(signalPending and (not rocIsPositive or not regimeIsUp or not aboveATR), "Gate Wait", shape.cross, location.abovebar, color=color.orange, size=size.tiny)
plotshape(confirmedEntry, "Entry", shape.triangleup, location.belowbar, color=isPhoenixWindow ? color.orange : color.lime, size=size.tiny)

