//@version=2
strategy ("My5min")

a = sma(close, 200)
b = sma(close, 10)

long = cross(a, b) and a < b
short = cross(a, b) and a > b

strategy.entry("long", strategy.long, when=long)
strategy.entry("short", strategy.short, when=short)

View in Pine Editor・11 lines
Use on chart
