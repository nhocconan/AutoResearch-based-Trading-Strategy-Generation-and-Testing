//@version=5
strategy("EMA PB Strat", 
     overlay=true, 
     process_orders_on_close=true, 
     calc_on_every_tick=true)

// ===== Inputs =====
emaLength    = input.int(20, "EMA Length")
pullbackPct  = input.float(2.0, "Pullback % (Above EMA)", step=0.1)
exitPct      = input.float(2.0, "Exit % Below EMA", step=0.1)
sessionET    = input.session("0930-1300", "Trading Session (ET)")
cooldownMins = input.int(30, "Cooldown After Win (minutes)")
macdFast     = input.int(12, "MACD Fast Length")
macdSlow     = input.int(26, "MACD Slow Length")
macdSignal   = input.int(9, "MACD Signal Length")
macdTF       = input.string("1", "MACD Timeframe")   // always pull from 1-min

// ===== EMA =====
ema20 = ta.ema(close, emaLength)

// ===== Session Filter =====
inTradingHours = not na(time(timeframe.period, sessionET))

// ===== Entry/Exit Conditions =====
withinPullback = high > ema20 and low <= ema20 * (1 + pullbackPct/100)   // touch EMA zone
exitCondition  = low < ema20 * (1 - exitPct/100)                         // under EMA by exitPct

// ===== Cooldown Logic (bar-based) =====
var int cooldownBars = na         
var int cooldownUntilBar = na     

cooldownBars := math.ceil(cooldownMins / timeframe.multiplier)

// ===== MACD on 1-minute timeframe =====
[macdLine, signalLine, _] = request.security(syminfo.tickerid, macdTF, ta.macd(close, macdFast, macdSlow, macdSignal))
macdDiff = macdLine - signalLine

macdOk = macdDiff >= -0.008

// ===== Closed Trades Check =====
if strategy.closedtrades > 0 and strategy.closedtrades != strategy.closedtrades[1]
    lastProfit = strategy.closedtrades.profit(strategy.closedtrades - 1)
    lastEntry  = strategy.closedtrades.entry_price(strategy.closedtrades - 1)
    lastReturnPct = lastProfit / lastEntry * 100
    
    if lastReturnPct > 2
        cooldownUntilBar := bar_index + cooldownBars   // block future entries for N bars

// ===== Cooldown =====
inCooldown = not na(cooldownUntilBar) and bar_index < cooldownUntilBar

// ===== Orders =====
if withinPullback and strategy.position_size == 0 and inTradingHours and not inCooldown and macdOk
    strategy.entry("Long", strategy.long)

if strategy.position_size > 0 and (exitCondition or not inTradingHours)
    strategy.close("Long")

// ===== Plots =====
plot(ema20, color=color.orange, title="20 EMA")
plot(ema20 * (1 + pullbackPct/100), color=color.green, title="+Pullback %")
plot(ema20 * (1 - exitPct/100),   color=color.red,   title="-Exit %")
bgcolor(inCooldown ? color.new(color.red, 85) : na, title="Cooldown Active")

plot(macdDiff, title="1m MACD Diff", color=color.blue)
hline(-0.008, "MACD Threshold", color=color.red)

