//@version=5
strategy("BTC BRD – Bullet-Proof Reversal Strategy", overlay=true, max_labels_count=500)

// ——— USER INPUTS ———
rr      = input.float(2, title="Risk-Reward Ratio", minval=0.5)
sl_type = input.string("ATR", title="Stop Loss Type", options=["ATR", "Percent"])
atr_mult= input.float(1.5, title="ATR Multiplier", minval=0.5)
sl_pct  = input.float(2, title="Stop Loss Percent", minval=0.5)
atr_len = input.int(14, title="ATR Length")

len = 4

pivotLow  = low[len] == ta.lowest(low, len * 2 + 1)
pivotHigh = high[len] == ta.highest(high, len * 2 + 1)

var float lastLow  = na
var float lastHigh = na

if pivotLow
    lastLow := low[len]

if pivotHigh
    lastHigh := high[len]

// ——— Market Structure Shift ———
bullHL = pivotLow and lastLow < nz(lastLow[1])
bullBOS = close > nz(lastHigh[1])
finalLong = bullHL and bullBOS

bearLH = pivotHigh and lastHigh > nz(lastHigh[1])
bearBOS = close < nz(lastLow[1])
finalShort = bearLH and bearBOS

plotshape(finalLong, title="Bull Reversal", style=shape.triangleup,
     color=color.new(color.green, 0), location=location.belowbar, size=size.large)
plotshape(finalShort, title="Bear Reversal", style=shape.triangledown,
     color=color.new(color.red, 0), location=location.abovebar, size=size.large)

// ——— ATR and Stop Loss / Take Profit Calculation ———
atr_val = ta.atr(atr_len)

long_sl = sl_type == "ATR" ? close - atr_val * atr_mult : close * (1 - sl_pct / 100)
long_tp = close + (close - long_sl) * rr

short_sl = sl_type == "ATR" ? close + atr_val * atr_mult : close * (1 + sl_pct / 100)
short_tp = close - (short_sl - close) * rr

// ——— Entries and Exits ———
if finalLong
    strategy.entry("Long", strategy.long)
    strategy.exit("Long Exit", from_entry="Long", stop=long_sl, limit=long_tp)

if finalShort
    strategy.entry("Short", strategy.short)
    strategy.exit("Short Exit", from_entry="Short", stop=short_sl, limit=short_tp)

