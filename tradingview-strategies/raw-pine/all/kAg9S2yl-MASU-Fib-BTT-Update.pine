        table.cell(tb, 1, 6, "61.8", text_color=color.new(c_fib_618,0), bgcolor=bg, text_size=sz, text_halign=text.align_center)
        table.cell(tb, 2, 6, not na(f618)?str.tostring(f618, format.mintick):"—", text_color=tx, bgcolor=bg, text_size=sz, text_halign=text.align_right)
        table.cell(tb, 0, 7, "Vol", text_color=dm, bgcolor=bg, text_size=sz, text_halign=text.align_left)
        table.cell(tb, 1, 7, str.tostring(math.round(atr_percentile,0))+"%", text_color=high_volatility?am:low_volatility?bl:dm, bgcolor=bg, text_size=sz, text_halign=text.align_center)
        table.cell(tb, 2, 7, volume_pressure=="BUYING"?"Buy":volume_pressure=="SELLING"?"Sell":"—", text_color=volume_buy_pct>60?gn:volume_buy_pct<40?rd:dm, bgcolor=bg, text_size=sz, text_halign=text.align_right)
        table.cell(tb, 0, 8, "S", text_color=gn, bgcolor=bg, text_size=sz, text_halign=text.align_left)
        table.cell(tb, 1, 8, str.tostring(dynamic_support, format.mintick), text_color=gn, bgcolor=bg, text_size=sz, text_halign=text.align_center)
        table.cell(tb, 2, 8, str.tostring(dynamic_resistance, format.mintick), text_color=rd, bgcolor=bg, text_size=sz, text_halign=text.align_right)
        table.cell(tb, 0, 9, "SL", text_color=rd, bgcolor=bg, text_size=sz, text_halign=text.align_left)
        table.cell(tb, 1, 9, str.tostring(universal_sl_display, format.mintick), text_color=rd, bgcolor=bg, text_size=sz, text_halign=text.align_center)
        table.cell(tb, 2, 9, str.tostring(universal_tp_display, format.mintick), text_color=gn, bgcolor=bg, text_size=sz, text_halign=text.align_right)
        table.cell(tb, 0, 10, "R:R", text_color=dm, bgcolor=bg, text_size=sz, text_halign=text.align_left)
        table.cell(tb, 1, 10, "1:"+str.tostring(math.round(rr_ratio,1)), text_color=rr_ratio>=2?gn:rr_ratio>=1.5?am:rd, bgcolor=bg, text_size=sz, text_halign=text.align_center)
        table.cell(tb, 2, 10, str.tostring(math.round(kelly_percentage*100,1))+"%K", text_color=dm, bgcolor=bg, text_size=sz, text_halign=text.align_right)
        table.cell(tb, 0, 11, "Score", text_color=dm, bgcolor=bg, text_size=sz, text_halign=text.align_left)
        table.cell(tb, 1, 11, str.tostring(confluence_score)+"/5", text_color=confluence_score>=4?gn:confluence_score>=3?am:rd, bgcolor=bg, text_size=sz, text_halign=text.align_center)
        table.cell(tb, 2, 11, current_session, text_color=bl, bgcolor=bg, text_size=sz, text_halign=text.align_right)
        table.cell(tb, 0, 12, str.tostring(close, format.mintick), text_color=tx, bgcolor=bg, text_size=sz, text_halign=text.align_left)
        table.cell(tb, 1, 12, "", bgcolor=bg, text_size=sz)
        table.cell(tb, 2, 12, timeframe.period + " v2.0", text_color=dm, bgcolor=bg, text_size=sz, text_halign=text.align_right)
        string sig_txt = current_signal == "LONG" ? "◆ LONG" : current_signal == "SHORT" ? "◆ SHORT" : "— WAIT"
        color sig_bg = current_signal == "LONG" ? color.new(gn,85) : current_signal == "SHORT" ? color.new(rd,85) : color.new(dm,90)
        color sig_tx = current_signal == "LONG" ? gn : current_signal == "SHORT" ? rd : dm
        table.cell(tb, 0, 13, sig_txt, text_color=sig_tx, bgcolor=sig_bg, text_size=size.small, text_halign=text.align_left)
