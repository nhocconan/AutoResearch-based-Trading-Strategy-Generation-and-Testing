//@version=5
strategy("Weekend Trend Trader - Presets",
     overlay=true,
     default_qty_type=strategy.percent_of_equity,
     default_qty_value=5,
     initial_capital=10000,
     process_orders_on_close=true)

// === PRESET UNIQUEMENT === //
preset = input.string("Original", "Preset", options=["Original", "Performance", "Optimised"])

// (optionnel) tu peux aussi figer SPX si tu veux 0 réglage
spxTicker = input.symbol("SPX", "Index Symbol ($SPX)", inline="SPX")

// === PARAMS (définis par preset) === //
float rocThreshold = na
int   rocLength = na
int   maLength = na
int   breakoutLength = na
float initialStopPct = na
float tightStopPct = na

switch preset
    "Original" =>
        rocThreshold   := 30
        rocLength      := 20
        maLength       := 10
        breakoutLength := 20
        initialStopPct := 40
        tightStopPct   := 10

    "Performance" =>
        rocThreshold   := 40
        rocLength      := 10
        maLength       := 10
        breakoutLength := 30
        initialStopPct := 50
        tightStopPct   := 30

    =>
        // fallback (ne devrait jamais arriver)
        rocThreshold   := 30
        rocLength      := 20
        maLength       := 10
        breakoutLength := 20
        initialStopPct := 40
        tightStopPct   := 10

// === TIMEFRAME VERIFICATION === //
if not timeframe.isweekly
    runtime.error("Utilise ce script sur un graphique WEEKLY")

// === FILTRE INDEX ($SPX) === //
spxClose = request.security(spxTicker, "W", close)
spxMA = ta.sma(spxClose, maLength)
indexUp = spxClose > spxMA

// === BREAKOUT === //
breakoutLevel = ta.highest(high, breakoutLength)
isBreakout = close > breakoutLevel[1]

// === ROC === //
roc = 100 * (close - close[rocLength]) / close[rocLength]
momentumOk = roc > rocThreshold

// === SIGNAL D'ENTRÉE === //
longCondition = isBreakout and momentumOk // and indexUp
if longCondition and strategy.position_size == 0
    strategy.entry("Buy", strategy.long)

// === TRAILING STOP === //
var float highestHigh = na
var float trailingStop = na
var bool wasIndexUp = na

if strategy.position_size > 0
    highestHigh := na(highestHigh) ? high : math.max(highestHigh, high)

    trendChanged = not na(wasIndexUp) and (indexUp != wasIndexUp)
    wasIndexUp := indexUp

    float stopPct = indexUp ? initialStopPct : tightStopPct
    float newStop = highestHigh * (1 - stopPct / 100)
    trailingStop := math.max(nz(trailingStop, newStop), newStop)

    if close < trailingStop
        strategy.close("Buy")

else if longCondition
    // Initialisation immédiate du stop dès le signal, avant que position_size > 0
    highestHigh  := high
    wasIndexUp   := indexUp
    float stopPct = indexUp ? initialStopPct : tightStopPct
    trailingStop := high * (1 - stopPct / 100)

else
    highestHigh  := na
    trailingStop := na
    wasIndexUp   := na

// === VISU === //
plotshape(true, title="SPX Trend", location=location.bottom, style=shape.square, color=indexUp ? color.green : color.red, size=size.small)
plot(breakoutLevel, title="Breakout High", color=color.aqua, linewidth=1, style=plot.style_line)
plot(strategy.position_size > 0 or longCondition ? trailingStop : na, title="Trailing Stop", color=color.red, linewidth=2, style=plot.style_linebr)
bgcolor(momentumOk ? color.new(color.purple, 85) : na, title="Momentum OK Background")

View in Pine Editor・105 lines
