//@version=6
// 
// ————————————————————————————————————————————————————————————————————————————————————————————————————
//
// STRATEGY DESCRIPTION
//
// This Pine Script automates the "4-Hour Range Scalping Strategy". The core logic is to identify the
// high and low of the first four hours of a major trading session (e.g., New York) and use that
// range as a "trap zone" for the rest of the day.
//
// HOW TO USE
//
// 1.  **Set Chart Timeframe:** Run on a **5-minute (5m)** chart.
// 2.  **Configure Settings:** Adjust the Trading Session and Risk/Reward Ratio in the settings.
// 3.  **Set Alerts:** Use the chart's "Alert" menu (clock icon) to create alerts for "Long Signal"
//     or "Short Signal" to automate your trading or receive notifications.
//
// ————————————————————————————————————————————————————————————————————————————————————————————————————

strategy("4-Hour Range Scalping [v6.3]",
         shorttitle="4H Scalp",
         overlay=true,
         initial_capital=10000,
         default_qty_type=strategy.percent_of_equity,
         default_qty_value=2, // <<< CRITICAL FIX: Changed from 100 to 2 for safe risk
         commission_type=strategy.commission.percent,
         commission_value=0.04,
         slippage=2)

// --- (The rest of your code remains exactly the same) ---
// --- Constants & Inputs ---
GROUP_STRATEGY = "Strategy Parameters"
rrRatio = input.float(2.0, "Risk/Reward Ratio", step=0.1, group=GROUP_STRATEGY)
sessionOption = input.string("New York", "Trading Session", options=["New York", "London", "Tokyo"], group=GROUP_STRATEGY)

GROUP_VISUALS = "Visual Parameters"
showShapes = input.bool(true, "Show Entry Arrows", group=GROUP_VISUALS)
showRangeFill = input.bool(true, "Show Range Fill", group=GROUP_VISUALS)

GROUP_BACKTEST = "Backtesting Period"
backtestStartDate = input.time(timestamp("01 Jan 2024 00:00 +0000"), "Start Date", group=GROUP_BACKTEST)
backtestEndDate = input.time(timestamp("01 Jan 2025 00:00 +0000"), "End Date", group=GROUP_BACKTEST)

// --- Time & Session Logic ---
var string tz = switch sessionOption
    "New York" => "America/New_York"
    "London"   => "Europe/London"
    "Tokyo"    => "Asia/Tokyo"
    => "America/New_York"

inDateRange() => time >= backtestStartDate and time < backtestEndDate
isNewDay = ta.change(time("D", tz)) != 0

// --- Corrected Range Calculation Logic ---
var float dailyRangeHigh = na
var float dailyRangeLow = na
var int barCounter = 0
var bool isRangeSet = false

if isNewDay and inDateRange()
    dailyRangeHigh := high
    dailyRangeLow := low
    barCounter := 1
    isRangeSet := false

if barCounter > 0 and barCounter < 48
    dailyRangeHigh := math.max(dailyRangeHigh, high)
    dailyRangeLow := math.min(dailyRangeLow, low)
    barCounter := barCounter + 1

if barCounter == 48
    isRangeSet := true
    barCounter := -1

// --- State & Signal Logic ---
var bool inBreakoutUp = false
var bool inBreakoutDown = false
var float breakoutPeak = na
var float breakoutTrough = na

if isNewDay
    inBreakoutUp := false
    inBreakoutDown := false
    breakoutPeak := na
    breakoutTrough := na

if isRangeSet
    if close > dailyRangeHigh
        inBreakoutUp := true
        inBreakoutDown := false
        breakoutPeak := math.max(high, nz(breakoutPeak, high))
        breakoutTrough := na

    if close < dailyRangeLow
        inBreakoutDown := true
        inBreakoutUp := false
        breakoutTrough := math.min(low, nz(breakoutTrough, low))
        breakoutPeak := na

// --- Entry & Alert Conditions ---
cross_under_high = ta.crossunder(close, dailyRangeHigh)
cross_over_low = ta.crossover(close, dailyRangeLow)

shortCondition = isRangeSet and inBreakoutUp and cross_under_high
longCondition = isRangeSet and inBreakoutDown and cross_over_low

// --- Strategy Execution ---
if inDateRange()
    if shortCondition and strategy.opentrades == 0
        sl_short = breakoutPeak
        tp_short = close - (sl_short - close) * rrRatio
        strategy.entry("Short", strategy.short)
        strategy.exit("Exit Short", from_entry="Short", loss=sl_short, profit=tp_short)
        alert(str.format("4H Scalp: New Short Signal on {0} @ {1, number}", syminfo.tickerid, close), alert.freq_once_per_bar_close)
        inBreakoutUp := false
        breakoutPeak := na

    if longCondition and strategy.opentrades == 0
        sl_long = breakoutTrough
        tp_long = close + (close - sl_long) * rrRatio
        strategy.entry("Long", strategy.long)
        strategy.exit("Exit Long", from_entry="Long", loss=sl_long, profit=tp_long)
        alert(str.format("4H Scalp: New Long Signal on {0} @ {1, number}", syminfo.tickerid, close), alert.freq_once_per_bar_close)
        inBreakoutDown := false
        breakoutTrough := na

// --- Alerts ---
alertcondition(longCondition, title="Long Signal", message="4H Scalp: Long Entry Triggered on {{ticker}}")
alertcondition(shortCondition, title="Short Signal", message="4H Scalp: Short Entry Triggered on {{ticker}}")

// --- Plotting ---
p_high = plot(isRangeSet and inDateRange() ? dailyRangeHigh : na, "Range High", color=color.new(color.red, 0), style=plot.style_linebr, linewidth=2)
p_low = plot(isRangeSet and inDateRange() ? dailyRangeLow : na, "Range Low", color=color.new(color.green, 0), style=plot.style_linebr, linewidth=2)
fill(p_high, p_low, color=showRangeFill ? color.new(color.gray, 90) : na, title="Range Fill")

plotshape(showShapes and longCondition, "Long Entry", style=shape.triangleup, location=location.belowbar, color=color.new(color.green, 0), size=size.small)
plotshape(showShapes and shortCondition, "Short Entry", style=shape.triangledown, location=location.abovebar, color=color.new(color.red, 0), size=size.small)

bgcolor(barCounter > 0 and barCounter < 48 ? color.new(color.blue, 95) : na)

View in Pine Editor・139 lines
