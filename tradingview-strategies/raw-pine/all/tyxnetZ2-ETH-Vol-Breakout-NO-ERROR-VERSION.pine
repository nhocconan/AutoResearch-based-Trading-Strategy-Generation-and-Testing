//@version=5
strategy("ETH Vol Breakout - NO ERROR VERSION", overlay=true, initial_capital=100000)

// --- INPUTS ---
// Try changing this to "DERIBIT:ETHDVOL" if it doesn't show trades
vol_ticker  = input.symbol("DERIBIT:ETHDVOL", "Volatility Symbol") 
vol_support = input.float(60.0, "Vol Support")
trail_perc  = input.float(10.0, "Trail %") / 100

// --- DATA WITH ERROR PROTECTION ---
// 'ignore_invalid_symbol=true' prevents the "Caution" crash
vol_data = request.security(vol_ticker, "D", close, ignore_invalid_symbol=true)

// Fallback: If vol_data is missing, we use a dummy value so the script keeps running
valid_vol = nz(vol_data, 100) 
in_compression = valid_vol <= vol_support

// --- LOGIC ---
hh = ta.highest(high[1], 3)
ll = ta.lowest(low[1], 3)
trail_ticks = (close * trail_perc) / syminfo.mintick

if in_compression and strategy.position_size == 0
    strategy.entry("Long", strategy.long, stop=hh)
    strategy.entry("Short", strategy.short, stop=ll)

if strategy.position_size != 0
    strategy.exit("Exit", trail_points=trail_ticks, trail_offset=trail_ticks)

// --- DEBUG PLOT ---
// If this line stays at 100, your Vol Ticker is still wrong!
plot(valid_vol, "Volatility Status", color=color.yellow, display=display.pane)

