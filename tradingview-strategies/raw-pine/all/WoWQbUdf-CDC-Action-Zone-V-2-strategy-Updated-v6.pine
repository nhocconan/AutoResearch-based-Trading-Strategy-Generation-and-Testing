//@version=6
strategy("CDC Action Zone V.2 strategy — Updated v6", overlay=true, margin_long=100, margin_short=100)

//-----------------------------
// Inputs
//-----------------------------
src  = input.source(ohlc4, "Data Array")
prd1 = input.int(12, "Short MA period")
prd2 = input.int(26, "Long MA period")

//-----------------------------
// Core Calculations
//-----------------------------
AP   = ta.ema(src, 2)
Fast = ta.ema(AP, prd1)
Slow = ta.ema(AP, prd2)

//-----------------------------
// Backtest Range
//-----------------------------
FromYear  = input.int(2019, "From Year", minval = 2009)
FromMonth = input.int(1, "From Month", minval = 1, maxval = 12)
FromDay   = input.int(1, "From Day", minval = 1, maxval = 31)

ToYear    = input.int(9999, "To Year", minval = 2009)
ToMonth   = input.int(12,  "To Month", minval = 1, maxval = 12)
ToDay     = input.int(31,   "To Day", minval = 1, maxval = 31)

start  = timestamp(FromYear, FromMonth, FromDay, 00, 00)
finish = timestamp(ToYear, ToMonth, ToDay, 23, 59)

window = (time >= start and time <= finish)

//-----------------------------
// CDC Color Conditions
//-----------------------------
Bullish = Fast > Slow
Bearish = Fast < Slow

Green  = Bullish and AP > Fast
Red    = Bearish and AP < Slow
Yellow = Bullish and AP < Fast
Blue   = Bearish and AP > Slow

//-----------------------------
// Trade Signals
//-----------------------------
Buy  = Green and not Green[1]
Sell = Red   and not Red[1]

Short = Red and not Red[1]
Cover = Red[1] and not Red

//-----------------------------
// Plot MAs
//-----------------------------
l1 = plot(Fast, "Fast", color=color.red, linewidth=1)
l2 = plot(Slow, "Slow", color=color.blue, linewidth=2)

bcolor =
     Green  ? color.lime   :
     Red    ? color.red    :
     Yellow ? color.yellow :
     Blue   ? color.blue   :
     color.white


//-----------------------------
// Strategy Logic
//-----------------------------
if (window and Buy)
    strategy.entry("Buy", strategy.long)

if (window and Sell)
    strategy.close_all()

