//@version=6
strategy("EMA 200 Trendline Break Strategy", overlay=true)

// Inputs
emaLength = input.int(200, "EMA Length")
lookback = input.int(8, "Trendline Lookback")
rr = input.float(2.0, "Risk Reward")

// EMA
ema200 = ta.ema(close, emaLength)
plot(ema200, color=color.orange, linewidth=2)

// Recent swing highs/lows
recentHigh = ta.highest(high, lookback)
recentLow = ta.lowest(low, lookback)

// Build trendlines
downTrend = ta.highest(high[1], lookback)
upTrend = ta.lowest(low[1], lookback)

// Entry Conditions
buyCondition =
 close > ema200 and
 close > downTrend and
 close[1] <= downTrend

sellCondition =
 close < ema200 and
 close < upTrend and
 close[1] >= upTrend

// Stop Loss
longSL = ta.lowest(low,3)
shortSL = ta.highest(high,3)

// Take Profit
longTP = close + (close - longSL) * rr
shortTP = close - (shortSL - close) * rr

// Entries
if buyCondition
    strategy.entry("BUY", strategy.long)
    strategy.exit("TP/SL", "BUY", stop=longSL, limit=longTP)

if sellCondition
    strategy.entry("SELL", strategy.short)
    strategy.exit("TP/SL", "SELL", stop=shortSL, limit=shortTP)

// Entry labels
plotshape(buyCondition, location=location.belowbar, color=color.green, style=shape.labelup, text="BUY")
plotshape(sellCondition, location=location.abovebar, color=color.red, style=shape.labeldown, text="SELL")

// TP/SL Boxes
var box tpBox = na
var box slBox = na

if buyCondition
    tpBox := box.new(bar_index, longTP, bar_index+8, close, bgcolor=color.new(color.green,80))
    slBox := box.new(bar_index, close, bar_index+8, longSL, bgcolor=color.new(color.red,80))

if sellCondition
    tpBox := box.new(bar_index, close, bar_index+8, shortTP, bgcolor=color.new(color.green,80))
    slBox := box.new(bar_index, shortSL, bar_index+8, close, bgcolor=color.new(color.red,80))

