//@version=3
strategy("fn-bug", overlay=true, calc_on_every_tick=false)

getLow(i) => low[i]

idx = n % 13 != 0 ? 1 : -1
s1 = if idx >= 0
    low[idx]
s2 = if idx >= 0
    getLow(idx) // why is it different?
s3 = if s1 != s2
    high[idx]
plot(s1, style=line,  linewidth=1, color=fuchsia, transp=10, offset=-1)
plot(s2, style=line,  linewidth=2, color=yellow,  transp=10, offset=-1)
plot(s3, style=cross, linewidth=4, color=red,     transp=0,  offset=-1)

