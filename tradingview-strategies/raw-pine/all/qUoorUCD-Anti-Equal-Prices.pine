//@version=6
// (c) TedDibiase21 - EQL/EQH Reversal System
strategy("EQL/EQH Reversal System", overlay=true, pyramiding=1, default_qty_type=strategy.fixed, default_qty_value=1, commission_type=strategy.commission.cash_per_contract, commission_value=2.0, calc_on_every_tick=false)

// ============================================================
// INPUTS
// ============================================================
i_lookback   = input.int(30,    "Lookback Bars",           minval=5,    maxval=200,  group="Detection")
i_tolerance  = input.float(5.0, "Tolerance (pts)",         minval=0.25, step=0.25,   group="Detection")
i_minTouches = input.int(3,     "Min Touches",             minval=2,    maxval=6,    group="Detection")
i_useSession = input.bool(true,  "Use Session Filter",                              group="Session")
i_sessStr    = input.session("0945-1400", "Session (ET)",                           group="Session")
i_entryDist  = input.float(5.0, "Entry Within (pts)",      minval=0.25, step=0.25,  group="Entries")
i_cooldown   = input.int(3,     "Cooldown Bars",           minval=1,    maxval=50,   group="Entries")
i_stopPts    = input.float(10.0,"Stop Loss (pts)",         minval=1.0,  step=0.25,   group="Risk")
i_tgtMult    = input.float(3.0, "Target ATR Multiplier",   minval=0.5,  step=0.25,   group="Risk")
i_useRSI     = input.bool(true,  "RSI Filter",                                      group="Filters")
i_rsiLen     = input.int(14,    "RSI Length",              minval=2,    maxval=30,   group="Filters")
i_rsiOB      = input.int(60,    "RSI Overbought (Shorts)", minval=50,   maxval=80,   group="Filters")
i_rsiOS      = input.int(40,    "RSI Oversold (Longs)",    minval=20,   maxval=50,   group="Filters")
i_useReject  = input.bool(true,  "Rejection Candle Filter",                         group="Filters")
i_longOnly   = input.bool(true,  "Longs Only",                                      group="Filters")

// ============================================================
// CALCULATIONS
// ============================================================
atr    = ta.atr(14)
rsi    = ta.rsi(close, i_rsiLen)
inSess = i_useSession ? not na(time(timeframe.period, i_sessStr, "America/New_York")) : true

// ============================================================
// DETECTION
// ============================================================
eqhCount = 0
eqlCount = 0
for i = 1 to i_lookback
    if math.abs(high[i] - high) <= i_tolerance
        eqhCount += 1
    if math.abs(low[i]  - low)  <= i_tolerance
        eqlCount += 1

isEQH = eqhCount >= i_minTouches and not i_longOnly
isEQL = eqlCount >= i_minTouches

// ============================================================
// FILTERS
// ============================================================
candleMid  = (high + low) / 2.0
eqhReject  = i_useReject ? close < candleMid : true
eqlReject  = i_useReject ? close > candleMid : true
rsiShortOK = i_useRSI ? rsi >= i_rsiOB : true
rsiLongOK  = i_useRSI ? rsi <= i_rsiOS : true

// ============================================================
// ENTRY TRACKING
// ============================================================
var float anchorEQH = na
var float anchorEQL = na
var bool  eqhDone   = false
var bool  eqlDone   = false
var int   barsShort = 999
var int   barsLong  = 999

barsShort += 1
barsLong  += 1

if isEQH
    if na(anchorEQH) or math.abs(high - anchorEQH) > i_tolerance * 2.0
        anchorEQH := high
        eqhDone   := false

if isEQL
    if na(anchorEQL) or math.abs(low - anchorEQL) > i_tolerance * 2.0
        anchorEQL := low
        eqlDone   := false

// ============================================================
// SIGNALS
// ============================================================
eqhDist  = isEQH ? math.abs(high - anchorEQH) : 9999.0
eqlDist  = isEQL ? math.abs(low  - anchorEQL) : 9999.0

shortSig = isEQH and inSess and not eqhDone and eqhDist <= i_entryDist and rsiShortOK and eqhReject and barsShort >= i_cooldown
longSig  = isEQL and inSess and not eqlDone  and eqlDist <= i_entryDist and rsiLongOK  and eqlReject and barsLong  >= i_cooldown

// ============================================================
// ORDERS
// ============================================================
tgtDist = atr * i_tgtMult

if shortSig
    eqhDone   := true
    barsShort := 0
    strategy.entry("Short", strategy.short)
    strategy.exit("SX", "Short", stop=anchorEQH + i_stopPts, limit=anchorEQH - tgtDist)

if longSig
    eqlDone  := true
    barsLong := 0
    strategy.entry("Long", strategy.long)
    strategy.exit("LX", "Long", stop=anchorEQL - i_stopPts, limit=anchorEQL + tgtDist)

if not inSess and strategy.position_size != 0
    strategy.close_all(comment="EOD")

// ============================================================
// VISUALS
// ============================================================
plotshape(isEQH and not isEQH[1], "EQH", shape.triangledown, location.abovebar, color.new(color.red,   40), size=size.tiny)
plotshape(isEQL and not isEQL[1], "EQL", shape.triangleup,   location.belowbar, color.new(color.green, 40), size=size.tiny)
plotshape(shortSig, "Short", shape.labeldown, location.abovebar, color.new(color.red,   0), text="S", textcolor=color.white, size=size.small)
plotshape(longSig,  "Long",  shape.labelup,   location.belowbar, color.new(color.green, 0), text="L", textcolor=color.white, size=size.small)
plot(i_useRSI ? rsi : na, "RSI", color.new(color.purple, 60), display=display.pane)
hline(i_rsiOB, "OB", color.new(color.red,   50), linestyle=hline.style_dashed)
hline(i_rsiOS, "OS", color.new(color.green, 50), linestyle=hline.style_dashed)
bgcolor(inSess ? color.new(color.blue, 97) : na)

// ============================================================
// TABLE
// ============================================================
if barstate.islast
    var t = table.new(position.top_right, 2, 6, bgcolor=color.new(color.black, 60), border_color=color.gray, border_width=1)
    table.cell(t, 0, 0, "EQL/EQH Reversal",  text_color=color.white, text_size=size.normal, bgcolor=color.new(color.blue, 40))
    table.cell(t, 1, 0, "Longs Only",        text_color=color.white, text_size=size.normal, bgcolor=color.new(color.blue, 40))
    table.cell(t, 0, 1, "Lookback/Touches",  text_color=color.gray)
    table.cell(t, 1, 1, str.tostring(i_lookback) + " bars / " + str.tostring(i_minTouches) + "+", text_color=color.white)
    table.cell(t, 0, 2, "Tolerance",         text_color=color.gray)
    table.cell(t, 1, 2, str.tostring(i_tolerance) + " pts",                                       text_color=color.white)
    table.cell(t, 0, 3, "Stop / Target",     text_color=color.gray)
    table.cell(t, 1, 3, str.tostring(i_stopPts) + " pts / " + str.tostring(i_tgtMult) + "x ATR", text_color=color.white)
    table.cell(t, 0, 4, "RSI Oversold",      text_color=color.gray)
    table.cell(t, 1, 4, i_useRSI ? "RSI <= " + str.tostring(i_rsiOS) : "OFF",                    text_color=i_useRSI ? color.lime : color.orange)
    table.cell(t, 0, 5, "Session",           text_color=color.gray)
    table.cell(t, 1, 5, i_useSession ? i_sessStr : "OFF",                                         text_color=i_useSession ? color.lime : color.orange)

