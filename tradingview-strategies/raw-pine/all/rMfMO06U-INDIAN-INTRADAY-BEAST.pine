//@version=5
strategy("VWAP + Volume Confirmation Strategy", overlay=true, margin_long=100, margin_short=100)

// === INPUTS ===
vwapLength = input.int(1, "VWAP Anchor Period (Days)", minval=1)
volLength = input.int(20, "Average Volume Period", minval=1)
volPercent = input.float(120.0, "Volume Threshold (%)", step=0.1, tooltip="Volume must be above this % of average volume to confirm a trade")

// === VWAP CALCULATION ===
vwapValue = ta.vwap

// === VOLUME FILTER ===
avgVol = ta.sma(volume, volLength)
volCondition = volume > avgVol * (volPercent / 100)

// === TRADE CONDITIONS ===
buyCondition  = ta.crossover(close, vwapValue) and volCondition
sellCondition = ta.crossunder(close, vwapValue) and volCondition

// === STRATEGY LOGIC ===
if (buyCondition)
    strategy.entry("BUY", strategy.long)

if (sellCondition)
    strategy.close("BUY")

// === PLOT SIGNALS ===
plot(vwapValue, color=color.new(color.orange, 0), title="VWAP", linewidth=2)
plotshape(buyCondition, title="Buy Signal", style=shape.triangleup, color=color.new(color.green, 0), size=size.large, location=location.belowbar, text="BUY")
plotshape(sellCondition, title="Sell Signal", style=shape.triangledown, color=color.new(color.red, 0), size=size.large, location=location.abovebar, text="SELL")

// === DEBUG LABELS (OPTIONAL) ===
plotchar(volCondition, title="Volume OK", char="✔", location=location.bottom, color=color.new(color.green, 0))

