//@version=6
strategy("MES 1m EMA Bounce Scalp - High RR v6", 
     overlay = true,
     default_qty_type = strategy.fixed,
     default_qty_value = 1,                  // 1 contract; scale up in live
     currency = currency.USD,
     commission_type = strategy.commission.cash_per_contract,
     commission_value = 1.5,                 // Realistic low-cost broker rate
     pyramiding = 0,
     calc_on_every_tick = true,
     calc_on_order_fills = true)

// ────────────────────────────────────────
// Inputs
// ────────────────────────────────────────
int emaLength      = input.int(20, "EMA Length", minval=5, maxval=50)
int rsiLength      = input.int(14, "RSI Length", minval=5)
int rsiThreshold   = input.int(45, "RSI Threshold (Long > / Short < 100- )", minval=30, maxval=70)  // Loosened
float stopPoints   = input.float(4.0, "Stop Loss (points)", minval=1.0, step=0.25)
float partialPoints= input.float(4.0, "Partial TP (1:1 points)", minval=1.0, step=0.25)
float targetPoints = input.float(8.0, "Full TP (1:2 points)", minval=2.0, step=0.5)
float trailOffset  = input.float(2.0, "Trail Offset (points after partial)", minval=0.5, step=0.25)
int volSmaLength   = input.int(20, "Volume SMA Length")

// ────────────────────────────────────────
// Session Filter: 9:30-16:00 ET using bar time (reliable in v6)
int hour_et = hour(time, "America/New_York")
int min_et  = minute(time, "America/New_York")
bool inSession = (hour_et > 9 or (hour_et == 9 and min_et >= 30)) and (hour_et < 16)

// Draw vertical lines at session start/end (as requested)
var line sessionStart = na
var line sessionEnd = na
if barstate.isnew and inSession[1] == false and inSession
    sessionStart := line.new(bar_index, high, bar_index, low, extend=extend.right, color=color.green, width=2)
if barstate.isnew and inSession[1] and inSession == false
    sessionEnd := line.new(bar_index, high, bar_index, low, extend=extend.right, color=color.red, width=2)

// ────────────────────────────────────────
// Indicators
// ────────────────────────────────────────
float ema20  = ta.ema(close, emaLength)
float rsi    = ta.rsi(close, rsiLength)
float volSma = ta.sma(volume, volSmaLength)

// ────────────────────────────────────────
// Entry Logic: Pullback bounce + filters
// ────────────────────────────────────────
bool longPullback  = ta.crossunder(close[1], ema20[1]) and close > ema20
bool longMomentum  = rsi > rsiThreshold
bool highVol       = volume > volSma
bool entryLong     = inSession and longPullback and longMomentum and highVol and strategy.position_size == 0

bool shortPullback = ta.crossover(close[1], ema20[1]) and close < ema20
bool shortMomentum = rsi < (100 - rsiThreshold)
bool entryShort    = inSession and shortPullback and shortMomentum and highVol and strategy.position_size == 0

// ────────────────────────────────────────
// Risk distances
// ────────────────────────────────────────
float stopDistance   = stopPoints
float partialDistance = partialPoints
float targetDistance = targetPoints

// ────────────────────────────────────────
// Execute Entries & Exits with Partials/Trailing
// ────────────────────────────────────────
if entryLong
    strategy.entry("Long Bounce", strategy.long)

if strategy.position_size > 0
    // Partial exit at 1:1
    strategy.exit("Partial Long", from_entry = "Long Bounce", qty_percent = 50, limit = strategy.position_avg_price + partialDistance)
    // After partial, move stop to BE and trail the rest
    if strategy.position_size > 0 and close > strategy.position_avg_price + partialDistance
        strategy.exit("Trail Long", from_entry = "Long Bounce", trail_points = trailOffset, trail_offset = trailOffset, stop = strategy.position_avg_price)
    // Full target if not trailed
    strategy.exit("Full Long", from_entry = "Long Bounce", limit = strategy.position_avg_price + targetDistance, stop = strategy.position_avg_price - stopDistance)

if entryShort
    strategy.entry("Short Bounce", strategy.short)

if strategy.position_size < 0
    // Partial exit at 1:1
    strategy.exit("Partial Short", from_entry = "Short Bounce", qty_percent = 50, limit = strategy.position_avg_price - partialDistance)
    // After partial, move stop to BE and trail the rest
    if strategy.position_size < 0 and close < strategy.position_avg_price - partialDistance
        strategy.exit("Trail Short", from_entry = "Short Bounce", trail_points = trailOffset, trail_offset = trailOffset, stop = strategy.position_avg_price)
    // Full target if not trailed
    strategy.exit("Full Short", from_entry = "Short Bounce", limit = strategy.position_avg_price - targetDistance, stop = strategy.position_avg_price + stopDistance)

// ────────────────────────────────────────
// Visuals
// ────────────────────────────────────────
plot(ema20, "EMA 20", color = color.orange, linewidth = 2)
bgcolor(inSession ? color.new(color.gray, 95) : na, title = "Session BG")
plotshape(entryLong, title = "Long Entry", location = location.belowbar, color = color.lime, style = shape.labelup, text = "Long", size = size.small)
plotshape(entryShort, title = "Short Entry", location = location.abovebar, color = color.fuchsia, style = shape.labeldown, text = "Short", size = size.small)

// Alerts
if entryLong
    alert("MES 1m High RR → LONG @ " + str.tostring(close, "#.##"), alert.freq_once_per_bar_close)
if entryShort
    alert("MES 1m High RR → SHORT @ " + str.tostring(close, "#.##"), alert.freq_once_per_bar_close)

