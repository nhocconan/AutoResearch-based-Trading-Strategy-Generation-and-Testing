//@version=5
strategy("SuperTrend + RSI Breakout Strategy", overlay=true, margin_long=100, margin_short=100)

// === Inputs ===
// SuperTrend
atrPeriod   = input.int(15, "SuperTrend ATR Period")
atrMult     = input.float(2.0, "SuperTrend ATR Multiplier")

// RSI
rsiLength   = input.int(14, "RSI Length")
rsiOS       = input.int(30, "RSI Oversold Level")
rsiOB       = input.int(70, "RSI Overbought Level")

// Pip-based SL/TP
slPips      = input.int(20, "Stop Loss (pips)")
tpPips      = input.int(30, "Take Profit (pips)")

// === SuperTrend Calculation ===
[superTrend, dir] = ta.supertrend(atrMult, atrPeriod)
// dir == -1 → bullish trend, dir == 1 → bearish trend
bullTrend = dir == -1
bearTrend = dir == 1

plot(superTrend, "SuperTrend", color=bullTrend ? color.green : color.red)

// === RSI Calculation ===
rsi = ta.rsi(close, rsiLength)
plot(rsi, "RSI", color=color.blue)
hline(rsiOS, "Oversold", color=color.green)
hline(rsiOB, "Overbought", color=color.red)

// === Pip Conversion ===
pipValue = syminfo.mintick
slDist   = slPips * pipValue
tpDist   = tpPips * pipValue

// === Entry Conditions ===
// Long: RSI crosses below oversold + SuperTrend bullish
longCondition  = ta.crossunder(rsi, rsiOS) and bullTrend and strategy.position_size == 0

// Short: RSI crosses above overbought + SuperTrend bearish
shortCondition = ta.crossover(rsi, rsiOB) and bearTrend and strategy.position_size == 0

// === Orders ===
if (longCondition)
    strategy.entry("Long", strategy.long)
    strategy.exit("TP/SL Long", "Long", stop=close - slDist, limit=close + tpDist)

if (shortCondition)
    strategy.entry("Short", strategy.short)
    strategy.exit("TP/SL Short", "Short", stop=close + slDist, limit=close - tpDist)

