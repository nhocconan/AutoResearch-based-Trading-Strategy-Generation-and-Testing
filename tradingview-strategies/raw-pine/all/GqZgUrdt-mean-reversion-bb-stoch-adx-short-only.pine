//@version=5
strategy("Mean Reversion: BB + Stoch + ADX (Short Only)", overlay=true, initial_capital=100, default_qty_type=strategy.cash, default_qty_value=100, commission_type=strategy.commission.percent, commission_value=0.04)

// --- Входные параметры ---
// Bollinger Bands
bb_mult = input.float(2.0, "BB Multiplier")
bb_len  = input.int(20, "BB Length")

// Stochastic
stoch_len = input.int(14, "Stoch Length")
stoch_k   = input.int(3, "Stoch %K")
stoch_d   = input.int(3, "Stoch %D")

// ADX
adx_len    = input.int(14, "ADX Length")
adx_cutoff = input.int(25, "ADX Trend Filter (Max)")

// ATR Exit
atr_len = input.int(14, "ATR Length")
tp_mult = input.float(3.5, "TP Mult (ATR)")
sl_mult = input.float(2.0, "SL Mult (ATR)")

// --- Расчет индикаторов ---
// Bollinger Bands
[bb_mid, bb_upper, bb_lower] = ta.bb(close, bb_len, bb_mult)

// Stochastic
stoch_k_val = ta.sma(ta.stoch(close, high, low, stoch_len), stoch_k)

// ADX
[plus_di, minus_di, adx] = ta.dmi(adx_len, adx_len)

// ATR
atr = ta.atr(atr_len)

// --- Логика условий ---
// Рынок считается спокойным (флэт), если ADX ниже порога
is_flat = adx < adx_cutoff

// Сигнал в Шорт: Цена выше верхней ленты + Стохастик > 80 + Флэт (ADX < 25)
short_signal = ta.crossover(high, bb_upper) and stoch_k_val > 80 and is_flat

// --- Выполнение сделок ---
if (short_signal and strategy.position_size == 0)
    float sl = close + (atr * sl_mult)
    float tp = close - (atr * tp_mult)
    strategy.entry("Short", strategy.short, comment="BB Upper + Overbought")
    strategy.exit("Exit Short", "Short", stop=sl, limit=tp, comment_loss="SL", comment_profit="TP")

// --- Визуализация ---
plot(bb_upper, color=color.new(color.red, 50), title="BB Upper")
plot(bb_mid, color=color.new(color.gray, 80), title="BB Mid")
// Нижнюю ленту оставил для визуального контекста, но она не используется в логике
plot(bb_lower, color=color.new(color.blue, 80), title="BB Lower")

// Фон: подсвечиваем зоны, где ADX разрешает вход (флэт)
bgcolor(is_flat ? color.new(color.green, 90) : color.new(color.red, 90))

