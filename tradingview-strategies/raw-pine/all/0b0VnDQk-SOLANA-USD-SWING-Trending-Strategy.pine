//@version=5
strategy("SOL Intraday Trend & ADX Filter", overlay=true, initial_capital=100, default_qty_type=strategy.percent_of_equity, default_qty_value=100, commission_type=strategy.commission.percent, commission_value=0.05)

// ==========================================
// 1. INPUTS & SETTINGS
// ==========================================

// Supertrend Settings
atrPeriod = input.int(10, "Supertrend ATR Length", group="Supertrend")
factor = input.float(3.0, "Supertrend Factor", group="Supertrend")

// ADX Settings (Sideways Filter)
adxlen = input.int(14, title="ADX Smoothing", group="ADX Filter")
dilen = input.int(14, title="DI Length", group="ADX Filter")
adxThreshold = input.int(25, title="ADX Threshold (Min trend strength)", group="ADX Filter")

// Risk Management (Trailing SL)
trailPerc = input.float(1.5, title="Trailing Stop Activation (%)", step=0.1, group="Risk Management")
trailOffsetPerc = input.float(0.5, title="Trailing Stop Offset (%)", step=0.1, group="Risk Management")

// ==========================================
// 2. INDICATOR CALCULATIONS
// ==========================================

// --- Background Heikin Ashi ---
// We pull HA data securely while keeping the main chart normal for realistic execution
haTicker = ticker.heikinashi(syminfo.tickerid)
haClose = request.security(haTicker, timeframe.period, close)
haOpen = request.security(haTicker, timeframe.period, open)
haHigh = request.security(haTicker, timeframe.period, high)
haLow = request.security(haTicker, timeframe.period, low)

haBullish = haClose > haOpen
haBearish = haClose < haOpen

// --- Supertrend ---
[supertrend, direction] = ta.supertrend(factor, atrPeriod)

// --- ADX ---
dirmov(len) =>
    up = ta.change(high)
    down = -ta.change(low)
    plusDM = na(up) ? na : (up > down and up > 0 ? up : 0)
    minusDM = na(down) ? na : (down > up and down > 0 ? down : 0)
    truerange = ta.rma(ta.tr, len)
    plus = fixnan(100 * ta.rma(plusDM, len) / truerange)
    minus = fixnan(100 * ta.rma(minusDM, len) / truerange)
    [plus, minus]

adx(dilen, adxlen) =>
    [plus, minus] = dirmov(dilen)
    sum = plus + minus
    adxValue = 100 * ta.rma(math.abs(plus - minus) / (sum == 0 ? 1 : sum), adxlen)
    adxValue

sig_adx = adx(dilen, adxlen)

// ==========================================
// 3. ENTRY CONDITIONS
// ==========================================

// Is the market actually moving?
isTrending = sig_adx > adxThreshold

// Trend Alignment
bullishTrend = direction < 0
bearishTrend = direction > 0

// Final Entry Triggers
longCondition = bullishTrend and isTrending and haBullish
shortCondition = bearishTrend and isTrending and haBearish

// Execute Trades
if (longCondition and strategy.position_size == 0)
    strategy.entry("Long", strategy.long)

if (shortCondition and strategy.position_size == 0)
    strategy.entry("Short", strategy.short)

// ==========================================
// 4. TRAILING STOP LOSS LOGIC
// ==========================================

// Convert percentages to ticks for TradingView's strategy.exit function
longTrailTicks = (close * (trailPerc / 100)) / syminfo.mintick
longOffsetTicks = (close * (trailOffsetPerc / 100)) / syminfo.mintick

shortTrailTicks = (close * (trailPerc / 100)) / syminfo.mintick
shortOffsetTicks = (close * (trailOffsetPerc / 100)) / syminfo.mintick

// Manage active positions with the trailing stop
if (strategy.position_size > 0)
    strategy.exit("Trail Long", "Long", trail_points=longTrailTicks, trail_offset=longOffsetTicks)

if (strategy.position_size < 0)
    strategy.exit("Trail Short", "Short", trail_points=shortTrailTicks, trail_offset=shortOffsetTicks)

// ==========================================
// 5. CHART VISUALS
// ==========================================
plot(supertrend, color=direction < 0 ? color.green : color.red, title="Supertrend")
bgcolor(isTrending ? na : color.new(color.gray, 90), title="Sideways Market Dimmer")

