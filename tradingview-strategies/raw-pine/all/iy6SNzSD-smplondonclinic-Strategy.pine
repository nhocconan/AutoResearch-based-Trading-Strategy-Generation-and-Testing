//@version=5
strategy("MA Crossover with Fractals and Pullbacks", overlay=true)

// Define strategy parameters
fast_ma_length = input(12, title="Fast MA Length")
slow_ma_length = input(26, title="Slow MA Length")
regime_ma_length = input(200, title="Regime MA Length")
fractal_length = input(5, title="Fractal Length")

// Calculate moving averages
fast_ma = ta.sma(close, fast_ma_length)
slow_ma = ta.sma(close, slow_ma_length)
regime_ma = ta.sma(close, regime_ma_length)

// Detect fractals
fractal_high = ta.highest(high, fractal_length)
fractal_low = ta.lowest(low, fractal_length)
bullish_fractal = close[fractal_length] < close and close[fractal_length] == fractal_high[fractal_length]
bearish_fractal = close[fractal_length] > close and close[fractal_length] == fractal_low[fractal_length]

// Buy and sell conditions
buy_condition = ta.crossover(fast_ma, slow_ma) and close > regime_ma and bullish_fractal
sell_condition = ta.crossunder(fast_ma, slow_ma) and close < regime_ma and bearish_fractal

// Plot moving averages
plot(fast_ma, color=color.blue, title="Fast MA")
plot(slow_ma, color=color.red, title="Slow MA")
plot(regime_ma, color=color.green, title="Regime MA")

// Strategy entry and exit
strategy.entry("Buy", strategy.long, when=buy_condition)
strategy.entry("Sell", strategy.short, when=sell_condition)

// Exit rules
strategy.exit("Exit Buy", "Buy", loss=close * 0.02) // 2% stop loss for buy
strategy.exit("Exit Sell", "Sell", loss=close * 0.02) // 2% stop loss for sell
