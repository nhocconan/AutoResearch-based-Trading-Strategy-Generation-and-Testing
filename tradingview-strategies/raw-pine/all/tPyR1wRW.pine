//@version=6
strategy('MTF MACD + Accelerator Oscillator Strategy ', overlay = true, margin_long = 100, margin_short = 100)

// === INPUTS ===
higher_tf = input.timeframe('60', '上位足の時間足')
macd_fast = input.int(12, 'MACD Fast EMA')
macd_slow = input.int(26, 'MACD Slow EMA')
macd_signal = input.int(9, 'MACD Signal SMA')
atr_mult_tp = input.float(1.5, '利確倍率（ATR）')
atr_mult_sl = input.float(1.0, '損切り倍率（ATR）')

// === HIGHER TIMEFRAME MACD ===
[macd_h, signal_h, _] = ta.macd(request.security(syminfo.tickerid, higher_tf, close), macd_fast, macd_slow, macd_signal)
macd_up = macd_h > signal_h
macd_down = macd_h < signal_h

// === LOWER TIMEFRAME ACCELERATOR OSCILLATOR ===
// AO = SMA(5) - SMA(34)
ao = ta.sma(hl2, 5) - ta.sma(hl2, 34)
// AC = AO - SMA(5, AO)
ac = ao - ta.sma(ao, 5)

// === ENTRY CONDITIONS ===
long_cond = macd_up and ta.crossover(ac, 0)
short_cond = macd_down and ta.crossunder(ac, 0)

// === ATR BASED EXIT ===
atr = ta.atr(14)
long_tp = strategy.position_avg_price + atr * atr_mult_tp
long_sl = strategy.position_avg_price - atr * atr_mult_sl
short_tp = strategy.position_avg_price - atr * atr_mult_tp
short_sl = strategy.position_avg_price + atr * atr_mult_sl

// === STRATEGY EXECUTION ===
if long_cond
    strategy.entry('Long', strategy.long)
if short_cond
    strategy.entry('Short', strategy.short)

// Exit when opposite signal appears or SL/TP is hit
if strategy.position_size > 0
    strategy.exit('Long Exit', 'Long', stop = long_sl, limit = long_tp)
if strategy.position_size < 0
    strategy.exit('Short Exit', 'Short', stop = short_sl, limit = short_tp)

// === ALERT CONDITIONS ===
alertcondition(long_cond, title = 'Buy Signal', message = '📈 Long Signal: MTF MACD + AC Strategy')
alertcondition(short_cond, title = 'Sell Signal', message = '📉 Short Signal: MTF MACD + AC Strategy')

// === PLOTTING ===
plot(ac, title = 'Accelerator Oscillator', color = color.new(color.aqua, 0))
hline(0, 'Zero Line', color = color.gray)
plotshape(long_cond, title = 'Buy Signal', location = location.belowbar, color = color.new(color.green, 0), style = shape.triangleup, size = size.tiny)
plotshape(short_cond, title = 'Sell Signal', location = location.abovebar, color = color.new(color.red, 0), style = shape.triangledown, size = size.tiny)
// === REAL-TIME ALERT TRIGGERS ===
if long_cond
    alert('📈 Long Signal: MTF MACD + AC Strategy', alert.freq_once_per_bar_close)
if short_cond
    alert('📉 Short Signal: MTF MACD + AC Strategy', alert.freq_once_per_bar_close)

View in Pine Editor・59 lines
