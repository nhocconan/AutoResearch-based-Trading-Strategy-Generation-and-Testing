//@version=3
strategy("Gap MA", overlay=true)
per=input(35, type=integer, minval=12, step=1)
pp=round(per/3)
a=highest(high,4)
ao=lowest(close[per-2*pp],pp)
A=(a+ao)/2
if open>A 
    strategy.entry("long", true, 1)
else
    strategy.close("long")

if open<A
    strategy.entry("short", false, 1)
else
    strategy.close("short")
plot(A, linewidth=3)

