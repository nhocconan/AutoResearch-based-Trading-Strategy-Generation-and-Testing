//@version=6
strategy('VWAP Retest + EMA9 Cross + Candle Pattern [3% TP, -0.5% VWAP SL, Above YH, Slippage Simulated]', overlay = true, initial_capital = 100000, default_qty_type = strategy.percent_of_equity, default_qty_value = 10, commission_type = strategy.commission.percent, commission_value = 0.03, slippage = 1)
// — Inputs
emaLength = input.int(9, title = 'EMA Length')
tpPct = input.float(3, title = 'Take Profit %', step = 0.1)
retestBuffer = input.float(0.2, title = 'VWAP Retest Buffer ($)', step = 0.01)

// — Time Filter (US session 9:30–12:30 EST)
inSession = hour >= 9 and hour < 12 or hour == 12 and minute <= 30

// — Indicators
vwap = ta.vwap
ema9 = ta.ema(close, emaLength)


// — Yesterday's High
prevHigh = request.security(syminfo.tickerid, 'D', high[1], lookahead = barmerge.lookahead_on)

// — Candle Patterns
isBullishHammer = close > open and open - low > 2 * math.abs(close - open) and high - close < 2 * math.abs(close - open)
isBullishEngulfing = close > open and close > close[1] and open < open[1] and close > open[1]
bodySize = math.abs(close - open)
avgBodySize = ta.sma(bodySize, 5)
isMomentumCandle = close > open and bodySize > avgBodySize and close > high - (high - low) * 0.2
hasCandlePattern = isBullishHammer or isBullishEngulfing or isMomentumCandle

// — Entry Conditions
emaCrossUp = ta.crossover(ema9, vwap)
recentCross = emaCrossUp or emaCrossUp[1] or emaCrossUp[2] // New: Check if crossover occurred within last 2 bars
retestVWAP = low <= vwap + retestBuffer and low >= vwap - retestBuffer
priceAboveVWAP = close > vwap
closeAboveYHigh = close > prevHigh // replaced high > prevHigh
rawBuySignal = recentCross and retestVWAP and priceAboveVWAP and closeAboveYHigh and hasCandlePattern and inSession



// — Simulate Slippage or Entry Delay by shifting signal forward
buySignal = rawBuySignal


// — Persistent VWAP at entry
var float vwapAtEntry = na

if buySignal
    vwapAtEntry := vwap
    
if strategy.position_size == 0
    vwapAtEntry := na


// — Entry & Exit Logic
entryPrice = close
takeProfitPrice = entryPrice * (1 + tpPct / 100)
stopLossPrice = vwapAtEntry * 0.995

if buySignal
    strategy.entry('BUY', strategy.long)
    strategy.exit('TP/SL', from_entry = 'BUY', limit = takeProfitPrice, stop = stopLossPrice)

// — Force Close at 1:00 PM EST
forceCloseTime = hour == 13 and minute == 0
if forceCloseTime and strategy.position_size > 0
    strategy.close('BUY', comment = 'Force Close 1PM')

// — Visual Markers
plotshape(buySignal, title = 'Buy Signal', location = location.belowbar, color = color.fuchsia, style = shape.labelup, text = 'SETUP')
plotshape(isBullishHammer, title = 'Hammer', location = location.abovebar, color = color.green, style = shape.triangleup, text = 'H')
plotshape(isBullishEngulfing, title = 'Engulfing', location = location.abovebar, color = color.green, style = shape.triangleup, text = 'BE')
plotshape(isMomentumCandle, title = 'Momentum', location = location.abovebar, color = color.green, style = shape.triangleup, text = 'M')


// — Visual Help
plot(vwap, title = 'VWAP', color = color.white, linewidth = 2)
plot(ema9, title = 'EMA 9', color = color.orange)


// — Get yesterday's high/low from daily timeframe
// prevHigh = request.security(syminfo.tickerid, "D", high[1], lookahead=barmerge.lookahead_on)
prevLow = request.security(syminfo.tickerid, 'D', low[1], lookahead = barmerge.lookahead_on)
// — Get today's date
todayDay = dayofmonth(time)
todayMonth = month(time)
todayYear = year(time)
// — Get current candle's date from intraday timeframe
barDay = dayofmonth(time)
barMonth = month(time)
barYear = year(time)
// — Only show labels for today’s intraday bars
isToday = barDay == todayDay and barMonth == todayMonth and barYear == todayYear
// — Plot labels only once per day (to avoid clutter)
plotLabelHigh = isToday and bar_index == ta.highest(bar_index, 1)
plotLabelLow = isToday and bar_index == ta.highest(bar_index, 1)
// — Show label at previous high and low
if plotLabelHigh
    label.new(x = bar_index, y = prevHigh, text = 'YH', style = label.style_label_down, color = color.green, textcolor = color.white, size = size.tiny)
if plotLabelLow
    label.new(x = bar_index, y = prevLow, text = 'YL', style = label.style_label_up, color = color.red, textcolor = color.white, size = size.tiny)

