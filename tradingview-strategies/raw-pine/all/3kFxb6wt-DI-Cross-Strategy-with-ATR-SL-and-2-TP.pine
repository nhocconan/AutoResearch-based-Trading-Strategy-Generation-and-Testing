//@version=5
strategy("DI+/- Cross Strategy with ATR SL and 2% TP", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=100)

// === INPUTS ===
length = input.int(14, title="DI Length")
threshold = input.int(40, title="Threshold")
tpPerc = input.float(2.0, title="Take Profit (%)")
atrLength = input.int(14, title="ATR Length")
atrMult = input.float(1.5, title="ATR Multiplier for SL")

// === CALCULATIONS ===
[plusDI, minusDI, _] = ta.dmi(length, length)
atr = ta.atr(atrLength)

// === CONDITIONS ===
buySignal = ta.crossover(plusDI, threshold)
sellSignal = ta.crossover(minusDI, threshold)

// === STRATEGY LOGIC ===
// Long trade parameters
longTP = close * (1 + tpPerc / 100)
longSL = close - atr * atrMult

// Short trade parameters
shortTP = close * (1 - tpPerc / 100)
shortSL = close + atr * atrMult

// Enter Long
if (buySignal)
    strategy.entry("Long", strategy.long)
    strategy.exit("Exit Long", from_entry="Long", stop=longSL, limit=longTP)

// Enter Short
if (sellSignal)
    strategy.entry("Short", strategy.short)
    strategy.exit("Exit Short", from_entry="Short", stop=shortSL, limit=shortTP)

