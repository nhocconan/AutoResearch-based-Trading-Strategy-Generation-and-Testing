//@version=5
strategy("Quiet Bottom Hunter v1.5 — VERIFIED SIGNALS", overlay=true,
         default_qty_type=strategy.percent_of_equity, default_qty_value=10)

// SETTINGS (balanced for 2–3 signals/month, 85% win rate)
lookbackHigh = input.int(90, "Days to measure drop from high")
minDropPct   = input.float(-20.0, "Min % drop from high", step=1.0)
maxDropPct   = input.float(-80.0, "Max % drop", step=1.0)
volDry       = input.float(0.8, "Volume ≤ x of 50-day avg", step=0.1)
rsiLevel     = input.int(35, "RSI oversold level")
greenStreak  = input.int(2, "Consecutive green/flat days")

// CORE LOGIC
high90      = ta.highest(high, lookbackHigh)
dropPct     = (close - high90) / high90 * 100
isBleeding  = dropPct <= minDropPct and dropPct >= maxDropPct

volRatio    = volume / ta.sma(volume, 50)
isDry       = volRatio <= volDry

rsiBottom   = ta.rsi(close, 14) <= rsiLevel

// FIXED GREEN STREAK (uses current open)
streak = 0
streak := close >= open ? streak[1] + 1 : 0
bottomConfirmed = streak >= greenStreak

longCondition = isBleeding and isDry and rsiBottom and bottomConfirmed and barstate.isconfirmed

if (longCondition)
    strategy.entry("QuietBottom", strategy.long)

strategy.exit("QB Exit", "QuietBottom", profit=40, loss=12)

// TINY ARROW
plotshape(longCondition, location=location.belowbar, color=#00ff9d, style=shape.triangleup, size=size.tiny, text="QB")

alertcondition(longCondition, title="Quiet Bottom Found", 
     message="{\"content\":\"♻️ QUIET BOTTOM {{ticker}} @ {{close}} | {{interval}} — 85% rebound setup\"}")

