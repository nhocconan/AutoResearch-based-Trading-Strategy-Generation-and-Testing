//@version=5
strategy("VWAP + Multi-Timeframe RSI Strategy", overlay=true, margin_long=100, margin_short=100)

// --- Inputs
rsiLength     = input.int(14, "RSI Length")
rsiOB         = input.int(70, "RSI Overbought")
rsiOS         = input.int(30, "RSI Oversold")
higherTF      = input.timeframe("60", "Higher Timeframe RSI") // default H1

// --- VWAP
vwapValue = ta.vwap

// --- RSI (current TF)
rsiCurr = ta.rsi(close, rsiLength)

// --- RSI (higher TF)
rsiHTF = request.security(syminfo.tickerid, higherTF, ta.rsi(close, rsiLength))

// --- Conditions
longCondition  = close > vwapValue and rsiCurr < rsiOB and rsiHTF > 50
shortCondition = close < vwapValue and rsiCurr > rsiOS and rsiHTF < 50

// --- Strategy Execution
if (longCondition)
    strategy.entry("Long", strategy.long)

if (shortCondition)
    strategy.entry("Short", strategy.short)

// --- Exit rules (TP/SL relative to VWAP)
strategy.exit("Exit Long",  from_entry="Long", stop=vwapValue * 0.995, profit=vwapValue * 1.02)
strategy.exit("Exit Short", from_entry="Short", stop=vwapValue * 1.005, profit=vwapValue * 0.98)

// --- Alerts
alertcondition(longCondition, title="Buy Signal", message="📈 BUY - VWAP + MTF RSI Bullish Confirmation")
alertcondition(shortCondition, title="Sell Signal", message="📉 SELL - VWAP + MTF RSI Bearish Confirmation")

// --- Plot
plot(vwapValue, "VWAP", color=color.yellow, linewidth=2)
plotshape(longCondition, title="Buy", style=shape.labelup, color=color.green, text="BUY")
plotshape(shortCondition, title="Sell", style=shape.labeldown, color=color.red, text="SELL")

