//@version=4
//study(title="Histogram Strategy by Sedkur", shorttitle="Histogram Strategy by Sedkur")
strategy (title="Histogram Strategy by Sedkur", shorttitle="HS")

// Getting inputs
dyear = input(title="Year", type=input.integer, defval=2017, minval=1950, maxval=2500)
//select = input(title="Select", type=input.string, defval="MACD", options=["MACD", "Histogram"])
fast_length = input(title="Fast Length", type=input.integer, defval=64)
slow_length = input(title="Slow Length", type=input.integer, defval=270)
buyh = input(title="Buy if histogram >", type=input.float, defval=-1.0, minval=-10000, maxval=10000, step=0.1) 
buyh2 = input(title="Buy if histogram <", type=input.float, defval=1.0, minval=-10000, maxval=10000, step=0.1)
sellh2 = input(title="Sell if histogram >", type=input.float, defval=0.003, minval=-10000, maxval=10000, step=0.1)
sellh = input(title="Sell if histogram <", type=input.float, defval=1.0, minval=-10000, maxval=10000, step=0.1)

hist_length = input(title="Histogram Length", type=input.integer, defval=9, minval=1, maxval=100)
hist_error = input(title="Histogram Error Margin", type=input.integer, defval=0, minval=0, maxval=10)
src = input(title="Source", type=input.source, defval=close)
signal_length = input(title="Signal Smoothing", type=input.integer, minval = 1, maxval = 50, defval = 9)
sma_source = input(title="Simple MA(Oscillator)", type=input.bool, defval=false)
sma_signal = input(title="Simple MA(Signal Line)", type=input.bool, defval=false)


// Plot colors
col_grow_above = #26A69A
col_grow_below = #FFCDD2
col_fall_above = #B2DFDB
col_fall_below = #EF5350
col_macd = #0094ff
col_signal = #ff6a00

/// Calculating
fast_ma = sma_source ? sma(src, fast_length) : ema(src, fast_length)
slow_ma = sma_source ? sma(src, slow_length) : ema(src, slow_length)
macd = fast_ma - slow_ma
signal = sma_signal ? sma(macd, signal_length) : ema(macd, signal_length)
hist = macd - signal

plot(hist, title="Histogram", style=plot.style_columns, color=(hist>=0 ? (hist[1] < hist ? col_grow_above : col_fall_above) : (hist[1] < hist ? col_grow_below : col_fall_below) ), transp=0 )
//plot(macd, title="MACD", color=col_macd, transp=0)
//plot(signal, title="Signal", color=col_signal, transp=0)

//bullish = hist[1] <= hist and buyh<=hist?true:false
//bearish = hist[1] >= hist and sellh>=hist?true:false
bull=0
bear=0
ax=0
bx=0
//bullish = true
//bearish = true

for i=0 to hist_length+hist_error
    if (hist[i+1] <= hist[i])
        bull:=bull+1
    if ((hist[i+1] >= hist[i]) and ax<hist_error)
        ax:=ax+1
//        hist_length:=hist_length+1

bullish = bull==hist_length+1?true:false 


for j=0 to hist_length+hist_error
    if (hist[j+1] >= hist[j])
        bear:=bear+1
        
    if ((hist[j+1] <= hist[j]) and bx<hist_error)
        bx:=bx+1
//        hist_length:=hist_length+1
        
bearish = bear==hist_length+1?true:false 

//if (bear>(hist_length/2))
//    bearish := bear==hist_length?true:false  

bullish2 = buyh<=hist and hist<=buyh2?true:false
bearish2 = sellh>=hist and hist>=sellh2?true:false

//bullish = hist[1] <= hist and hist[2] <= hist and hist[3] <= hist and hist[4] <= hist and hist[5] <= hist?true:false
//bearish = hist[1] >= hist and hist[2] >= hist and hist[3] >= hist and hist[4] >= hist and hist[5] >= hist?true:false

strategy.entry("buy", strategy.long, comment="buy", when = bullish and bullish2 and year>=dyear)
strategy.entry("sell", strategy.short, comment="sell", when = bearish and bearish2 and year>=dyear)

