//@version=6
strategy("Multi-Mode Adaptive Strategy [MMAS]",
     overlay=true,
     initial_capital=100000,
     pyramiding=0,
     commission_type=strategy.commission.percent,
     commission_value=0.05,
     calc_on_every_tick=true,
     calc_on_order_fills=true,
     max_labels_count=500)

// ==============================
// Inputs
// ==============================
mode       = input.string("Trend", "Mode", options=["Trend", "Mean-Reversion", "Breakout"])
src        = input.source(close, "Source")
tf         = input.string("", "Higher TF (optional)", tooltip="Example: 60, 240, D. Leave empty to use chart TF.")
useHTF     = tf != ""

riskPct    = input.float(1.0, "Risk per Trade (%)", minval=0.1, maxval=10, step=0.1)
useSLTP    = input.bool(true, "Use Stop & Take Profit")
slPct      = input.float(1.0, "Stop Loss (%)", minval=0.1, maxval=10, step=0.1)
tpPct      = input.float(2.0, "Take Profit (%)", minval=0.1, maxval=20, step=0.1)

// ==============================
// Helpers
// ==============================
get(srcInput) =>
    useHTF ? request.security(syminfo.tickerid, tf, srcInput, barmerge.gaps_off, barmerge.lookahead_off) : srcInput

price   = get(src)
maFast  = ta.sma(get(close), 20)
maSlow  = ta.sma(get(close), 50)
atrT    = ta.atr(14)
rsi     = ta.rsi(get(close), 14)
donHigh = ta.highest(get(high), 20)
donLow  = ta.lowest(get(low), 20)

// ==============================
// Signals per Mode
// ==============================
trendLong  = price > maFast and maFast > maSlow
trendShort = price < maFast and maFast < maSlow
trendSL    = price - 2.0 * atrT
trendSS    = price + 2.0 * atrT

mrLong     = rsi <= 30
mrShort    = rsi >= 70
mrSL       = price - 1.5 * atrT
mrSS       = price + 1.5 * atrT

boLong     = ta.crossover(price, donHigh)
boShort    = ta.crossunder(price, donLow)
boSL       = price - 2.0 * atrT
boSS       = price + 2.0 * atrT

// ==============================
// Mode switch (v6 syntax)
// ==============================
bool goLong  = false
bool goShort = false
float stopLong = na
float stopShort = na

switch mode
    "Trend" => 
        goLong   := trendLong
        goShort  := trendShort
        stopLong := trendSL
        stopShort:= trendSS
    "Mean-Reversion" => 
        goLong   := mrLong
        goShort  := mrShort
        stopLong := mrSL
        stopShort:= mrSS
    "Breakout" => 
        goLong   := boLong
        goShort  := boShort
        stopLong := boSL
        stopShort:= boSS

// ==============================
// Entries
// ==============================
if goLong and strategy.position_size <= 0
    strategy.entry("LONG", strategy.long)

if goShort and strategy.position_size >= 0
    strategy.entry("SHORT", strategy.short)

// ==============================
// Exits
// ==============================
if useSLTP
    if strategy.position_size > 0
        longSL = strategy.position_avg_price * (1.0 - slPct/100.0)
        longTP = strategy.position_avg_price * (1.0 + tpPct/100.0)
        strategy.exit("LX", "LONG", stop=longSL, limit=longTP)
    if strategy.position_size < 0
        shortSL = strategy.position_avg_price * (1.0 + slPct/100.0)
        shortTP = strategy.position_avg_price * (1.0 - tpPct/100.0)
        strategy.exit("SX", "SHORT", stop=shortSL, limit=shortTP)

// ==============================
// Plotting
// ==============================
plot(maFast, "Fast MA", color=color.teal)
plot(maSlow, "Slow MA", color=color.orange)
plot(donHigh, "Donchian High", color=color.green)
plot(donLow,  "Donchian Low",  color=color.red)

