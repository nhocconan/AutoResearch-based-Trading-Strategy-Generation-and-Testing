//@version=5
strategy("Strategia S&P 500 vs US10Y Yield", overlay=true, initial_capital=10000, default_qty_type=strategy.percent_of_equity, default_qty_value=100)

// --- USTAWIENIA ---
// Symbol rentowności obligacji (Treasury Yield 10Y)
yieldSymbol = input.symbol("US10Y", "Symbol Rentowności (Yield)")
// Okres dla zakresu (range) - z obrazka wynika, że to 63 dni (ok. 3 miesiące handlowe)
lookbackPeriod = input.int(63, "Okres zakresu (dni)", minval=1)
// Próg procentowy (80% zakresu)
thresholdPercent = input.float(0.80, "Próg zakresu (0.80 = 80%)", step=0.01)

// --- POBIERANIE DANYCH ---
// Pobieramy zamknięcia rentowności 10-letniej. Używamy request.security, aby mieć dane niezależnie od wykresu, na którym jesteśmy.
yieldClose = request.security(yieldSymbol, "D", close)

// --- OBLICZENIA WSKAŹNIKA (Yield % of Range) ---
// Obliczamy najwyższy i najniższy poziom rentowności w oknie 63 dni
yieldHigh = ta.highest(yieldClose, lookbackPeriod)
yieldLow  = ta.lowest(yieldClose, lookbackPeriod)

// Obliczamy pozycję obecnej rentowności w tym zakresie (Stochastic formula)
// Wzór: (Obecna cena - Minimum) / (Maksimum - Minimum)
yieldPosition = (yieldClose - yieldLow) / (yieldHigh - yieldLow)

// --- LOGIKA STRATEGII ---
// Warunek "Risk Off" (Ucieczka do gotówki): Jeśli Yield jest powyżej 80% zakresu
isRiskOff = yieldPosition > thresholdPercent

// Warunek "Risk On" (Kupno akcji): Jeśli Yield jest poniżej lub równy 80% zakresu
isRiskOn = not isRiskOff

// --- WYKONYWANIE ZLECEŃ ---
if (isRiskOn)
    // Jeśli jest bezpiecznie, wchodzimy w pozycję długą (lub ją utrzymujemy)
    strategy.entry("Long SP500", strategy.long, comment="Kupno")
else
    // Jeśli rentowność rośnie gwałtownie (Risk Off), zamykamy pozycję (przechodzimy w gotówkę)
    strategy.close("Long SP500", comment="Gotówka")

// --- WIZUALIZACJA (Opcjonalna) ---
// Kolor tła, żeby widzieć kiedy strategia jest poza rynkiem
bgcolor(isRiskOff ? color.new(color.red, 90) : na, title="Okresy w gotówce")

// Możesz dodać plotowanie wskaźnika w osobnym oknie, jeśli zmienisz overlay=false
// plot(yieldPosition, title="Yield Position", color=color.red)
// hline(thresholdPercent, title="Próg 80%", color=color.gray, linestyle=hline.style_dashed)

