//@version=3
strategy("Strong Potential Asset Strategy (EMA + EMA)", overlay=true)
fastPeriod = input(5, minval=1, title="Fast EMA Length")
slowPeriod = input(9, minval=1, title="Slow EMA Length")
minDiff = input(0.01, minval=0.01, title="Difference")
crossoverTolerance = input(5, minval=0.01, title="Exit tolerance")

fastEMA = ema(close, fastPeriod)
slowEMA = ema(close, slowPeriod)
plot(fastEMA, color=green)
plot(slowEMA, color=red)
difference = fastEMA - slowEMA

yearsToTest = input(2, minval=1, title="Years to test")
start = timenow - (31540000000 * yearsToTest)
window() => time >= start and time <= timenow ? true : false

if (difference >= minDiff)
    strategy.entry("My Long Entry Id", strategy.long, when=strategy.position_size == 0 and window())

if (difference <= 0 and difference <= (crossoverTolerance * -1))
    strategy.close("My Long Entry Id")

