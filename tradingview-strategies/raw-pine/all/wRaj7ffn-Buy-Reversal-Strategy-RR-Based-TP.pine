//@version=6
strategy("Buy_Reversal Strategy (RR Based TP)", 
     overlay=true,
     calc_on_every_tick=true,
     process_orders_on_close=false,
     pyramiding=0)

// ===== INPUTS =====
length      = input.int(50, "Channel Length")
atrLength   = input.int(20, "ATR Length")
swingLookbk = input.int(5, "Swing Lookback")
rrMultiplier = input.float(2.0, "Risk Reward Ratio (TP)") // ⭐ NEW

// ===== CHANNEL =====
downBound = ta.lowest(low[1], length)

// ===== ATR =====
atr = ta.atr(atrLength)

// ===== VARIABLES =====
var bool sellActive = false
var float trailSL = na
var float tpPrice = na

// ===== FIRST BREAKOUT SELL MARK =====
sellBreak = low < downBound and low[1] >= downBound[1]

if sellBreak and not sellActive
    sellActive := true
    trailSL := high + atr

    label.new(bar_index, high, "",
         style=label.style_label_down,
         color=color.red, textcolor=color.white)

    // EXIT BUY IF RUNNING
    if strategy.position_size > 0
        strategy.close("BUY")

// ===== TRAILING UPDATE =====
if sellActive
    newSL = ta.highest(high, swingLookbk) + atr
    trailSL := math.min(trailSL, newSL)

// ===== BUY ENTRY =====
buySignal = sellActive and ta.crossover(close, trailSL)

if buySignal
    strategy.entry("BUY", strategy.long)

    label.new(bar_index, low, "BUY",
         style=label.style_label_up,
         color=color.green, textcolor=color.white)

    sellActive := false
    trailSL := na
    tpPrice := na

// ===================================================
// ===== RISK REWARD PROFIT TARGET CALCULATION =====
// ===================================================
if strategy.position_size > 0 and na(tpPrice)
    risk = strategy.position_avg_price - downBound
    tpPrice := strategy.position_avg_price + (risk * rrMultiplier)

// ===== EXIT WHEN TARGET HIT =====
if strategy.position_size > 0 and not na(tpPrice)
    if close >= tpPrice
        strategy.close("BUY")

// ===== RESET =====
if strategy.position_size == 0
    tpPrice := na

// ===== PLOTS =====
plot(downBound, "Lower Channel", color=color.red)
plot(trailSL, "ATR Trail", color=color.orange, style=plot.style_linebr)
plot(tpPrice, "RR Target", color=color.blue)

