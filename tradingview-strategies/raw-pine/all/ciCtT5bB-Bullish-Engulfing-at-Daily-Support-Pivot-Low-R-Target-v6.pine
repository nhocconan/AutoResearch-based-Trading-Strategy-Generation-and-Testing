//@version=6
strategy("Bullish Engulfing at Daily Support (Pivot Low) - R Target (v6)",
     overlay=true,
     initial_capital=100000,
     commission_type=strategy.commission.percent,
     commission_value=0.0,
     calc_on_every_tick=false,
     process_orders_on_close=true)

// ─────────────────────────────────────────────────────────────────────────────
// Inputs
// ─────────────────────────────────────────────────────────────────────────────
useDailyOnly     = input.bool(true, "Only trade when chart timeframe is Daily?")
pivotLeft        = input.int(3, "Pivot left bars (daily)", minval=1)
pivotRight       = input.int(3, "Pivot right bars (daily)", minval=1)
supportTolPct    = input.float(0.5, "Support tolerance (%)", minval=0.0, step=0.1)
strictEngulf     = input.bool(false, "Strict engulfing (>, <) instead of (>=, <=)?")

riskPct          = input.float(1.0, "Risk per trade (% of equity)", minval=0.1, step=0.1)
rMultipleTP      = input.float(2.8, "Take profit (R multiple)", minval=0.2, step=0.1)
stopBufferATR    = input.float(0.2, "Stop buffer (ATR multiple)", minval=0.0, step=0.1)
atrLen           = input.int(14, "ATR length", minval=1)

// ─────────────────────────────────────────────────────────────────────────────
// Daily series (works even if chart isn't daily)
// ─────────────────────────────────────────────────────────────────────────────
dOpen  = request.security(syminfo.tickerid, "D", open)
dHigh  = request.security(syminfo.tickerid, "D", high)
dLow   = request.security(syminfo.tickerid, "D", low)
dClose = request.security(syminfo.tickerid, "D", close)

dOpen1  = request.security(syminfo.tickerid, "D", open[1])
dClose1 = request.security(syminfo.tickerid, "D", close[1])

dATR = request.security(syminfo.tickerid, "D", ta.atr(atrLen))

// ─────────────────────────────────────────────────────────────────────────────
// Support = last confirmed daily pivot low
// ─────────────────────────────────────────────────────────────────────────────
dPivotLow = request.security(syminfo.tickerid, "D", ta.pivotlow(low, pivotLeft, pivotRight))

var float lastSupport = na
if not na(dPivotLow)
    lastSupport := dPivotLow

// Price "at support" if daily low is within tolerance zone
tol = supportTolPct / 100.0
atSupport = not na(lastSupport) and (math.abs(dLow - lastSupport) / lastSupport <= tol or dLow <= lastSupport * (1.0 + tol))

// ─────────────────────────────────────────────────────────────────────────────
// Bullish engulfing (daily)
// ─────────────────────────────────────────────────────────────────────────────
bullishNow = dClose > dOpen

bool engulfOK = false
if strictEngulf
    engulfOK := (dOpen < dClose1) and (dClose > dOpen1)
else
    engulfOK := (dOpen <= dClose1) and (dClose >= dOpen1)

bullEngulf = bullishNow and engulfOK

// ─────────────────────────────────────────────────────────────────────────────
// Filters
// ─────────────────────────────────────────────────────────────────────────────
tfOk = (not useDailyOnly) or timeframe.isdaily

// Entry condition
longSignal = tfOk and atSupport and bullEngulf

// ─────────────────────────────────────────────────────────────────────────────
// Position sizing + exits (R-based target)
// Stop: below min(support, engulfing low) minus ATR buffer
// ─────────────────────────────────────────────────────────────────────────────
stopRef = na(lastSupport) ? dLow : math.min(lastSupport, dLow)
stopLevel = stopRef - (dATR * stopBufferATR)

riskPerUnit = dClose - stopLevel
validRisk = riskPerUnit > syminfo.mintick

riskDollars = strategy.equity * (riskPct / 100.0)
qty = validRisk ? (riskDollars / riskPerUnit) : na

tpLevel = dClose + (riskPerUnit * rMultipleTP)

// Orders
if longSignal and validRisk
    strategy.entry("L", strategy.long, qty=qty)
    strategy.exit("L-exit", "L", stop=stopLevel, limit=tpLevel)

// ─────────────────────────────────────────────────────────────────────────────
// Plotting
// ─────────────────────────────────────────────────────────────────────────────
plot(lastSupport, "Daily Pivot Support", linewidth=2, style=plot.style_linebr)
plotshape(longSignal, title="Bull Engulf @ Support", style=shape.triangleup, location=location.belowbar, size=size.tiny)

var label info = na
if barstate.islast
    if not na(info)
        label.delete(info)
    info := label.new(bar_index, high,
         "Support=" + (na(lastSupport) ? "na" : str.tostring(lastSupport, format.mintick)) +
         "\nTol=" + str.tostring(supportTolPct) + "%" +
         "\nR TP=" + str.tostring(rMultipleTP),
         style=label.style_label_left, textcolor=color.white, color=color.new(color.black, 60))

