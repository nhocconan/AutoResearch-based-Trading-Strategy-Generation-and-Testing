//@version=3
strategy(title="Help needed with basic strategy", shorttitle="Help Needed", overlay=true)

// Revision:        1
// Author:          @GordonR 

//=== Inputs ===
fastMAPeriod    = input(defval = 10, title = "Fast MA Period", minval=1)
slowMAPeriod    = input(defval = 20, title = "Slow MA Period", minval=1)

//=== Calculations ===
fastMA = sma(close, fastMAPeriod)
slowMA = sma(close, slowMAPeriod)

//=== Drawing ===
//Plot the moving average lines
fastMAPlot = plot(fastMA, color = blue, linewidth = 1, title='Fast MA')
slowMAPlot = plot(slowMA, color = navy, linewidth = 2, title='Slow MA')

//=== Buy / Sell indicators ===
longEntryCondition = crossover(fastMA,slowMA)
plotshape(longEntryCondition, color=green, style=shape.arrowup, text="Buy")
strategy.entry(id = "Long", long = true, when = longEntryCondition)             //Why is this off by 1 compared to the arrow we just drew?

shortEntryCondition = crossunder(fastMA,slowMA)
plotshape(shortEntryCondition, color=red, style=shape.arrowdown, text="Sell")
strategy.entry(id = "Short", long = false, when = shortEntryCondition)          //Why is this off by 1 compared to the arrow we just drew?

