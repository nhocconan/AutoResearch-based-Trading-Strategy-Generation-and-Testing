//@version=2
strategy(title='Ali Jitu Abis', shorttitle='Ali_Jitu_Abis_Strategy', overlay=true, pyramiding=0, initial_capital=100, currency=currency.USD, default_qty_type = strategy.cash, default_qty_value = 100)

// Parabolic SAR
parabolicSARStart=input(0.01)
parabolicSARInc=input(0.01)
parabolicSARMax=input(0.2)
psarDot = sar(parabolicSARStart,parabolicSARInc,parabolicSARMax)
longConditionPSAR = psarDot > close
shortConditionPSAR = psarDot < close

// Stoch
periodK = input(14, title="K", minval=1)
periodD = input(3, title="D", minval=1)
smoothK = input(3, title="Smooth", minval=1)
k = sma(stoch(close, high, low, periodK), smoothK)
d = sma(k, periodD)
h0 = 80
h1 = 20
longConditionStoch = k < h1
shortConditionStoch = k > h0

// Security
securityPeriod=input('180')
longConditionSecurity = crossover(security(tickerid, securityPeriod, close),security(tickerid, securityPeriod, open))
shortConditionSecurity = crossunder(security(tickerid, securityPeriod, close),security(tickerid, securityPeriod, open))

// Generate Signal
longCondition = longConditionSecurity and longConditionPSAR and longConditionStoch
shortCondition = shortConditionSecurity and shortConditionPSAR and shortConditionStoch

if (longCondition)
    strategy.entry("Long", strategy.long)

if (shortCondition)
    strategy.entry("Short", strategy.short)

