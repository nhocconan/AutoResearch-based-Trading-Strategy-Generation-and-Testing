//@version=6
strategy("Channel Breakout – BUY + SELL + Body TL SL + AUTO REVERSE",
     overlay=true,
     pyramiding=0)

// ================= INPUTS =================
length     = input.int(30, "Channel Length")
leftBars   = input.int(8, "Swing Left")
rightBars  = input.int(5, "Swing Right")
extendBars = input.int(4, "Extend Line Right")
slCandles  = input.int(8, "Exit after N candles beyond line")

// ================= CHANNEL =================
upBound   = ta.highest(high, length)
downBound = ta.lowest(low, length)

// ================= SWINGS =================
swingLow  = ta.pivotlow(low, leftBars, rightBars)
swingHigh = ta.pivothigh(high, leftBars, rightBars)

var float lastSwingLow = na
var int   lastSwingLowBar = na
var float lastSwingHigh = na
var int   lastSwingHighBar = na

if not na(swingLow)
    lastSwingLow := swingLow
    lastSwingLowBar := bar_index - rightBars

if not na(swingHigh)
    lastSwingHigh := swingHigh
    lastSwingHighBar := bar_index - rightBars

// ================= ENTRIES =================
strategy.entry("BUY", strategy.long, stop=upBound + syminfo.mintick)
strategy.entry("SELL", strategy.short, stop=downBound - syminfo.mintick)

// ================= TRENDLINES =================
var line buyLine  = na
var line sellLine = na
var int buyCount  = 0
var int sellCount = 0

newLong  = strategy.position_size > 0 and strategy.position_size[1] <= 0
newShort = strategy.position_size < 0 and strategy.position_size[1] >= 0

if newLong and not na(lastSwingLow)
    line.delete(buyLine)
    buyLine := line.new(bar_index-1, low[1], lastSwingLowBar + extendBars, lastSwingLow,
         color=color.blue, width=2)
    buyCount := 0

if newShort and not na(lastSwingHigh)
    line.delete(sellLine)
    sellLine := line.new(bar_index-1, high[1], lastSwingHighBar + extendBars, lastSwingHigh,
         color=color.red, width=2)
    sellCount := 0

// ================= BUY SL → REVERSE TO SELL =================
if strategy.position_size > 0 and not na(buyLine)
    lp = line.get_price(buyLine, bar_index)
    if close < open and math.max(open, close) < lp and low < lp
        buyCount += 1

if buyCount >= slCandles
    strategy.entry("SELL", strategy.short)
    buyCount := 0

// ================= SELL SL → REVERSE TO BUY =================
if strategy.position_size < 0 and not na(sellLine)
    lp = line.get_price(sellLine, bar_index)
    if close > open and math.min(open, close) > lp and high > lp
        sellCount += 1

if sellCount >= slCandles
    strategy.entry("BUY", strategy.long)
    sellCount := 0

// ================= PLOTS =================
plot(upBound, "Upper Channel", color=color.green)
plot(downBound, "Lower Channel", color=color.red)

plotshape(swingHigh, style=shape.triangleup, location=location.abovebar, color=color.orange)
plotshape(swingLow, style=shape.triangledown, location=location.belowbar, color=color.purple)

View in Pine Editor・84 lines
