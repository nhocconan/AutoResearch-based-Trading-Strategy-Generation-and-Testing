//@version=5
strategy("AVWAP+RSI Confluence — 1R Tester", overlay=true, process_orders_on_close=true, initial_capital=100000)

// ---- PLACEHOLDER signals (swap with your AVWAP+RSI logic) ----
rsi = ta.rsi(close, 14)
longSignal  = ta.crossover(close, ta.sma(close, 20)) and rsi > 50
shortSignal = ta.crossunder(close, ta.sma(close, 20)) and rsi < 50

// ---- 1R risk model via ATR ----
atr     = ta.atr(14)
atrMult = input.float(1.0, "ATR multiple for 1R", step=0.1)

// Long entries/exits
if longSignal
    entry = close
    strategy.entry("L", strategy.long)
    strategy.exit("L-Exit", "L", stop=entry - atr*atrMult, limit=entry + atr*atrMult)

// Short entries/exits
if shortSignal
    entry = close
    strategy.entry("S", strategy.short)
    strategy.exit("S-Exit", "S", stop=entry + atr*atrMult, limit=entry - atr*atrMult)

// ---- Count +1R wins vs -1R losses on CLOSED trades ----
var wins   = 0
var losses = 0
newClosed = ta.change(strategy.closedtrades) > 0
if newClosed
    pl = strategy.closedtrades.profit(strategy.closedtrades - 1)
    if pl > 0
        wins += 1
    else if pl < 0
        losses += 1
winrate = (wins + losses) > 0 ? 100 * wins / (wins + losses) : na

var t = table.new(position.top_right, 1, 3)
if barstate.islast
    table.cell(t, 0, 0, "Wins: "   + str.tostring(wins))
    table.cell(t, 0, 1, "Losses: " + str.tostring(losses))
    table.cell(t, 0, 2, "WinRate: "+ str.tostring(winrate, "#.##") + "%")

