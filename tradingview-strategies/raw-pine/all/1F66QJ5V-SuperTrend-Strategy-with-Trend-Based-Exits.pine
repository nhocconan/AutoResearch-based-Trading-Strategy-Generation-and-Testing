//@version=6
strategy('SuperTrend Strategy with Trend-Based Exits', overlay = true, initial_capital = 10000, default_qty_type = strategy.cash, default_qty_value = 1000, pyramiding = 1, commission_type = strategy.commission.percent, commission_value = 0.05, slippage = 5)

// === User Inputs ===
risk_per_trade = input.float(200, title = 'Risk per trade (USD)', minval = 10, step = 10)  // Fixed dollar risk per trade, recommened risk per trade = 2% of initial capital
atrPeriod = input.int(92, title = 'ATR Length', minval = 1, step = 1)                      // ATR period for SuperTrend, relevant for ETH only, please adjust for other assets
factor = input.float(4.6, title = 'Factor', minval = 0.01, step = 0.1)                    // SuperTrend multiplier, relevant for ETH only, please adjust for other assets
lot_step = input.float(0.01, title = 'Qty step', step = 0.01)                             // Position rounding step, default 0.01 is suitable for ETH, BTC, MKR or other "expensive" assets, otherwise use 1,10 or 100)

// === SuperTrend Calculation ===
[supertrend, direction] = ta.supertrend(factor, atrPeriod)
price = close
stop_loss_distance = math.abs(price - supertrend)

// === Position Sizing with Rounding ===
position_size_raw = risk_per_trade / stop_loss_distance
position_size = math.floor(position_size_raw / lot_step) * lot_step

// === Trend Direction Logic ===
intDirection = int(direction)
var int lastDirection = na
isNewDirection = na(lastDirection) or intDirection != lastDirection

// === Entry Logic ===
if isNewDirection
    // Close existing positions before reversing
    strategy.close('Long')
    strategy.close('Short')

    // Enter new position based on direction
    if intDirection == -1 and strategy.position_size <= 0
        strategy.entry('Long', strategy.long, qty = position_size)
    else if intDirection == 1 and strategy.position_size >= 0
        strategy.entry('Short', strategy.short, qty = position_size)

    // Save current direction
    lastDirection := intDirection

// === Exit Logic (Stop on SuperTrend) ===
if strategy.position_size > 0
    strategy.exit('Exit Long', 'Long', stop = supertrend)
if strategy.position_size < 0
    strategy.exit('Exit Short', 'Short', stop = supertrend)

// === SuperTrend Visualization ===
plot(supertrend, title = 'Supertrend', color = direction < 0 ? color.green : color.red)

