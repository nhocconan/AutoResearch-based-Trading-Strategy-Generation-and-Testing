//@version=5
strategy("Indian Scalper 2025 – PSAR + SMA50 + RSI≤50 + High Volume", 
         overlay=true, 
         commission_value=0.025, 
         default_qty_type=strategy.percent_of_equity, 
         default_qty_value=100, 
         pyramiding=0)

// ────────────────── INPUTS ──────────────────
psarStep = input.float(0.02,  "PSAR Step",          step=0.001)
psarMax  = input.float(0.20,  "PSAR Max",           step=0.01)
volMult  = input.float(1.5,   "Volume Multiplier",  minval=1.0, step=0.1)

// ────────────────── INDICATORS ──────────────────
sma50    = ta.sma(close, 50)
psar     = ta.sar(psarStep, psarStep, psarMax)
rsi      = ta.rsi(close, 14)
avgVol   = ta.sma(volume, 20)
highVol  = volume > avgVol * volMult

// ────────────────── PLOTS ──────────────────
plot(sma50, color=color.orange, linewidth=2, title="SMA 50")
plot(psar, style=plot.style_circles, linewidth=3, 
     color=psar < close ? color.green : color.red, title="Parabolic SAR")
barcolor(highVol ? (close > open ? #00ff00 : #ff0066) : na, title="High Volume Candle")

// ────────────────── ENTRY CONDITIONS ──────────────────
longCondition  = close > sma50 and ta.crossover(psar, close) and rsi <= 50 and highVol
shortCondition = close < sma50 and ta.crossunder(psar, close) and rsi >= 50 and highVol

// ────────────────── ENTRIES WITH MOBILE ALERTS ──────────────────
if longCondition
    strategy.entry("Long", strategy.long,
         alert_message="BUY {{ticker}} @ {{close}} | HIGH VOL | SL ≈{{close - ta.atr(14)*1.2}} | Target 1:2+")

if shortCondition
    strategy.entry("Short", strategy.short,
         alert_message="SELL {{ticker}} @ {{close}} | HIGH VOL | SL ≈{{close + ta.atr(14)*1.2}} | Target 1:2+")

// ────────────────── EXITS (2R profit + 1.2×ATR stop + PSAR trail) ──────────────────
atr14 = ta.atr(14)
strategy.exit("XL", "Long",  profit=atr14*2, loss=atr14*1.2, trail_points=psar)
strategy.exit("XS", "Short", profit=atr14*2, loss=atr14*1.2, trail_points=psar)

// ────────────────── BIG ARROWS ──────────────────
plotshape(longCondition,  title="BUY",  location=location.belowbar, color=color.new(color.lime,0),
          style=shape.triangleup, size=size.large, text="BUY\nVOL", textcolor=color.black)

plotshape(shortCondition, title="SELL", location=location.abovebar, color=color.new(color.red,0),
          style=shape.triangledown, size=size.large, text="SELL\nVOL", textcolor=color.white)

