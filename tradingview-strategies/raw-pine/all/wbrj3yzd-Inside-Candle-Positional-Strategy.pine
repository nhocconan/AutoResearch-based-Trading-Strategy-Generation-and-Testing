//@version=5
strategy("Inside Candle Positional Strategy", overlay=true, initial_capital=1000, commission_type=strategy.commission.percent, commission_value=0.05, default_qty_type=strategy.fixed, default_qty_value=1, pyramiding=0)

// ─────────────────────────────
// INPUTS
// ─────────────────────────────

groupRisk = "Risk Management"
rr = input.float(3.0, "Risk Reward Ratio", minval = 0.1, group = groupRisk)

groupTSL = "Trailing Stop"
useTSL = input.bool(true, "Use Trailing Stop", group = groupTSL)
atrPeriod = input.int(10, "ATR Period", minval = 1, group = groupTSL)
atrMultiplier = input.float(1.0, "ATR Multiplier", minval = 0.1, group = groupTSL)

groupVisual = "Visual Settings"
insideColor = input.color(color.yellow, "Inside Candle Color", group = groupVisual)

// ─────────────────────────────
// MOTHER & INSIDE CANDLE LOGIC
// ─────────────────────────────

var float motherHigh = na
var float motherLow = na
var bool motherActive = false
var bool breakoutTaken = false

insideBar = high < high[1] and low > low[1]

// Highlight inside candle
barcolor(insideBar ? insideColor : na)

if insideBar and strategy.position_size == 0
    motherHigh := high[1]
    motherLow := low[1]
    motherActive := true
    breakoutTaken := false

// ─────────────────────────────
// ENTRY CONDITIONS
// ─────────────────────────────

longCondition = motherActive and not breakoutTaken and close > motherHigh and strategy.position_size == 0
shortCondition = motherActive and not breakoutTaken and close < motherLow and strategy.position_size == 0

if longCondition
    strategy.entry("Long Entry", strategy.long)
    breakoutTaken := true

if shortCondition
    strategy.entry("Short Entry", strategy.short)
    breakoutTaken := true

// ─────────────────────────────
// TRADE VARIABLES
// ─────────────────────────────

var float initialSL = na
var float target = na
var float trailingSL = na

atrValue = ta.atr(atrPeriod) * atrMultiplier

newLong = strategy.position_size > 0 and strategy.position_size[1] == 0
newShort = strategy.position_size < 0 and strategy.position_size[1] == 0
positionClosed = strategy.position_size == 0 and strategy.position_size[1] != 0

// ─────────────────────────────
// SET INITIAL SL & TARGET
// ─────────────────────────────

if newLong
    entryPrice = strategy.position_avg_price
    risk = entryPrice - motherLow
    initialSL := motherLow
    target := entryPrice + risk * rr
    trailingSL := initialSL

if newShort
    entryPrice = strategy.position_avg_price
    risk = motherHigh - entryPrice
    initialSL := motherHigh
    target := entryPrice - risk * rr
    trailingSL := initialSL

// ─────────────────────────────
// TRAILING STOP UPDATE
// ─────────────────────────────

if strategy.position_size > 0 and useTSL
    newTSL = close - atrValue
    trailingSL := math.max(trailingSL, newTSL)
    trailingSL := math.max(trailingSL, initialSL)

if strategy.position_size < 0 and useTSL
    newTSL = close + atrValue
    trailingSL := math.min(trailingSL, newTSL)
    trailingSL := math.min(trailingSL, initialSL)

activeSL = useTSL ? trailingSL : initialSL

// ─────────────────────────────
// EXIT LOGIC
// ─────────────────────────────

if strategy.position_size > 0
    strategy.exit("Long Exit", from_entry = "Long Entry", stop = activeSL, limit = target)

if strategy.position_size < 0
    strategy.exit("Short Exit", from_entry = "Short Entry", stop = activeSL, limit = target)

// Reset after close
if positionClosed
    motherActive := false
    initialSL := na
    target := na
    trailingSL := na

// ─────────────────────────────
// VISUAL PLOTS
// ─────────────────────────────

plot(strategy.position_avg_price, title="Entry", style=plot.style_linebr, linewidth=2)
plot(initialSL, title="Initial SL", style=plot.style_linebr, linewidth=2)
plot(useTSL ? trailingSL : na, title="Trailing SL", style=plot.style_linebr, linewidth=2)
plot(target, title="Target", style=plot.style_linebr, linewidth=2)

// ─────────────────────────────
// ALERTS
// ─────────────────────────────

alertcondition(longCondition, "Long Entry", "Long Entry")
alertcondition(shortCondition, "Short Entry", "Short Entry")
alertcondition(positionClosed and strategy.position_size[1] > 0, "Long Exit", "Long Exit")
alertcondition(positionClosed and strategy.position_size[1] < 0, "Short Exit", "Short Exit")

