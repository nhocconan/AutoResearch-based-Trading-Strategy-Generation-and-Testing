//@version=5
strategy("Diaper Sniper v16 — LOW VOL V CATCHER", overlay=true,
         default_qty_type=strategy.percent_of_equity, default_qty_value=15)

// SETTINGS
lookback     = input.int(30, "Lookback bars")
minDropPct   = input.float(-6.0, "Min % drop from high")

// DROP FROM HIGH (previous bars)
highPrev = ta.highest(high[1], lookback)
drop     = (close - highPrev) / highPrev * 100
isDown   = drop <= minDropPct

// VOLUME — REMOVED ENTIRELY (catches dead-quiet reversals)
volOk    = true

// GREEN CANDLE
green    = close > open

// TRIGGER
diaper   = isDown and green

if (diaper)
    strategy.entry("Diaper", strategy.long)

strategy.exit("DiaperExit", "Diaper", profit=20, loss=8)

// TINY ARROWS
plotshape(diaper, location=location.belowbar, color=#39ff14, style=shape.triangleup, size=size.tiny, text="D")

alertcondition(diaper, title="Diaper Sniper", message="{\"content\":\"🚀 DIAPER V {{ticker}} @ {{close}} | {{interval}}\"}")

