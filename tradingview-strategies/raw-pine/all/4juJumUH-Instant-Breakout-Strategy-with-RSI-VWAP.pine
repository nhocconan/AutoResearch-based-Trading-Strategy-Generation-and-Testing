//@version=6
strategy("Instant Breakout Strategy with RSI & VWAP", overlay=true)

// Inputs with Tooltips
int pivot_left = input.int(3, "Left Pivot Bars", minval=1, tooltip="Number of bars to the left to detect pivot highs. Lower values increase sensitivity.")
int pivot_right = input.int(3, "Right Pivot Bars", minval=1, tooltip="Number of bars to the right to detect pivot highs. Lower values increase sensitivity.")
float vol_multiplier = input.float(1.5, "Volume Surge Multiplier", minval=1.0, tooltip="Multiplier for volume surge detection. Higher values require stronger volume spikes.")
float mom_threshold = input.float(0.01, "Momentum Threshold (e.g., 1%)", minval=0.0, tooltip="Minimum percentage price change from bar open to consider momentum. Lower for more signals.")
float tp_multiplier = input.float(9.0, "Take-Profit ATR Multiplier", minval=0.5, tooltip="Multiplier of ATR for take-profit level. Higher values set farther targets.")
float sl_multiplier = input.float(1.0, "Stop-Loss ATR Multiplier", minval=0.5, tooltip="Multiplier of ATR for stop-loss level. Lower values tighten stops.")
bool use_filters = input.bool(false, "Use Volume/Momentum Filters", tooltip="Enable to apply volume, momentum, RSI, and VWAP filters. Disable for basic pivot breakouts.")

// Detect pivot highs and lows
float pivot_high = ta.pivothigh(high, pivot_left, pivot_right)
float pivot_low = ta.pivotlow(low, pivot_left, pivot_right)

// Store most recent pivot levels
var float last_high = na
var float last_low = na
if not na(pivot_high)
    last_high := pivot_high
if not na(pivot_low)
    last_low := pivot_low

// Volume average for surge detection
float vol_sma = ta.sma(volume, 20)

// Intra-bar momentum tracking (price change from bar open)
varip float bar_open = na
if barstate.isnew
    bar_open := open
bool intra_mom_up = (close - bar_open) / bar_open > mom_threshold
bool intra_mom_down = (close - bar_open) / bar_open < -mom_threshold
bool volume_ok = volume > vol_sma * vol_multiplier

// RSI and VWAP for confluence
float rsi = ta.rsi(close, 3)  // Short period for 1s TF
float vwap = ta.vwap(close)

// Breakout conditions with RSI and VWAP confluence
bool bullish_breakout = ta.crossover(close, last_high) and (use_filters ? volume_ok and intra_mom_up and rsi > 50 and close > vwap : true)
bool bearish_breakout = ta.crossunder(close, last_low) and (use_filters ? volume_ok and intra_mom_down and rsi < 50 and close < vwap : true)

// Calculate ATR for TP/SL
float atr = ta.atr(14)

// Entry and exit logic
if bullish_breakout
    strategy.entry("Long", strategy.long, comment="Bullish Breakout")
    strategy.exit("Long Exit", "Long", limit=close + atr * tp_multiplier, stop=close - atr * sl_multiplier)
    if strategy.position_size < 0
        strategy.close("Short", comment="Close Short on Bullish Breakout")

if bearish_breakout
    strategy.entry("Short", strategy.short, comment="Bearish Breakout")
    strategy.exit("Short Exit", "Short", limit=close - atr * tp_multiplier, stop=close + atr * sl_multiplier)
    if strategy.position_size > 0
        strategy.close("Long", comment="Close Long on Bearish Breakout")

// Plot signals
plotshape(bullish_breakout, title="Bullish Breakout", location=location.belowbar, style=shape.triangleup, color=color.green, size=size.small)
plotshape(bearish_breakout, title="Bearish Breakout", location=location.abovebar, style=shape.triangledown, color=color.red, size=size.small)

// Plot pivot levels for reference
plot(last_high, "Resistance", color=color.lime, style=plot.style_line, offset=-pivot_right)
plot(last_low, "Support", color=color.red, style=plot.style_line, offset=-pivot_right)

// Plot confluence indicators
plot(rsi, title="RSI (3)", color=color.blue, display=display.pane)  // Removed invalid tooltip
plot(vwap, title="VWAP", color=color.purple, linewidth=2)  // Removed invalid tooltip

