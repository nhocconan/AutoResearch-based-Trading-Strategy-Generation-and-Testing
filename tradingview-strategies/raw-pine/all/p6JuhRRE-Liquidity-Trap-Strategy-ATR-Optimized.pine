//@version=5
strategy("Liquidity Trap Strategy - ATR Optimized", overlay=true, 
     default_qty_type=strategy.percent_of_equity, default_qty_value=10, calc_on_every_tick=false)

// ───────────── INPUTS ─────────────
atrLen          = input.int(14, "ATR Length")
atrMultiplier   = input.float(1.5, "ATR Multiplier for SL", step=0.1)
riskReward      = input.float(2.0, "Risk-Reward Ratio", step=0.1)

// ───────────── DAILY HIGH / LOW ─────────────
var line pdhLine = na
var line pdlLine = na

prevDayHigh = request.security(syminfo.tickerid, "D", high[1])
prevDayLow  = request.security(syminfo.tickerid, "D", low[1])

var bool tradedToday = false

// Draw anchored lines each day
if dayofweek != dayofweek[1]
    tradedToday := false
    line.delete(pdhLine)
    line.delete(pdlLine)
    pdhLine := line.new(bar_index[1], prevDayHigh, bar_index, prevDayHigh, color=color.green, width=2, extend=extend.right)
    pdlLine := line.new(bar_index[1], prevDayLow, bar_index, prevDayLow, color=color.red, width=2, extend=extend.right)
else
    line.set_xy2(pdhLine, bar_index, prevDayHigh)
    line.set_xy2(pdlLine, bar_index, prevDayLow)

// ───────────── TRAP LOGIC ─────────────
breaksAbovePDH = high > prevDayHigh
reversesBelowPDH = close < prevDayHigh
buyerTrap = breaksAbovePDH and reversesBelowPDH and not tradedToday

breaksBelowPDL = low < prevDayLow
reversesAbovePDL = close > prevDayLow
sellerTrap = breaksBelowPDL and reversesAbovePDL and not tradedToday

// ───────────── ATR CALCULATION ─────────────
atr = ta.atr(atrLen)

// ───────────── STRATEGY EXECUTION ─────────────
if buyerTrap
    shortSL = math.max(high + atr * atrMultiplier, high)  // SL beyond trap candle or ATR
    shortTP = close - (shortSL - close) * riskReward
    strategy.entry("Short", strategy.short)
    strategy.exit("Short Exit", "Short", stop=shortSL, limit=shortTP)
    label.new(bar_index, high, "Short", color=color.red, style=label.style_label_down, textcolor=color.white, size=size.small)
    tradedToday := true

if sellerTrap
    longSL = math.min(low - atr * atrMultiplier, low)    // SL beyond trap candle or ATR
    longTP = close + (close - longSL) * riskReward
    strategy.entry("Long", strategy.long)
    strategy.exit("Long Exit", "Long", stop=longSL, limit=longTP)
    label.new(bar_index, low, "Long", color=color.green, style=label.style_label_up, textcolor=color.white, size=size.small)
    tradedToday := true

// Optional: close opposite position if opposite trap occurs
if strategy.position_size > 0 and buyerTrap
    strategy.close("Long")
if strategy.position_size < 0 and sellerTrap
    strategy.close("Short")

