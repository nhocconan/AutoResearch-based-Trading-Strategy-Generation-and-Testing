//@version=6
strategy("Recovery Strategy", overlay=true, pyramiding=5, margin_long=20)

// Input parameters
lookback_period = input.int(126, "Lookback Period for High Peak (bars)", minval=1, tooltip="Number of bars to look back for recent high (default: ~6 months)")
drop_percent = input.float(10.0, "Initial Drop Percentage to Buy (%)", minval=0.1, step=0.1, tooltip="Percentage drop from recent high to trigger initial buy")
additional_drop_percent = input.float(2.0, "Additional Drop Percentage to Buy (%)", minval=0.1, step=0.1, tooltip="Further drop percentage from recent high to add to position")
holding_period = input.int(126, "Holding Period (bars)", minval=1, tooltip="Number of bars to hold each position before selling (default: ~6 months)")
order_size_percent = input.float(100.0, "Order Size (% of Equity)", minval=0.1, maxval=100.0, step=0.1, tooltip="Percentage of equity to use per trade (e.g., 100 for full equity, 50 for half)")
margin_percent = input.float(20.0, "Margin for Long Positions (%)", minval=1.0, maxval=100.0, step=0.1, tooltip="Percentage of position value covered by equity (e.g., 20 = 5:1 leverage)")

// Find the highest high in the lookback period
recent_high = ta.highest(high, lookback_period)

// Define initial buy condition: price drops by drop_percent or more from recent high
buy_condition = close <= recent_high * (1 - drop_percent / 100)

// Define additional buy condition: price drops by an additional_drop_percent increment
var float last_entry_level = na
if strategy.position_size == 0
    last_entry_level := na  // Reset when no position is open
if buy_condition and strategy.position_size > 0
    if close <= recent_high * (1 - (drop_percent + additional_drop_percent * (strategy.opentrades + 1)) / 100)
        last_entry_level := close

// Enter long position when buy condition is met (initial or additional)
if buy_condition and (strategy.position_size == 0 or (strategy.position_size > 0 and close <= recent_high * (1 - (drop_percent + additional_drop_percent * (strategy.opentrades + 1)) / 100)))
    strategy.entry("Buy" + str.tostring(strategy.opentrades + 1), strategy.long, qty=strategy.equity * order_size_percent / 100 / close)

// Set exit: sell each position after its own holding_period bars, regardless of profit or loss
if strategy.position_size > 0
    for i = 0 to strategy.opentrades - 1
        bars_since_entry = bar_index - strategy.opentrades.entry_bar_index(i)
        if bars_since_entry >= holding_period
            strategy.close("Buy" + str.tostring(i + 1), comment="Time Exit Trade " + str.tostring(i + 1))

// Draw a label at the recent high when it changes, without text
if ta.change(recent_high) != 0
    label.new(bar_index, recent_high, "", color=color.new(color.blue, 0), style=label.style_label_down)

