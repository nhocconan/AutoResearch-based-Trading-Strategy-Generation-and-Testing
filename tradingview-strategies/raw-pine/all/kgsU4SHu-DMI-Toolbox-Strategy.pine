//@version=6
strategy(title="DMI Toolbox Strategy", shorttitle="DMI Toolbox", overlay=false, default_qty_type=strategy.percent_of_equity, default_qty_value=10, initial_capital=10000, currency=currency.USD, pyramiding=5, commission_type=strategy.commission.percent, commission_value=0.1, slippage=3, backtest_fill_limits_assumption=1, calc_on_every_tick=true)

intro = "DIRECTIONAL MOVEMENT INDEX (DMI), first developed by J. Welles Wilder, uses +DI (upward movement), -DI (downward movement), and ADX (trend strength)."

// Input parameters
lensig = input.int(20, title="ADX Signal Length", minval=3, group=intro )
len = input.int(14, minval=1, title="DI Length", group=intro)
plusEma = input.int(4, "Smoothed +DI Period", minval=3, group=intro)
smoothAdxPeriod = input.int(8, "Smoothed ADX Period", minval=3, group=intro)
smoothMinusPeriod = input.int(8, "Smoothed -DI Period", minval=3, group=intro)


// Mandatory criteria for long entries
mandToolTip = "If checked, this MUST be true or none of the DMI options below will trigger a long entry"
useBullPatternReq = input.bool(true, "Require Bullish +DI above -DI Signal", group="Mandatory REQUIREMENTS for a Long Entry", tooltip=mandToolTip)
maxCandlesSincePlusDiCross = input.int(150, "Max candles since +DI crossed above -DI", minval=1, maxval=500, group="Mandatory REQUIREMENTS for a Long Entry", tooltip=mandToolTip)
usePriceBelowSMA = input.bool(false, "Price is below the 21 Period Moving Average", group="Mandatory REQUIREMENTS for a Long Entry", tooltip=mandToolTip)
usePriceAbove200SMA = input.bool(true, "Price is above its 200 Period Moving Average", group="Mandatory REQUIREMENTS for a Long Entry", tooltip=mandToolTip)
useVolumeAboveSMA = input.bool(true, "Volume is above its 21 Period Moving Average", group="Mandatory REQUIREMENTS for a Long Entry", tooltip=mandToolTip)

// Conditions for long entries
usePlusDiCrossoverSignal = input.bool(false, "+DI Crossover smooth -DI Long Signal", group="+DI (blue) PATTERNS FOR ENTERING A LONG POSITION", tooltip = "Blue crossing above Orange")
usePlusDiCross20 = input.bool(false, "+DI crossover 20", group="+DI (blue) PATTERNS FOR ENTERING A LONG POSITION", tooltip = "Blue rising above 20")
usePlusDiCross25 = input.bool(false, "+DI crossover 25", group="+DI (blue) PATTERNS FOR ENTERING A LONG POSITION", tooltip = "Blue rising above 25")
usePlusDiCross30 = input.bool(true, "+DI crossover 30", group="+DI (blue) PATTERNS FOR ENTERING A LONG POSITION", tooltip = "Blue rising above 30")

useAdxCrossSmoothADX = input.bool(false, "ADX crossover smooth ADX", group="ADX (red) PATTERNS FOR ENTERING A LONG POSITION", tooltip = "Red crossing above White")
useAdxCrossSmoothMinus = input.bool(false, "ADX crossover smooth -DI", group="ADX (red) PATTERNS FOR ENTERING A LONG POSITION", tooltip = "Red crossing above Orange")
useAdxCrossPlusDI = input.bool(false, "ADX crossover +DI", group="ADX (red) PATTERNS FOR ENTERING A LONG POSITION", tooltip = "Red crossing above Blue")
useAdxCross10 = input.bool(false, "ADX crossover 10", group="ADX (red) PATTERNS FOR ENTERING A LONG POSITION", tooltip = "Red rising above 10")
useAdxCross20 = input.bool(false, "ADX crossover 20", group="ADX (red) PATTERNS FOR ENTERING A LONG POSITION", tooltip = "Red rising above 20")
useAdxCross30 = input.bool(false, "ADX crossover 30", group="ADX (red) PATTERNS FOR ENTERING A LONG POSITION", tooltip = "Red rising above 30")

// Smooth ADX conditions for long entries
useSmoothAdxCrossSmoothMinus = input.bool(true, "Smooth ADX crossover smooth -DI", group="Smooth ADX (white) patterns for entering a long", tooltip = "White crossing above Orange")
useSmoothAdxCrossPlusDI = input.bool(false, "Smooth ADX crossover +DI", group="Smooth ADX (white) patterns for entering a long", tooltip = "White crossing above Blue")
useSmoothAdxCross10 = input.bool(false, "Smooth ADX crossover 10", group="Smooth ADX (white) patterns for entering a long", tooltip = "White rising above 10")
useSmoothAdxCross20 = input.bool(false, "Smooth ADX crossover 20", group="Smooth ADX (white) patterns for entering a long", tooltip = "White rising above 20")
useSmoothAdxCross30 = input.bool(false, "Smooth ADX crossover 30", group="Smooth ADX (white) patterns for entering a long", tooltip = "White rising above 30")

// Complex patterns for long entries
usePotentialPumpSignal = input.bool(false, "ADX Sustained Momentum Signal", group="Complex Patterns for Long Entry", tooltip = "ADX (red) crossed above Smooth ADX (white), then ADX crossed above -DI (orange), then ADX crossed above +DI (blue)")

// Exit conditions
useBearishDiExit = input.bool(false, "Exit on +DI Crossunder -DI", group="EXIT LONG", tooltip = "Blue crosses under Orange")
useAdxTrendReversalExit = input.bool(true, "Exit on ADX Trend Reversal", group="EXIT LONG", tooltip = "Red crosses under White")
minAdxForTrendReversalExit = input.int(38, "Minimum ADX Level for Trend Reversal Exit", minval=10, step=1, group="EXIT LONG", tooltip = "Red must be above this level")

// Strategy settings
useStopLoss = input.bool(true, "Use Stop Loss", group="RISK MANAGEMENT")
stopLossPercent = input.float(2.5, "Stop Loss %", minval=0.1, maxval=10.0, step=0.1, group="RISK MANAGEMENT")
useTakeProfit = input.bool(false, "Use Take Profit", group="RISK MANAGEMENT")
takeProfitPercent = input.float(8.0, "Take Profit %", minval=0.1, step=0.25, group="RISK MANAGEMENT")

// DMI calculations
up = ta.change(high)
down = -ta.change(low)
plusDM = na(up) ? na : (up > down and up > 0 ? up : 0)
minusDM = na(down) ? na : (down > up and down > 0 ? down : 0)
trur = ta.rma(ta.tr, len)
plus = ta.rma(fixnan(100 * ta.rma(plusDM, len) / trur), plusEma)
minus = fixnan(100 * ta.rma(minusDM, len) / trur)
plusMinusGap = ta.rma(5 + (plus - minus), 3)
sum = plus + minus
adx = 100 * ta.ema(math.abs(plus - minus) / (sum == 0 ? 1 : sum), lensig)
smoothMinus = ta.sma(minus, smoothMinusPeriod)
smoothADX = ta.sma(adx, smoothAdxPeriod)

// Additional criteria calculations
sma21 = ta.sma(close, 21)
sma200 = ta.sma(close, 200)
volumeSma21 = ta.sma(volume, 21)

// Pattern Recognition: +DI crosses above smoothMinus, we want to count the bars 
// and reset the counter if +DI crosses below smoothMinus 
var int plusCrossBarIndex = na
var bool bullishPattern = false
// Candle counter: starts counting when bullishCross occurs, resets to 0 when bearishCross occurs
var int candleCounter = 0

// Detect +DI crossing over or under SmoothMinus
bullishDI = ta.crossover(plus, smoothMinus)
bearishDI = ta.crossunder(plus, smoothMinus)

// Identify various adx patterns that can be bullish or bearish
adxBullish = ta.crossover(adx, smoothMinus)
adxBearish = ta.crossover(adx, plus)
adxTrendReversal = ta.crossunder(adx, smoothADX)
bearishReversal = adxTrendReversal and plus > smoothMinus
bullishReversal = adxTrendReversal and smoothMinus > plus
adxCrossPlusNow = ta.crossover(adx, plus)

// Update candle counter based on cross events
if bullishDI
    candleCounter := 1
else if bearishDI
    candleCounter := 0
else if candleCounter > 0
    candleCounter := candleCounter + 1

// Track when +DI crosses above SmoothMinus (for all conditions, not just the checkbox)
if bullishDI
    plusCrossBarIndex := bar_index
    bullishPattern := true

// Reset pattern if more than 12 candles have passed
if bullishPattern and bearishDI
    bullishPattern := false
    plusCrossBarIndex := na

// Additional crossover conditions for long entries
plusDiCross20 = ta.crossover(plus, 20)
plusDiCross25 = ta.crossover(plus, 25)
plusDiCross30 = ta.crossover(plus, 30)

// Regular ADX crossover conditions
adxCrossSmoothMinus = ta.crossover(adx, smoothMinus)
adxCrossSmoothADX = ta.crossover(adx, smoothADX)
adxCrossPlusDI = ta.crossover(adx, plus)
adxCross10 = ta.crossover(adx, 10)
adxCross20 = ta.crossover(adx, 20)
adxCross30 = ta.crossover(adx, 30)

// Smooth ADX crossover conditions
smoothAdxCrossSmoothMinus = ta.crossover(smoothADX, smoothMinus)
smoothAdxCrossPlusDI = ta.crossover(smoothADX, plus)
smoothAdxCross10 = ta.crossover(smoothADX, 10)
smoothAdxCross20 = ta.crossover(smoothADX, 20)
smoothAdxCross30 = ta.crossover(smoothADX, 30)

// Complex high-probability pattern for sharp price rise
barsSinceAdxBullish = ta.barssince(adxBullish) // count bars since ADX crossed up -DI
barsSinceAdxCrossSmoothADX = ta.barssince(adxCrossSmoothADX) // count bars since ADX crossed up smoothADX
potentialPumpSignal = barsSinceAdxBullish < barsSinceAdxCrossSmoothADX and barsSinceAdxCrossSmoothADX < candleCounter and adxCrossPlusNow // ADX (red) crossover Smooth ADX (white), then ADX crossover -DI (orange), then ADX crossover +DI (blue) 

// Strategy logic
longCondition = usePlusDiCrossoverSignal and bullishDI

// Check individual additional conditions
plusDiConditions = (usePlusDiCross20 and plusDiCross20) or (usePlusDiCross25 and plusDiCross25) or (usePlusDiCross30 and plusDiCross30)
adxCrossConditions1 = (useAdxCrossSmoothMinus and adxCrossSmoothMinus) or (useAdxCrossSmoothADX and adxCrossSmoothADX) or (useAdxCrossPlusDI and adxCrossPlusDI)
adxCrossConditions2 = (useAdxCross10 and adxCross10) or (useAdxCross20 and adxCross20) or (useAdxCross30 and adxCross30)

// Smooth ADX conditions
smoothAdxConditions1 = (useSmoothAdxCrossSmoothMinus and smoothAdxCrossSmoothMinus) or (useSmoothAdxCrossPlusDI and smoothAdxCrossPlusDI)
smoothAdxConditions2 = (useSmoothAdxCross10 and smoothAdxCross10) or (useSmoothAdxCross20 and smoothAdxCross20) or (useSmoothAdxCross30 and smoothAdxCross30)

// Additional criteria using existing variables

maxCandlesCriteria = bullishPattern and candleCounter <= maxCandlesSincePlusDiCross
priceBelowSmaCriteria = not usePriceBelowSMA or close < sma21
priceAbove200SmaCriteria = not usePriceAbove200SMA or close > sma200
volumeAboveSmaCriteria = not useVolumeAboveSMA or volume > volumeSma21
bullPatternCriteria = not useBullPatternReq or bullishPattern

mandatoryCriteriaMet = maxCandlesCriteria and priceBelowSmaCriteria and priceAbove200SmaCriteria and volumeAboveSmaCriteria and bullPatternCriteria

longConditions = (plusDiConditions or adxCrossConditions1 or adxCrossConditions2 or smoothAdxConditions1 or smoothAdxConditions2)

complexPatternCondition = usePotentialPumpSignal and potentialPumpSignal

exitCondition = (useBearishDiExit and bearishDI) or (useAdxTrendReversalExit and adxTrendReversal and adx > minAdxForTrendReversalExit)

// Entry and exit logic
if mandatoryCriteriaMet and (longConditions or complexPatternCondition)
    strategy.entry("Long", strategy.long)

if exitCondition
    strategy.close("Long")

// Stop loss and take profit
openProfit = strategy.openprofit_percent 
if openProfit < (stopLossPercent * -1) and useStopLoss
    strategy.close_all("Stop Loss")

if openProfit >= takeProfitPercent and useTakeProfit
    strategy.close_all("Take Profit")


// Plotting
plot(adx, color=#F50057, title="ADX")
plot(plus, color=#2962FF, title="+DI")
plot(minus, color=color.new(#FF6D00, 65), title="-DI")
plot(plusMinusGap, color=color.new(color.yellow, 100), title="pmGap")
plot(smoothADX, color=color.white, title="SmoothADX")
plot(smoothMinus, color=color.orange, title="SmoothMinus")

// Plot entry and exit signals
bgcolor(bullishDI ? color.new(color.green, 60) : bearishDI ? color.new(color.red, 60) : na)
bgcolor(plus > minus ?  color.new(color.green, 90) : plus < minus ? color.new(color.red, 90) : na)
plotshape(bearishReversal, "ADX Bearish Reversal", shape.triangledown, location.top, color.red, size=size.tiny)
plotshape(bullishReversal, "ADX Bullish Reversal", shape.triangleup, location.bottom, color.green, size=size.tiny)


// Label at ADX and +DI intersection
if adxCrossPlusDI
    label.new(bar_index, adx, "⇪", style=label.style_none, textcolor=color.blue, size=size.normal, tooltip="ADX crossover +DI")

// Label at ADX and smooth -DI intersection
if adxCrossSmoothMinus
    label.new(bar_index, adx, "⇪", style=label.style_none, textcolor=color.orange, size=size.normal, tooltip="ADX crossover -DI")

// Label at ADX and smooth -DI intersection
if adxCrossSmoothADX
    label.new(bar_index, adx, "⇪", style=label.style_none, textcolor=color.white, size=size.normal, tooltip="ADX crossover Smooth ADX")

// Multi-timeframe bullish pattern data
bullishPattern5M = request.security(syminfo.tickerid, "5", bullishPattern)
bullishPattern15M = request.security(syminfo.tickerid, "15", bullishPattern)
bullishPattern60M = request.security(syminfo.tickerid, "60", bullishPattern)
bullishPattern240M = request.security(syminfo.tickerid, "240", bullishPattern)
bullishPattern1D = request.security(syminfo.tickerid, "1D", bullishPattern)

// Table in upper right corner
if barstate.islast or barstate.isrealtime
    var table infoTable = table.new(position.top_right, 2, 6, bgcolor=chart.bg_color, border_width=1, border_color=chart.fg_color, frame_color=chart.fg_color, frame_width=1, force_overlay=true)
    
    // Headers
    table.cell(infoTable, 0, 0, "Time Frame", text_color=color.white, bgcolor=color.black)
    table.cell(infoTable, 1, 0, "Signal", text_color=color.white, bgcolor=color.black)
    
    // 5M row
    table.cell(infoTable, 0, 1, "5M", text_color=color.white, bgcolor=color.black)
    table.cell(infoTable, 1, 1, bullishPattern5M ? "+DI" : "-DI", text_color=bullishPattern5M ? color.lime : color.red, bgcolor=color.black)
    
    // 15M row
    table.cell(infoTable, 0, 2, "15M", text_color=color.white, bgcolor=color.black)
    table.cell(infoTable, 1, 2, bullishPattern15M ? "+DI" : "-DI", text_color=bullishPattern15M ? color.lime : color.red, bgcolor=color.black)
    
    // 60M row
    table.cell(infoTable, 0, 3, "60M", text_color=color.white, bgcolor=color.black)
    table.cell(infoTable, 1, 3, bullishPattern60M ? "+DI" : "-DI", text_color=bullishPattern60M ? color.lime : color.red, bgcolor=color.black)
    
    // 240M row
    table.cell(infoTable, 0, 4, "240M", text_color=color.white, bgcolor=color.black)
    table.cell(infoTable, 1, 4, bullishPattern240M ? "+DI" : "-DI", text_color=bullishPattern240M ? color.lime : color.red, bgcolor=color.black)
    
    // 1D row
    table.cell(infoTable, 0, 5, "1D", text_color=color.white, bgcolor=color.black)
    table.cell(infoTable, 1, 5, bullishPattern1D ? "+DI" : "-DI", text_color=bullishPattern1D ? color.lime : color.red, bgcolor=color.black)

