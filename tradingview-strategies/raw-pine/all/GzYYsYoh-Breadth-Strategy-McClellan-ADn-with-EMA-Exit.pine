//@version=5
strategy("Breadth Strategy: McClellan + ADn (with EMA Exit)", overlay=true, margin_long=100, margin_short=100, initial_capital=100000)

// === INPUTS ===
tf = input.timeframe("D", "Breadth Timeframe")

// Breadth symbols
symUpVolNyse   = input.symbol("UPVOL.NY", "Up Volume NYSE")
symUpVolNasdaq = input.symbol("UPVOL.NQ", "Up Volume NASDAQ")
symDnVolNyse   = input.symbol("DNVOL.NY", "Down Volume NYSE")
symDnVolNasdaq = input.symbol("DNVOL.NQ", "Down Volume NASDAQ")

symUpIssuesNyse   = input.symbol("ADVN.NY", "Advancing Issues NYSE")
symUpIssuesNasdaq = input.symbol("ADVN.NQ", "Advancing Issues NASDAQ")
symDnIssuesNyse   = input.symbol("DECL.NY", "Declining Issues NYSE")
symDnIssuesNasdaq = input.symbol("DECL.NQ", "Declining Issues NASDAQ")

// === STRATEGY PARAMETERS ===
mcoLongLevel  = input.float(0.0, "McClellan > (Long Condition)")
adnLongLevel  = input.float(40.0, "ADn > (Long Condition)")
mcoShortLevel = input.float(3.0, "McClellan < (Short Condition)")
adnShortLevel = input.float(70.0, "ADn < (Short Condition)")

// EMA Exit Parameters
emaFastLen = input.int(50, "Fast EMA Length")
emaSlowLen = input.int(200, "Slow EMA Length")

// === McClellan Oscillator ===
upVolNyse   = request.security(symUpVolNyse, tf, close)
dnVolNyse   = request.security(symDnVolNyse, tf, close)
upVolNasdaq = request.security(symUpVolNasdaq, tf, close)
dnVolNasdaq = request.security(symDnVolNasdaq, tf, close)

ratWS = 100 * ((upVolNyse + upVolNasdaq) - (dnVolNyse + dnVolNasdaq)) / (upVolNyse + upVolNasdaq + dnVolNyse + dnVolNasdaq)

mcoWS = ta.ema(ratWS, 19) - ta.ema(ratWS, 39)
//plot(mcoWS, "McClellan Oscillator (WS)", color=color.new(color.blue, 0))

// === AD Line (ADn) ===
upIssuesNyse   = request.security(symUpIssuesNyse, tf, close)
dnIssuesNyse   = request.security(symDnIssuesNyse, tf, close)
upIssuesNasdaq = request.security(symUpIssuesNasdaq, tf, close)
dnIssuesNasdaq = request.security(symDnIssuesNasdaq, tf, close)

amplWS = (upIssuesNyse - dnIssuesNyse) + (upIssuesNasdaq - dnIssuesNasdaq)
lineaADWS = ta.cum(amplWS)

// Convert to %K stochastic of AD Line
estADWS = ta.stoch(lineaADWS, lineaADWS, lineaADWS, 21)
lineaADnWS = ta.ema(estADWS, 7)

//plot(lineaADnWS, "ADn Line (WS)", color=color.new(color.green, 0))

// === ENTRY CONDITIONS ===
longCond  = (mcoWS > mcoLongLevel) and (lineaADnWS > adnLongLevel)
shortCond = (mcoWS < mcoShortLevel) and (lineaADnWS < adnShortLevel)

// === STRATEGY ENTRIES ===
if (longCond)
    strategy.entry("Long", strategy.long)
if (shortCond)
    strategy.entry("Short", strategy.short)

// === OLD EXIT CONDITIONS (COMMENTED OUT) ===
// if (shortCond)
//     strategy.close("Long")
// if (longCond)
//     strategy.close("Short")

// === NEW EXIT CONDITION: EMA CROSS ===
emaFast = ta.ema(close, emaFastLen)
emaSlow = ta.ema(close, emaSlowLen)

plot(emaFast, "Fast EMA", color=color.orange)
plot(emaSlow, "Slow EMA", color=color.red)

// Exit when fast EMA crosses down slow EMA
if ta.crossover(emaFast, emaSlow)
    strategy.close("Short")   // optional: close shorts on bullish cross
if ta.crossunder(emaFast, emaSlow)
    strategy.close("Long")    // close longs on bearish cross

