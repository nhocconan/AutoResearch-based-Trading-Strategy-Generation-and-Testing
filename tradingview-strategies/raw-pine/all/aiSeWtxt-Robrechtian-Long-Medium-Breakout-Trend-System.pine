//@version=5
strategy(
     title           = "Robrechtian Long-Medium Breakout Trend System",
     shorttitle      = "Robrecht Breakout Trend",
     overlay         = true,
     initial_capital = 100000,
     currency        = currency.USD,
     pyramiding      = 5,                     // Base + up to 4 pyramids (edit as desired)
     default_qty_type= strategy.percent_of_equity,
     default_qty_value = 1,                   // 1% of equity per entry; adjust to taste
     calc_on_every_tick = false,
     commission_type = strategy.commission.percent,
     commission_value = 0.01                  // 0.01% per trade as placeholder
     )

// ─────────────────────────────────────────────
// Inputs
// ─────────────────────────────────────────────
entryLookback      = input.int(80,  "Entry / Exit Breakout Lookback (days)", minval = 20)
confirmLookback    = input.int(20,  "Short-Term Confirmation Lookback",       minval = 5)
maLength           = input.int(50,  "Trend Filter MA Length",                 minval = 10)
atrLength          = input.int(20,  "ATR Length (Explosive Bar Filter)",      minval = 5)
atrExplosiveMult   = input.float(2.5, "Explosive Bar Threshold (x ATR)",      minval = 1.0, step = 0.1)

allowLongs         = input.bool(true,  "Allow Long Trades")
allowShorts        = input.bool(true,  "Allow Short Trades")
useExplosiveFilter = input.bool(true,  "Use Explosive Bar Filter")

// ─────────────────────────────────────────────
// Core Calculations
// ─────────────────────────────────────────────

// Long/short "state"
inLong  = strategy.position_size > 0
inShort = strategy.position_size < 0

// Donchian-style channels (shifted by 1 bar to avoid look-ahead)
highestEntry  = ta.highest(high[1], entryLookback)
lowestEntry   = ta.lowest(low[1],  entryLookback)

highestConfirm = ta.highest(high[1], confirmLookback)
lowestConfirm  = ta.lowest(low[1],  confirmLookback)

// Moving average + slope filter
ma      = ta.sma(close, maLength)
maUp    = ma > ma[1]
maDown  = ma < ma[1]

// ATR + "explosive bar" detection
atr         = ta.atr(atrLength)
barRange    = high - low
explosive   = barRange > atrExplosiveMult * atr
okBar       = useExplosiveFilter ? not explosive : true

// Safety: enough bars?
enoughBars  = bar_index > entryLookback + 2

// ─────────────────────────────────────────────
// Entry Conditions
// ─────────────────────────────────────────────

// Base long entry: 80-day breakout + 20-day confirmation + upward slope + non-explosive
longBaseBreakout =
     enoughBars and
     allowLongs and
     not inLong and
     not inShort and
     close > highestEntry and
     close > highestConfirm and
     maUp and
     okBar

// Base short entry: mirror logic
shortBaseBreakout =
     enoughBars and
     allowShorts and
     not inShort and
     not inLong and
     close < lowestEntry and
     close < lowestConfirm and
     maDown and
     okBar

// Pyramiding: add on each new 20-day breakout in direction of existing trend
longPyramidCond =
     enoughBars and
     allowLongs and
     inLong and
     close > highestConfirm and
     maUp and
     okBar

shortPyramidCond =
     enoughBars and
     allowShorts and
     inShort and
     close < lowestConfirm and
     maDown and
     okBar

// ─────────────────────────────────────────────
// Exit Conditions (80-day opposite channel)
// Infinite upside: no profit targets, exit only on trend break
// ─────────────────────────────────────────────
exitLongCond =
     inLong and
     enoughBars and
     close < lowestEntry

exitShortCond =
     inShort and
     enoughBars and
     close > highestEntry

// ─────────────────────────────────────────────
// Execute Orders
// Priority: exits → base entries → pyramids
// ─────────────────────────────────────────────

// Exits
if exitLongCond
    strategy.close("Long")

if exitShortCond
    strategy.close("Short")

// Base entries
if longBaseBreakout
    strategy.entry("Long", strategy.long)

if shortBaseBreakout
    strategy.entry("Short", strategy.short)

// Pyramids
// We use the same order IDs; with `pyramiding > 0` this will add units
if not longBaseBreakout and longPyramidCond
    strategy.entry("Long", strategy.long)

if not shortBaseBreakout and shortPyramidCond
    strategy.entry("Short", strategy.short)

// ─────────────────────────────────────────────
// Plotting
// ─────────────────────────────────────────────
plot(ma, title = "Trend MA", color = color.new(color.orange, 0))

plot(highestEntry,  "80-day High (Entry/Exit)",  color = color.new(color.navy,  60), style = plot.style_linebr)
plot(lowestEntry,   "80-day Low (Entry/Exit)",   color = color.new(color.fuchsia,    60), style = plot.style_linebr)

plot(highestConfirm,"20-day High (Pyramid Ref)", color = color.new(color.teal,   80), style = plot.style_linebr)
plot(lowestConfirm, "20-day Low (Pyramid Ref)",  color = color.new(color.purple, 80), style = plot.style_linebr)

