//@version=5
strategy("EMA Crossover Strategy ($300 TP, 5-Minute, All Hours)", overlay=true, default_qty_type=strategy.fixed, default_qty_value=3)

// === INPUTS ===
emaFastLen     = input.int(9, title="Fast EMA Length")
emaMidLen      = input.int(20, title="Mid EMA Length")
emaSlowLen     = input.int(55, title="Slow EMA Length")
dollarRisk     = input.float(100, title="Risk per Trade ($)")
dollarTarget   = input.float(300, title="Profit Target per Trade ($)")

// === INDICATORS ===
emaFast = ta.ema(close, emaFastLen)
emaMid  = ta.ema(close, emaMidLen)
emaSlow = ta.ema(close, emaSlowLen)

// === CROSSOVER CONDITIONS ===
crossUpMid  = ta.crossover(emaFast, emaMid)
crossDownMid = ta.crossunder(emaFast, emaMid)
crossUpSlow = ta.crossover(emaFast, emaSlow)
crossDownSlow = ta.crossunder(emaFast, emaSlow)

// === ENTRY CONDITIONS ===
longEntry  = crossUpMid or crossUpSlow
shortEntry = crossDownMid or crossDownSlow

// === DOLLAR-BASED STOPS AND TARGETS ===
tickSize = syminfo.mintick
contractSize = 3
longStop = close - dollarRisk / (tickSize * contractSize)
shortStop = close + dollarRisk / (tickSize * contractSize)
longTP   = close + dollarTarget / (tickSize * contractSize)
shortTP  = close - dollarTarget / (tickSize * contractSize)

// === STRATEGY EXECUTION ===
if (longEntry)
    strategy.entry("Long", strategy.long)
    strategy.exit("Exit Long", from_entry="Long", stop=longStop, limit=longTP)

if (shortEntry)
    strategy.entry("Short", strategy.short)
    strategy.exit("Exit Short", from_entry="Short", stop=shortStop, limit=shortTP)

