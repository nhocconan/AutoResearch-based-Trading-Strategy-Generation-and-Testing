//@version=5
strategy("Long Only - Double EMA + Session", overlay=true, initial_capital=10000, default_qty_type=strategy.percent_of_equity, default_qty_value=100)

// --- Inputs ---
emaSlowLen  = input.int(200, "Macro Trend (EMA 200)")
emaFastLen  = input.int(50, "Local Trend (EMA 50)")
trailPerc   = input.float(5.0, "Trailing Stop %") / 100
sessionTime = input.session("0930-1300", "Trading Session (EST)") 

// --- Calculations ---
ema200 = ta.ema(close, emaSlowLen)
ema50  = ta.ema(close, emaFastLen)
rsi1   = ta.rsi(close, 14)
k      = ta.sma(ta.stoch(rsi1, rsi1, rsi1, 14), 3)

// --- Time & Session Filter ---
// Ensures we only enter trades during high-volume hours
isInSession = not na(time(timeframe.period, sessionTime, "America/New_York"))

// --- Entry Logic ---
// 1. Long-term trend UP (Above 200)
// 2. Short-term trend UP (Above 50)
// 3. Morning Session only
longCondition = ta.crossover(k, 20) and close > ema200 and close > ema50 and isInSession

// --- Trailing Stop Logic ---
var float trailPrice = na
if (strategy.position_size > 0)
    float currentTrailValue = high * (1 - trailPerc)
    trailPrice := math.max(nz(trailPrice, 0), currentTrailValue)
    
    if (close < trailPrice or k > 97)
        strategy.close("Long", comment = close < trailPrice ? "TS" : "RSI")
else
    trailPrice := na

// --- Execution ---
if (longCondition)
    strategy.entry("Long", strategy.long)

// --- Visuals ---
plot(ema200, color=color.white, linewidth=2, title="EMA 200")
plot(ema50, color=color.blue, title="EMA 50")
bgcolor(isInSession ? color.new(color.green, 90) : na, title="Trading Session Highlight")

