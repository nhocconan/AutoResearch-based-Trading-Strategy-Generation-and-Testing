//@version=6
strategy(
     title             = "JadeCap ICT Silver Bullet Strategy [PickMyTrade] v2.0",
     overlay           = true,
     default_qty_type  = strategy.fixed,
     default_qty_value = 1,
     pyramiding        = 0,
     commission_type   = strategy.commission.cash_per_contract,
     commission_value  = 5)

// INPUTS
float rrTarget = input.float(2.0,  "Risk : Reward Target", minval = 0.5, step = 0.5)
bool  useAM    = input.bool(true,  "Trade 10–11 AM Window")
bool  usePM    = input.bool(true,  "Trade 2–3 PM Window")
bool  showRng  = input.bool(true,  "Show Asian / London Ranges")
bool  show9AM  = input.bool(true,  "Show 9 AM Candle Levels")
bool  showLabels = input.bool(true, "Show Price Labels")
bool  eodClose = input.bool(true,  "Force Close at 4 PM EST")

group_colors = "Color Settings"
color colorAsianHigh = input(color.new(#FFD700, 0), "Asian High", group=group_colors)
color colorAsianLow  = input(color.new(#FFA500, 0), "Asian Low", group=group_colors)
color colorLonHigh   = input(color.new(#FF6B5B, 0), "London High", group=group_colors)
color colorLonLow    = input(color.new(#FF8C42, 0), "London Low", group=group_colors)
color color9AMHi     = input(color.new(#00D9FF, 0), "9AM High", group=group_colors)
color color9AMLo     = input(color.new(#00B4D8, 0), "9AM Low", group=group_colors)
color colorBear      = input(color.new(#FF1744, 0), "Bearish FVG", group=group_colors)
color colorBull      = input(color.new(#00E676, 0), "Bullish FVG", group=group_colors)

// TIME HELPERS
string TZ = "America/New_York"
int h  = hour(time, TZ)
int mn = minute(time, TZ)
int tM = h * 60 + mn

int T_ASIAN_START  = 20 * 60
int T_LONDON_START =  2 * 60
int T_LONDON_END   =  5 * 60
int T_NINE_AM      =  9 * 60
int T_AM_OPEN      = 10 * 60
int T_AM_CLOSE     = 11 * 60
int T_PM_OPEN      = 14 * 60
int T_PM_CLOSE     = 15 * 60
int T_EOD          = 16 * 60

// RANGE VARIABLES
var float asHigh = na
var float asLow  = na
var float lnHigh = na
var float lnLow  = na
var float n9H    = na
var float n9L    = na

// LABEL STORAGE (fix spam)
var label lab_asHigh = na
var label lab_asLow  = na
var label lab_lnHigh = na
var label lab_lnLow  = na
var label lab_n9H    = na
var label lab_n9L    = na

// ASIAN RANGE
bool inAsian = tM >= T_ASIAN_START
bool startAs = tM == T_ASIAN_START

if startAs
    asHigh := high
    asLow  := low
else if inAsian and not na(asHigh)
    asHigh := math.max(asHigh, high)
    asLow  := math.min(asLow, low)

// LONDON RANGE
bool inLondon = tM >= T_LONDON_START and tM < T_LONDON_END
bool startLn  = tM == T_LONDON_START

if startLn
    lnHigh := high
    lnLow  := low
else if inLondon and not na(lnHigh)
    lnHigh := math.max(lnHigh, high)
    lnLow  := math.min(lnLow, low)

// 9AM
if tM == T_NINE_AM
    n9H := high
    n9L := low

// RESET
bool isNewDay = tM == 0

var bool highSwept = false
var bool lowSwept  = false
var bool amDone    = false
var bool pmDone    = false

if isNewDay
    lnHigh := na
    lnLow  := na
    n9H    := na
    n9L    := na
    highSwept := false
    lowSwept  := false
    amDone := false
    pmDone := false

// SWEEP DETECTION
bool daytime = tM < T_ASIAN_START

if daytime
    if not na(asHigh) and high > asHigh
        highSwept := true
    if not na(lnHigh) and high > lnHigh
        highSwept := true
    if not na(n9H) and high > n9H
        highSwept := true
    if not na(asLow) and low < asLow
        lowSwept := true
    if not na(lnLow) and low < lnLow
        lowSwept := true
    if not na(n9L) and low < n9L
        lowSwept := true

// FVG
bool bearFVG = low[2] > high
bool bullFVG = high[2] < low

float bEntryPx = low[2]
float bSL      = high[2]
float lEntryPx = high[2]
float lSL      = low[2]

// ENTRY WINDOWS
bool inAMWin = useAM and tM >= T_AM_OPEN and tM < T_AM_CLOSE
bool inPMWin = usePM and tM >= T_PM_OPEN and tM < T_PM_CLOSE
bool inWin   = inAMWin or inPMWin
bool noPos   = strategy.position_size == 0

bool doBear = inWin and bearFVG and highSwept and noPos
bool doBull = inWin and bullFVG and lowSwept and noPos

if doBear
    slDist = bSL - bEntryPx
    tp = bEntryPx - slDist * rrTarget
    strategy.entry("SB Short", strategy.short, limit = bEntryPx)
    strategy.exit("SB Short X", from_entry="SB Short", stop=bSL, limit=tp)

if doBull
    slDist = lEntryPx - lSL
    tp = lEntryPx + slDist * rrTarget
    strategy.entry("SB Long", strategy.long, limit=lEntryPx)
    strategy.exit("SB Long X", from_entry="SB Long", stop=lSL, limit=tp)

// VISUALS
plot(showRng and daytime ? asHigh : na, "Asian High", color=colorAsianHigh, style=plot.style_stepline)
plot(showRng and daytime ? asLow  : na, "Asian Low",  color=colorAsianLow,  style=plot.style_stepline)
plot(showRng ? lnHigh : na, "London High", color=colorLonHigh)
plot(showRng ? lnLow  : na, "London Low",  color=colorLonLow)
plot(show9AM ? n9H : na, "9AM High", color=color9AMHi)
plot(show9AM ? n9L : na, "9AM Low",  color=color9AMLo)

// LABEL UPDATE (single label per level)

if showLabels and not na(asHigh)
    if na(lab_asHigh)
        lab_asHigh := label.new(bar_index, asHigh, str.tostring(asHigh, format.price), style=label.style_label_down, color=colorAsianHigh)
    else
        label.set_xy(lab_asHigh, bar_index, asHigh)
        label.set_text(lab_asHigh, str.tostring(asHigh, format.price))

if showLabels and not na(asLow)
    if na(lab_asLow)
        lab_asLow := label.new(bar_index, asLow, str.tostring(asLow, format.price), style=label.style_label_up, color=colorAsianLow)
    else
        label.set_xy(lab_asLow, bar_index, asLow)
        label.set_text(lab_asLow, str.tostring(asLow, format.price))

if showLabels and not na(lnHigh)
    if na(lab_lnHigh)
        lab_lnHigh := label.new(bar_index, lnHigh, str.tostring(lnHigh, format.price), style=label.style_label_down, color=colorLonHigh)
    else
        label.set_xy(lab_lnHigh, bar_index, lnHigh)
        label.set_text(lab_lnHigh, str.tostring(lnHigh, format.price))

if showLabels and not na(lnLow)
    if na(lab_lnLow)
        lab_lnLow := label.new(bar_index, lnLow, str.tostring(lnLow, format.price), style=label.style_label_up, color=colorLonLow)
    else
        label.set_xy(lab_lnLow, bar_index, lnLow)
        label.set_text(lab_lnLow, str.tostring(lnLow, format.price))

if showLabels and not na(n9H)
    if na(lab_n9H)
        lab_n9H := label.new(bar_index, n9H, str.tostring(n9H, format.price), style=label.style_label_down, color=color9AMHi)
    else
        label.set_xy(lab_n9H, bar_index, n9H)
        label.set_text(lab_n9H, str.tostring(n9H, format.price))

if showLabels and not na(n9L)
    if na(lab_n9L)
        lab_n9L := label.new(bar_index, n9L, str.tostring(n9L, format.price), style=label.style_label_up, color=color9AMLo)
    else
        label.set_xy(lab_n9L, bar_index, n9L)
        label.set_text(lab_n9L, str.tostring(n9L, format.price))

