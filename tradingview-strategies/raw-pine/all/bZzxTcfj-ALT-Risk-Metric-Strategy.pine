//@version=5
strategy("ALT Risk Strategy with Fear & Greed + PMI", 
     overlay=false, 
     initial_capital=10000, 
     default_qty_type=strategy.cash, 
     commission_type=strategy.commission.percent, 
     commission_value=0.1,
     pyramiding=1000,
     process_orders_on_close=true)

// === TICKER SELECTION ===
cryptoSymbol = input.string("ETH", "Crypto Symbol", options=["ETH", "SOL", "ADA", "LINK", "UNI", "XRP", "DOGE", "AVAX", "MATIC", "RENDER", "CUSTOM"])
customSymbol = input.string("", "Custom Symbol (if CUSTOM selected)")
quoteSymbol = input.string("USD", "Quote Currency", options=["USD", "USDT", "BUSD"])
exchange = input.string("BINANCE", "Exchange", options=["BINANCE", "COINBASE", "KRAKEN", "BITFINEX", "BYBIT"])

// Build the tickers
useSymbol = cryptoSymbol == "CUSTOM" ? customSymbol : cryptoSymbol
CRYPTO_BTC_TICKER = exchange + ":" + useSymbol + "BTC"  // For risk metric calculation
CRYPTO_USD_TICKER = useSymbol + quoteSymbol  // For 3Commas trading

// === RISK METRIC INPUTS ===
longTermLength   = input.int(150, "Long Term MA Length", minval=10, group="Risk Metric")
rsiLength        = input.int(10, "RSI Length", minval=1, group="Risk Metric")
signalFastLength = input.int(8, "MACD Fast Length", minval=1, group="Risk Metric")
signalSlowLength = input.int(26, "MACD Slow Length", minval=1, group="Risk Metric")
smoothingLength  = input.int(5, "Smoothing Length", minval=1, group="Risk Metric")

// === FEAR & GREED SETTINGS ===
useFearGreed = input.bool(true, "Include Fear & Greed in Risk Metric", group="Fear & Greed")
fgSmoothing = input.int(5, "F&G Smoothing", minval=1, maxval=10, group="Fear & Greed")
fgMode = input.string("Crypto", "F&G Mode", options=['Crypto', 'Traditional'], group="Fear & Greed")
fgWeight = input.float(0.20, "F&G Weight", minval=0.0, maxval=1.0, step=0.05, group="Fear & Greed", tooltip="How much F&G influences the risk metric (0-1)")
showFearGreed = input.bool(false, "Show F&G Separately", group="Fear & Greed")

// === US ISM PMI SETTINGS ===
usePMI = input.bool(true, "Include ISM PMI in Risk Metric", group="ISM PMI")
pmiWeight = input.float(0.15, "PMI Weight", minval=0.0, maxval=1.0, step=0.05, group="ISM PMI", tooltip="How much PMI influences the risk metric (0-1)")
pmiSmoothing = input.int(3, "PMI Smoothing", minval=1, maxval=10, group="ISM PMI")
pmiOffset = input.int(0, "PMI Offset (days)", minval=-365, maxval=365, group="ISM PMI", tooltip="Shift PMI data forward (+) or backward (-) in time")
showPMI = input.bool(false, "Show PMI Separately", group="ISM PMI")

// === SOCIAL RISK SETTINGS ===
useSocialRisk = input.bool(true, "Include Social Risk in Risk Metric", group="Social Risk")
socialWeight = input.float(0.10, "Social Risk Weight", minval=0.0, maxval=1.0, step=0.05, group="Social Risk", tooltip="How much Social Risk influences the risk metric (0-1)")
socialRsiLength = input.int(14, "Social RSI Length", minval=1, group="Social Risk")
socialOverbought = input.int(70, "Social Overbought Level", minval=50, maxval=90, group="Social Risk")
socialOversold = input.int(30, "Social Oversold Level", minval=10, maxval=50, group="Social Risk")
socialSmoothing = input.int(7, "Social Smoothing Length", minval=1, maxval=50, group="Social Risk")
socialVolSens = input.float(1.0, "Social Vol Sensitivity", minval=0.1, maxval=2.0, step=0.1, group="Social Risk")
showSocialRisk = input.bool(false, "Show Social Risk Separately", group="Social Risk")

// === 3COMMAS CREDENTIALS ===
bot_uuid = input.string("", "3Commas Bot UUID", group="3Commas", tooltip="Get this from your Signal Bot settings")
secret_token = input.string("", "3Commas Secret Token", group="3Commas", tooltip="Get this from your Signal Bot settings")
use_3commas = input.bool(false, "Enable 3Commas Alerts", group="3Commas")

// === BUY THRESHOLDS & AMOUNTS ===
buyL1_thresh = input.float(70.0, "Buy L1 Threshold", group="Buy Settings")
buyL2_thresh = input.float(50.0, "Buy L2 Threshold", group="Buy Settings")
buyL3_thresh = input.float(30.0, "Buy L3 Threshold", group="Buy Settings")
buyL1_amt = input.float(5.0, "Buy L1 $ Amount", group="Buy Settings")
buyL2_amt = input.float(6.0, "Buy L2 $ Amount", group="Buy Settings")
buyL3_amt = input.float(7.0, "Buy L3 $ Amount", group="Buy Settings")

// === SELL THRESHOLDS & PERCENTAGES ===
sellL1_thresh = input.float(70.0, "Sell L1 Threshold", group="Sell Settings")
sellL2_thresh = input.float(85.0, "Sell L2 Threshold", group="Sell Settings")
sellL3_thresh = input.float(100.0, "Sell L3 Threshold", group="Sell Settings")
sellL1_pct = input.float(25.0, "Sell L1 %", group="Sell Settings")
sellL2_pct = input.float(35.0, "Sell L2 %", group="Sell Settings")
sellL3_pct = input.float(40.0, "Sell L3 %", group="Sell Settings")

// === FUNCTION TO CALCULATE ALL COMPONENTS ON WEEKLY ===
f_get_weekly_data() =>
    // MACD calculation
    fastMA = ta.ema(close, signalFastLength)
    slowMA = ta.ema(close, signalSlowLength)
    macdLine = fastMA - slowMA
    
    // MACD normalization (500 bar lookback on weekly)
    macdMax = ta.highest(macdLine, 500)
    macdMin = ta.lowest(macdLine, 500)
    macdRange = macdMax != macdMin ? (macdLine - macdMin) / (macdMax - macdMin) * 100 : 50
    normalizedMacd = macdRange < 0 ? 0 : macdRange > 100 ? 100 : macdRange
    
    // RSI
    rsiVal = ta.rsi(close, rsiLength)
    
    // Deviation
    longMA = ta.sma(close, longTermLength)
    deviation = (close - longMA) / longMA
    
    // Fear & Greed components
    pmacd = (close/ta.ema(close, 89) - 1) * 100
    ror = (close - close[89])/close[89] * 100
    accDist = close==high and close==low or high==low ? 0 : ((2 * close - low - high) / (high - low))
    vol_fg = volume
    moneyFlow = nz(vol_fg) != 0 ? ta.sma(accDist * vol_fg, 13) / ta.sma(vol_fg, 13) * 100 : 0
    
    [normalizedMacd, rsiVal, deviation, pmacd, ror, moneyFlow, vol_fg]

// === FETCH ALL DATA FROM WEEKLY TIMEFRAME ===
[normalizedMacd_W, rsi_W, dev_W, pmacd_W, ror_W, moneyFlow_W, vol_fg_W] = request.security(CRYPTO_BTC_TICKER, "W", f_get_weekly_data(), barmerge.gaps_off, barmerge.lookahead_off)

// === BASE RISK METRIC FROM ALT/BTC (ALL WEEKLY DATA) ===
baseRiskOsc_W = (normalizedMacd_W * 0.05) + (rsi_W * 0.60) + ((dev_W + 1) * 0.35 * 100)

// === FEAR & GREED INDEX - EXTERNAL WEEKLY DATA ===
volatility_fg_W = request.security("BVOL24H", "W", -(close/ta.ema(close, 89) - 1) * 100, barmerge.gaps_off, barmerge.lookahead_off)
btcdom_W = request.security("BTC.D", "W", (1 - close[13] / close) * 100, barmerge.gaps_off, barmerge.lookahead_off)
vix_fg_W = request.security("VIX", "W", -(close/ta.ema(close, 89) - 1) * 100, barmerge.gaps_off, barmerge.lookahead_off)
gold_fg_W = request.security("GOLD", "W", (1 - close[13] / close) * 100, barmerge.gaps_off, barmerge.lookahead_off)

val1_fg = fgMode == "Crypto" ? volatility_fg_W : vix_fg_W
val2_fg = fgMode == "Crypto" ? btcdom_W : gold_fg_W

// Calculate F&G on weekly data
fearGreedCycle_W = nz(vol_fg_W) == 0 ? 
     (pmacd_W + ror_W + val1_fg + val2_fg) / 4 : 
     (pmacd_W + ror_W + moneyFlow_W + val1_fg + val2_fg) / 5

// Apply smoothing on weekly timeframe via security call
fearGreedIndex_raw = request.security(CRYPTO_BTC_TICKER, "W", ta.rma(fearGreedCycle_W, fgSmoothing), barmerge.gaps_off, barmerge.lookahead_off)

// Normalize Fear & Greed to 0-100 scale (from -40 to +50 range)
fearGreedIndex = (fearGreedIndex_raw + 40) / 90 * 100
fearGreedIndex := fearGreedIndex < 0 ? 0 : fearGreedIndex > 100 ? 100 : fearGreedIndex

// === US ISM PMI DATA ===
// Fetch ISM PMI data (daily)
pmiData_raw = request.security("ECONOMICS:USBCOI", "D", close, barmerge.gaps_off, barmerge.lookahead_off)

// Apply offset to PMI data
pmiData_offset = pmiData_raw[pmiOffset]

// Smooth PMI data
pmiData_smoothed = ta.sma(pmiData_offset, pmiSmoothing)

// Normalize PMI to enhance extremes, not flatten
// PMI 50 (neutral) = no impact
// PMI < 50 (contraction) = LOWERS risk metric (enhances buying)
// PMI > 50 (expansion) = RAISES risk metric (enhances selling)
// Apply dead zone and amplification like Social Risk

// Declare variable
var float pmiNormalized = 50

// Dead zone: 48-52 = neutral (no impact)
// Beyond that, amplify the signal
pmiDeviation = pmiData_smoothed - 50

if pmiDeviation > 2
    // Expansion: scale +2 to +20 → 50 to 100
    pmiNormalized := 50 + ((pmiDeviation - 2) / 18 * 50)
else if pmiDeviation < -2
    // Contraction: scale -2 to -20 → 50 to 0
    pmiNormalized := 50 + ((pmiDeviation + 2) / 18 * 50)
else
    // Neutral zone (48-52): no impact
    pmiNormalized := 50

pmiNormalized := pmiNormalized < 0 ? 0 : pmiNormalized > 100 ? 100 : pmiNormalized

// === SOCIAL RISK INDICATOR ===
// Calculate on chart timeframe
socialRsi = ta.rsi(close, socialRsiLength)

// Normalized RSI centered at 0 (-50 to +50)
socialRsiCentered = socialRsi - 50

// Volatility dampener - SIMPLIFIED to avoid sign flipping
socialVol = ta.atr(14) / close
socialVolAvg = ta.sma(socialVol, 50)
// When vol is high, reduce the signal strength (but keep the sign)
// When vol is low, keep full signal strength
socialVolMultiplier = socialVol > socialVolAvg ? (1.0 / socialVolSens) : 1.0

socialProxy = socialRsiCentered * socialVolMultiplier

// Extreme boost
socialBoost = socialRsi > socialOverbought + 10 ? 25 : 
              socialRsi > socialOverbought ? 15 : 
              socialRsi < socialOversold - 10 ? -25 : 
              socialRsi < socialOversold ? -15 : 0.0

socialRiskRaw = socialProxy + socialBoost

// Smoothing
socialRiskSmooth = ta.ema(socialRiskRaw, socialSmoothing)

// Apply neutral zone (-5 to +5)
socialRiskFinal = math.abs(socialRiskSmooth) <= 5 ? 0 : socialRiskSmooth

// Range: -100 to +100, where:
// Positive = HIGH social risk (greed/overbought) = should RAISE risk metric
// Negative = LOW social risk (fear/oversold) = should LOWER risk metric
// Between -5 and +5 = neutral (no impact)

// === COMBINE ALL INDICATORS INTO FINAL RISK METRIC ===
// All indicators use ADDITIVE adjustments to avoid flattening

// Start with pure Base risk (no weighted averaging)
combinedRiskOsc_W = baseRiskOsc_W

// Fear & Greed adjustment (additive)
fgAdjustment = 0.0
if useFearGreed
    // F&G deviation from neutral (50)
    fgDeviation = fearGreedIndex - 50  // Range: -50 to +50
    // Scale to adjustment: -50 = -50 points, 0 = 0 points, +50 = +50 points
    // Then apply weight
    fgAdjustment := fgDeviation * fgWeight
    combinedRiskOsc_W := combinedRiskOsc_W + fgAdjustment

// PMI adjustment (additive)
pmiAdjustment = 0.0
if usePMI
    // PMI deviation from neutral (50)
    pmiDeviation = pmiData_smoothed - 50  // Range: -20 to +20
    // Scale to adjustment: -20 = -20 points, 0 = 0 points, +20 = +20 points
    // Then apply weight
    pmiAdjustment := pmiDeviation * pmiWeight
    combinedRiskOsc_W := combinedRiskOsc_W + pmiAdjustment

// Social Risk adjustment (additive)
socialAdjustment = 0.0
if useSocialRisk
    // Apply adjustment only outside neutral zone (-5 to +5)
    // Social Risk: Positive (red) = greed/high risk = should RAISE metric
    //             Negative (green) = fear/low risk = should LOWER metric
    // Social = +60 → adjustment = +30 × weight (RAISES risk metric)
    // Social = -60 → adjustment = -30 × weight (LOWERS risk metric)
    socialAdjustment := (socialRiskFinal / 2) * socialWeight
    combinedRiskOsc_W := combinedRiskOsc_W + socialAdjustment

// Apply final smoothing on weekly data
riskMetric = request.security(CRYPTO_BTC_TICKER, "W", ta.ema(combinedRiskOsc_W, smoothingLength), barmerge.gaps_off, barmerge.lookahead_off)

// === STATE VARIABLES ===
var bool sellL1_done = false
var bool sellL2_done = false
var bool sellL3_done = false

// === BUY LOGIC ===
var float buyAmount = 0.0
buyTier = "NONE"

if riskMetric <= buyL3_thresh
    buyAmount := buyL1_amt + buyL2_amt + buyL3_amt
    buyTier := "L3"
else if riskMetric <= buyL2_thresh
    buyAmount := buyL1_amt + buyL2_amt
    buyTier := "L2"
else if riskMetric <= buyL1_thresh
    buyAmount := buyL1_amt
    buyTier := "L1"
else
    buyAmount := 0
    buyTier := "NONE"

buyTrigger = buyAmount > 0

// === BUY EXECUTION ===
if buyTrigger
    strategy.entry("BUY", strategy.long, qty=buyAmount/close, comment="BUY " + buyTier)
    label.new(bar_index, riskMetric, "BUY " + buyTier + "\n$" + str.tostring(buyAmount), 
         style=label.style_label_up, color=color.green, textcolor=color.white, size=size.small)
    
    // Reset sell levels when new buy occurs
    sellL1_done := false
    sellL2_done := false
    sellL3_done := false

    // Send 3Commas buy alert
    if use_3commas
        buyJson = '{"secret":"' + secret_token + '","max_lag":"300","timestamp":"' + str.tostring(timenow) + '","trigger_price":"' + str.tostring(close) + '","tv_exchange":"' + exchange + '","tv_instrument":"' + CRYPTO_USD_TICKER + '","action":"enter_long","bot_uuid":"' + bot_uuid + '","order":{"amount":"' + str.tostring(buyAmount) + '","currency_type":"quote","order_type":"market"}}'
        alert(buyJson, alert.freq_once_per_bar_close)
    
// === SELL LOGIC ===
sell1Cond = strategy.position_size > 0 and riskMetric >= sellL1_thresh and not sellL1_done
sell2Cond = strategy.position_size > 0 and riskMetric >= sellL2_thresh and sellL1_done and not sellL2_done
sell3Cond = strategy.position_size > 0 and riskMetric >= sellL3_thresh and sellL2_done and not sellL3_done

if sell1Cond
    strategy.close("BUY", qty_percent=sellL1_pct, comment="SELL L1")
    label.new(bar_index, riskMetric, "SELL L1\n" + str.tostring(sellL1_pct) + "%", 
         style=label.style_label_down, color=color.orange, textcolor=color.white, size=size.small)
    sellL1_done := true
    
    if use_3commas
        sellJson = '{"secret":"' + secret_token + '","max_lag":"300","timestamp":"' + str.tostring(timenow) + '","trigger_price":"' + str.tostring(close) + '","tv_exchange":"' + exchange + '","tv_instrument":"' + CRYPTO_USD_TICKER + '","action":"exit_long","bot_uuid":"' + bot_uuid + '","order":{"amount":"' + str.tostring(sellL1_pct) + '","currency_type":"position_percent","order_type":"market"}}'
        alert(sellJson, alert.freq_once_per_bar_close)

if sell2Cond
    strategy.close("BUY", qty_percent=sellL2_pct, comment="SELL L2")
    label.new(bar_index, riskMetric, "SELL L2\n" + str.tostring(sellL2_pct) + "%", 
         style=label.style_label_down, color=color.red, textcolor=color.white, size=size.small)
    sellL2_done := true
    
    if use_3commas
        sellJson = '{"secret":"' + secret_token + '","max_lag":"300","timestamp":"' + str.tostring(timenow) + '","trigger_price":"' + str.tostring(close) + '","tv_exchange":"' + exchange + '","tv_instrument":"' + CRYPTO_USD_TICKER + '","action":"exit_long","bot_uuid":"' + bot_uuid + '","order":{"amount":"' + str.tostring(sellL2_pct) + '","currency_type":"position_percent","order_type":"market"}}'
        alert(sellJson, alert.freq_once_per_bar_close)

if sell3Cond
    strategy.close("BUY", qty_percent=sellL3_pct, comment="SELL L3")
    label.new(bar_index, riskMetric, "SELL L3\n" + str.tostring(sellL3_pct) + "%", 
         style=label.style_label_down, color=color.maroon, textcolor=color.white, size=size.small)
    sellL3_done := true
    
    if use_3commas
        sellJson = '{"secret":"' + secret_token + '","max_lag":"300","timestamp":"' + str.tostring(timenow) + '","trigger_price":"' + str.tostring(close) + '","tv_exchange":"' + exchange + '","tv_instrument":"' + CRYPTO_USD_TICKER + '","action":"exit_long","bot_uuid":"' + bot_uuid + '","order":{"amount":"' + str.tostring(sellL3_pct) + '","currency_type":"position_percent","order_type":"market"}}'
        alert(sellJson, alert.freq_once_per_bar_close)

// === COLOR-CODED PLOTTING ===
riskColor = (riskMetric <= buyL3_thresh ? color.green :
             riskMetric <= buyL2_thresh ? color.lime :
             riskMetric <= buyL1_thresh ? color.yellow :
             riskMetric <= sellL1_thresh ? color.orange :
             riskMetric <= sellL2_thresh ? color.red :
             color.maroon)

plot(riskMetric, title="Risk Metric", color=riskColor, linewidth=2)

// === HORIZONTAL THRESHOLDS ===
hline(buyL3_thresh, "Buy L3", color=color.green, linewidth=2)
hline(buyL2_thresh, "Buy L2", color=color.lime)
hline(buyL1_thresh, "Buy L1", color=color.yellow, linestyle=hline.style_dashed)
hline(sellL1_thresh, "Sell L1", color=color.orange, linestyle=hline.style_dashed)
hline(sellL2_thresh, "Sell L2", color=color.red)
hline(sellL3_thresh, "Sell L3", color=color.maroon, linewidth=2)

// === FEAR & GREED DISPLAY (OPTIONAL SEPARATE PLOT) ===
fgLabel = fearGreedIndex > 90 ? "X-Greed" :
          fearGreedIndex > 75 ? "Greed" :
          fearGreedIndex > 60 ? "Greed+" :
          fearGreedIndex > 40 ? "Neutral" :
          fearGreedIndex > 25 ? "Fear" :
          "X-Fear"

fgColor = fearGreedIndex > 90 ? color.new(#006400, 0) :
          fearGreedIndex > 75 ? color.new(color.green, 0) :
          fearGreedIndex > 60 ? color.new(color.blue, 0) :
          fearGreedIndex > 40 ? color.new(color.gray, 0) :
          fearGreedIndex > 25 ? color.new(color.orange, 0) :
          color.new(color.red, 0)

plot(showFearGreed ? fearGreedIndex : na, "Fear & Greed", color=color.new(color.white, 60), linewidth=1, style=plot.style_line)

if showFearGreed
    var label fgDisplayLabel = na
    label.delete(fgDisplayLabel)
    fgDisplayLabel := label.new(bar_index, fearGreedIndex, fgLabel, 
         color=fgColor, textcolor=color.white, style=label.style_label_left, size=size.tiny)

// === PMI DISPLAY (OPTIONAL SEPARATE PLOT) ===
plot(showPMI ? pmiData_smoothed : na, "ISM PMI", color=color.blue, linewidth=1)
hline(showPMI ? 50 : na, "PMI 50", color=color.new(color.blue, 70), linestyle=hline.style_dotted)

// === SOCIAL RISK DISPLAY (OPTIONAL SEPARATE PLOT) ===
plot(showSocialRisk ? socialRiskFinal : na, "Social Risk", color=socialRiskFinal > 0 ? color.red : color.green, linewidth=1)
hline(showSocialRisk ? 60 : na, "Social Greed", color=color.new(color.red, 70), linestyle=hline.style_dotted)
hline(showSocialRisk ? -60 : na, "Social Fear", color=color.new(color.green, 70), linestyle=hline.style_dotted)
hline(showSocialRisk ? 0 : na, "Social Neutral", color=color.new(color.gray, 70), linestyle=hline.style_dashed)

// === INFO TABLE ===
if barstate.islast
    var table infoTable = table.new(position.top_right, 2, 12, border_width=1)
    
    table.cell(infoTable, 0, 0, "Risk Metric", bgcolor=color.navy, text_color=color.white)
    table.cell(infoTable, 1, 0, str.tostring(riskMetric, "#.#"), bgcolor=riskColor, text_color=color.white)
    
    table.cell(infoTable, 0, 1, "Base Risk", bgcolor=color.gray, text_color=color.white)
    table.cell(infoTable, 1, 1, str.tostring(baseRiskOsc_W, "#.#"), bgcolor=color.gray, text_color=color.white)
    
    table.cell(infoTable, 0, 2, "F&G Adjust", bgcolor=color.gray, text_color=color.white)
    table.cell(infoTable, 1, 2, str.tostring(fgAdjustment, "#.#"), bgcolor=fgAdjustment > 0 ? color.red : color.green, text_color=color.white)
    
    table.cell(infoTable, 0, 3, "PMI Adjust", bgcolor=color.blue, text_color=color.white)
    table.cell(infoTable, 1, 3, str.tostring(pmiAdjustment, "#.#"), bgcolor=pmiAdjustment > 0 ? color.red : color.green, text_color=color.white)
    
    table.cell(infoTable, 0, 4, "Social Adjust", bgcolor=color.purple, text_color=color.white)
    table.cell(infoTable, 1, 4, str.tostring(socialAdjustment, "#.#"), bgcolor=socialAdjustment > 0 ? color.red : color.green, text_color=color.white)
    
    table.cell(infoTable, 0, 5, "F&G Index", bgcolor=color.gray, text_color=color.white)
    table.cell(infoTable, 1, 5, useFearGreed ? str.tostring(fearGreedIndex, "#.#") : "OFF", bgcolor=useFearGreed ? fgColor : color.gray, text_color=color.white)
    
    table.cell(infoTable, 0, 6, "F&G Weight", bgcolor=color.gray, text_color=color.white)
    table.cell(infoTable, 1, 6, useFearGreed ? str.tostring(fgWeight * 100, "#") + "%" : "-", bgcolor=color.gray, text_color=color.white)
    
    table.cell(infoTable, 0, 7, "ISM PMI", bgcolor=color.blue, text_color=color.white)
    pmiColor = pmiData_smoothed < 45 ? color.red : pmiData_smoothed < 50 ? color.orange : pmiData_smoothed < 55 ? color.yellow : color.green
    table.cell(infoTable, 1, 7, usePMI ? str.tostring(pmiData_smoothed, "#.#") : "OFF", bgcolor=usePMI ? pmiColor : color.gray, text_color=color.white)
    
    table.cell(infoTable, 0, 8, "PMI Weight", bgcolor=color.blue, text_color=color.white)
    table.cell(infoTable, 1, 8, usePMI ? str.tostring(pmiWeight * 100, "#") + "%" : "-", bgcolor=color.blue, text_color=color.white)
    
    table.cell(infoTable, 0, 9, "Social Risk", bgcolor=color.purple, text_color=color.white)
    socialColor = socialRiskFinal > 30 ? color.red : socialRiskFinal > 0 ? color.orange : socialRiskFinal > -30 ? color.yellow : color.green
    table.cell(infoTable, 1, 9, useSocialRisk ? str.tostring(socialRiskFinal, "#.#") : "OFF", bgcolor=useSocialRisk ? socialColor : color.gray, text_color=color.white)
    
    table.cell(infoTable, 0, 10, "Social Weight", bgcolor=color.purple, text_color=color.white)
    table.cell(infoTable, 1, 10, useSocialRisk ? str.tostring(socialWeight * 100, "#") + "%" : "-", bgcolor=color.purple, text_color=color.white)
    
    table.cell(infoTable, 0, 11, "Position", bgcolor=color.navy, text_color=color.white)
    posColor = strategy.position_size > 0 ? color.green : color.gray
    table.cell(infoTable, 1, 11, strategy.position_size > 0 ? "LONG" : "FLAT", bgcolor=posColor, text_color=color.white)

