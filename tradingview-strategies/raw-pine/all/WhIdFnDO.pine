//@version=6
strategy("Ratchet Exit Strategy + Market Filter", 
     overlay = true, 
     initial_capital = 10000, 
     default_qty_type = strategy.percent_of_equity, 
     default_qty_value = 100, 
     pyramiding = 1, 
     commission_type = strategy.commission.percent, 
     commission_value = 0.1,
     currency = currency.USD)

// ─────────────────────
// 1. Inputs
// ─────────────────────
sma25Len  = input.int(25,  "SMA 25 (Momentum)", group="SMAs")
sma50Len  = input.int(50,  "SMA 50 (Trend)",    group="SMAs")
sma100Len = input.int(100, "SMA 100 (Medium)",  group="SMAs")
sma200Len = input.int(200, "SMA 200 (Long)",    group="SMAs")

// 🛡️ NEU: Market Filter Inputs
group_filter = "🛡️ Market Regime Filter"
useMarketFilter = input.bool(true, "Nur handeln wenn Index > SMA200?", group=group_filter, tooltip="Schützt vor Bärenmärkten. Handelt nur, wenn der breite Markt steigt.")
marketTicker    = input.symbol("NASDAQ:QQQ", "Markt-Referenz (z.B. QQQ)", group=group_filter)

// VIX Filter Inputs
group_vix = "VIX Filter"
useVixFilter = input.bool(true, "VIX Filter aktivieren?", group=group_vix)
vixThreshold = input.float(32.0, "VIX Schwellenwert", group=group_vix)

// Exit Einstellungen
group_exit    = "Exit Logic (Ratchet System)"
slInitialPerc = input.float(10.0, "Initial Stop Loss %",        group=group_exit)
profitStep1   = input.float(10.0, "Trigger für Stufe 1 (+%)",   group=group_exit)
slStep1Perc   = input.float(8.0,  "Abstand Stufe 1 (%)",  group=group_exit)
profitStep2   = input.float(15.0, "Trigger für Stufe 2 (+%)",   group=group_exit)
trailPerc     = input.float(8.0,  "Trailing Abstand (%)",       group=group_exit)

// ─────────────────────
// 2. Datenabruf & Indikatoren
// ─────────────────────
vixClose = request.security("CBOE:VIX", "D", close)

// 🛡️ NEU: Markt-Daten holen & Checken
marketClose = request.security(marketTicker, "D", close)
marketSMA200 = request.security(marketTicker, "D", ta.sma(close, 200))
isBullMarket = (not useMarketFilter) or (marketClose > marketSMA200)

sma25  = ta.sma(close, sma25Len)
sma50  = ta.sma(close, sma50Len)
sma100 = ta.sma(close, sma100Len)
sma200 = ta.sma(close, sma200Len)

plot(sma25, "SMA 25", color=color.purple)
plot(sma50, "SMA 50", color=color.green, linewidth=2)
plot(sma100, "SMA 100", color=color.blue)
plot(sma200, "SMA 200", color=color.orange, linewidth=2)

// Market Filter Status im Chart anzeigen (Hintergrundfarbe)
bgcolor(useMarketFilter and not isBullMarket ? color.new(color.red, 90) : na, title="Bear Market Filter Active")

// ─────────────────────
// 3. Entry Logik
// ─────────────────────
entryCross  = ta.crossover(sma25, sma50)
f_threeBarBreak(float _sma) => close > _sma and close[1] > _sma[1] and close[2] > _sma[2] and close[3] < _sma[3]

breakout50  = f_threeBarBreak(sma50)
breakout100 = f_threeBarBreak(sma100)
breakout200 = f_threeBarBreak(sma200)

vixCondition = (not useVixFilter) or (vixClose < vixThreshold)

// 🛡️ COMBINED CONDITION: VIX ok AND Market ok
if vixCondition and isBullMarket
    if entryCross
        strategy.entry("Long", strategy.long, comment="Entry: 25x50")
    if breakout50
        strategy.entry("Long", strategy.long, comment="Entry: SMA50")
    if breakout100
        strategy.entry("Long", strategy.long, comment="Entry: SMA100")
    if breakout200
        strategy.entry("Long", strategy.long, comment="Entry: SMA200")

// ─────────────────────
// 4. Exits (Panic & Ratchet)
// ─────────────────────

// VIX Panic
if useVixFilter and vixClose > vixThreshold
    strategy.close_all(comment = "VIX Panic Exit")

// OPTIONAL: Market Panic Exit (Wenn Markt unter SMA200 fällt, alles verkaufen?)
// Aktuell deaktiviert, da wir Trades oft noch auslaufen lassen wollen. 
// Entkommentieren für maximalen Schutz:
// if useMarketFilter and marketClose < marketSMA200
//     strategy.close_all(comment = "Market Regime Exit")

// Ratchet Logic (Stage 1 Dynamic Version)
var int exitStage = 0         
var float activeStopPrice = 0.0 
var float highestHigh = 0.0    
var float stage1RefPrice = 0.0
float plotStop = na

if strategy.position_size == 0
    exitStage := 0
    activeStopPrice := 0.0
    highestHigh := 0.0
    stage1RefPrice := 0.0

if strategy.position_size > 0
    float avgEntry = strategy.position_avg_price
    float currentProfitPerc = (close - avgEntry) / avgEntry * 100.0
    
    if highestHigh == 0.0
        highestHigh := high
    else
        highestHigh := math.max(highestHigh, high)

    if exitStage < 1 and currentProfitPerc >= profitStep1
        exitStage := 1 
        stage1RefPrice := close 
    
    if exitStage < 2 and currentProfitPerc >= profitStep2
        exitStage := 2

    float potentialStop = 0.0
    string commentText = ""

    if exitStage == 0
        potentialStop = avgEntry * (1 - slInitialPerc / 100.0)
        commentText := "Initial Stop"
    else if exitStage == 1
        potentialStop = stage1RefPrice * (1 - slStep1Perc / 100.0)
        commentText := "Locked Stage 1"
    else if exitStage == 2
        potentialStop = highestHigh * (1 - trailPerc / 100.0)
        commentText := "Trailing"

    if strategy.position_size[1] == 0
        activeStopPrice := potentialStop
    else
        activeStopPrice := math.max(activeStopPrice, potentialStop)

    plotStop := activeStopPrice
    strategy.exit("Ratchet Exit", stop = activeStopPrice, comment_loss = commentText)

if ta.crossunder(sma25, sma50)
    strategy.close_all(comment = "Dead Cross")

plot(plotStop, "Active Stop Loss", color=color.red, style=plot.style_linebr, linewidth=2)

