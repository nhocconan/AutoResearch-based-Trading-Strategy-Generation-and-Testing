// Plotting the TP and SL levels. I want to modify this part so that the TP and SLs plot out only from the entry to the exit of a trade. 
// I guess that would be another window, where a window is opened when strategy.position_size==0, and closed when !=0
buyTPColor = strategy.position_entry_name == "LE" ? color.olive : na
buySLColor = strategy.position_entry_name == "LE" ? color.orange : na
sellTPColor = strategy.position_entry_name == "SE"? color.olive : na
sellSLColor = strategy.position_entry_name == "SE" ? color.orange : na
plot(showLongSLTP ? buyTP1 : na, linewidth = 1, style = plot.style_linebr, color = buyTPColor)
d = plot(showLongSLTP ? buyTP2 : na, linewidth = 5, style = plot.style_linebr, color = buyTPColor)
a = plot(showLongSLTP ? buySL : na , linewidth = 5,  style = plot.style_linebr, color = buySLColor)
plot(showShortSLTP ? sellTP1 : na, linewidth = 1,  style = plot.style_linebr, color = sellTPColor)
c = plot(showShortSLTP ? sellTP2 : na, linewidth = 5,  style = plot.style_linebr, color = sellTPColor)
b = plot(showShortSLTP ? sellSL : na, linewidth = 5,  style = plot.style_linebr, color = sellSLColor)
e = plot(strategy.position_entry_name == "LE" ? LEPrice : na, linewidth = 5, style = plot.style_linebr, color = color.green)
f = plot(strategy.position_entry_name == "SE" ? SEPrice : na, linewidth = 5, style = plot.style_linebr, color = color.red)
// POSITION SHADING
fill(b, f, color = color.red, transp = 85)
fill(f, c, color = color.green, transp = 85)
fill(a, e, color = color.red, transp = 85)
fill(e, d, color = color.green, transp = 85)

