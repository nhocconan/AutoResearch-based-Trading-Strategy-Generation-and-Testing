//  4.  https://backtest-rookies.com/2018/10/26/tradingview-opening-a-window/ 
//  5.  https://www.youtube.com/watch?v=zhEukjCzXwM
//  6.  https://backtest-rookies.com/2017/11/21/tradingview-creating-alerts/
//  7.  https://www.tradingview.com/wiki/FAQ#How_much_history_is_available_on_a_chart.3F
//  8.  https://www.hexcolortool.com/   - for colour hex codes


//-------------------------------------------------------------------

//Some other nice plots that are not part of the strategy.

//plot yesterday's high and low, and today's open as a horizontal line with crosses
daily_high = security(syminfo.tickerid, "D", high[1], lookahead=barmerge.lookahead_on)
daily_low = security(syminfo.tickerid, "D", low[1], lookahead=barmerge.lookahead_on)
daily_open = security(syminfo.tickerid,"D",open,lookahead=barmerge.lookahead_on)

showHighLow = input(true, "show Daily H L plot line?")
plot(showHighLow? daily_high : na, style=plot.style_stepline, color=color.green, linewidth = 3)
plot(showHighLow? daily_low : na, style=plot.style_stepline, color=color.red, linewidth = 3)
plot(showHighLow? daily_open : na,style=plot.style_circles,color=color.silver)

//plot Day of week labels at 0700 AEST
session = input(defval="1600-1601",type=input.session) // 1700 in the exchange time zone(EST NY UTC-5) seems to return 0800 AEST. The adjustment from EST to AEST is EST+15, conversely, AEST = EST - 15
t=time(timeframe.period,session)

labelText = dayofweek==dayofweek.monday ? "Tue" 
     : dayofweek==dayofweek.tuesday? "Wed"
     : dayofweek==dayofweek.wednesday? "Thur"
     : dayofweek==dayofweek.thursday? "Fri"
     : dayofweek==dayofweek.friday? "Mon"
     : na
//I notice the above will return the day of week at 1700 EST.Hence I made some adjustments so that the label returns at 7am of AEST day of week     

session_open=na(t)? false : true
if session_open 
    label.new(bar_index,na,labelText,color=color.green,textcolor=color.white,style=label.style_labeldown,yloc=yloc.abovebar)
else
    na

