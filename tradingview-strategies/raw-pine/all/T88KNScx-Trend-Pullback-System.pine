//@version=6
strategy("Trend Pullback System", overlay=true, fill_orders_on_standard_ohlc = true)

longCondition = ta.crossover(ta.sma(close, 14), ta.sma(close, 28))
if (longCondition)
    strategy.entry("Long Entry", strategy.long)

shortCondition = ta.crossunder(ta.sma(close, 14), ta.sma(close, 28))
if (shortCondition)
    strategy.entry("Short Entry", strategy.short)

//----------------------------------------------------
// INPUTS
//----------------------------------------------------
smaShortLen = input.int(6, "Short MA Length (trend accel)")
smaLongLen = input.int(14, "Long MA Length (trend base)")
hullLen = input.int(20, "Hull MA Length (secondary trend ref)")
swingLen = input.int(5, "Swing lookback length (diamonds pivots)")
pullbackSupportBars = input.int(3, "Bars since support allowed for entry")
allowLongs = input.bool(true, "Enable Long Trades")
allowShorts = input.bool(true, "Enable Short Trades")
trailWithDiamonds = input.bool(true, "Trail stop using diamonds after entry if trend persists")
smiLenK = input.int(14, "SMI Length K")
smiLenD = input.int(5, "SMI Length D")
smiLenSig = input.int(3, "SMI Signal Length")

//----------------------------------------------------
// CORE MAs / TREND
//----------------------------------------------------
smaShort = ta.sma(close, smaShortLen)
smaLong = ta.sma(close, smaLongLen)

// Hull MA (basic Hull calc: WMA(2*WMA(price, n/2)-WMA(price,n), sqrt(n)))
wmaf = ta.wma(close, math.round(hullLen * 0.5))
wmas = ta.wma(close, hullLen)
hullMA = ta.wma(2.0 * wmaf - wmas, math.round(math.sqrt(hullLen)))

// slope of long MA
longSlopeUp = smaLong > smaLong[1]
longSlopeDown = smaLong < smaLong[1]

// major trend states
upTrend = (close > smaLong) and (smaShort > smaLong) and longSlopeUp
downTrend = (close < smaLong) and (smaShort < smaLong) and longSlopeDown

//----------------------------------------------------
// PIVOTS (Diamonds)
//----------------------------------------------------
isSwingLow = low == ta.lowest(low, swingLen)
isSwingHigh = high == ta.highest(high, swingLen)

// diamonds per method logic
greenDiamond = upTrend and isSwingLow // bullish support / long add / TP shorts
redDiamond = downTrend and isSwingHigh // bearish resistance / short add / TP longs

//----------------------------------------------------
// BUY / SELL ZONES
//----------------------------------------------------
// BUY Zone (longSetup)
recentGreenSupport = ta.barssince(greenDiamond) <= pullbackSupportBars
regainMA = ta.crossover(close, smaShort) or (close > smaShort)
longSetup = recentGreenSupport and (upTrend or (close > smaLong and longSlopeUp)) and regainMA

// SELL Zone (shortSetup)
recentRedResist = ta.barssince(redDiamond) <= pullbackSupportBars
loseMA = ta.crossunder(close, smaShort) or (close < smaShort)
shortSetup = recentRedResist and (downTrend or (close < smaLong and longSlopeDown)) and loseMA

// Weak setups (yellow "W")
weakLong = isSwingLow and (not upTrend) and (close > smaLong)
weakShort = isSwingHigh and (not downTrend) and (close < smaLong)

//----------------------------------------------------
// STOPS & TARGETS (persistent vars)
//----------------------------------------------------
var float longStop = na
var float longTarget = na
var float shortStop = na
var float shortTarget = na

// When long setup appears: initialize stop/target
if longSetup
    longStop := ta.lowest(low, pullbackSupportBars + 1)
    longTarget := ta.highest(high, pullbackSupportBars + 1)

// When short setup appears: initialize stop/target
if shortSetup
    shortStop := ta.highest(high, pullbackSupportBars + 1)
    shortTarget := ta.lowest(low, pullbackSupportBars + 1)

//----------------------------------------------------
// TRAILING STOP LOGIC (flat, no nested if chains)
//----------------------------------------------------
var bool canTrailLong = false
var bool canTrailShort = false

// recompute trail conditions every bar
canTrailLong := trailWithDiamonds and (strategy.position_size > 0) and greenDiamond and upTrend and (not shortSetup) and (not na(longStop)) and (low > longStop)
canTrailShort := trailWithDiamonds and (strategy.position_size < 0) and redDiamond and downTrend and (not longSetup) and (not na(shortStop)) and (high < shortStop)

// apply trail adjustments
if canTrailLong
    longStop := low

if canTrailShort
    shortStop := high

//----------------------------------------------------
// ENTRY ORDERS
//----------------------------------------------------
if allowLongs and longSetup
    strategy.entry("TKT Long", strategy.long, comment="BUY Zone")

if allowShorts and shortSetup
    strategy.entry("TKT Short", strategy.short, comment="SELL Zone")

//----------------------------------------------------
// EXIT ORDERS
//----------------------------------------------------
useStopLong = na(longStop) ? low : longStop
useTargetLong = na(longTarget) ? high : longTarget
useStopShort = na(shortStop) ? high : shortStop
useTargetShort = na(shortTarget) ? low : shortTarget

strategy.exit("TRT Long Exit", from_entry="TRT Long", stop=useStopLong, limit=useTargetLong)
strategy.exit("TRT Short Exit", from_entry="TRT Short", stop=useStopShort, limit=useTargetShort)

//----------------------------------------------------
// EXIT WARNING MARKER (stop sign)
//----------------------------------------------------
exitWarnLong = (strategy.position_size > 0) and shortSetup
exitWarnShort = (strategy.position_size < 0) and longSetup
exitWarn = exitWarnLong or exitWarnShort

//----------------------------------------------------
// REFERENCE LEVELS (weekly / monthly / yearly closes)
//----------------------------------------------------
lastWeekClose = request.security(syminfo.tickerid, "1W", close[1])
lastMonthClose = request.security(syminfo.tickerid, "1M", close[1])
lastYearClose = request.security(syminfo.tickerid, "12M", close[1])

// FIX: Color names accessed using the `color.` namespace or hex for colors like brown.
plot(lastWeekClose, title="Last Week Close", color=color.new(#996633, 40), style=plot.style_linebr, linewidth=1)
plot(lastMonthClose, title="Last Month Close", color=color.new(color.blue, 60), style=plot.style_linebr, linewidth=1)
plot(lastYearClose, title="Last Year Close", color=color.new(color.aqua, 60), style=plot.style_linebr, linewidth=1)

//----------------------------------------------------
// BAR COLORING (trend bars)
//----------------------------------------------------
bullBar = upTrend
bearBar = downTrend
barColor = bullBar ? color.new(color.lime, 0) : bearBar ? color.new(color.red, 0) : color.new(color.black, 0)
//bgcolor(barColor)

//----------------------------------------------------
// VISUAL MARKERS ON PRICE
//----------------------------------------------------
// Moving averages
plot(smaLong, title="SMA Long", color=color.new(color.black, 0), linewidth=2)
plot(smaShort, title="SMA Short", color=color.new(color.teal, 0), linewidth=2)
plot(hullMA, title="Hull MA", color=color.new(color.blue, 0), linewidth=2, style=plot.style_line)
// Diamonds (support/resistance)
plotshape(greenDiamond, title="Green Diamond (Support / Long Re-entry or TP for Shorts)", style=shape.diamond, location=location.belowbar, color=color.new(color.lime, 0), size=size.tiny, text="♦")
plotshape(redDiamond, title="Red Diamond (Resistance / Short Re-entry or TP for Longs)", style=shape.diamond, location=location.abovebar, color=color.new(color.red, 0), size=size.tiny, text="♦")
 
// BUY / SELL Zone arrows
plotshape(longSetup, title="BUY Zone Arrow (Long Setup/Entry/Take Profit Short)", style=shape.triangleup, location=location.belowbar, color=color.new(color.lime,0), size=size.small, text="BUY")
plotshape(shortSetup, title="SELL Zone Arrow (Short Setup/Entry/Take Profit Long)", style=shape.triangledown, location=location.abovebar, color=color.new(color.red,0), size=size.small, text="SELL")

// Weak setups in yellow
plotshape(weakLong, title="Weak Long Setup", style=shape.triangleup, location=location.belowbar, color=color.new(color.yellow,0), size=size.tiny, text="W")
plotshape(weakShort, title="Weak Short Setup", style=shape.triangledown, location=location.abovebar, color=color.new(color.yellow,0), size=size.tiny, text="W")

// EXIT warning marker ("stop sign")
plotshape(exitWarn, title="Stop Sign / Exit Warning", style=shape.labeldown, location=location.abovebar, color=color.new(color.orange,0), textcolor=color.black, text="EXIT", size=size.tiny)

//----------------------------------------------------
// MOMENTUM PANEL (SMI-style, hidden by default)
//----------------------------------------------------
// inline calc instead of custom function to avoid return/result issues
ll = ta.lowest(close, smiLenK)
hh = ta.highest(close, smiLenK)
mid = (hh + ll) * 0.5
diff = close - mid
rng = hh - ll
diffSmooth = ta.ema(ta.ema(diff, smiLenD), smiLenSig)
rngSmooth = ta.ema(ta.ema(rng, smiLenD), smiLenSig) / 2.0
smiVal = rngSmooth != 0 ? (diffSmooth / rngSmooth) * 100.0 : 0.0
smiSig = ta.ema(smiVal, smiLenSig)
smiOB = 40.0
smiOS = -40.0
smiColor = smiVal > smiSig ? color.lime : color.red

// FIX: Named arguments for color, linewidth, and display are explicitly used.
plot(smiVal, title="SMI / Momentum", color=smiColor, linewidth=2, display=display.none)
plot(smiSig, title="SMI Signal", color=color.new(color.gray,0), linewidth=1, display=display.none)

// FIX: Named arguments for hline color and display are explicitly used.
hline(smiOB, title="SMI Overbought-ish", color=color.new(color.red,70), display=display.none)
hline(smiOS, title="SMI Oversold-ish", color=color.new(color.lime,70), display=display.none)
hline(0, title="Midline", color=color.new(color.gray,80), display=display.none)

//----------------------------------------------------
// ALERTS
//----------------------------------------------------
alertcondition(longSetup, title="TRT Long Setup", message="Target Rich Trades: BUY Zone long setup triggered")
alertcondition(shortSetup, title="TRT Short Setup", message="Target Rich Trades: SELL Zone short setup triggered")
alertcondition(exitWarn, title="TRT Exit Warning", message="Target Rich Trades: Opposite signal against open position (Stop Sign)")

