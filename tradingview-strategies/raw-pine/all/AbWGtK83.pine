//@version=5
strategy("CCI and MACD Auto Trading Strategy with Risk/Reward", overlay=true)

// CCI settings
length = input.int(14, minval=1, title="CCI Length")
cciSrc = input(hlc3, title="CCI Source")
cciMa = ta.sma(cciSrc, length)
cci = (cciSrc - cciMa) / (0.015 * ta.dev(cciSrc, length))

// MACD settings
fast_length = input.int(title="MACD Fast Length", defval=12)
slow_length = input.int(title="MACD Slow Length", defval=26)
macdSrc = input(close, title="MACD Source")
signal_length = input.int(title="MACD Signal Smoothing", minval=1, maxval=50, defval=9)
sma_source = input.string(title="MACD Oscillator MA Type", defval="EMA", options=["SMA", "EMA"])
sma_signal = input.string(title="MACD Signal Line MA Type", defval="EMA", options=["SMA", "EMA"])

// MACD calculations
fast_ma = (sma_source == "SMA") ? ta.sma(macdSrc, fast_length) : ta.ema(macdSrc, fast_length)
slow_ma = (sma_source == "SMA") ? ta.sma(macdSrc, slow_length) : ta.ema(macdSrc, slow_length)
macd = fast_ma - slow_ma
signal = (sma_signal == "SMA") ? ta.sma(macd, signal_length) : ta.ema(macd, signal_length)
hist = macd - signal

// Detect recent lows and highs
lookbackPeriod = input.int(10, title="Lookback Period")
recentLow = ta.lowest(low, lookbackPeriod)
recentHigh = ta.highest(high, lookbackPeriod)

// Plot options
showCCI = input.bool(false, title="Show CCI")
showMACD = input.bool(false, title="Show MACD")
showRecentLowHigh = input.bool(false, title="Show Recent Low/High")



// Trading logic
longCondition = (hist > 0) and (ta.crossover(cci, -100))
shortCondition = (hist < 0) and (ta.crossunder(cci, 100))

// Risk/Reward ratio
riskRewardRatio = 1.5

if (longCondition) 
    var float stopLossPrice = na
    var float takeProfitPrice = na
    stopLossPrice := recentLow
    takeProfitPrice := close + (close - stopLossPrice) * riskRewardRatio
    strategy.entry("Long", strategy.long)
    strategy.exit("Take Profit/Stop Loss", "Long", stop=stopLossPrice, limit=takeProfitPrice)

if (shortCondition) 
    var float stopLossPrice = na
    var float takeProfitPrice = na
    stopLossPrice := recentHigh
    takeProfitPrice := close - (stopLossPrice - close) * riskRewardRatio
    strategy.entry("Short", strategy.short)
    strategy.exit("Take Profit/Stop Loss", "Short", stop=stopLossPrice, limit=takeProfitPrice)

