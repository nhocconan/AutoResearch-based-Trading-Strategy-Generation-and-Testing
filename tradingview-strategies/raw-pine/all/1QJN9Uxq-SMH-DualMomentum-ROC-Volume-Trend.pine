//@version=5
strategy("SMH_DualMomentum (ROC + Volume Trend)", overlay=true, initial_capital=100000, commission_type=strategy.commission.percent, commission_value=0.0)

// === Inputs (match Python hyperparameters) ===
rocPeriod     = input.int(20, "ROC Period", minval=1)
rocThreshold  = input.float(3.0, "ROC Threshold (%)", step=0.1)   // e.g., 3 means +3%
volPeriod     = input.int(20, "Volume SMA Period", minval=1)

// === Core indicators ===
// ROC as percent change over rocPeriod
roc = 100 * (close / close[rocPeriod] - 1)

// Volume SMA
volSma = ta.sma(volume, volPeriod)

// Volume rising condition (volume above its SMA)
volumeRising = volume > volSma

// Entry: Strong positive momentum + rising volume
longCondition = (roc > rocThreshold) and volumeRising

// Exit: Momentum turns negative
exitCondition = (roc < 0)

// === Orders ===
if (longCondition) and (strategy.position_size <= 0)
    strategy.entry("Long", strategy.long)

if (exitCondition) and (strategy.position_size > 0)
    strategy.close("Long")

// === Visuals ===
plot(volSma, title="Volume SMA", color=color.new(color.orange, 0), style=plot.style_line, linewidth=2, display=display.none)
plotchar(longCondition, title="Entry Signal", char="▲", location=location.belowbar, color=color.new(color.lime, 0), size=size.tiny)
plotchar(exitCondition and strategy.position_size > 0, title="Exit Signal", char="▼", location=location.abovebar, color=color.new(color.red, 0), size=size.tiny)

// Optional: show ROC in Data Window (not overlay)
rocPlot = input.bool(false, "Plot ROC in separate pane?")
plot(rocPlot ? roc : na, title="ROC (%)", color=color.new(color.blue, 0), linewidth=2)
hline(0, "ROC 0%", color=color.new(color.gray, 70))
hline(rocThreshold, "ROC Threshold", color=color.new(color.green, 70))

