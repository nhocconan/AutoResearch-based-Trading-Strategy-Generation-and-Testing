//@version=5
strategy("The Engulfing Liquidity Signal with Adjustable Trailing Stop", overlay=true)

// BUYING VOLUME AND SELLING VOLUME //
buyVolume = high == low ? 0 : volume * (close - low) / (high - low)
sellVolume = -(high == low ? 0 : volume * (high - close) / (high - low))
netVolume = buyVolume + sellVolume

b = netVolume > 0 ? netVolume : 0
length1=input(2,"BuyMaMult")
BL=input(22,"BuyMaLength")
mab = length1*ta.sma(b, BL)

s = netVolume < 0 ? netVolume : 0
length=input(2,"SellMaMult")
SL=input(22,"SellMaLength")
mas = length*ta.sma(s, SL)

cum=math.sum(netVolume,10)

long=netVolume>mab and netVolume[1]<0 and netVolume[2]<0 and netVolume>-(netVolume[1])and netVolume[1]>netVolume[2]
short=netVolume<mas and netVolume[1]>0 and netVolume[2]>0 and -netVolume>(netVolume[1])and netVolume[1]<netVolume[2]

LongC=close>open and close[1]<open[1] and close>high[1] and netVolume>mab and netVolume>-netVolume[1] and netVolume[1]<0 
ShortC=close<open and close[1]>open[1] and close<low[1] and netVolume<mas and netVolume<-netVolume[1] and netVolume[1]>0 

alertcondition(LongC,"Buy")
alertcondition(ShortC,"Sell")

// Levels of Fibonacci on Buy Signal
lowestLow = ta.lowest(low, 50) // Lowest low for previous 50 bars, modify as needed

// Fibonacci Levels from Buy Signal
var float fibRetrace1 = na
var float fibRetrace2 = na
var float fibRetrace3 = na
var float fibRetrace4 = na
var float fibExt1 = na
var float fibExt2 = na
var float fibExt3 = na

// Store Fibonacci levels when a Buy signal occurs
if LongC
    fibRetrace1 := lowestLow + (close - lowestLow) * 0.236
    fibRetrace2 := lowestLow + (close - lowestLow) * 0.382
    fibRetrace3 := lowestLow + (close - lowestLow) * 0.618
    fibRetrace4 := lowestLow + (close - lowestLow) * 0.786
    fibExt1 := lowestLow + (close - lowestLow) * 1.0
    fibExt2 := lowestLow + (close - lowestLow) * 1.618
    fibExt3 := lowestLow + (close - lowestLow) * 2.618

// Trailing Stop Logic: Track the highest price since the trade started
var float highestSinceEntry = na

// Allow the user to adjust the trailing stop percentage through the settings
trail_percentage = input.float(0.3, "Trailing Stop Percentage", minval=0.1, maxval=1.0, step=0.01)  // Default 30%

// Trailing stop distance (adjust based on your strategy)
trail_offset = (close - lowestLow) * trail_percentage  // User-defined percentage for trailing stop

// Buy Logic and Execution with Trailing Stop
if LongC
    strategy.entry("Buy", strategy.long)
    highestSinceEntry := high  // Track the highest point since entry
    
    // Calculate the dynamic trailing stop price: stop level follows the highest price
    trailStopLevel = highestSinceEntry - trail_offset
    
    // Set Exit Conditions (only trailing stop, no fixed take profit)
    strategy.exit("Trailing Stop", "Buy", stop=trailStopLevel)  // Trailing Stop only, no fixed take profit

// Update the highest price reached during the trade
if (strategy.opentrades > 0)
    highestSinceEntry := math.max(highestSinceEntry, high)  // Update the highest price reached during the trade

// Close the position when a Sell Signal (ShortC) is triggered
if ShortC
    strategy.close("Buy", comment="Sell Signal")  // Close the Buy position on Sell Signal

// Plot Fibonacci Levels (These will be plotted only on Buy Signal, but not used for take profit)
if LongC
    line.new(bar_index[1], fibRetrace1, bar_index, fibRetrace1, color=color.green, width=1, style=line.style_dashed)
    line.new(bar_index[1], fibRetrace2, bar_index, fibRetrace2, color=color.green, width=1, style=line.style_dashed)
    line.new(bar_index[1], fibRetrace3, bar_index, fibRetrace3, color=color.green, width=1, style=line.style_dashed)
    line.new(bar_index[1], fibRetrace4, bar_index, fibRetrace4, color=color.green, width=1, style=line.style_dashed)
    line.new(bar_index[1], fibExt1, bar_index, fibExt1, color=color.red, width=1, style=line.style_dashed)
    line.new(bar_index[1], fibExt2, bar_index, fibExt2, color=color.red, width=1, style=line.style_dashed)
    line.new(bar_index[1], fibExt3, bar_index, fibExt3, color=color.red, width=1, style=line.style_dashed)

