//@version=3
strategy(title="Never Lose A Trade Again", shorttitle='NLATA', overlay=true, initial_capital=5000, pyramiding=10, default_qty_type=strategy.cash, default_qty_value=500, currency=currency.EUR)

fastLength = 13
slowLength = 34

fastMovingAverage = ema(close, fastLength)
slowMovingAverage = ema(close, slowLength)
[_, _, hist] = macd(close, 12, 26, 9)
delta = fastMovingAverage - slowMovingAverage
fillingColor = delta > 0 ? color(red, 25) : color(lime, 25)

fastMovingAveragePlot = plot(fastMovingAverage, title='FMA', color=fuchsia, linewidth=3)
slowMovingAveragePlot = plot(slowMovingAverage, title='SMA', color=blue, linewidth=3)
fill(fastMovingAveragePlot, slowMovingAveragePlot, color=fillingColor)

shouldBuy = delta < 0 and hist < 0 and hist > hist[1]
strategy.entry('BUY', strategy.long, when=shouldBuy)
plotshape(shouldBuy, color=lime, style=shape.arrowup, text="BUY")

shouldSell = delta > 0 and hist > 0 and hist < hist[1]
strategy.exit('SELL', 'BUY', when=shouldSell)
plotshape(shouldSell, color=red, style=shape.arrowdown, text="SELL")

