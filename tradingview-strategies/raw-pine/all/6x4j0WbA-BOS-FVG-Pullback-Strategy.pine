//@version=5
strategy("BOS + Demand Pullback Strategy", overlay=true)

// Inputs
minGreen = input.int(1, "Min. grüne Kerzen (Impuls)")
pivotLen = input.int(5, "Pivot Length")
atrLen = input.int(14, "ATR Length")
atrMult = input.float(2.0, "Min. Impuls in ATR")
maxZoneAge = input.int(20, "Max. Zonen-Alter (Kerzen)")

// ATR
atrVal = ta.atr(atrLen)

// ─────────────────────────────
// BOS via Market Structure
// ─────────────────────────────
swingHigh = ta.pivothigh(high, pivotLen, pivotLen)

var float lastHigh = na
var bool highBroken = false

if not na(swingHigh)
    lastHigh := swingHigh
    highBroken := false

bos = not highBroken and not na(lastHigh) and high > lastHigh and close[1] <= lastHigh

if bos
    highBroken := true

// ─────────────────────────────
// Impuls (grüne Kerzen)
// ─────────────────────────────
var int greenCount = 0
var float firstGreenOpen = na

if close > open
    if greenCount == 0
        firstGreenOpen := open
    greenCount += 1
else
    greenCount := 0
    firstGreenOpen := na

impulseRange = not na(firstGreenOpen) ? close - firstGreenOpen : 0
strongImpulse = greenCount >= minGreen and impulseRange >= atrMult * atrVal and bos

plotshape(strongImpulse, title="BUY", style=shape.labelup,
     location=location.belowbar, color=color.lime, text="Stromg ")

// ─────────────────────────────
// DEMAND ZONE (letzte rote Kerze vor Impuls)
// ─────────────────────────────
var float zoneTop = na
var float zoneBottom = na
var int zoneBar = na
var bool zoneActive = false
var box zoneBox = na

// Zone NUR beim ersten Impuls erzeugen
if strongImpulse
    // letzte rote Kerze suchen (max 10 Kerzen zurück)
    for i = 1 to 10
        if close[i] < open[i]
            zoneTop := high[i]
            zoneBottom := low[i]
            zoneBar := bar_index
            zoneActive := true

            zoneBox := box.new(left=bar_index,right=bar_index + 5,top=zoneTop, bottom=zoneBottom,  bgcolor=color.new(color.red, 80), border_color=color.red    )
            break

// ─────────────────────────────
// Pullback in Demand-Zone
// ─────────────────────────────
zoneValid = zoneActive and bar_index > zoneBar and bar_index - zoneBar <= maxZoneAge

pullbackIntoZone =zoneValid and low <= zoneTop and  low >= zoneBottom and close >= zoneTop 

body      = math.abs(close - open)
range_     = high - low
upperWick = high - math.max(open, close)
lowerWick = math.min(open, close) - low

marubozuBull = close > open and  upperWick <= range_ * 0.1 and  lowerWick <= range_ * 0.1

engulfingBull =   close > open and  close[1] < open[1] and   close > open[1] and  open <= close[1]

pinbarBull =  close > open and  lowerWick >= body * 2 and upperWick <= body

bullishCandle =  marubozuBull or   engulfingBull or  pinbarBull

trend = close > ta.ema(close, 100)


candle_ok = close > open 
buySignal = pullbackIntoZone and candle_ok and bullishCandle and trend

// ─────────────────────────────
// Trade
// ─────────────────────────────
if buySignal and strategy.opentrades == 0
    entryPrice = close
    stopPrice  = zoneBottom
    risk       = entryPrice - stopPrice
    tpPrice    = entryPrice + risk * 1.5    

    strategy.entry("Long", strategy.long)
    strategy.exit("SL/TP", "Long", stop=stopPrice, limit=tpPrice)

// Visual
plotshape(buySignal, title="BUY", style=shape.labelup,
     location=location.belowbar, color=color.lime, text="BUY")

