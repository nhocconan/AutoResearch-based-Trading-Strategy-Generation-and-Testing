//@version=6
strategy("Aurum DCX AVE Gold and Silver Strategy", shorttitle="Aurum DCX AVE",
     overlay=true, pyramiding=0, 
     initial_capital=20000, currency=currency.USD,
     commission_type=strategy.commission.percent, commission_value=0.03,
     slippage=5, calc_on_every_tick=false, calc_on_order_fills=false, process_orders_on_close=true, margin_long = 0 , margin_short = 0 )

// =============== GROUPS
group_setup = "Setup"
group_dcx   = "Directional Convexity Index"
group_ave   = "Adaptive Volatility Envelope"
group_bias  = "Intermarket Bias"
group_risk  = "Risk"
group_ui    = "UI"

// =============== INPUTS
// Setup
symbol         = input.symbol("TVC:GOLD", "Symbol")
src            = input.source(hlc3, "Price source", group=group_setup, tooltip="Primary source for smoothing and envelopes")
sig_tf         = input.timeframe("", "Signal timeframe empty uses chart", group=group_setup)
confirm_tf     = input.timeframe("D", "Confirm timeframe", group=group_setup, tooltip="Used for bias and anchored metrics")

// DCX
dcx_len        = input.int(10, "DCX window", minval=5, group=group_dcx, tooltip="Lookback for DM and volatility normalizers")
dcx_rise_len   = input.int(4, "DCX rise bars", minval=1, group=group_dcx, tooltip="Rising condition window")
dcx_th         = input.float(20, "DCX entry threshold", minval=0, maxval=100, group=group_dcx, tooltip="Heat needed to allow breaks")
eff_floor      = input.float(0.03, "Efficiency floor", minval=0.0, maxval=0.5, step=0.01, group=group_dcx, tooltip="Prevents zeroing in chop")
conv_weight    = input.float(0.35, "Convexity weight 0..1", minval=0, maxval=1, step=0.05, group=group_dcx)

// AVE
ave_len        = input.int(30, "AVE window", minval=5, group=group_ave, tooltip="Midline and volatility window")
ave_ma_type    = input.string("ALMA", "Midline type", options=["EMA","HMA","ALMA"], group=group_ave)
q_tr           = input.int(80, "TR percentile 0..100", minval=50, maxval=100, step=1, group=group_ave, tooltip="Upper tail of TR to catch squeeze breaks")
volv_ref       = input.float(0.05, "Vol of vol reference", minval=0.05, maxval=2.0, step=0.05, group=group_ave, tooltip="Controls blend of ATR and percentile TR")
mult_base      = input.float(1.8, "Base envelope mult", minval=0.2, maxval=5, step=0.1, group=group_ave)
mult_adapt     = input.float(0.85, "Regime adapt 0..1", minval=0, maxval=1, step=0.05, group=group_ave, tooltip="Widens bands with DCX heat")

// Bias
use_dxy_bias   = input.bool(true, "Use DXY bias", group=group_bias)
dxy_symbol     = input.symbol("TVC:DXY", "DXY symbol", group=group_bias)
dxy_tf         = input.timeframe("D", "DXY timeframe", group=group_bias)
dxy_len        = input.int(10, "DXY trend window", minval=5, group=group_bias)

// Risk
risk_pct       = input.float(2.2, "Risk percent per trade", minval=0.1, maxval=5, step=0.1, group=group_risk)
wk_atr_len     = input.int(14, "Weekly ATR", minval=7, group=group_risk)
sl_atr_mult    = input.float(2.0, "Stop ATR weekly mult", minval=0.5, maxval=6, step=0.1, group=group_risk)
tp_rr          = input.float(2.0, "Take profit R multiple", minval=0.5, maxval=6, step=0.1, group=group_risk)
use_trail      = input.bool(false, "Trail with AVE band", group=group_risk)

// // UI
// show_bands     = input.bool(true, "Show AVE bands", group=group_ui)
// show_mid       = input.bool(true, "Show midline", group=group_ui)
// show_vwap      = input.bool(false, "Show daily VWAP", group=group_ui)
// show_labels    = input.bool(true, "Show signals", group=group_ui)

// =============== UTILS
clamp(x, lo, hi) =>
    math.min(math.max(x, lo), hi)

clamp_from_zero(x, hi) =>
    math.min(math.max(x, 0.0), hi)

ma_sel(source, len) =>
    switch ave_ma_type
        "EMA"  => ta.ema(source, len)
        "ALMA" => ta.alma(source, len, 0.85, 6)
        => ta.hma(source, len)

// Blend of ATR and percentile TR with regime widening from DCX
ave_calc(len, q_pct, mult_b, adapt_01, dcx_0_100) =>
    tr = ta.tr
    atr = ta.atr(len)
    qtr = ta.percentile_linear_interpolation(tr, len, q_pct)
    vol_vol = ta.stdev(tr, len) / math.max(ta.ema(tr, len), 1e-10)
    w = clamp(vol_vol / math.max(volv_ref, 1e-6), 0.0, 1.0)
    v = w * qtr + (1 - w) * atr
    basis = ma_sel(src, len)
    heat = clamp_from_zero(dcx_0_100 / 100.0, 1.0)
    mult = mult_b * (1 + adapt_01 * (heat - 0.5) * 2.0)
    [basis, basis + mult * v, basis - mult * v, v, mult]

// Directional Convexity Index 0..100  returns [dcx  di_plus  di_minus]
dcx_calc(len) =>
    dm_pos = math.max(high - high[1], 0)
    dm_neg = math.max(low[1] - low, 0)
    tr = ta.tr
    tr_s = ta.rma(tr, len)
    dmp = 100 * ta.rma(dm_pos, len) / math.max(tr_s, 1e-10)
    dmn = 100 * ta.rma(dm_neg, len) / math.max(tr_s, 1e-10)
    dx = 100 * math.abs(dmp - dmn) / math.max(dmp + dmn, 1e-10)
    disp = math.abs(close - close[len])
    path = math.sum(math.abs(ta.change(close)), len)
    eff = clamp(disp / math.max(path, 1e-10), eff_floor, 1.0)
    acc = ta.change(ta.change(close))
    pacc = ta.rma(math.max(acc, 0), len)
    nacc = ta.rma(math.max(-acc, 0), len)
    conv = (pacc - nacc) / math.max(pacc + nacc, 1e-10)
    conv01 = 0.5 * (conv + 1.0)
    mix = (1.0 - conv_weight) * eff + conv_weight * conv01
    dcx = 100.0 * math.sqrt((dx / 100.0) * mix)
    [dcx, dmp, dmn]

// =============== CORE CALC
[dcx, di_p, di_m] = request.security(
     symbol, sig_tf == "" ? timeframe.period : sig_tf, dcx_calc(dcx_len),
     gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)

dcx_up   = ta.rising(dcx, dcx_rise_len)
dcx_down = ta.falling(dcx, dcx_rise_len)
dir_sign = di_p > di_m ? 1 : di_p < di_m ? -1 : 0

[basis, upper, lower, ave_vol, ave_mult] =    request.security(        symbol, sig_tf == "" ? timeframe.period : sig_tf,        ave_calc(ave_len, q_tr, mult_base, mult_adapt, dcx),        gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)

// Daily VWAP
vwap_anchor_daily = request.security(symbol, "D", ta.vwap(open), gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)

// DXY bias
dxy_close  = use_dxy_bias ? request.security(dxy_symbol, dxy_tf, close, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off) : na
dxy_trend  = use_dxy_bias ? ta.ema(dxy_close, dxy_len) : na
bias_long  = not use_dxy_bias or (dxy_close < dxy_trend)
bias_short = not use_dxy_bias or (dxy_close > dxy_trend)

// Weekly ATR
wk_atr = request.security(symbol, "W", ta.atr(wk_atr_len), gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)

// =============== SIGNALS
closex   = request.security(symbol, timeframe.period, close)
break_up = closex > upper and dcx > dcx_th and dcx_up   and dir_sign > 0 and bias_long
break_dn = closex < lower and dcx > dcx_th and dcx_down and dir_sign < 0 and bias_short

// =============== ORDERS
if break_up
    strategy.close("L")
    strategy.entry("L", strategy.long)

if break_dn
    strategy.close("L")
    strategy.entry("S", strategy.short)

// Brackets
if ta.change(strategy.opentrades) > 0
    ep = strategy.opentrades.entry_price(0)
    longPos = strategy.position_size > 0
    dist = sl_atr_mult * wk_atr
    sl_price = longPos ? math.min(lower, ep - dist) : math.max(upper, ep + dist)
    tp_price = longPos ? ep + tp_rr * math.abs(ep - sl_price) : ep - tp_rr * math.abs(ep - sl_price)
    strategy.exit(longPos ? "XL" : "XS", from_entry=longPos ? "L" : "S", stop=sl_price, limit=tp_price)

// Optional trailing
if use_trail and strategy.position_size != 0
    if strategy.position_size > 0
        trailL = math.max(lower, strategy.position_avg_price - wk_atr)
        strategy.exit("TL", from_entry="L", stop=trailL)
    if strategy.position_size < 0
        trailS = math.min(upper, strategy.position_avg_price + wk_atr)
        strategy.exit("TS", from_entry="S", stop=trailS)

// Alerts
alertcondition(break_up, "Aurum Long", "Long {{ticker}}")
alertcondition(break_dn, "Aurum Short", "Short {{ticker}}")

