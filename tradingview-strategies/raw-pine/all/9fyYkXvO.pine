//@version=6
strategy("VIX Counter-Trend Strategy", overlay=true)

// --- 1. Define Parameters (Adjustable buying the dip and exit thresholds) ---
// VIX Buy Threshold: VIX reaching or exceeding this value is considered extreme panic
vix_buy_threshold = input.float(25.0, "VIX Buy Threshold (Panic Value)", minval=20.0)
// VIX Moving Average Period
vix_ma_period = input.int(5, "VIX MA Period", minval=1)

// Exit Condition Selection
exit_mode = input.string("Holding Days", "Exit Condition", options=["Holding Days", "VIX Retreat", "Both"])
// Exit Days: Number of days after purchase to force exit
exit_days = input.int(100, "Forced Exit Days After Purchase", minval=1)
// VIX Sell Threshold
vix_sell_threshold = input.float(20.0, "VIX Sell Threshold (Calm Value)", minval=10.0)

// --- 2. Get VIX Data ---
// The VIX ticker on TradingView is usually TVC:VIX
// Use request.security() function to fetch the VIX daily close price on the VOO chart
vix_data = request.security("TVC:VIX", "D", close)

// Calculate the 5-day Moving Average of VIX
vix_ma = request.security("TVC:VIX", "D", ta.sma(close, vix_ma_period))

// --- 3. Strategy Logic: Buy Condition ---
// Determine if VIX has reached the buying the dip threshold AND VIX crosses under the 5-day MA
// Cross Under: VIX drops below the MA from above
// Use [1] to ensure data is confirmed (i.e., cross occurred on the previous bar)
vix_cross_under = ta.crossunder(vix_data, vix_ma)
buy_condition = vix_data[1] >= vix_buy_threshold and vix_cross_under[1]

// Execute Buy Entry
if buy_condition
    strategy.entry("BuyVOO", strategy.long, comment="VIX Panic Dip Buy")

// --- 4. Strategy Logic: Sell Condition ---
// Calculate the number of holding bars
var int bars_since_entry = 0
if strategy.position_size > 0
    bars_since_entry := bars_since_entry + 1
else
    bars_since_entry := 0

// Determine various exit conditions
time_exit = bars_since_entry >= exit_days
vix_exit = vix_data <= vix_sell_threshold

// Execute Sell based on user's selected mode
if exit_mode == "Holding Days"
    if time_exit
        strategy.close("BuyVOO", comment="Holding Period Exceeded")
else if exit_mode == "VIX Retreat"
    if vix_exit
        strategy.close("BuyVOO", comment="VIX Below " + str.tostring(vix_sell_threshold))
else if exit_mode == "Both"
    if time_exit or vix_exit
        strategy.close("BuyVOO", comment=time_exit ? "Holding Period Exceeded" : "VIX Below " + str.tostring(vix_sell_threshold))

