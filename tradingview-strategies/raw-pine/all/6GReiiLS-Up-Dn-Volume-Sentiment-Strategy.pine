//@version=5
strategy(title='Up/Dn Volume Sentiment R Strategy', shorttitle='UD Vol R Strat', precision=1)

//============================
// USER INPUTS
//============================
maLength = input.int(50, minval=1, title='Up/Dn Vol Length')
normLookback = input.int(756, minval=50, title='Normalization Lookback')

// Entry levels
longLevel  = input.int(10, title='Long Entry Level (≤)')
shortLevel = input.int(90, title='Short Entry Level (≥)')

// Risk settings
stopPercent = input.float(5.0, title='Stop Loss %') / 100
rTarget = input.float(2.0, title='Profit Target (R Multiple)')

//============================
// UP / DOWN VOLUME
//============================
upVol = close > close[1] ? volume : 0
dnVol = close < close[1] ? volume : 0

sumUp = ta.sma(upVol, maLength)
sumDn = ta.sma(dnVol, maLength)

upDnVolRatio = sumDn == 0 ? na : sumUp / sumDn

//============================
// NORMALIZATION
//============================
lowestRatio  = ta.lowest(upDnVolRatio, normLookback)
highestRatio = ta.highest(upDnVolRatio, normLookback)

sentimentOsc = (upDnVolRatio - lowestRatio) / (highestRatio - lowestRatio) * 100

//============================
// ENTRY CONDITIONS
//============================
longCondition  = sentimentOsc <= longLevel
shortCondition = sentimentOsc >= shortLevel

if longCondition
    strategy.entry("Long", strategy.long)

if shortCondition
    strategy.entry("Short", strategy.short)

//============================
// R-BASED STOPS AND TARGETS
//============================
longStop = strategy.position_avg_price * (1 - stopPercent)
shortStop = strategy.position_avg_price * (1 + stopPercent)

longTarget = strategy.position_avg_price * (1 + stopPercent * rTarget)
shortTarget = strategy.position_avg_price * (1 - stopPercent * rTarget)

strategy.exit("Long Exit", from_entry="Long", stop=longStop, limit=longTarget)
strategy.exit("Short Exit", from_entry="Short", stop=shortStop, limit=shortTarget)

//============================
// PLOTS
//============================
plot(sentimentOsc, title='Sentiment Oscillator', color=color.orange)

hline(longLevel,  "Long Entry",  color=color.green)
hline(shortLevel, "Short Entry", color=color.red)
hline(50, "Neutral", color=color.gray)

