//@version=5
strategy(title='Fibonacci + RSI - Strategy', overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=100, initial_capital=10000, currency=currency.USD)

// Inputs
    // RSI Inputs
len = input.int(title='[RSI] Length', minval=0, step=1, defval=14)
overSold = input(title='[RSI] Over Sold %', defval=30)
overBought = input(title='[RSI] Over Bought %', defval=60)
    // Fibonacci Levels 
length = input.int(title='[Fibonacci] Length', defval=60, minval=1)
src = hlc3
mult = input.float(title='[Fibonacci] Multiplier', defval=2.0, minval=0.001, maxval=50)
level = input(title='[Fibonacci] Level', defval=500)
adx_max = input.int(51,"ADX Max")

var int longEntryBar  = na
var int shortEntryBar = na

// Calculate Fibonacci
basis = ta.vwma(src, length)
dev = mult * ta.stdev(src, length)
targetDown = basis + 0.001 * level * dev
fu1 = basis + 1 * dev
targetUp = basis - 0.001 * level * dev
fd1 = basis - 1 * dev

// Calculate RSI
vrsi = ta.rsi(close, len)

    // Actual Targets
bought = strategy.position_size[0] > strategy.position_size[1]
exit_long = ta.valuewhen(bought, targetUp, 0)
sold = strategy.position_size[0] < strategy.position_size[1]
exit_short = ta.valuewhen(sold, targetDown, 0)




// Conditions to Open Trades
openLong = low < fd1 and ta.crossover(vrsi[1], overSold)
openShort = high > fu1 and ta.crossunder(vrsi[1], overBought)

[a,b,adx_htf ] = request.security(syminfo.tickerid,"60", ta.dmi(14,14), barmerge.gaps_off, barmerge.lookahead_off)

adx_ok = adx_htf < adx_max

// === Time Filter Inputs ===
use_time_filter  = input.bool(true,  "Use Time Filter (UTC)")
start_hour       = input.int(16, "Start Hour", minval=0, maxval=23)
end_hour         = input.int(22, "End Hour", minval=0, maxval=23)

use_lunch_filter = input.bool(false,  "Avoid Lunch Chop")
lunch_start      = input.int(19, "Lunch Start", minval=0, maxval=23)
lunch_end        = input.int(20, "Lunch End", minval=0, maxval=23)

// === Current Hour (Exchange Time) ===
h =   hour(time, "UTC")

// === Time Conditions ===
in_main_session  = h >= start_hour and h < end_hour
in_lunch         = h >= lunch_start and h < lunch_end

time_ok = not use_time_filter or (in_main_session and (not use_lunch_filter or not in_lunch))


openLong := openLong and adx_ok 
openShort := openShort and adx_ok 


// Conditions to Close Trades
closeLong = high > exit_long
closeShort = low < exit_short


// Plots
plot(basis, color=color.new(color.blue, 0), linewidth=2, title='[Fibonacci Level] Basis')
plot(fu1, color=color.new(color.red, 0), linewidth=2, title='1', title='[Fibonacci Level] Top')
plot(fd1, color=color.new(color.green, 0), linewidth=2, title='1', title='[Fibonacci Level] Bottom')
plot(targetUp, color=color.new(color.gray, 0), linewidth=2, title='1', title='[Fibonacci Level] Top')


// Strategy Orders

// Entry Orders
strategy.entry(id='Long', direction=strategy.long, when=openLong and high < targetUp and time_ok, limit=close)
strategy.entry(id='Short', direction=strategy.short, when=openShort and low > targetDown and time_ok, limit=close)



if closeLong and strategy.position_size > 0
    strategy.close("Long")

if closeShort and strategy.position_size < 0
    strategy.close("Short")

// === ATR Inputs ===
atr_len = input.int(14, title='[ATR] Length')
atr_sl_mult = input.float(3.0, title='[ATR] SL Multiplier', step=0.1)
atr_tp_mult = input.float(3.0, title='[ATR] TP Multiplier', step=0.1)

atr = ta.atr(atr_len)

// === ATR based SL / TP ===
sl_long  = strategy.position_avg_price - atr * atr_sl_mult
tp_long  = strategy.position_avg_price + atr * atr_tp_mult

sl_short = strategy.position_avg_price + atr * atr_sl_mult
tp_short = strategy.position_avg_price - atr * atr_tp_mult

strategy.exit(id="ATR_Long", from_entry="Long",stop=sl_long, limit=tp_long)

strategy.exit(id="ATR_Short",from_entry="Short",stop=sl_short, limit=tp_short)

pip = syminfo.mintick * 10

rsi_val = ""
if len != 14
    rsi_val := "_" + str.tostring(len) 
alarm_id = syminfo.prefix + ""+ syminfo.ticker + "_" + str.tostring(timeframe.period) + "_" + str.tostring(overSold) + "_" + str.tostring(overBought) + "_" + str.tostring(length) + "_" + str.tostring(mult) + "_"  + str.tostring(level) + "_"  + str.tostring(adx_max) + "_"  + str.tostring(atr_sl_mult) + "_"  + str.tostring(atr_tp_mult) + rsi_val


if openLong and high < targetUp
    sl_pips_long = atr * atr_sl_mult / pip
    tp_pips_long = atr * atr_tp_mult / pip
    sl_pips = math.round(sl_pips_long * 10) / 10
    tp_pips = math.round(tp_pips_long * 10) / 10
    label.new(bar_index, high, str.tostring(h),style = label.style_label_down)

    alert('{"signal":"BUY", "strategy": "FIB" ,"symbol":"' + syminfo.ticker + '","broker":"' + syminfo.prefix  + '","tp":' + str.tostring(tp_pips_long) + ',"sl":' + str.tostring(sl_pips) +  ',"period":' + str.tostring(timeframe.period) + ',"sl_diff":' + str.tostring(0) + ',"tp_diff":' + str.tostring(0) + ',"factor":' + str.tostring(1) + ',"atr":' + str.tostring(1) + ',"dataset":"No", "alarm_id":"' + alarm_id + '"}', alert.freq_once_per_bar_close)

if openShort and low > targetDown
    sl_pips_short = atr * atr_sl_mult / pip
    tp_pips_short = atr * atr_tp_mult / pip
    sl_pips = math.round(sl_pips_short * 10) / 10
    tp_pips = math.round(tp_pips_short * 10) / 10
    alert('{"signal":"SELL","strategy": "FIB" ,"symbol":"' + syminfo.ticker + '","broker":"' + syminfo.prefix  + '","tp":' + str.tostring(tp_pips_short) + ',"sl":' + str.tostring(sl_pips) +  ',"period":' + str.tostring(timeframe.period) + ',"sl_diff":' + str.tostring(0) + ',"tp_diff":' + str.tostring(0) + ',"factor":' + str.tostring(1) + ',"atr":' + str.tostring(1) + ',"dataset":"No", "alarm_id":' + alarm_id + '"}', alert.freq_once_per_bar_close)


if strategy.position_size > 0 and closeLong
    alert('{"signal":"EXIT","strategy": "FIB" ,"symbol":"' + syminfo.ticker + '","broker":"' + syminfo.prefix  + '","tp":' + str.tostring(0) + ',"sl":' + str.tostring(0) +  ',"period":' + str.tostring(timeframe.period) + ',"sl_diff":' + str.tostring(0) + ',"tp_diff":' + str.tostring(0) + ',"factor":' + str.tostring(1) + ',"atr":' + str.tostring(1) + ',"dataset":"No", "alarm_id":"' + alarm_id + '"}', alert.freq_once_per_bar_close)

if strategy.position_size < 0 and closeShort
    alert('{"signal":"EXIT","strategy": "FIB" ,"symbol":"' + syminfo.ticker + '","broker":"' + syminfo.prefix  + '","tp":' + str.tostring(0) + ',"sl":' + str.tostring(0) +  ',"period":' + str.tostring(timeframe.period) + ',"sl_diff":' + str.tostring(0) + ',"tp_diff":' + str.tostring(0) + ',"factor":' + str.tostring(1) + ',"atr":' + str.tostring(1) + ',"dataset":"No", "alarm_id":"' + alarm_id + '"}', alert.freq_once_per_bar_close)


newLong  = strategy.position_size > 0 and strategy.position_size[1] == 0
newShort = strategy.position_size < 0 and strategy.position_size[1] == 0
if newLong
    line.new(x1 = bar_index, y1 = sl_long,x2 = bar_index + 10,y2 = sl_long,color = color.red,width = 2,style = line.style_solid )
    line.new(x1 = bar_index, y1 = targetUp,x2 = bar_index + 10,y2 = targetUp,color = color.green,width = 2,style = line.style_solid )
if newShort
    line.new(x1 = bar_index, y1 = targetDown,x2 = bar_index + 10,y2 = targetDown,color = color.green,width = 2,style = line.style_solid )
    line.new(x1 = bar_index,y1 = sl_short, x2 = bar_index + 10,y2 = sl_short,color = color.red,width = 2,style = line.style_solid )

if newLong
    longEntryBar := bar_index

if newShort
    shortEntryBar := bar_index

