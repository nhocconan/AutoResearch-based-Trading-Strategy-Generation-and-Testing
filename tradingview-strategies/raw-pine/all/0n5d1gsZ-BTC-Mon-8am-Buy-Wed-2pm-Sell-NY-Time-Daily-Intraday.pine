//@version=5
strategy("BTC Mon 8am Buy / Wed 2pm Sell (NY Time, Daily + Intraday)",
     overlay = true,
     initial_capital = 10000,
     pyramiding = 0,
     commission_type = strategy.commission.percent,
     commission_value = 0.1,
     process_orders_on_close = true)

// --- Get time in New York timezone tied to chart's resolution ---
nyTime   = time(timeframe.period, "America/New_York")

dayNY    = dayofweek(nyTime)
hourNY   = hour(nyTime)
minuteNY = minute(nyTime)
weekNY   = weekofyear(nyTime)

isIntraday = timeframe.isintraday

// --- Intraday exact-time logic (best on <= 1h charts) ---
// Buy: Monday 08:00 NY
enterIntraday = isIntraday and dayNY == dayofweek.monday    and hourNY == 8  and minuteNY == 0
// Sell: Wednesday 14:00 (2pm) NY
exitIntraday  = isIntraday and dayNY == dayofweek.wednesday and hourNY == 14 and minuteNY == 0

// --- Daily-or-higher logic: approximate by day only ---
enterDaily = (not isIntraday) and dayNY == dayofweek.monday
exitDaily  = (not isIntraday) and dayNY == dayofweek.wednesday

// --- Combined conditions ---
enterCond = enterIntraday or enterDaily
exitCond  = exitIntraday  or exitDaily

// --- Only one entry per week ---
var int lastEntryWeek = na
canEnter = na(lastEntryWeek) or (weekNY != lastEntryWeek)

if enterCond and canEnter and strategy.position_size == 0
    strategy.entry("Long_Mon8", strategy.long)
    lastEntryWeek := weekNY

if exitCond and strategy.position_size > 0
    strategy.close("Long_Mon8")

