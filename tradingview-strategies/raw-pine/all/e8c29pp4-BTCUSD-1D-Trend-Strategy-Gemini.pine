//@version=5
strategy("BTC 5m Cycle Scalper", overlay=true, initial_capital=10000, default_qty_type=strategy.percent_of_equity, default_qty_value=100, commission_type=strategy.commission.percent, commission_value=0.1, slippage=1)

// --- Parameters ---
// We use a much longer SMA (800) to represent the "Macro" trend on a 5m chart
smaLength = input.int(800, "Intraday HODL Line (800 SMA)")
rsiLen = input.int(14, "RSI Period")
rsiBuy = input.int(30, "Oversold Buy Zone")
rsiSell = input.int(75, "Overbought Sell Zone")

// --- Indicators ---
sma800 = ta.sma(close, smaLength)
rsiVal = ta.rsi(close, rsiLen)

// --- Date Filter (2018-2069) ---
inRange = time >= timestamp(2018, 1, 1, 0, 0) and time <= timestamp(2069, 12, 31, 23, 59)

// --- Logic ---
// BUY: Only when price is above the long-term SMA (Trend is up) and RSI hits a deep dip
buyCondition = close > sma800 and ta.crossover(rsiVal, rsiBuy)

// SELL: Take profit when RSI is overextended OR if price breaks below the 800 SMA
sellCondition = rsiVal > rsiSell or ta.crossunder(close, sma800)

// --- Execution (Strict No Line Breaks in Calls) ---
if (inRange)
    if (buyCondition)
        strategy.entry("Long", strategy.long, comment="5m Dip Buy")
    if (sellCondition)
        strategy.close("Long", comment="5m Cycle Exit")

// --- Visuals ---
plot(sma800, color=color.new(color.yellow, 0), linewidth=2, title="800 SMA Trend")
plotshape(buyCondition, style=shape.triangleup, location=location.belowbar, color=color.green, size=size.small, title="Buy")
plotshape(rsiVal > rsiSell, style=shape.triangledown, location=location.abovebar, color=color.red, size=size.small, title="Take Profit")

