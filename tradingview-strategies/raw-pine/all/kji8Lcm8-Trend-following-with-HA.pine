//@version=3
strategy("My Strategy", overlay=true)
//inputs 
StartYear = input(2017, title="Start")
EndYear = input(2017, title="End")
lmt = input(0.0020, title="Limit")
// calculate HA closing price
HA_cl = security(heikinashi("EURUSD"), "D", close)
HA_op = security(heikinashi("EURUSD"), "D", open)
// calculate WMA
fastMA = wma(HA_cl,2)
plot(fastMA,color=red)
// calculate MA
slowMA = sma(HA_cl,2)
plot(slowMA,color=blue)
// entry rules - if crossover/under, enter on open mkt order the next day
longCondition1=crossover(fastMA,slowMA)
if (longCondition1)
    strategy.entry("My Long Entry", strategy.long, limit = HA_op + lmt, when =  year > (StartYear - 1) and year < (EndYear + 1))
// if cannot get good price cancel trade    
shortCondition1=crossunder(fastMA,slowMA)
if (shortCondition1)
    strategy.entry("My Short Entry", strategy.short, limit = HA_op - lmt, when =  year > (StartYear - 1) and year < (EndYear + 1))

