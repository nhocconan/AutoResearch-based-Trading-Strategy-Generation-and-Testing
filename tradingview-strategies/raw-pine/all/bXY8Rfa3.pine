//@version=5
strategy("Tailwind.(BTC)", overlay=true, initial_capital=20000, default_qty_type=strategy.percent_of_equity, default_qty_value=10, commission_type=strategy.commission.percent, commission_value=0.1)

// --- CONFIGURATION ---
grp_grid = "Grid Configuration"
step_size = input.float(3000, title="Step Size (Grid)", group=grp_grid)

grp_risk = "Risk Management"
tp_mult = input.float(1.4, title="TP Multiplier (x Grid)", step=0.1, group=grp_risk)
sl_mult = input.float(1.0, title="SL Multiplier (x Grid)", step=0.1, group=grp_risk)

grp_filt = "Entry Filters"
max_dist_pct = input.float(60.0, title="Max % Travel Allowed", minval=1.0, maxval=99.0, group=grp_filt)
use_ema   = input.bool(false, title="Use EMA Filter?", group=grp_filt)
ema_len   = input.int(200, title="EMA Length", minval=1, group=grp_filt)

// --- CALCULATIONS ---
level_base = math.floor(close / step_size) * step_size
limit_price_entry = level_base + (step_size * (max_dist_pct / 100.0))
ema_trend = ta.ema(close, ema_len)

// --- ENTRY LOGIC ---
// Strict cross: Open below base, Close above base
strict_cross = (open < level_base) and (close > level_base)
price_is_valid = close <= limit_price_entry
trend_ok = use_ema ? (close > ema_trend) : true

// --- VISUAL MANAGEMENT (Persistent Variables) ---
var line line_tp = na
var line line_sl = na

// --- EXECUTION ---
if (strict_cross and price_is_valid and trend_ok and strategy.position_size == 0)
    
    // 1. Define Prices (Direct and fixed calculation)
    
    // TP: Base Level + (Step * Multiplier)
    take_profit = level_base + (step_size * tp_mult)
    
    // SL: Base Level - (Step * Multiplier)
    // We do not add the entry 'offset'. The SL is rigid relative to the level.
    stop_loss = level_base - (step_size * sl_mult)
    
    // 2. Execute
    id = "Long " + str.tostring(level_base)
    strategy.entry(id, strategy.long)
    strategy.exit("Exit " + id, id, limit=take_profit, stop=stop_loss)

    // 3. Draw initial lines
    line_tp := line.new(bar_index, take_profit, bar_index + 1, take_profit, color=color.green, style=line.style_dashed, width=2)
    line_sl := line.new(bar_index, stop_loss, bar_index + 1, stop_loss, color=color.red, style=line.style_dashed, width=2)

// --- VISUAL MAINTENANCE ---
if strategy.position_size > 0
    line.set_x2(line_tp, bar_index + 5)
    line.set_x2(line_sl, bar_index + 5)

// --- PLOTTING ---
plot(level_base, color=color.new(color.gray, 60), style=plot.style_circles, title="Grid Level")
plot(use_ema ? ema_trend : na, color=color.orange, title="Trend EMA", linewidth=2)

