//@version=6
strategy("EMA and Dow Theory Strategies V3", overlay=true, initial_capital = 16600, commission_type=strategy.commission.percent, commission_value=0.055, margin_long = 0.001, margin_short = 0.001, precision = 4, default_qty_type=strategy.percent_of_equity, default_qty_value=3)
import TradingView/ta/7

// =====================
// ✅ パラメーター（5個に絞った）
// =====================
emaLen       = input.int(50,   "EMA期間",              group="[ SETTINGS ]")
// EMAの傾きでトレンド方向を判断。大きいほど長期トレンドを見る（推奨: 30〜100）

atrFactor    = input.float(4.0, "ATR倍率（TP距離）",   group="[ SETTINGS ]", step=0.1)
// TP1=ATR×1倍、TP2=ATR×2倍、TP3=ATR×3倍の基準となる倍率

stopLoss     = input.float(-6.0, "損切り(%)",           group="[ SETTINGS ]", step=0.5)
// エントリーからこの%を超えたら損切り

adxThreshold = input.float(18.0, "ADXしきい値",         group="[ SETTINGS ]", step=0.5)
// これ以下のADXは横ばい相場と判断してエントリーしない（推奨: 18〜25）

swingLen     = input.int(4,    "スイング検出期間",       group="[ SETTINGS ]", minval=1)
// ダウ理論のスイング高値・安値を検出する感度（大きいほど大きいスイングのみ反応）

// =====================
// EMA計算（1本）
// =====================
ema = ta.ema(close, emaLen)

// 傾き判断：今のEMA > 前のEMAなら上昇トレンド
emaUp   = ema > ema[1]
emaDown = ema < ema[1]

// =====================
// ADX（期間14固定）
// =====================
[_, _, adxValue] = ta.dmi(14, 14)
isTrending = adxValue > adxThreshold

// =====================
// スイング検出
// =====================
isSwingHigh = high[swingLen] == ta.highest(high, swingLen * 2 + 1)
isSwingLow  = low[swingLen]  == ta.lowest(low,  swingLen * 2 + 1)

var float lastSwingHigh = na
var float lastSwingLow  = na
lastSwingHigh := isSwingHigh ? high[swingLen] : lastSwingHigh
lastSwingLow  := isSwingLow  ? low[swingLen]  : lastSwingLow

// =====================
// ダウ理論トレンド判定
// =====================
var int trend = 0
if not na(lastSwingHigh) and close > lastSwingHigh and trend != 1
    trend := 1
if not na(lastSwingLow)  and close < lastSwingLow  and trend != -1
    trend := -1

// =====================
// エントリー条件
// EMA傾き ＋ ダウ理論トレンド ＋ ADX
// =====================
goLong  = emaUp   and trend == 1  and isTrending
goShort = emaDown and trend == -1 and isTrending

// =====================
// ATR / TP計算
// =====================
atr = ta.atr(50) * atrFactor

var float tp1  = na
var float tp2  = na
var float tp3  = na
var float tp11 = na
var float tp22 = na
var float tp33 = na
var float entr = na

// =====================
// PnL計算
// =====================
var float PnL = 0.
LastTriggeredPrice = strategy.opentrades.entry_price(strategy.opentrades - 1)
if strategy.position_size > 0.0 and LastTriggeredPrice != 0.0
    PnL := ((close - LastTriggeredPrice) / LastTriggeredPrice) * 100.0
else if strategy.position_size < 0.0 and LastTriggeredPrice != 0.0
    PnL := ((LastTriggeredPrice - close) / LastTriggeredPrice) * 100.0

var float TruePnL = na
var float Equity_AtStartTrade = na
TruePnL := na(Equity_AtStartTrade) ? na : ((strategy.equity / Equity_AtStartTrade) - 1.0) * 100.0

// =====================
// 損切り
// =====================
if PnL < stopLoss and strategy.position_size > 0.
    strategy.close("Long", "SL Long")
    alert('{"Symbol":"' + syminfo.ticker + '","Side":"Buy","Price":' + str.tostring(close) + ',"Exit":true,"HalfExit":false, "Vertion":"3"}', alert.freq_once_per_bar)

if PnL < stopLoss and strategy.position_size < 0.
    strategy.close("Short", "SL Short")
    alert('{"Symbol":"' + syminfo.ticker + '","Side":"Sell","Price":' + str.tostring(close) + ',"Exit":true,"HalfExit":false, "Vertion":"3"}', alert.freq_once_per_bar)

// =====================
// トレンド反転クローズ
// =====================
if trend == 1 and strategy.position_size < 0
    strategy.close("Short", "trendChange→Long")
    alert('{"Symbol":"' + syminfo.ticker + '","Side":"Sell","Price":' + str.tostring(close) + ',"Exit":true,"HalfExit":false, "Vertion":"3"}', alert.freq_once_per_bar)

if trend == -1 and strategy.position_size > 0
    strategy.close("Long", "trendChange→Short")
    alert('{"Symbol":"' + syminfo.ticker + '","Side":"Buy","Price":' + str.tostring(close) + ',"Exit":true,"HalfExit":false, "Vertion":"3"}', alert.freq_once_per_bar)

// =====================
// ロングエントリー
// =====================
if strategy.position_size <= 0. and goLong
    if strategy.position_size < 0
        strategy.close("Short", comment="Exit Short→Long")
        alert('{"Symbol":"' + syminfo.ticker + '","Side":"Sell","Price":' + str.tostring(close) + ',"Exit":true,"HalfExit":false, "Vertion":"3"}', alert.freq_once_per_bar)

    if strategy.position_size == 0
        Equity_AtStartTrade := strategy.equity
        strategy.entry("Long", strategy.long)
        alert('{"Symbol":"' + syminfo.ticker + '","Side":"Buy","Price":' + str.tostring(close) + ',"Exit":false,"HalfExit":false, "Vertion":"3","Stop":'+str.tostring(0)+'}', alert.freq_once_per_bar_close)
        tp1  := close + atr
        tp2  := close + atr * 2
        tp3  := close + atr * 3
        tp11 := na
        tp22 := na
        tp33 := na
        entr := close

// =====================
// ショートエントリー
// =====================
if strategy.position_size >= 0. and goShort
    if strategy.position_size > 0
        strategy.close("Long", comment="Exit Long→Short")
        alert('{"Symbol":"' + syminfo.ticker + '","Side":"Buy","Price":' + str.tostring(close) + ',"Exit":true,"HalfExit":false, "Vertion":"3"}', alert.freq_once_per_bar)

    if strategy.position_size == 0
        Equity_AtStartTrade := strategy.equity
        strategy.entry("Short", strategy.short)
        alert('{"Symbol":"' + syminfo.ticker + '","Side":"Sell","Price":' + str.tostring(close) + ',"Exit":false,"HalfExit":false, "Vertion":"3","Stop":'+str.tostring(0)+'}', alert.freq_once_per_bar_close)
        tp11 := close - atr
        tp22 := close - atr * 2
        tp33 := close - atr * 3
        tp1  := na
        tp2  := na
        tp3  := na
        entr := close

// =====================
// TP処理
// =====================
if strategy.position_size > 0
    if high > tp1
        strategy.close('Long', 'Long TP1', qty_percent=30)
        alert('{"Symbol":"' + syminfo.ticker + '","Side":"Buy","Price":' + str.tostring(close) + ',"Exit":true,"halfExit":true, "vertion":"TP1"}', alert.freq_once_per_bar)
        tp1 := na
    if high > tp2
        strategy.close('Long', 'Long TP2', qty_percent=30)
        alert('{"Symbol":"' + syminfo.ticker + '","Side":"Buy","Price":' + str.tostring(close) + ',"Exit":true,"halfExit":true, "vertion":"TP2"}', alert.freq_once_per_bar)
        tp2 := na
    if high > tp3
        strategy.close('Long', 'Long TP3', qty_percent=30)
        alert('{"Symbol":"' + syminfo.ticker + '","Side":"Buy","Price":' + str.tostring(close) + ',"Exit":true,"halfExit":true, "vertion":"TP3"}', alert.freq_once_per_bar)
        tp3  := na
        entr := na

if strategy.position_size < 0
    if low < tp11
        strategy.close('Short', 'Short TP1', qty_percent=30)
        alert('{"Symbol":"' + syminfo.ticker + '","Side":"Sell","Price":' + str.tostring(close) + ',"Exit":true,"halfExit":true, "vertion":"TP1"}', alert.freq_once_per_bar)
        tp11 := na
    if low < tp22
        strategy.close('Short', 'Short TP2', qty_percent=30)
        alert('{"Symbol":"' + syminfo.ticker + '","Side":"Sell","Price":' + str.tostring(close) + ',"Exit":true,"halfExit":true, "vertion":"TP2"}', alert.freq_once_per_bar)
        tp22 := na
    if low < tp33
        strategy.close('Short', 'Short TP3', qty_percent=30)
        alert('{"Symbol":"' + syminfo.ticker + '","Side":"Sell","Price":' + str.tostring(close) + ',"Exit":true,"halfExit":true, "vertion":"TP3"}', alert.freq_once_per_bar)
        tp33 := na
        entr := na

// =====================
// 描画
// =====================

// スイングライン
plot(trend == -1 ? lastSwingHigh : na, "スイングハイ", color.red,   1, plot.style_linebr)
plot(trend ==  1 ? lastSwingLow  : na, "スイングロー", color.green, 1, plot.style_linebr)

// グラデーションゾーン
barPrice = close
sh_base = trend == -1 ? lastSwingHigh : na
sh_s1   = trend == -1 ? sh_base - (sh_base - barPrice) * 0.2 : na
sh_s2   = trend == -1 ? sh_base - (sh_base - barPrice) * 0.4 : na
sh_s3   = trend == -1 ? sh_base - (sh_base - barPrice) * 0.6 : na
sh_s4   = trend == -1 ? sh_base - (sh_base - barPrice) * 0.8 : na
sh_end  = trend == -1 ? barPrice : na
sh_p0 = plot(sh_base, display=display.none)
sh_p1 = plot(sh_s1,   display=display.none)
sh_p2 = plot(sh_s2,   display=display.none)
sh_p3 = plot(sh_s3,   display=display.none)
sh_p4 = plot(sh_s4,   display=display.none)
sh_p5 = plot(sh_end,  display=display.none)
fill(sh_p0, sh_p1, color.new(color.red, 20))
fill(sh_p1, sh_p2, color.new(color.red, 40))
fill(sh_p2, sh_p3, color.new(color.red, 60))
fill(sh_p3, sh_p4, color.new(color.red, 80))
fill(sh_p4, sh_p5, color.new(color.red, 90))

sl_base = trend ==  1 ? lastSwingLow : na
sl_s1   = trend ==  1 ? sl_base + (barPrice - sl_base) * 0.2 : na
sl_s2   = trend ==  1 ? sl_base + (barPrice - sl_base) * 0.4 : na
sl_s3   = trend ==  1 ? sl_base + (barPrice - sl_base) * 0.6 : na
sl_s4   = trend ==  1 ? sl_base + (barPrice - sl_base) * 0.8 : na
sl_end  = trend ==  1 ? barPrice : na
sl_p0 = plot(sl_base, display=display.none)
sl_p1 = plot(sl_s1,   display=display.none)
sl_p2 = plot(sl_s2,   display=display.none)
sl_p3 = plot(sl_s3,   display=display.none)
sl_p4 = plot(sl_s4,   display=display.none)
sl_p5 = plot(sl_end,  display=display.none)
fill(sl_p0, sl_p1, color.new(color.green, 20))
fill(sl_p1, sl_p2, color.new(color.green, 40))
fill(sl_p2, sl_p3, color.new(color.green, 60))
fill(sl_p3, sl_p4, color.new(color.green, 80))
fill(sl_p4, sl_p5, color.new(color.green, 90))

// EMAライン（傾きで色変化）
emaColor = emaUp ? color.lime : color.red
plot(ema, "EMA", color=emaColor, linewidth=2)

// TPライン
tpCol = strategy.position_size > 0 ? color.lime : strategy.position_size < 0 ? #e42c2c : na
plot(tp1,  "TP1 Long",  style=plot.style_linebr, color=tpCol)
plot(tp2,  "TP2 Long",  style=plot.style_linebr, color=tpCol)
p3  = plot(tp3,  "TP3 Long",  style=plot.style_linebr, color=tpCol)
plot(tp11, "TP1 Short", style=plot.style_linebr, color=tpCol)
plot(tp22, "TP2 Short", style=plot.style_linebr, color=tpCol)
p33 = plot(tp33, "TP3 Short", style=plot.style_linebr, color=tpCol)
pe  = plot(entr != entr[1] ? na : entr, "Enter", color=chart.fg_color, style=plot.style_linebr)
fill(pe, p3,  color.new(tpCol, 90))
fill(pe, p33, color.new(tpCol, 90))

// 横ばいゾーン背景
bgcolor(not isTrending ? color.new(color.gray, 88) : na, title="横ばいゾーン(ADX低)")

// ポジション背景
lowestClose = ta.lowest(close, 10)
_css      = strategy.position_size == 0.0 ? color.white  :strategy.position_size >  0.0 ? color.yellow :strategy.position_size <  0.0 ? color.purple : na
plotBottom = strategy.position_size == 0.0 ? lowestClose : LastTriggeredPrice
_plot0 = plot(plotBottom, color=na)
_plot1 = plot(close,      color=na)
fill(_plot0, _plot1, color.new(_css, 70))

// 上位足スイング（参考表示）
htfSwingHigh = request.security(syminfo.tickerid, "240", ta.pivothigh(high, swingLen, swingLen))
htfSwingLow  = request.security(syminfo.tickerid, "240", ta.pivotlow(low,  swingLen, swingLen))
var float lastHTFSwingHigh = na
var float lastHTFSwingLow  = na
lastHTFSwingHigh := na(htfSwingHigh) ? lastHTFSwingHigh : htfSwingHigh
lastHTFSwingLow  := na(htfSwingLow)  ? lastHTFSwingLow  : htfSwingLow
htfClose = request.security(syminfo.tickerid, "240", close)
var int htfTrend = 0
if not na(lastHTFSwingHigh) and htfClose > lastHTFSwingHigh and htfTrend != 1
    htfTrend := 1
if not na(lastHTFSwingLow)  and htfClose < lastHTFSwingLow  and htfTrend != -1
    htfTrend := -1
plot(htfTrend == -1 ? lastHTFSwingHigh : na, "上位足スイングハイ", color.fuchsia, 2, plot.style_linebr)
plot(htfTrend ==  1 ? lastHTFSwingLow  : na, "上位足スイングロー", color.aqua,    2, plot.style_linebr)

// デバッグ
plotchar(strategy.equity, "資産残高",  "", location.top, color=color.white)
plotchar(adxValue,         "ADX値",     "", location.top, color=color.orange)
plotchar(ema,              "EMA",       "", location.top, color=color.lime)
colorPnL = PnL > 0.0 ? color.green : color.red
plotchar(PnL,     "PnL",     "", location.top, color=colorPnL)
plotchar(TruePnL, "TruePnL", "", location.top, color=color.aqua)

// 直近トレードラベル
rangeR    = high - low
avgRangeR = ta.sma(rangeR, 20)
var float TruePnLToDisplay = PnL
if strategy.closedtrades > 0
    lastTradeIndex     = strategy.closedtrades - 1
    lastTradeProfit    = strategy.closedtrades.profit_percent(lastTradeIndex)
    lastTradeEntryBar  = strategy.closedtrades.exit_bar_index(lastTradeIndex)
    lastTradeDirection = strategy.closedtrades.size(lastTradeIndex)
    if lastTradeEntryBar == bar_index
        tradeColor   = TruePnLToDisplay > 0 ? color.green : color.red
        uscitaFinale = strategy.position_size == 0. or
             lastTradeDirection > 0.0 and strategy.position_size < 0. or
             lastTradeDirection < 0.0 and strategy.position_size > 0.
        _size      = size.normal
        Perc_PL    = str.tostring(math.round(PnL[1], 1)) + '%'
        text_color = color.black
        if uscitaFinale
            _size      := size.large
            Perc_PL    := str.tostring(math.round(TruePnLToDisplay, 1)) + '%\n(' + str.tostring(math.round(lastTradeProfit, 1)) + '%)'
            text_color := color.white
        label.new(x=bar_index, y=high + avgRangeR * 5, text=Perc_PL,
             color=tradeColor, textcolor=text_color,
             style=label.style_label_down, size=_size)
    else
        TruePnLToDisplay := TruePnL

