fill                    ( RMI_FAST_PLOT         , RMI_FAST_PLOT_HIGH        , transp=80     , color=magenta                                             , title='Fast   High Fill'  , editable=false    )
fill                    ( RMI_FAST_PLOT         , RMI_FAST_PLOT_LOW         , transp=80     , color=magenta                                             , title='Fast   Low  Fill'  , editable=false    )

fill                    ( RMI_MEDI_PLOT         , RMI_MEDI_PLOT_HIGH        , transp=80     , color=cyan                                                , title='Medium High Fill'  , editable=false    )
fill                    ( RMI_MEDI_PLOT         , RMI_MEDI_PLOT_LOW         , transp=80     , color=cyan                                                , title='Medium Low  Fill'  , editable=false    )

fill                    ( RMI_SLOW_PLOT         , RMI_SLOW_PLOT_HIGH        , transp=80     , color=oker                                                , title='Slow   High Fill'  , editable=false    )
fill                    ( RMI_SLOW_PLOT         , RMI_SLOW_PLOT_LOW         , transp=80     , color=oker                                                , title='Slow   Low  Fill'  , editable=false    )

