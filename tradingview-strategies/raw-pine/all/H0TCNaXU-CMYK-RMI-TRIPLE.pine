//                                                              RMI
//▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒
RMI_FAST_PLOT           = plot  ( RMI_FAST_ON   ? RMI_FAST          : na    , transp=30     , color=magenta                                             , title='RMI Fast'          , editable=true     )

RMI_MEDI_PLOT           = plot  ( RMI_MEDI_ON   ? RMI_MEDI          : na    , transp=20     , color=cyan                                                , title='RMI Medium'        , editable=true     )

RMI_SLOW_PLOT           = plot  ( RMI_SLOW_ON   ? RMI_SLOW          : na    , transp=10     , color=oker                                                , title='RMI Slow'          , editable=true     )

//                                                              LINES
//▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒
plot                    ( RMI_FAST_ON   ? RMI_FAST_HIGH : na                , transp=20     , color=purple                                              , title='Fast   High'       , editable=false    )
plot                    ( RMI_MEDI_ON   ? RMI_MEDI_HIGH : na                , transp=20     , color=blues                                               , title='Medium High'       , editable=false    )
plot                    ( RMI_SLOW_ON   ? RMI_SLOW_HIGH : na                , transp=20     , color=reds                                                , title='Slow   High'       , editable=false    )

hline                   ( 00                    , linestyle=dotted                          , color=white                                               , title='Midline'           , editable=false    )

plot                    ( RMI_FAST_ON   ? RMI_FAST_LOW  : na                , transp=20     , color=purple                                              , title='Fast   Low'        , editable=false    )
plot                    ( RMI_MEDI_ON   ? RMI_MEDI_LOW  : na                , transp=20     , color=blues                                               , title='Medium Low'        , editable=false    )
plot                    ( RMI_SLOW_ON   ? RMI_SLOW_LOW  : na                , transp=20     , color=reds                                                , title='Slow   Low'        , editable=false    )

//                                                              RMI FILL LINES
//▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒
RMI_FAST_PLOT_HIGH      = plot   ( RMI_FAST     >= RMI_FAST_HIGH and RMI_FAST_ON ? RMI_FAST_HIGH : RMI_FAST_ON ? RMI_FAST : na , color=magenta          , title='Fast   Over  High' , editable=false    , transp=100 )
RMI_MEDI_PLOT_HIGH      = plot   ( RMI_MEDI     >= RMI_MEDI_HIGH and RMI_MEDI_ON ? RMI_MEDI_HIGH : RMI_MEDI_ON ? RMI_MEDI : na , color=cyan             , title='Medium Over  High' , editable=false    , transp=100 )
RMI_SLOW_PLOT_HIGH      = plot   ( RMI_SLOW     >= RMI_SLOW_HIGH and RMI_SLOW_ON ? RMI_SLOW_HIGH : RMI_SLOW_ON ? RMI_SLOW : na , color=oker             , title='Slow   Over  High' , editable=false    , transp=100 )

RMI_FAST_PLOT_LOW       = plot   ( RMI_FAST     <= RMI_FAST_LOW  and RMI_FAST_ON ? RMI_FAST_LOW  : RMI_FAST_ON ? RMI_FAST : na , color=magenta          , title='Fast   Under Low'  , editable=false    , transp=100 )
RMI_MEDI_PLOT_LOW       = plot   ( RMI_MEDI     <= RMI_MEDI_LOW  and RMI_MEDI_ON ? RMI_MEDI_LOW  : RMI_MEDI_ON ? RMI_MEDI : na , color=cyan             , title='Medium Under Low'  , editable=false    , transp=100 )
RMI_SLOW_PLOT_LOW       = plot   ( RMI_SLOW     <= RMI_SLOW_LOW  and RMI_SLOW_ON ? RMI_SLOW_LOW  : RMI_SLOW_ON ? RMI_SLOW : na , color=oker             , title='SLow   Under Low'  , editable=false    , transp=100 )

