K111        = #111111   , K555          = #555555   , K999          = #999999   , 

//                                                                              FUNCTIONS
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
//                                                              RMI
//▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒ 
rmi(SOURCE,LENGHT,MOMENTUM)=>
    INC                 = ema   (max(SOURCE              - SOURCE[MOMENTUM]   , 0)    , LENGHT)
    DEC                 = ema   (max(SOURCE[MOMENTUM]    - SOURCE             , 0)    , LENGHT)
    RMI                 = DEC   == 0    ? 0     : 50 - 100 / (1     + INC / DEC)
    
//                                                                              INPUTS
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
RESOLUTION              = input ( defval=1      , minval=1                  , type=integer                          , title="Resolution (Minutes)"                  )
SLOWCORRECTION          = input ( defval=10     , minval=9                  , type=integer                          , title="Slowcorrection 10's"                   )
//                                                              SOURCE
//▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒
RMI_SOURCE              = input ( defval=close                              , type=source                           , title="Source"                                )

//                                                              RMI
//▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒
RMI_FAST_LENGHT         = input ( defval=29     , minval=1                  , type=integer                          , title="Fast   RMI Length"                     ) / RESOLUTION
RMI_FAST_MOMENTUM       = input ( defval=7      , minval=1                                                          , title="Fast   RMI Momentum"                   ) / RESOLUTION
RMI_FAST_ON             = input ( defval=true                               , type=bool                             , title="Fast   RMI On"                         ) 

RMI_MEDI_LENGHT         = input ( defval=239    , minval=1                  , type=integer                          , title="Medium RMI Length"                     ) / RESOLUTION
RMI_MEDI_MOMENTUM       = input ( defval=23     , minval=1                                                          , title="Medium RMI Momentum"                   ) / RESOLUTION
RMI_MEDI_ON             = input ( defval=true                               , type=bool                             , title="Medium RMI On"                         )

RMI_SLOW_LENGHT         = input ( defval=2467   , minval=1                  , type=integer                          , title="Slow   RMI Length"                     ) / RESOLUTION * (SLOWCORRECTION/10)
RMI_SLOW_MOMENTUM       = input ( defval=239    , minval=1                                                          , title="Slow   RMI Momentum"                   ) / RESOLUTION * (SLOWCORRECTION/10)
RMI_SLOW_ON             = input ( defval=true                               , type=bool                             , title="Slow   RMI On"                         )

//                    RMI boundaries
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
RMI_FAST_HIGH_BNDR      = input ( defval=31     , minval=00  , maxval=50    , type=integer                          , title="Fast   HIGH Boundary"                  )
RMI_MEDI_HIGH_BNDR      = input ( defval=23     , minval=00  , maxval=50    , type=integer                          , title="Medium HIGH Boundary"                  )
RMI_SLOW_HIGH_BNDR      = input ( defval=19     , minval=00  , maxval=50    , type=integer                          , title="Slow   HIGH Boundary"                  )

RMI_FAST_LOW_BNDR       = input ( defval=-31    , minval=-50 , maxval=00    , type=integer                          , title="Fast   LOW Boundary"                   )
RMI_MEDI_LOW_BNDR       = input ( defval=-23    , minval=-50 , maxval=00    , type=integer                          , title="Medium LOW Boundary"                   )
RMI_SLOW_LOW_BNDR       = input ( defval=-19    , minval=-50 , maxval=00    , type=integer                          , title="Slow   LOW Boundary"                   )

//                    RMI boundary correction
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
RMI_TREND_CORRECTION    = input ( defval=true                               , type=bool                             , title="Trend Boundary correction on Slow RMI" )
RMI_TREND_LENGHT        = input ( defval=2467   , minval=00  , maxval=2500  , type=integer                          , title="Trend Lenght"                          ) / RESOLUTION
RMI_TREND_FACTOR        = input ( defval=3      , minval=00  , maxval=2500  , type=integer                          , title="Trend Factor 10's"                     ) 

//                                                              AUTOMATION
//▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒
DELAY_BETWEEN_ENTRIES   = input ( defval=199     , minval=0                                                         , title="Delay Between Entries"                 ) / RESOLUTION
ENTRY_ONCE_PER_DIP      = input ( defval=false                              , type=bool                             , title="Or Entry Once Per Dip/Top"             )
//                    RISK MANAGEMENT
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
PYRAMIDING              = input ( defval=9      , minval=9  , maxval=9      , type=integer                          , title="Pyramiding"                            ) // NOT ADJUSTABLE YET

TAKEPROFIT              = input ( defval=20000  , minval=0                                                          , title="Take Profit Pips %/1000"               )
STOPLOSS                = input ( defval=15000  , minval=0                                                          , title="Stop Loss   Pips %/1000"               )
COMISSION_VALUE         = input ( defval=0.25   , minval=0  , maxval=1      , type=float        , step=0.01         , title="Comission value for offsetting Takeprofit/stoploss")


VIEWPOSITIONS           = input ( defval=false                              , type=bool                             , title="View Positions"                        )

//                    Additional Entries
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
ENTRY_EXTRAS            = input ( defval=true                               , type=bool                             , title="Extra Entries on Opportune Moments"    )

//                                                                              CALCULATION
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
//                                                              RMI
//▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒
RMI_FAST                = rmi   ( RMI_SOURCE    , RMI_FAST_LENGHT   , RMI_FAST_MOMENTUM )

RMI_MEDI                = rmi   ( RMI_SOURCE    , RMI_MEDI_LENGHT   , RMI_MEDI_MOMENTUM )

RMI_SLOW                = rmi   ( RMI_SOURCE    , RMI_SLOW_LENGHT   , RMI_SLOW_MOMENTUM )

//                                                              TREND CORRECTION
//▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒
RMI_TREND               = sma   ( RMI_FAST + RMI_MEDI + RMI_SLOW    , RMI_TREND_LENGHT  )   /   ( 1     /   ( RMI_TREND_FACTOR  / 10    ))
RMI_CORRECTION          = iff   ( RMI_TREND_CORRECTION  , RMI_TREND        , 0)

RMI_FAST_HIGH           = RMI_FAST_HIGH_BNDR
RMI_MEDI_HIGH           = RMI_MEDI_HIGH_BNDR
RMI_SLOW_HIGH           = RMI_SLOW_HIGH_BNDR    + iff   ( RMI_CORRECTION < 0    , RMI_CORRECTION    , 0)

RMI_FAST_LOW            = RMI_FAST_LOW_BNDR
RMI_MEDI_LOW            = RMI_MEDI_LOW_BNDR
RMI_SLOW_LOW            = RMI_SLOW_LOW_BNDR     + iff   ( RMI_CORRECTION > 0    , RMI_CORRECTION    , 0)

//                                                                              CONDITIONS
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
//                                                              OVER AND UNDER
//▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒
//                      TOPS
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
RMI_FAST_TOP            = RMI_FAST              >=  RMI_FAST_HIGH   ? 1 : not RMI_FAST_ON   ? 1 : 0
RMI_MEDI_TOP            = RMI_MEDI              >=  RMI_MEDI_HIGH   ? 1 : not RMI_MEDI_ON   ? 1 : 0
RMI_SLOW_TOP            = RMI_SLOW              >=  RMI_SLOW_HIGH   ? 1 : not RMI_SLOW_ON   ? 1 : 0

//                      DIPS
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
RMI_FAST_DIP            = RMI_FAST              <=  RMI_FAST_LOW    ? 1 : not RMI_FAST_ON   ? 1 : 0
RMI_MEDI_DIP            = RMI_MEDI              <=  RMI_MEDI_LOW    ? 1 : not RMI_MEDI_ON   ? 1 : 0
RMI_SLOW_DIP            = RMI_SLOW              <=  RMI_SLOW_LOW    ? 1 : not RMI_SLOW_ON   ? 1 : 0

//                      3 RMI FMS
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
RMI_TOP_3               = RMI_FAST_TOP          and RMI_MEDI_TOP        and RMI_SLOW_TOP    ? 1 : 0
RMI_DIP_3               = RMI_FAST_DIP          and RMI_MEDI_DIP        and RMI_SLOW_DIP    ? 1 : 0

//                      2 RMI FM
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
RMI_TOP_2               = RMI_FAST_TOP          and RMI_MEDI_TOP        and not iff(RMI_SLOW >=  RMI_SLOW_HIGH,1,0)  ? 1 : 0
RMI_DIP_2               = RMI_FAST_DIP          and RMI_MEDI_DIP        and not iff(RMI_SLOW <=  RMI_SLOW_LOW,1,0)   ? 1 : 0

//                      1 RMI F
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░

//                                                              CROSSINGS
//▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒
//                      TOPS
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
RMI_FAST_TOP_IN         = crossover ( RMI_FAST          , RMI_FAST_HIGH )
RMI_FAST_TOP_OUT        = crossunder( RMI_FAST          , RMI_FAST_HIGH )

RMI_MEDI_TOP_IN         = crossover ( RMI_MEDI          , RMI_MEDI_HIGH )
RMI_MEDI_TOP_OUT        = crossunder( RMI_MEDI          , RMI_MEDI_HIGH )

RMI_SLOW_TOP_IN         = crossover ( RMI_SLOW          , RMI_SLOW_HIGH )
RMI_SLOW_TOP_OUT        = crossunder( RMI_SLOW          , RMI_SLOW_HIGH )

//                      DIPS
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
RMI_FAST_DIP_IN         = crossunder( RMI_FAST          , RMI_FAST_LOW  )
RMI_FAST_DIP_OUT        = crossover ( RMI_FAST          , RMI_FAST_LOW  )

RMI_MEDI_DIP_IN         = crossunder( RMI_MEDI          , RMI_MEDI_LOW  )
RMI_MEDI_DIP_OUT        = crossover ( RMI_MEDI          , RMI_MEDI_LOW  )

RMI_SLOW_DIP_IN         = crossunder( RMI_SLOW          , RMI_SLOW_LOW  )
RMI_SLOW_DIP_OUT        = crossover ( RMI_SLOW          , RMI_SLOW_LOW  )

//                                                                              AUTOMATION
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
//                                                              SHORT
//▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒
SHORT_PULSE             = RMI_TOP_3                     and not offset   ( RMI_TOP_3                        ? 1         : 0 , 1 )                                                       ? 1     : 0 
//                      DELAY BETWEEN ENTRIES
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
SHORT_SWEEP             = sma       ( SHORT_PULSE       , DELAY_BETWEEN_ENTRIES )   > 0                     ? 1         : 0
SHORT_DBE_OUT           = fixnan    ( RMI_TOP_3                                                             ? 1         : SHORT_PULSE   or RMI_MEDI_TOP_OUT or SHORT_SWEEP              ? 0     : na    )
SHORT_DBE               = offset    ( SHORT_SWEEP       , 1 )   < SHORT_PULSE                               ? 1         : 0 
//                      ONCE PER DIP/TOP ENTRY
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
SHORT_OPD_OUT           = fixnan    ( RMI_TOP_3                                                             ? 1         : SHORT_PULSE   or RMI_MEDI_TOP_OUT                             ? 0     : na    )
SHORT_OPD               = iff       ( ENTRY_ONCE_PER_DIP, offset( SHORT_OPD_OUT,1)  > SHORT_OPD_OUT         ? 1         : 0             , offset    ( SHORT_SWEEP , 1) < SHORT_PULSE    ? 1     : 0     )

SHORT                   = ENTRY_ONCE_PER_DIP                                                                ? SHORT_OPD : SHORT_DBE

//                                                              LONG
//▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒
LONG_PULSE              = RMI_DIP_3                     and not offset  ( RMI_DIP_3                         ? 1         : 0 , 1 )                                                       ? 1     : 0 
//                      DELAY BETWEEN ENTRIES
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
LONG_SWEEP              = sma       ( LONG_PULSE        , DELAY_BETWEEN_ENTRIES )   > 0                     ? 1         : 0
LONG_DBE_OUT            = fixnan    ( RMI_DIP_3                                                             ? 1         : LONG_PULSE    or  RMI_MEDI_DIP_OUT or LONG_SWEEP              ? 0     : na    )
LONG_DBE                = offset    ( LONG_SWEEP        , 1)    < LONG_PULSE                                ? 1         : 0 
//                      ONCE PER DIP/TOP ENTRY
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
LONG_OPD_OUT            = fixnan    ( RMI_DIP_3                                                             ? 1         : LONG_PULSE    or RMI_MEDI_DIP_OUT                             ? 0     : na    )
LONG_OPD                = iff       ( ENTRY_ONCE_PER_DIP, offset( LONG_OPD_OUT,1)   > LONG_OPD_OUT          ? 1         : 0             , offset    ( LONG_SWEEP  , 1) < LONG_PULSE     ? 1     : 0     )

LONG                    = ENTRY_ONCE_PER_DIP                                                                ? LONG_OPD  : LONG_DBE

//                                                                              ANALYTHICAL
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
//                                                              PHASE
//▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒
PHASE_SWITCH            = fixnan    ( SHORT             ? 1             : LONG                              ? 0         : na    )
PHASE_COLOR             = PHASE_SWITCH    ? cyan  : oker

PHASE_LONG              = offset    ( PHASE_SWITCH      , 1) > PHASE_SWITCH
PHASE_SHORT             = offset    ( PHASE_SWITCH      , 1) < PHASE_SWITCH

PHASE_LONG_IV           = fixnan    ( PHASE_LONG        ? close         : na )
PHASE_SHORT_IV          = fixnan    ( PHASE_SHORT       ? close         : na )

//                                                      HIGHEST/LOWEST ENTRY
//▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒
//                    ON ENTRY IF LARGER
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
PHASE_LONG_LV           = fixnan    ( LONG              and close < PHASE_LONG_IV                           ? close     : PHASE_LONG    ?   PHASE_LONG_IV       : na )
PHASE_SHORT_LV          = fixnan    ( SHORT             and close > PHASE_SHORT_IV                          ? close     : PHASE_SHORT   ?   PHASE_SHORT_IV      : na )

//                                                                              ADDITIONAL ENRTRIES
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░


//                                                              SHORT
//▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒
X_SHORT_PULSE           = RMI_TOP_2                     and not offset  ( RMI_TOP_2                         ? 1         : 0 , 1 )                                                       ? 1     : 0 
//                      DELAY BETWEEN ENTRIES
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
X_SHORT_SWEEP           = sma       ( X_SHORT_PULSE     , DELAY_BETWEEN_ENTRIES )   >   0                   ? 1         : 0
X_SHORT_DBE_OUT         = fixnan    ( RMI_TOP_2         ? 1     : X_SHORT_PULSE     or RMI_MEDI_TOP_OUT or X_SHORT_SWEEP                                                                ? 0     : na    )
X_SHORT_DBE             = offset    ( X_SHORT_SWEEP     , 1)    < X_SHORT_PULSE                             ? 1         : 0 
//                      ONCE PER DIP/TOP ENTRY
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
X_SHORT_OPD_OUT         = fixnan    ( RMI_TOP_2         ? 1     : X_SHORT_PULSE     or RMI_MEDI_TOP_OUT     ? 0         : na    )
X_SHORT_OPD             = iff       ( ENTRY_ONCE_PER_DIP, offset( X_SHORT_OPD_OUT,1)> X_SHORT_OPD_OUT       ? 1         : 0         , offset    ( X_SHORT_SWEEP  ,1) < X_SHORT_PULSE    ? 1     : 0     )

SHORT_EXTRA_INPUT       = ENTRY_ONCE_PER_DIP            ? X_SHORT_OPD               : X_SHORT_DBE
SHORT_EXTRA             = ENTRY_EXTRAS                  and SHORT_EXTRA_INPUT       and iff ( close > PHASE_SHORT_LV    , 1 , 0 )


//                                                              LONG
//▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒
X_LONG_PULSE            = RMI_DIP_2                     and not offset  ( RMI_DIP_2                         ? 1         : 0 , 1 )                                                       ? 1     : 0 
//                      DELAY BETWEEN ENTRIES
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
X_LONG_SWEEP            = sma       ( X_LONG_PULSE      , DELAY_BETWEEN_ENTRIES )   >   0                   ? 1         : 0
X_LONG_DBE_OUT          = fixnan    ( RMI_DIP_3         ? 1     : X_LONG_PULSE      or RMI_MEDI_DIP_OUT or X_LONG_SWEEP                                                                 ? 0     : na    )
X_LONG_DBE              = offset    ( X_LONG_SWEEP      , 1)    <  X_LONG_PULSE                             ? 1         : 0 
//                      ONCE PER DIP/TOP ENTRY
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
X_LONG_OPD_OUT          = fixnan    ( RMI_DIP_2         ? 1     : X_LONG_PULSE      or RMI_MEDI_DIP_OUT     ? 0         : na    )
X_LONG_OPD              = iff       ( ENTRY_ONCE_PER_DIP, offset( X_LONG_OPD_OUT,1) > X_LONG_OPD_OUT        ? 1         : 0         , offset    ( X_LONG_SWEEP  ,1) < X_LONG_PULSE      ? 1     : 0     )

LONG_EXTRA_INPUT        = ENTRY_ONCE_PER_DIP            ? X_LONG_OPD    : X_LONG_DBE
LONG_EXTRA              = ENTRY_EXTRAS                  and LONG_EXTRA_INPUT        and iff( close < PHASE_LONG_LV      , 1 , 0 )

//                    ADJUSTED VALUE AFTER ADDITIONAL ENTRY
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
// REQUIRES REBUILD  :: ORDER OF LOGIC INCAPABLE OR POST ADJUSTMENT

