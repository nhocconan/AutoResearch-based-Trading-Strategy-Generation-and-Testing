PYR_SHORTS_A                = na
PYR_SHORTS_A                := PYR_SHORTS_OPEN == 1 and (SHORT or SHORT_EXTRA) ? close : nz(PYR_SHORTS_A[1])
PYR_SHORTS_A                := (TAKEPROFIT_SHORT_A[1] or STOPLOSS_SHORT_A[1]) or (LONG or LONG_EXTRA) ? 0 : PYR_SHORTS_A
OPEN_SHORT_A                = PYR_SHORTS_OPEN == 1 and (SHORT or SHORT_EXTRA) ? 1 : 0

PYR_SHORTS_B                = na
PYR_SHORTS_B                := PYR_SHORTS_OPEN == 2 and (SHORT or SHORT_EXTRA) ? close : nz(PYR_SHORTS_B[1])
PYR_SHORTS_B                := (TAKEPROFIT_SHORT_B[1] or STOPLOSS_SHORT_B[1]) or (LONG or LONG_EXTRA) ? 0 : PYR_SHORTS_B
OPEN_SHORT_B                = PYR_SHORTS_OPEN == 2 and (SHORT or SHORT_EXTRA) ? 1 : 0

