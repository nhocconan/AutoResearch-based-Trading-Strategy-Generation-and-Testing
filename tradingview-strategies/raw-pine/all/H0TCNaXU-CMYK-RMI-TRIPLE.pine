OPEN_SHORT_C                = PYR_SHORTS_OPEN == 3 and (SHORT or SHORT_EXTRA) ? 1 : 0

PYR_SHORTS_D                = na
PYR_SHORTS_D                := PYR_SHORTS_OPEN == 4 and (SHORT or SHORT_EXTRA) ? close : nz(PYR_SHORTS_D[1])
PYR_SHORTS_D                := (TAKEPROFIT_SHORT_D[1] or STOPLOSS_SHORT_D[1]) or (LONG or LONG_EXTRA) ? 0 : PYR_SHORTS_D
OPEN_SHORT_D                = PYR_SHORTS_OPEN == 4 and (SHORT or SHORT_EXTRA) ? 1 : 0

PYR_SHORTS_E                = na
PYR_SHORTS_E                := PYR_SHORTS_OPEN == 5 and (SHORT or SHORT_EXTRA) ? close : nz(PYR_SHORTS_E[1])
PYR_SHORTS_E                := (TAKEPROFIT_SHORT_E[1] or STOPLOSS_SHORT_E[1]) or (LONG or LONG_EXTRA) ? 0 : PYR_SHORTS_E
OPEN_SHORT_E                = PYR_SHORTS_OPEN == 5 and (SHORT or SHORT_EXTRA) ? 1 : 0

PYR_SHORTS_F                = na
PYR_SHORTS_F                := PYR_SHORTS_OPEN == 6 and (SHORT or SHORT_EXTRA) ? close : nz(PYR_SHORTS_F[1])
PYR_SHORTS_F                := (TAKEPROFIT_SHORT_F[1] or STOPLOSS_SHORT_F[1]) or (LONG or LONG_EXTRA) ? 0 : PYR_SHORTS_F
OPEN_SHORT_F                = PYR_SHORTS_OPEN == 6 and (SHORT or SHORT_EXTRA) ? 1 : 0

PYR_SHORTS_G                = na
PYR_SHORTS_G                := PYR_SHORTS_OPEN == 7 and (SHORT or SHORT_EXTRA) ? close : nz(PYR_SHORTS_G[1])
PYR_SHORTS_G                := (TAKEPROFIT_SHORT_G[1] or STOPLOSS_SHORT_G[1]) or (LONG or LONG_EXTRA) ? 0 : PYR_SHORTS_G
OPEN_SHORT_G                = PYR_SHORTS_OPEN == 7 and (SHORT or SHORT_EXTRA) ? 1 : 0

PYR_SHORTS_H                = na
PYR_SHORTS_H                := PYR_SHORTS_OPEN == 8 and (SHORT or SHORT_EXTRA) ? close : nz(PYR_SHORTS_H[1])
PYR_SHORTS_H                := (TAKEPROFIT_SHORT_H[1] or STOPLOSS_SHORT_H[1]) or (LONG or LONG_EXTRA) ? 0 : PYR_SHORTS_H
OPEN_SHORT_H                = PYR_SHORTS_OPEN == 8 and (SHORT or SHORT_EXTRA) ? 1 : 0

PYR_SHORTS_I                = na
PYR_SHORTS_I                := PYR_SHORTS_OPEN == 9 and (SHORT or SHORT_EXTRA) ? close : nz(PYR_SHORTS_I[1])
