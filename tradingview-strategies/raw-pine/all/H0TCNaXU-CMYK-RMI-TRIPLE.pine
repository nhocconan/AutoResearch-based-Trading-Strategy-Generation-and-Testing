PYR_LONGS_F                 := (TAKEPROFIT_LONG_F[1] or STOPLOSS_LONG_F[1]) or (SHORT or SHORT_EXTRA) ? 0 : PYR_LONGS_F
OPEN_LONG_F                 = PYR_LONGS_OPEN == 6 and (LONG or LONG_EXTRA) ? 1 : 0

PYR_LONGS_G                 = na
PYR_LONGS_G                 := PYR_LONGS_OPEN == 7 and (LONG or LONG_EXTRA) ? close : nz(PYR_LONGS_G[1])
PYR_LONGS_G                 := (TAKEPROFIT_LONG_G[1] or STOPLOSS_LONG_G[1]) or (SHORT or SHORT_EXTRA) ? 0 : PYR_LONGS_G
OPEN_LONG_G                 = PYR_LONGS_OPEN == 7 and (LONG or LONG_EXTRA) ? 1 : 0

PYR_LONGS_H                 = na
PYR_LONGS_H                 := PYR_LONGS_OPEN == 8 and (LONG or LONG_EXTRA) ? close : nz(PYR_LONGS_H[1])
PYR_LONGS_H                 := (TAKEPROFIT_LONG_H[1] or STOPLOSS_LONG_H[1]) or (SHORT or SHORT_EXTRA) ? 0 : PYR_LONGS_H
OPEN_LONG_H                 = PYR_LONGS_OPEN == 8 and (LONG or LONG_EXTRA) ? 1 : 0

PYR_LONGS_I                 = na
PYR_LONGS_I                 := PYR_LONGS_OPEN == 9 and (LONG or LONG_EXTRA) ? close : nz(PYR_LONGS_I[1])
PYR_LONGS_I                 := (TAKEPROFIT_LONG_I[1] or STOPLOSS_LONG_I[1]) or (SHORT or SHORT_EXTRA) ? 0 : PYR_LONGS_I
OPEN_LONG_I                 = PYR_LONGS_OPEN == 9 and (LONG or LONG_EXTRA) ? 1 : 0

//                                                              STOP LOSS
//▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒
//                      FACTOR
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
STOPLOSS_LONG_FACTOR        = (( 100000 - STOPLOSS   ) / 100000     ) - (   COMISSION_VALUE /   100 )
STOPLOSS_SHORT_FACTOR       = (( 100000 + STOPLOSS   ) / 100000     ) + (   COMISSION_VALUE /   100 )

//                      SHORTS
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
STOPLOSS_SHORT_A            := PYR_SHORTS_A     * STOPLOSS_SHORT_FACTOR     < close     and PYR_SHORTS_A > 0 ? 1    : LONG or LONG_EXTRA    ? 0     :   nz(STOPLOSS_SHORT_A[1])  
STOPLOSS_SHORT_B            := PYR_SHORTS_B     * STOPLOSS_SHORT_FACTOR     < close     and PYR_SHORTS_B > 0 ? 1    : LONG or LONG_EXTRA    ? 0     :   nz(STOPLOSS_SHORT_B[1]) 
STOPLOSS_SHORT_C            := PYR_SHORTS_C     * STOPLOSS_SHORT_FACTOR     < close     and PYR_SHORTS_C > 0 ? 1    : LONG or LONG_EXTRA    ? 0     :   nz(STOPLOSS_SHORT_C[1]) 
STOPLOSS_SHORT_D            := PYR_SHORTS_D     * STOPLOSS_SHORT_FACTOR     < close     and PYR_SHORTS_D > 0 ? 1    : LONG or LONG_EXTRA    ? 0     :   nz(STOPLOSS_SHORT_D[1]) 
STOPLOSS_SHORT_E            := PYR_SHORTS_E     * STOPLOSS_SHORT_FACTOR     < close     and PYR_SHORTS_E > 0 ? 1    : LONG or LONG_EXTRA    ? 0     :   nz(STOPLOSS_SHORT_E[1]) 
STOPLOSS_SHORT_F            := PYR_SHORTS_F     * STOPLOSS_SHORT_FACTOR     < close     and PYR_SHORTS_F > 0 ? 1    : LONG or LONG_EXTRA    ? 0     :   nz(STOPLOSS_SHORT_F[1]) 
STOPLOSS_SHORT_G            := PYR_SHORTS_G     * STOPLOSS_SHORT_FACTOR     < close     and PYR_SHORTS_G > 0 ? 1    : LONG or LONG_EXTRA    ? 0     :   nz(STOPLOSS_SHORT_G[1]) 
STOPLOSS_SHORT_H            := PYR_SHORTS_H     * STOPLOSS_SHORT_FACTOR     < close     and PYR_SHORTS_H > 0 ? 1    : LONG or LONG_EXTRA    ? 0     :   nz(STOPLOSS_SHORT_H[1]) 
STOPLOSS_SHORT_I            := PYR_SHORTS_I     * STOPLOSS_SHORT_FACTOR     < close     and PYR_SHORTS_I > 0 ? 1    : LONG or LONG_EXTRA    ? 0     :   nz(STOPLOSS_SHORT_I[1])

//                      LONGS
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
STOPLOSS_LONG_A             := PYR_LONGS_A      * STOPLOSS_LONG_FACTOR      > close     and PYR_LONGS_A > 0 ? 1     : SHORT or SHORT_EXTRA  ? 0     :   nz(STOPLOSS_LONG_A[1])
STOPLOSS_LONG_B             := PYR_LONGS_B      * STOPLOSS_LONG_FACTOR      > close     and PYR_LONGS_B > 0 ? 1     : SHORT or SHORT_EXTRA  ? 0     :   nz(STOPLOSS_LONG_B[1])    
STOPLOSS_LONG_C             := PYR_LONGS_C      * STOPLOSS_LONG_FACTOR      > close     and PYR_LONGS_C > 0 ? 1     : SHORT or SHORT_EXTRA  ? 0     :   nz(STOPLOSS_LONG_C[1])  
STOPLOSS_LONG_D             := PYR_LONGS_D      * STOPLOSS_LONG_FACTOR      > close     and PYR_LONGS_D > 0 ? 1     : SHORT or SHORT_EXTRA  ? 0     :   nz(STOPLOSS_LONG_D[1])  
STOPLOSS_LONG_E             := PYR_LONGS_E      * STOPLOSS_LONG_FACTOR      > close     and PYR_LONGS_E > 0 ? 1     : SHORT or SHORT_EXTRA  ? 0     :   nz(STOPLOSS_LONG_E[1])  
STOPLOSS_LONG_F             := PYR_LONGS_F      * STOPLOSS_LONG_FACTOR      > close     and PYR_LONGS_F > 0 ? 1     : SHORT or SHORT_EXTRA  ? 0     :   nz(STOPLOSS_LONG_F[1])  
STOPLOSS_LONG_G             := PYR_LONGS_G      * STOPLOSS_LONG_FACTOR      > close     and PYR_LONGS_G > 0 ? 1     : SHORT or SHORT_EXTRA  ? 0     :   nz(STOPLOSS_LONG_G[1])  
STOPLOSS_LONG_H             := PYR_LONGS_H      * STOPLOSS_LONG_FACTOR      > close     and PYR_LONGS_H > 0 ? 1     : SHORT or SHORT_EXTRA  ? 0     :   nz(STOPLOSS_LONG_H[1])  
STOPLOSS_LONG_I             := PYR_LONGS_I      * STOPLOSS_LONG_FACTOR      > close     and PYR_LONGS_I > 0 ? 1     : SHORT or SHORT_EXTRA  ? 0     :   nz(STOPLOSS_LONG_I[1]) 

//                                                              TAKE PROFIT
//▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒
//                      FACTOR
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
TAKEPROFIT_LONG_FACTOR      = (( 100000 + TAKEPROFIT   ) / 100000   ) + (   COMISSION_VALUE /   100 )
TAKEPROFIT_SHORT_FACTOR     = (( 100000 - TAKEPROFIT   ) / 100000   ) - (   COMISSION_VALUE /   100 )

//                      SHORTS
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
TAKEPROFIT_SHORT_A          := PYR_SHORTS_A     * TAKEPROFIT_SHORT_FACTOR   > close     and PYR_SHORTS_A > 0 ? 1    : LONG or LONG_EXTRA    ? 0     :   nz(TAKEPROFIT_SHORT_A[1])  
TAKEPROFIT_SHORT_B          := PYR_SHORTS_B     * TAKEPROFIT_SHORT_FACTOR   > close     and PYR_SHORTS_B > 0 ? 1    : LONG or LONG_EXTRA    ? 0     :   nz(TAKEPROFIT_SHORT_B[1]) 
TAKEPROFIT_SHORT_C          := PYR_SHORTS_C     * TAKEPROFIT_SHORT_FACTOR   > close     and PYR_SHORTS_C > 0 ? 1    : LONG or LONG_EXTRA    ? 0     :   nz(TAKEPROFIT_SHORT_C[1]) 
TAKEPROFIT_SHORT_D          := PYR_SHORTS_D     * TAKEPROFIT_SHORT_FACTOR   > close     and PYR_SHORTS_D > 0 ? 1    : LONG or LONG_EXTRA    ? 0     :   nz(TAKEPROFIT_SHORT_D[1]) 
TAKEPROFIT_SHORT_E          := PYR_SHORTS_E     * TAKEPROFIT_SHORT_FACTOR   > close     and PYR_SHORTS_E > 0 ? 1    : LONG or LONG_EXTRA    ? 0     :   nz(TAKEPROFIT_SHORT_E[1]) 
TAKEPROFIT_SHORT_F          := PYR_SHORTS_F     * TAKEPROFIT_SHORT_FACTOR   > close     and PYR_SHORTS_F > 0 ? 1    : LONG or LONG_EXTRA    ? 0     :   nz(TAKEPROFIT_SHORT_F[1]) 
TAKEPROFIT_SHORT_G          := PYR_SHORTS_G     * TAKEPROFIT_SHORT_FACTOR   > close     and PYR_SHORTS_G > 0 ? 1    : LONG or LONG_EXTRA    ? 0     :   nz(TAKEPROFIT_SHORT_G[1]) 
TAKEPROFIT_SHORT_H          := PYR_SHORTS_H     * TAKEPROFIT_SHORT_FACTOR   > close     and PYR_SHORTS_H > 0 ? 1    : LONG or LONG_EXTRA    ? 0     :   nz(TAKEPROFIT_SHORT_H[1]) 
TAKEPROFIT_SHORT_I          := PYR_SHORTS_I     * TAKEPROFIT_SHORT_FACTOR   > close     and PYR_SHORTS_I > 0 ? 1    : LONG or LONG_EXTRA    ? 0     :   nz(TAKEPROFIT_SHORT_I[1])

//                      LONGS
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
TAKEPROFIT_LONG_A           := PYR_LONGS_A      * TAKEPROFIT_LONG_FACTOR    < close     and PYR_LONGS_A > 0 ? 1     : SHORT or SHORT_EXTRA  ? 0     :   nz(TAKEPROFIT_LONG_A[1])
TAKEPROFIT_LONG_B           := PYR_LONGS_B      * TAKEPROFIT_LONG_FACTOR    < close     and PYR_LONGS_B > 0 ? 1     : SHORT or SHORT_EXTRA  ? 0     :   nz(TAKEPROFIT_LONG_B[1])    
TAKEPROFIT_LONG_C           := PYR_LONGS_C      * TAKEPROFIT_LONG_FACTOR    < close     and PYR_LONGS_C > 0 ? 1     : SHORT or SHORT_EXTRA  ? 0     :   nz(TAKEPROFIT_LONG_C[1])  
TAKEPROFIT_LONG_D           := PYR_LONGS_D      * TAKEPROFIT_LONG_FACTOR    < close     and PYR_LONGS_D > 0 ? 1     : SHORT or SHORT_EXTRA  ? 0     :   nz(TAKEPROFIT_LONG_D[1])  
TAKEPROFIT_LONG_E           := PYR_LONGS_E      * TAKEPROFIT_LONG_FACTOR    < close     and PYR_LONGS_E > 0 ? 1     : SHORT or SHORT_EXTRA  ? 0     :   nz(TAKEPROFIT_LONG_E[1])  
TAKEPROFIT_LONG_F           := PYR_LONGS_F      * TAKEPROFIT_LONG_FACTOR    < close     and PYR_LONGS_F > 0 ? 1     : SHORT or SHORT_EXTRA  ? 0     :   nz(TAKEPROFIT_LONG_F[1])  
TAKEPROFIT_LONG_G           := PYR_LONGS_G      * TAKEPROFIT_LONG_FACTOR    < close     and PYR_LONGS_G > 0 ? 1     : SHORT or SHORT_EXTRA  ? 0     :   nz(TAKEPROFIT_LONG_G[1])  
TAKEPROFIT_LONG_H           := PYR_LONGS_H      * TAKEPROFIT_LONG_FACTOR    < close     and PYR_LONGS_H > 0 ? 1     : SHORT or SHORT_EXTRA  ? 0     :   nz(TAKEPROFIT_LONG_H[1])  
TAKEPROFIT_LONG_I           := PYR_LONGS_I      * TAKEPROFIT_LONG_FACTOR    < close     and PYR_LONGS_I > 0 ? 1     : SHORT or SHORT_EXTRA  ? 0     :   nz(TAKEPROFIT_LONG_I[1])  


//                                                                              BACKTESTING
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
//                                                              SHORTS
//▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒
//                      SHORT A
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
if ( (SHORT or SHORT_EXTRA)       and     PYR_SHORTS_OPEN == 1 )
    strategy.entry  ( "SHORT ENTRY :: A"    , strategy.short)

if ( (LONG or LONG_EXTRA)     or      (STOPLOSS_SHORT_A or TAKEPROFIT_SHORT_A) )
    strategy.close  ( "SHORT ENTRY :: A"    , strategy.short)     
    
//                      SHORT B
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
if ( (SHORT or SHORT_EXTRA)       and     PYR_SHORTS_OPEN == 2 )
    strategy.entry  ( "SHORT ENTRY :: B"    , strategy.short)

if ( (LONG or LONG_EXTRA)     or      (STOPLOSS_SHORT_B or TAKEPROFIT_SHORT_B) )
    strategy.close  ( "SHORT ENTRY :: B"    , strategy.short)     
    
//                      SHORT C
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
if ( (SHORT or SHORT_EXTRA)       and     PYR_SHORTS_OPEN == 3 )
    strategy.entry  ( "SHORT ENTRY :: C"    , strategy.short)

if ( (LONG or LONG_EXTRA)     or      (STOPLOSS_SHORT_C or TAKEPROFIT_SHORT_C) )
    strategy.close  ( "SHORT ENTRY :: C"    , strategy.short)     
    
//                      SHORT D
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
if ( (SHORT or SHORT_EXTRA)       and     PYR_SHORTS_OPEN == 4 )
    strategy.entry  ( "SHORT ENTRY :: D"    , strategy.short)
if ( (LONG or LONG_EXTRA)     or      (STOPLOSS_SHORT_D or TAKEPROFIT_SHORT_D) )
    strategy.close  ( "SHORT ENTRY :: D"    , strategy.short)     

    
//                      SHORT E
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
if ( (SHORT or SHORT_EXTRA)       and     PYR_SHORTS_OPEN == 5 )
    strategy.entry  ( "SHORT ENTRY :: E"    , strategy.short)

if ( (LONG or LONG_EXTRA)     or      (STOPLOSS_SHORT_E or TAKEPROFIT_SHORT_E) )
    strategy.close  ( "SHORT ENTRY :: E"    , strategy.short)     

//                      SHORT F
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
if ( (SHORT or SHORT_EXTRA)       and     PYR_SHORTS_OPEN == 6 )
    strategy.entry  ( "SHORT ENTRY :: F"    , strategy.short)

if ( (LONG or LONG_EXTRA)     or      (STOPLOSS_SHORT_F or TAKEPROFIT_SHORT_F) )
    strategy.close  ( "SHORT ENTRY :: F"    , strategy.short)     
    
//                      SHORT G
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
if ( (SHORT or SHORT_EXTRA)       and     PYR_SHORTS_OPEN == 7 )
    strategy.entry  ( "SHORT ENTRY :: G"    , strategy.short)

if ( (LONG or LONG_EXTRA)     or      (STOPLOSS_SHORT_G or TAKEPROFIT_SHORT_G) )
    strategy.close  ( "SHORT ENTRY :: G"    , strategy.short)     

//                      SHORT H
//░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░
if ( (SHORT or SHORT_EXTRA)       and     PYR_SHORTS_OPEN == 8 )
    strategy.entry  ( "SHORT ENTRY :: H"    , strategy.short)

if ( (LONG or LONG_EXTRA)     or      (STOPLOSS_SHORT_H or TAKEPROFIT_SHORT_H) )
