//Candles and Pattern//
/////////////////////////////

if (close[1]>open[1] and body[1]>cLarge[1] and bodySz[1]>=0.7 and close<open and bodySz>=0.7 and open>=close[1] and close>open[1] and close<((open[1]+close[1])/2))
    num_true_criteria := num_true_criteria - 1
    
if (open[1]<close[1] and body[1]>cLarge[1] and close[1] >= max(close,open) and open[1]<=min(close,open)) and (body<=cSmall and bodySz<pctCDb and (high-max(close,open))>(pctCDw*truerange) and (min(close,open)-low)>(pctCDw*truerange))
    num_true_criteria := num_true_criteria - 1
    
if open>close and atrratio>=szOvr
    num_true_criteria := num_true_criteria - 1
    
if not oversizeBarBu  and not oversizeBarBe and (close[1]>open[1] and close<open and open>=close[1] and close<open[1] and body>=cLarge and ratio>=szBg) and (not strictEn or (high>=high[1] and low<=lowest(low,ne+1)))
    num_true_criteria := num_true_criteria - 1
    
if not bearishEngulf and not oversizeBarBu  and not oversizeBarBe and not darkCloud and body>cLarge and (close <= (low + (truerange * pctCs))) and (open >= (high - (truerange * pctCs)))  
    num_true_criteria := num_true_criteria - 1
    
if (open>low[1] and close>low[1] and low<low[1]) and (open > (low + (truerange * pctCp)) and close > (low + (truerange * pctCp)))    
    num_true_criteria := num_true_criteria - 1
   
if insideBar_ and not pBarUp and not pBarDn and open>close
    num_true_criteria := num_true_criteria - 1
  
if not bearishEngulf and not oversizeBarBe and not oversizeBarBu  and not pBarUp and not pBarDn and outsideBarBe_  
    num_true_criteria := num_true_criteria - 1

if nc==2? (open[4]<open[3] and open[3]<close[3] and close[1]<close[2] and close<close[1] and pBarUp_[2] and body>cSmall) : nc==1? (open[2]<close[2] and close<close[1] and pBarUp_[1] and body>cSmall) : false 
    num_true_criteria := num_true_criteria - 1
    
if (close[2] > open[2] and min(open[1],close[1])>=close[2] and close[2]>=high[3] and close < open and body[1]<=cSmall and close<(close[2]+open[2])/2 and body[2]>cLarge[2])
    num_true_criteria := num_true_criteria - 1

if close[1] > open[1] and open > close and open <= close[1] and open[1] <= close and open - close < close[1] - open[1] and open[trend] < open
    num_true_criteria := num_true_criteria - 1
//plotshape(scndleptrn and data6 ? data6 : na , title= "Bearish Harami", color=red, style=shape.arrowdown, text="Bearish\nHarami")

if close[1] > open[1] and open > close and open >= close[1] and open[1] >= close and open - close > close[1] - open[1] and open[trend] < open
    num_true_criteria := num_true_criteria - 1
//plotshape(scndleptrn and data8 ? data8 : na ,  title= "Bearish Engulfing", color=red, style=shape.arrowdown, text="Bearish\nEngulfing")

if open[1]<close[1] and open<=open[1] and close<=open and open[trend] < open
    num_true_criteria := num_true_criteria - 1
//plotshape(scndleptrn and data13 ? data13 : na , title= "Bearish Kicker", color=red, style=shape.arrowdown, text="Bearish\nKicker")

if ((high-low>4*(open-close))and((close-low)/(.001+high-low)>=0.75)and((open-low)/(.001+high-low)>=0.75))and open[trend] < open and high[1] < open and high[2] < open
    num_true_criteria := num_true_criteria - 1
//plotshape(scndleptrn and data14 ? data14 : na ,  title= "Hanging Man", color=red, style=shape.arrowdown, text="Hanging\nMan")


/////////////////////////////
//Moving Averages//
////////////////////////////

//
if ma_down 
    num_true_criteria := num_true_criteria - 1
    
if ma_down2 
    num_true_criteria := num_true_criteria - 1
    
if ma_down3 
    num_true_criteria := num_true_criteria - 1
    
if ma_down4 
    num_true_criteria := num_true_criteria - 1
    
//


if emaFast < emaSlow and close > emaFast
    num_true_criteria := num_true_criteria - 1

if emaFast < emaSlow and close[1] > emaFast and close < emaFast
    num_true_criteria := num_true_criteria - 1

if emaFast < emaSlow
    num_true_criteria := num_true_criteria - 1
   
//
   
///////////////////////////////////
//Moving Average Crosses//
///////////////////////////////////

if crossunder(out1, out2)
    num_true_criteria := num_true_criteria - 1

if crossunder(out1, out3) 
    num_true_criteria := num_true_criteria - 1

if crossunder(out1, out4) 
    num_true_criteria := num_true_criteria - 1

if crossunder(out2, out3) 
    num_true_criteria := num_true_criteria - 1

if crossunder(out2, out4) 
    num_true_criteria := num_true_criteria - 1

if crossunder(out3, out4)
    num_true_criteria := num_true_criteria - 1

//    
    
////////////////////////////
//Bollinger Bands//
///////////////////////////

//

if close >= upperbb
    num_true_criteria := num_true_criteria - 1
    
    
    
if sellZoneEnter()
    num_true_criteria := num_true_criteria - 1
    
if trendDownStart()
    num_true_criteria := num_true_criteria - 1
    
    
//

////////////////////////////
//Parabolic SAR//
///////////////////////////

//
if sarDown
    num_true_criteria := num_true_criteria - 1

//




/////////////////////////////////
//Supertrend//
////////////////////////////////

if cross(STsl,close) and close<STsl 
    num_true_criteria := num_true_criteria - 1

if STrend == -1 and STrend[1] == 1 
    num_true_criteria := num_true_criteria - 2


//

////////////////////////////////
//Trend Trader//
///////////////////////////////

if pos == -1
    num_true_criteria := num_true_criteria - 1


/////////////////////////////////
//Ichimoku//
////////////////////////////////

//
if leadLine1 < leadLine2  
    num_true_criteria := num_true_criteria - 1
//


//////////////////////////////
//RSI Trends//
/////////////////////////////

  
if close < rsima200 and close > rsima5 and rsi > 90 and emaFast < emaSlow  
    num_true_criteria := num_true_criteria - 1
    
if close < out4 and close > out1 and rsi > 90 and emaFast < emaSlow  
    num_true_criteria := num_true_criteria - 1
    
if close < out4 and close > out1 and rsi > 80  
    num_true_criteria := num_true_criteria - 1
    
if close < sma200 and close > sma5 and rsi > 90
    num_true_criteria := num_true_criteria - 1

if rsiOB and (barstate.ishistory or drawOnRT)
    num_true_criteria := num_true_criteria - 1
 
//

//////////////////////////////
//Slingshot//
/////////////////////////////

//
//Aggressive Entry or Alert To Potential Trade
if emaFast < emaSlow and close > emaFast
    num_true_criteria := num_true_criteria - 1
    
//Conservative Entry Code For Highlight Bars
if emaFast < emaSlow and close[1] > emaFast and close < emaFast
    num_true_criteria := num_true_criteria - 1

//Define Up and Down Trend for Trend Arrows at Top and Bottom of Screen
if emaFast < emaSlow
    num_true_criteria := num_true_criteria - 1

//SlingShot
if close < rsima200 and close > rsima5 and rsi > 90 and emaFast < emaSlow 
    num_true_criteria := num_true_criteria - 1
    
//

////////////////////////////////////////////

if downTrend 
    num_true_criteria := num_true_criteria - 1
    
if codiff2*-1 
    num_true_criteria := num_true_criteria - 1


//////////////////////////////////////////
    
if close > sma200 and close[1] < sma5[1] and high > sma5 and ((close[1] > sma200[1] and close[1] < sma5[1] and rsi[1] < 10) or (close[2] > sma200[2] and close[2] < sma5[2] and rsi[2] < 10) or (close[3] > sma200[3] and close[3] < sma5[3] and rsi[3] < 10) or (close[4] > sma200[4] and close[4] < sma5[4] and rsi[4] < 10) )
    num_true_criteria := num_true_criteria - 1
    
    
//////////////////////////////////////
//MACD//
////////////////////////////

if MACD <0
    num_true_criteria := num_true_criteria - 1
    
if crossunder(MACD,0)
    num_true_criteria := num_true_criteria - 1
    
if dm<dm[1]
    num_true_criteria := num_true_criteria - 1
    
//
    
//////////////////////////////////////////
//Super Guppy//
/////////////////////////////////////////

    
if sell==1 and barssince(nz(sell[1],1)==1)>Lookback
    num_true_criteria := num_true_criteria - 1
    
if sellbreak==1 and barssince(nz(buybreak[1],1)==1)>Lookback and barssince(nz(sellbreak[1],1)==1)>Lookback
    num_true_criteria := num_true_criteria - 1
    
/////////////////////////////////////////////////////////////////////////////////////////////////////////////////
/////////////////////////////////////////////////////////////////////////////////////////////////////////////////


barcolor(getColor(num_true_criteria))

plot(num_true_criteria, title = "Trend Number", color = getColor(num_true_criteria), style = line, linewidth = 1, transp = 60)
plot(20, title = "Mid Line", color = black, style = line, linewidth = 3, transp = 50)

