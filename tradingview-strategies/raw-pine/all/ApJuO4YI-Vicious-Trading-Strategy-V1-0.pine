atrLen = input(14, minval=1,title="ATR Length")
pctSm= input(25.0,minval=0.01,title="Maximum %ATR size for Body of Small Body Candle (Doji etc)")
pctLg= input(50.0,minval=0.01,title="Mininum %ATR size for Body of Lange Body Candle (Engulfing etc)")
sdc = input(false,title="Show Dark Cloud Cover")
spl = input(false,title="Show Piecing Line")
sdj = input(false,title="Show Doji")
pctDw = input(60,minval=0,maxval=90,title="Doji, Min % of Range of Candle for Wicks")
sengulf = input(false,title="Show Engulfing Candles")
strictEn = input(false,title="Engulfing Candles must Also be Outside Bars")
szBg   = input(1.1,minval=1.1,step=0.01,title="Mininum Size Ratio of Engulfing candle to Previous candle")
ne   = 1 //input(1,minval=1,title="How Many candles need to be Engulfed")
smstar = input(false,title="Show Morning Star and Evening Star")
sestar = smstar
sOvr   = input(false,title="Show Oversize Bars")
szOvr  = input(5.0,minval=2.0,step=0.1,title="Mininum Size Ratio to ATR for Oversize Candle")
sosb = input(false,title="Show Outside Bars")
szOs  = input(1.1,minval=1.1,step=0.01,title="Mininum Size Ratio of Outside Bars to Previous candle")
sisb = input(false,title="Show Inside Bars")
szIs  = input(0.9,minval=0.1,maxval=0.99,step=0.01,title="Maximum Size Ratio of Inside Bars to Previous candle")
ssb = input(false, title="Show Shaved Bars")
spb   = input(false,title="Show Reject Pin Bars")
shmr = input(false,title="Show Hammers (Hanging Man and Shooting Star)")
nc    = input(1,minval=1,maxval=2,title="Number of Confirm Bars for Hammer and Shooting Star (1 or 2)")
pctP = input(66, minval=1, maxval=99, title="PinBar/Hammer, Min % of Range of Candle for Long Wick")
pctS= input(5, minval=0,maxval=95,title="% Candle Range for Shaved Bar")
sname=input(true,title="Show Price Action Bar Names")
cbar = input(true,title="Colour Price Action Bars")
setalm = input(false, title="Show Alert Dot at bottom of chart for Selected PA Candles")

// Constants colours that include fully non-transparent option.
GREEN = #008000FF
LIME  = #00FF00FF
RED   = #FF0000FF
BLUE  = #0000FFFF
DODGERBLUE = #1E90FFFF
AQUA  = #00FFFFFF
DARKRED = #8B0000FF
GRAY = #808080FF
YELLOW = #FFFF00FF
ORANGE = #FFA500FF
FUCHSIA = #FF00FFFF

//
truerange = tr
truerange := truerange<=0 ?close*0.00001: truerange
body = abs(open-close)
bodySz = body/truerange // ratio of body to total candle range
//sma50 = sma(close,50)

// Large and Small candle body sizes relative to ATR(14)
avgtr = atr(atrLen)
cLarge = avgtr*pctLg * 0.01
cSmall = avgtr*pctSm * 0.01
ratio  = truerange/truerange[1]
atrratio = truerange/avgtr

darkCloud=sdc and (close[1]>open[1] and body[1]>cLarge[1] and bodySz[1]>=0.7 and close<open and bodySz>=0.7 
                   and open>=close[1] and close>open[1] and close<((open[1]+close[1])/2))
//plotshape(scndleptrn and darkCloud and sname,title="Dark Cloud Cover",text='DCC',color=red,transp=0, style=shape.arrowdown,location=location.abovebar)

piecingLine=spl and (close[1]<open[1] and body[1]>cLarge[1] and bodySz[1]>=0.7 and close>open and bodySz>=0.7 
                     and open<=close[1] and close<open[1] and close>((open[1]+close[1])/2))
//plotshape(scndleptrn and piecingLine and sname,title="Piercieng Line",text="PL",color=lime,transp=0, style=shape.arrowup,location=location.belowbar)

// Calculate Doji/Harami Candles
pctCDw = (pctDw/2) * 0.01
pctCDb = (100-pctDw) * 0.01
dojiBull=sdj and (open[1]>close[1] and body[1]>cLarge[1] and open[1] >= max(close,open) and close[1]<=min(close,open))
             and (body<=cSmall and bodySz<pctCDb and (high-max(close,open))>(pctCDw*truerange) and (min(close,open)-low)>(pctCDw*truerange))
dojiBear=sdj and (open[1]<close[1] and body[1]>cLarge[1] and close[1] >= max(close,open) and open[1]<=min(close,open))
             and (body<=cSmall and bodySz<pctCDb and (high-max(close,open))>(pctCDw*truerange) and (min(close,open)-low)>(pctCDw*truerange))
//
//plotshape(scndleptrn and dojiBear and sname?high:na,title="Bearish Doji",text='DOJI',color=fuchsia,transp=0, style=shape.arrowdown,location=location.abovebar)
//plotshape(scndleptrn and dojiBear and cbar?max(open,close):na,title="Bear Colour Doji",color=fuchsia,transp=50, style=shape.circle,location=location.absolute,size=size.normal)
//
//plotshape(scndleptrn and dojiBull and sname?high:na,title="Bullish Doji",text='DOJI',color=fuchsia,transp=0, style=shape.arrowup,location=location.belowbar)
//plotshape(scndleptrn and dojiBull and cbar?max(open,close):na,title="Bull Colour Doji",color=fuchsia,transp=50, style=shape.circle,location=location.absolute,size=size.normal)

//Oversize Bars
oversizeBarBu = sOvr and open<close and atrratio>=szOvr
oversizeBarBe = sOvr and open>close and atrratio>=szOvr

//Outside Bars
//plotshape(scndleptrn and oversizeBarBu and sname,title="Oversize Bull Bar",text="OV",color=green,transp=0, style=shape.arrowup,location=location.belowbar)
//plotshape(scndleptrn and oversizeBarBe and sname,title="Oversize Bear Bar",text="OV",color=maroon,transp=0, style=shape.arrowdown,location=location.abovebar)

//
bullishEngulf= sengulf and not oversizeBarBu and not oversizeBarBe and (close[1]<open[1] and close>open and open<=close[1] and close>open[1] and body>=cLarge and ratio>=szBg) and 
               (not strictEn or (low<=low[1] and high>=highest(high,ne+1)))

//plotshape(scndleptrn and bullishEngulf and sname,title="Bullish Engulfing",text='EN',color=lime,transp=0, style=shape.arrowup,location=location.belowbar)

bearishEngulf=sengulf and not oversizeBarBu  and not oversizeBarBe and (close[1]>open[1] and close<open and open>=close[1] and close<open[1] and body>=cLarge and ratio>=szBg) and 
               (not strictEn or (high>=high[1] and low<=lowest(low,ne+1)))
//plotshape(scndleptrn and bearishEngulf and sname,title="Bearish Engulfing",text='EN',color=red,transp=0, style=shape.arrowdown,location=location.abovebar)

//
//Shaved Bars Percentages
pctCs = pctS * 0.01
pctSPO = pctCs

//Shaved Bars
sBarUp = ssb and not bullishEngulf and not oversizeBarBe  and not oversizeBarBu and not piecingLine and body>cLarge and (close >= (high - (truerange * pctCs))) and (open <= (low + (truerange * pctCs)))
sBarDown = ssb and not bearishEngulf and not oversizeBarBu  and not oversizeBarBe and not darkCloud and body>cLarge and (close <= (low + (truerange * pctCs))) and (open >= (high - (truerange * pctCs))) 
//plotshape(scndleptrn and sBarDown and sname,title="Bearish Shaved Bar",text="SB",color=red,transp=0, style=shape.arrowdown,location=location.abovebar)
//plotshape(scndleptrn and sBarUp and sname,title="Bullish Shaved Bar",text="SB",color=lime,transp=0, style=shape.arrowup,location=location.belowbar)

//PBar Percentages
pctCp = pctP * .01

//PinBars Long Upper Shadow represent selling pressure
pBarUp_ = (open<high[1] and close<high[1] and high>high[1]) and (open < (high - (truerange * pctCp)) and close < (high - (truerange * pctCp)))
pBarUp  = spb and pBarUp_
//PinBars with Long Lower Shadow represent buying pressure
pBarDn_ = (open>low[1] and close>low[1] and low<low[1]) and (open > (low + (truerange * pctCp)) and close > (low + (truerange * pctCp)))
pBarDn  = spb and pBarDn_
//
//plotshape(scndleptrn and pBarUp and sname,title="Up Rejection Pin Bar",text='PB',color=red,transp=0, style=shape.arrowdown,location=location.abovebar)
//plotshape(scndleptrn and pBarDn and sname,title="Down Rejection Pin Bar",text='PB',color=lime,transp=0, style=shape.arrowup,location=location.belowbar)

//Inside Bars
insideBar_ = (high<=high[1] and low>=low[1] and ratio<=szIs)
insideBarBu = sisb and insideBar_ and not pBarUp and not pBarDn and open<close
insideBarBe = sisb and insideBar_ and not pBarUp and not pBarDn and open>close
//Outside Bars
outsideBarBu_ = open<close and (high>=high[1] and low<=low[1]) and ratio>=szOs
outsideBarBe_ = open>close and (high>=high[1] and low<=low[1]) and ratio>=szOs
outsideBarBu = sosb and not bullishEngulf and not oversizeBarBu and not oversizeBarBe  and not pBarUp and not pBarDn and outsideBarBu_
outsideBarBe = sosb and not bearishEngulf and not oversizeBarBe and not oversizeBarBu  and not pBarUp and not pBarDn and outsideBarBe_

//Inside Bars
//plotshape(scndleptrn and insideBarBu and sname,title="Bullish Inside Bar",text="IB",color=green, transp=0,style=shape.arrowup,location=location.belowbar)
//plotshape(scndleptrn and insideBarBe and sname,title="Bearish Inside Bar",text="IB",color=maroon, transp=0,style=shape.arrowdown,location=location.abovebar)
//Outside Bars
//plotshape(scndleptrn and outsideBarBe and sname,title="Bearish Outside Bar",text="OB",color=maroon,transp=0, style=shape.arrowdown,location=location.abovebar)
//plotshape(scndleptrn and outsideBarBu and sname,title="Bullish Outside Bar",text="OB",color=green,transp=0, style=shape.arrowup,location=location.belowbar)


//Shooting Star Long Upper Shadow represent selling pressure and confirmed
sstar = shmr? nc==2? (open[4]<open[3] and open[3]<close[3] and close[1]<close[2] and close<close[1] and pBarUp_[2] and body>cSmall) : 
              nc==1? (open[2]<close[2] and close<close[1] and pBarUp_[1] and body>cSmall) : false : false
//Hammer (Hanging Man) with Long Lower Shadow represent buying pressure and confirmed
hmr   = shmr? nc==2? (open[4]>open[3] and open[3]>close[3] and close[1]>close[2] and close>close[1] and pBarDn_[2] and body>cSmall) : 
              nc==1?  (open[2]>close[2] and close>close[1] and pBarDn_[1] and body>cSmall) : false : false

//plotshape(scndleptrn and sstar and sname and nc==1,title="Shooting Star 1",text='SS',color=red,transp=0, offset=-1,style=shape.arrowdown,location=location.abovebar)
//plotshape(scndleptrn and hmr and sname and nc==1,title="Hammer (Hanging Man) 1",text='HM',color=lime,transp=0,offset=-1, style=shape.arrowup,location=location.belowbar)
//plotshape(scndleptrn and sstar and sname and nc==2,title="Shooting Star 2",text='SS',color=red,transp=0, offset=-2,style=shape.arrowdown,location=location.abovebar)
//plotshape(scndleptrn and hmr and sname and nc==2,title="Hammer (Hanging Man) 2",text='HM',color=lime,transp=0,offset=-2, style=shape.arrowup,location=location.belowbar)

// Evening and morning Star patterns.
estar  = sestar and (close[2] > open[2] and min(open[1],close[1])>=close[2] and close[2]>=high[3] 
                     and close < open and body[1]<=cSmall and close<(close[2]+open[2])/2 and body[2]>cLarge[2])

//plotshape(scndleptrn and estar, title= "Evening Star", color=red,transp=0, style=shape.arrowdown, text="ES",offset=-1)

mstar  = smstar and (close[2] < open[2] and max(open[1],close[1])<=close[2] and close[2]<=low[3]
                     and close > open and body[1]<=cSmall and close>(close[2]+open[2])/2 and body[2]>cLarge[2])
//plotshape(scndleptrn and mstar,  title= "Morning Star", location=location.belowbar, color=lime,transp=0, style=shape.arrowup, text="MS",offset=-1)


bcolor = dojiBull or dojiBear? FUCHSIA : 
         insideBarBe or insideBarBu? ORANGE : 
         (sstar or pBarUp or bearishEngulf or darkCloud or outsideBarBe or estar or oversizeBarBe)? YELLOW : 
         (hmr or pBarDn or bullishEngulf or piecingLine or outsideBarBu or mstar or oversizeBarBu)? AQUA :  
         sBarUp ? DODGERBLUE : 
         sBarDown ? BLUE : na
//
//barcolor(scndleptrn and cbar?bcolor:na,title="Bar Colouring")

