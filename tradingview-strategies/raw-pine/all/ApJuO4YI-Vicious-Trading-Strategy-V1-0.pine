spacing1 = input(false, title="_____________________________________________________________")
//Moving Averages
sumalin = input(false, title="Show Multi Moving Average?____________________________________")

//Created by user ChrisMoody 4-24-2014
//Plots The Majority of Moving Averages
//Defaults to Current Chart Time Frame --- But Can Be Changed to Higher Or Lower Time Frames
//2nd MA Capability with Show Crosses Feature
//study(title="CM_Ultimate_MA_MTF", shorttitle="CM_Ultimate_MA_MTF", overlay=true)
//inputs
//src = close
useCurrentRes = input(true, title="Use Current Chart Resolution?")
resCustom = input(title="Use Different Timeframe? Uncheck Box Above", type=resolution, defval="D")
len = input(6, title="Moving Average Length - LookBack Period")
atype = input(1,minval=1,maxval=7,title="1=SMA, 2=EMA, 3=WMA, 4=HullMA, 5=VWMA, 6=RMA, 7=TEMA")
cc = input(true,title="Change Color Based On Direction?")
smoothe = input(2, minval=1, maxval=10, title="Color Smoothing - 1 = No Smoothing")
doma2 = input(false, title="Optional 2nd Moving Average")
len2 = input(20, title="Moving Average Length - Optional 2nd MA")
atype2 = input(1,minval=1,maxval=7,title="1=SMA, 2=EMA, 3=WMA, 4=HullMA, 5=VWMA, 6=RMA, 7=TEMA")
cc2 = input(true,title="Change Color Based On Direction 2nd MA?")
warn = input(false, title="***You Can Turn On The Show Dots Parameter Below Without Plotting 2nd MA to See Crosses***")
warn2 = input(false, title="***If Using Cross Feature W/O Plotting 2ndMA - Make Sure 2ndMA Parameters are Set Correctly***")
sd = input(false, title="Show Dots on Cross of Both MA's")
//Added Code
doma3 = input(false, title="Optional 3rd Moving Average")
len3 = input(50, title="Moving Average Length - Optional 3rd MA")
atype3 = input(1,minval=1,maxval=7,title="1=SMA, 2=EMA, 3=WMA, 4=HullMA, 5=VWMA, 6=RMA, 7=TEMA")
cc3 = input(true,title="Change Color Based On Direction 3rd MA?")
//
doma4 = input(false, title="Optional 4th Moving Average")
len4 = input(100, title="Moving Average Length - Optional 4th MA")
atype4 = input(1,minval=1,maxval=7,title="1=SMA, 2=EMA, 3=WMA, 4=HullMA, 5=VWMA, 6=RMA, 7=TEMA")
cc4 = input(true,title="Change Color Based On Direction 4th MA?")
//////


res = useCurrentRes ? period : resCustom
//hull ma definition
hullma = wma(2*wma(src, len/2)-wma(src, len), round(sqrt(len)))
//
n2ma=2*wma(src,round(len/2))
nma=wma(src,len)
diff=n2ma-nma
sqn=round(sqrt(len))
n2ma1=2*wma(src[1],round(len/2))
nma1=wma(src[1],len)
diff1=n2ma1-nma1
sqn1=round(sqrt(len))
n1=wma(diff,sqn)
n2=wma(diff1,sqn)
//c=n1>n2?green:red
//ma= plot(shmalin and n1 ? n1 : na,title = "HULL MA", linewidth=3, color=c)


//TEMA definition
ema1 = ema(src, len)
ema2 = ema(ema1, len)
ema3 = ema(ema2, len)
tema = 3 * (ema1 - ema2) + ema3

avg = atype == 1 ? sma(src,len) : atype == 2 ? ema(src,len) : atype == 3 ? wma(src,len) : atype == 4 ? hullma : atype == 5 ? vwma(src, len) : atype == 6 ? rma(src,len) : tema
//2nd Ma - hull ma definition
hullma2 = wma(2*wma(src, len2/2)-wma(src, len2), round(sqrt(len2)))
//2nd MA TEMA definition
sema1a = ema(src, len2)
sema2a = ema(sema1a, len2)
sema3a = ema(sema2a, len2)
stemaa = 3 * (sema1a - sema2a) + sema3a

avg2 = atype2 == 1 ? sma(src,len2) : atype2 == 2 ? ema(src,len2) : atype2 == 3 ? wma(src,len2) : atype2 == 4 ? hullma2 : atype2 == 5 ? vwma(src, len2) : atype2 == 6 ? rma(src,len2) : tema
//Added Code for 3rd and 4th//
//3rd Ma - hull ma definition
hullma3 = wma(2*wma(src, len3/2)-wma(src, len3), round(sqrt(len3)))
//3rd MA TEMA definition
sema1b = ema(src, len3)
sema2b = ema(sema1b, len3)
sema3b = ema(sema2b, len3)
stemab = 3 * (sema1b - sema2b) + sema3b

avg3 = atype3 == 1 ? sma(src,len3) : atype3 == 2 ? ema(src,len3) : atype3 == 3 ? wma(src,len3) : atype3 == 4 ? hullma3 : atype3 == 5 ? vwma(src, len3) : atype3 == 6 ? rma(src,len3) : tema
//
//4th Ma - hull ma definition
hullma4 = wma(2*wma(src, len4/2)-wma(src, len4), round(sqrt(len4)))
//4th MA TEMA definition
sema1c = ema(src, len4)
sema2c = ema(sema1c, len4)
sema3c = ema(sema2c, len4)
stemac = 3 * (sema1c - sema2c) + sema3c

avg4 = atype4 == 1 ? sma(src,len4) : atype4 == 2 ? ema(src,len4) : atype4 == 3 ? wma(src,len4) : atype4 == 4 ? hullma4 : atype4 == 5 ? vwma(src, len4) : atype4 == 6 ? rma(src,len4) : tema

out = avg 
out_two = avg2
//
out_three = avg3
out_four = avg4
//

out1 = security(tickerid, res, out)
out2 = security(tickerid, res, out_two)
//
out3 = security(tickerid, res, out_three)
out4 = security(tickerid, res, out_four)
//

ma_up = out1 >= out1[smoothe]
ma_down = out1 < out1[smoothe]

ma_up2 = out2 >= out2[smoothe]
ma_down2 = out2 < out2[smoothe]
//
ma_up3 = out3 >= out3[smoothe]
ma_down3 = out3 < out3[smoothe]

ma_up4 = out4 >= out4[smoothe]
ma_down4 = out4 < out4[smoothe]


col = n1>n2 ? cc ? ma_up ? lime : ma_down ? red : aqua : aqua : aqua
col2 = n1>n2 ? cc2 ? ma_up2 ? lime : ma_down2 ? red : aqua : aqua : aqua
//
col3 = n1>n2 ? cc3 ? ma_up3 ? lime : ma_down3 ? red : aqua : aqua : aqua
col4 = n1>n2 ? cc4 ? ma_up4 ? lime : ma_down4 ? red : aqua : aqua : aqua
//
//c=n1>n2?green:red
//

circleYPosition = out2

//plot(sumalin and out1 ? out1 : na, title="Multi-Timeframe Moving Avg", style=line, linewidth=4, color = col)
//plot(sumalin and doma2 and out2 ? out2 : na, title="2nd Multi-TimeFrame Moving Average", style=line, linewidth=4, color=col2)
//
//plot(sumalin and doma3 and out3 ? out3 : na, title="3rd Multi-TimeFrame Moving Average", style=circles, linewidth=4, color=col3)
//plot(sumalin and doma4 and out4 ? out4 : na, title="4th Multi-TimeFrame Moving Average", style=circles, linewidth=4, color=col4)
//
//plot(sd and cross(out1, out2) or sd and cross(out1, out3) or sd and cross(out1, out4) or sd and cross(out2, out3) or sd and cross(out2, out4) or sd and cross(out3, out4)? circleYPosition : na,style=cross, linewidth=5, color=yellow)

// Fast MA Vs Slow MA
sfma = input(false, title="Show FastMA?")
sslma = input(false, title="Show SlowMA?")
//
fastPer = input(7, minval=1,title="Fast MM")
slowPer = input(20,minval=1,title="Slow MM")


fastMM = sma(src, fastPer) 
slowMM = sma(src, slowPer)
 
//ma1=plot(sfma and fastMM ? fastMM : na ,color=rising(fastMM,2)?green:red,linewidth=2,transp=20,title="Fast MM")
//ma2=plot(sslma and slowMM ? slowMM : na ,color=rising(slowMM,2)?#F705F9:blue,linewidth=2,transp=20,title="Slow MM")
//



//Bollinger Bands
spacing2 = input(false, title="_____________________________________________________________")
sbblin = input(false, title="Show Bollinger Bands?")
//
length = input(20, minval=1)
//src = input(close, title="Source")
mult = input(2.0, minval=0.001, maxval=50)
basis = sma(src, length)
dev = mult * stdev(src, length)
upperbb = basis + dev
lowerbb = basis - dev
//p1 = plot(sbblin and upperbb ? upperbb : na, title = "BB_UPPER",  color=black, linewidth=3)
//p2 = plot(sbblin and lowerbb ? lowerbb : na, title = "BB_LOWER", color=black, linewidth=3)
//fill(p1, p2)
//

// Parabolic SAR
spacing3 = input(false, title="_____________________________________________________________")
sus = input(false, "Show Up Trending Parabolic Sar")
sds = input(false, "Show Down Trending Parabolic Sar")
//
start = input(2, minval=0, maxval=10, title="Start - Default = 2 - Multiplied by .01")
increment = input(2, minval=0, maxval=10, title="Step Setting (Sensitivity) - Default = 2 - Multiplied by .01" )
maximum = input(2, minval=1, maxval=10, title="Maximum Step (Sensitivity) - Default = 2 - Multiplied by .10")
disc = input(false, title="Start and Step settings are *.01 so 2 = .02 etc, Maximum Step is *.10 so 2 = .2")
startCalc = start * .01
incrementCalc = increment * .01
maximumCalc = maximum * .10
sarUp = sar(startCalc, incrementCalc, maximumCalc)
sarDown = sar(startCalc, incrementCalc, maximumCalc)
colUp = close >= sarDown ? lime : na
colDown = close <= sarUp ? red : na
//plot(sus and sarUp ? sarUp : na, title="Up Trending SAR", style=circles, linewidth=3,color=colUp)
//plot(sds and sarDown ? sarDown : na, title="Up Trending SAR", style=circles, linewidth=3,color=colDown)


//SUPER TREND
spacing4 = input(false, title="_____________________________________________________________")
sstrnd = input(false, title="Show Supertrend?")
//
STFactor=input(3, minval=1,maxval = 100)
STPd=input(7, minval=1,maxval = 100)

STUp=hl2-(STFactor*atr(STPd))
STDn=hl2+(STFactor*atr(STPd))
STrendUp=0.0
STrendUp:=close[1]>STrendUp[1]? max(STUp,STrendUp[1]) : STUp

STrendDown=0.0
STrendDown:=close[1]<STrendDown[1]? min(STDn,STrendDown[1]) : STDn

STrend=0.0
STrend:= close > STrendDown[1] ? 1: close< STrendUp[1]? -1: nz(STrend[1],1)
STsl = STrend==1? STrendUp: STrendDown

linecolor = STrend == 1 ? green : red

//plot(sstrnd and STsl ? STsl : na , color = linecolor , style = line , linewidth = 3,title = "SuperTrend")

//plotshape(sstrnd and cross(close,STsl) and close>STsl ? cross(close,STsl) and close>STsl : na, "Up Arrow", shape.triangleup,location.belowbar,green,0,0)
//plotshape(sstrnd and cross(STsl,close) and close<STsl ? cross(STsl,close) and close<STsl : na, "Down Arrow", shape.triangledown , location.abovebar, red,0,0)

//plotarrow(sstrnd and STrend == 1 and STrend[1] == -1 ? STrend : na, title="Up Entry Arrow", colorup=lime, maxheight=60, minheight=50, transp=0)
//plotarrow(sstrnd and STrend == -1 and STrend[1] == 1 ? STrend : na, title="Down Entry Arrow", colordown=red, maxheight=60, minheight=50, transp=0)

STgolong =  STrend == 1 and STrend[1] == -1
//alertcondition(sstrnd and STgolong ? STgolong : na, title='Long', message='SuperTrend V.1 Alert Long')
STgoshort =   STrend == -1 and STrend[1] == 1
//alertcondition(sstrnd and STgoshort ? STgoshort : na , title='Short', message='SuperTrend V.1 Alert Short')

//Doji signals
Precision = input(0.15, minval=0.0001, title="Doji's Max Body size")
//

//Trend Trader Strategy
spacing5 = input(false, title="_____________________________________________________________")
sttstrat = input(false, title="Show Trend Trader Strategy?")
//
Length = input(21, minval=1),
Multiplier = input(3, minval=1)
avgTR      = wma(atr(1), Length)
highestC   = highest(Length)
lowestC    = lowest(Length)
hiLimit = highestC[1]-(avgTR[1] * Multiplier)
loLimit = lowestC[1]+(avgTR[1] * Multiplier)
ret=0.0
ret := iff(close > hiLimit and close > loLimit, hiLimit, iff(close < loLimit and close < hiLimit, loLimit, nz(ret[1], 0)))
pos=0.0
pos :=    iff(close > ret, 1, iff(close < ret, -1, nz(pos[1], 0))) 
//plot(sttstrat and ret ? ret : na , color= black, linewidth=2,title="Trend Trader Strategy")
//

//
spacing6 = input(false, title="_____________________________________________________________")
sichmku = input(false, title="Show Ichimoku?")
//
conversionPeriods = input(9, minval=1, title="Conversion Line Periods"),
basePeriods = input(26, minval=1, title="Base Line Periods")
laggingSpan2Periods = input(52, minval=1, title="Lagging Span 2 Periods"),
displacement = input(26, minval=1, title="Displacement")

donchian(len) => avg(lowest(len), highest(len))

conversionLine = donchian(conversionPeriods)
baseLine = donchian(basePeriods)
leadLine1 = avg(conversionLine, baseLine)
leadLine2 = donchian(laggingSpan2Periods)

//plot(sichmku and conversionLine ? conversionLine : na , color=#0496ff, title="Conversion Line")
//plot(sichmku and baseLine ? baseLine : na , color=#991515, title="Base Line")
//plot(sichmku and close ? close : na , offset = -displacement, color=#459915, title="Lagging Span")

//p12 = plot(sichmku and leadLine1 ? leadLine1 : na , offset = displacement, color=green, title="Lead 1")
//p22 = plot(sichmku and leadLine2 ? leadLine2 : na , offset = displacement, color=red, title="Lead 2")
//fill(p12, p22, color = leadLine1 > leadLine2 ? green : red)
//

//// Basic Definitions ////
range = high - low
//MovAvg's Code
sma5 = sma(close,5)
sma200= sma(close, 200)

//
//EMA Definitions
emaSlow = ema(close, 62)
emaFast = ema(close, 38)

//RSI Definitions
rsiup = rma(max(change(src), 0), 2)
rsidown = rma(-min(change(src), 0), 2)
rsi = rsidown == 0 ? 100 : rsiup == 0 ? 0 : 100 - (100 / (1 + rsiup / rsidown))
//Criteria for Moving Avg rules
rsima5 = sma(close,5)
rsima200= sma(close, 200)

//Slingshot Section//////
spacing7 = input(false, title="_____________________________________________________________")
//Moving Average Plots and Fill
smasslin = input(false, title="Show Sling Shot?")
sae = input(false, title="Show Aggressive Entry?, Or Use as Alert To Potential Conservative Entry?")
sce = input(false, title="Show Conservative Entry?")
st = input(false, title="Show Trend Arrows at Top and Bottom of Screen?")
def = input(false, title="Only Choose 1 - Either Conservative Entry Arrows or 'B'-'S' Letters")
pa = input(false, title="Show Conservative Entry Arrows?")
sl = input(false, title="Show 'B'-'S' Letters?")


//RSI Section//////
rsitrnd = input(false, title="Show RSI Trends?")


RSIUptrend() => rsitrnd and emaFast > emaSlow and close > rsima200 and close < rsima5 and rsi < 10 
RSIDowntrend() => rsitrnd and close < rsima200 and close > rsima5 and rsi > 90 and emaFast < emaSlow

RSIUptrendS = emaFast > emaSlow and close > rsima200 and close < rsima5 and rsi < 10 
RSIDowntrendS = close < rsima200 and close > rsima5 and rsi > 90 and emaFast < emaSlow


// RSI+ Overbought/Sold Indicator v2.0
spacing8 = input(false, title="_____________________________________________________________")
rsiLength = input(14, title="RSI Length:", type=integer, minval=1)
rsiOverbought = input(70, title="RSI Overbought:", type=integer, minval=1)
rsiOversold = input(30, title="RSI Oversold:", type=integer, minval=1)
drawOnRT = input(title="Draw On Candles Yet To Close:", type=bool, defval=true)
rsi2 = rsi(close, rsiLength)
// Check to see if RSI has crossed our threshold
rsiOB = rsi2 >= rsiOverbought
rsiOS = rsi2 <= rsiOversold
// Plot signals and trigger any alerts
//plotshape(rsiOS and (barstate.ishistory or drawOnRT), title= "Oversold", location=location.belowbar, color=red, transp=0, style=shape.arrowup, text="")
//plotshape(rsiOB and (barstate.ishistory or drawOnRT),  title= "Overbought", color=red, transp=0, style=shape.arrowdown, text="")
//alertcondition(rsiOB or rsiOS, title="RSI+ Alert!", message="RSI Alert for ")
