//MTFchannelLower = plot(MTFcheck ? MTFbasisDevMult(-MTFsigmaMultiply) : na, transp = 100, editable = false)
//fill(MTFchannelUpper, MTFchannelLower, color=silver, transp=80, title="Higher Reference Trend Tollerance Channel")
// - END PLOTTING    
//

////////////////////////////
//Parabolic SAR//
///////////////////////////

//
if sarUp
    num_true_criteria := num_true_criteria + 1
    

//


///////////////////////////////
//SuperTrend//
//////////////////////////////

//
if cross(close,STsl) and close>STsl 
    num_true_criteria := num_true_criteria + 1

if STrend == 1 and STrend[1] == -1
    num_true_criteria := num_true_criteria + 2


//
////////////////////////////////
//Trend Trader//
/////////////////////////////////

//
if pos == 1 
    num_true_criteria := num_true_criteria + 1

//

/////////////////////////////////
//Ichimoku//
////////////////////////////////

//
if leadLine1 > leadLine2
    num_true_criteria := num_true_criteria + 1
//

//////////////////////////////
//RSI Trends//
/////////////////////////////

if emaFast > emaSlow and close > rsima200 and close < rsima5 and rsi < 10 
    num_true_criteria := num_true_criteria + 1

if emaFast > emaSlow and close > out4 and close < out1 and rsi < 10 
    num_true_criteria := num_true_criteria + 1
    
if emaFast > emaSlow and close > out4 and close < out1 and rsi < 20 
    num_true_criteria := num_true_criteria + 1
    
if rsiOS and (barstate.ishistory or drawOnRT)
    num_true_criteria := num_true_criteria + 1

    
//

//////////////////////////////
//Slingshot//
/////////////////////////////

//

if emaFast > emaSlow and close < emaFast
    num_true_criteria := num_true_criteria + 1
    
if emaFast > emaSlow and close[1] < emaFast and close > emaFast
    num_true_criteria := num_true_criteria + 1
    
if emaFast >= emaSlow
    num_true_criteria := num_true_criteria + 1
    
if emaFast > emaSlow and close > rsima200 and close < rsima5 and rsi < 10
    num_true_criteria := num_true_criteria + 1
//


/////////////////////////////////////////

//
if upTrend 
    num_true_criteria := num_true_criteria + 1
    
if codiff 
    num_true_criteria := num_true_criteria + 1

//


//////////////////////////////////////////////////////
//Super Guppy//
/////////////////////////////////////////////////////

//

if buy==1 and barssince(nz(buy[1],1)==1)>Lookback
    num_true_criteria := num_true_criteria + 1
    
if buybreak==1 and barssince(nz(sellbreak[1],1)==1)>Lookback and barssince(nz(buybreak[1],1)==1)>Lookback
    num_true_criteria := num_true_criteria + 1
    
    
//

///////////////////////////////////////////////////////////////////////////////////////////////
    
/////////////////////////////////////////

//////////////////////////////////////
//MACD//
////////////////////////////

if MACD >0
    num_true_criteria := num_true_criteria + 1
    
if crossover(MACD,0)
    num_true_criteria := num_true_criteria + 1
    
if dm>dm[1]
    num_true_criteria := num_true_criteria + 1
    
//


if ema5 > ema20
    num_true_criteria := num_true_criteria + 1
    

    
if rsi >50
    num_true_criteria := num_true_criteria + 1

if close > sma200 and close < sma5 and rsi < 10
    num_true_criteria := num_true_criteria + 1
    
if close < sma200 and close[1] > sma5[1] and low < sma5 and ((close[1] < sma200[1] and close[1] > sma5[1] and rsi[1] > 90) or (close[2] < sma200[2] and close[2] > sma5[2] and rsi[2] > 90) or (close[3] < sma200[3] and close[3] > sma5[3] and rsi[3] > 90) or (close[4] < sma200[4] and close[4] > sma5[4] and rsi[4] > 90) )
    num_true_criteria := num_true_criteria + 1
        
    
if open > open[1]
    num_true_criteria := num_true_criteria + 1

if high > sma(low, 4)
    num_true_criteria := num_true_criteria + 1

if high[1] - low[1] > 100
    num_true_criteria := num_true_criteria + 1

if n % 2 == 0
    num_true_criteria := num_true_criteria + 1
    
