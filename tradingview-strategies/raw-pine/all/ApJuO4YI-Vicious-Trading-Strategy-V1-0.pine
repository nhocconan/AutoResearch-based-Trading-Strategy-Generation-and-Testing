// === INPUT BACKTEST RANGE ===
FromMonth = input(defval = 1, title = "From Month", minval = 1, maxval = 12)
FromDay   = input(defval = 1, title = "From Day", minval = 1, maxval = 31)
FromYear  = input(defval = 2010, title = "From Year", minval = 1980)
ToMonth   = input(defval = 1, title = "To Month", minval = 1, maxval = 12)
ToDay     = input(defval = 1, title = "To Day", minval = 1, maxval = 31)
ToYear    = input(defval = 9999, title = "To Year", minval = 1980)

// === FUNCTION EXAMPLE ===
Tstart     = timestamp(FromYear, FromMonth, FromDay, 00, 00)  // backtest start window
Tfinish    = timestamp(ToYear, ToMonth, ToDay, 23, 59)        // backtest finish window
window()  => time >= Tstart and time <= Tfinish ? true : false // create function "within window of time"

// === SERIES SETUP ===
//buy  = crossover(sma(close, fastMA), sma(close, slowMA))     // buy when fastMA crosses over slowMA
//sell = crossunder(sma(close, fastMA), sma(close, slowMA))    // sell when fastMA crosses under slowMA

// === EXECUTION ===
//strategy.entry("L", strategy.long, when = window() and buy)  // buy long when "within window of time" AND crossover
//strategy.close("L", when = window() and sell)                // sell long when "within window of time" AND crossunder         



///////////////////////////////////




longCondition = crossover(num_true_criteria, 24) or crossover(num_true_criteria, 28) or  crossover(num_true_criteria, ema(num_true_criteria,15)) or STgolong or trendUpStart() or buyZoneEnter() //or upTrend //or RSIUptrendS 
//if (longCondition)
strategy.entry("Vicious Overall Long Entry", strategy.long, when = window() and longCondition )
strategy.close("Vicious Overall Long Entry", when = window() and crossunder(num_true_criteria, 20) or STgoshort or RSIDowntrendS or sellZoneEnter() ) //or crossunder(num_true_criteria, sma(num_true_criteria,5) ) )

shortCondition = STgolong == true ? na : trendUpStart()== true ? na : buyZoneEnter()== true ? na : upTrend== true ? na : RSIUptrendS == true ? na : num_true_criteria < 20 and crossunder(num_true_criteria, 19) or STgoshort or trendDownStart() or sellZoneEnter() //or RSIDowntrendS or downTrend
//if (shortCondition)
strategy.entry("Vicious Overall Short", strategy.short, when = window() and shortCondition )
strategy.close("Vicious Overall Short", when = window() and crossover(num_true_criteria, 19) or STgolong or trendUpStart() or buyZoneEnter() or upTrend or RSIUptrendS or  crossover(num_true_criteria, ema(num_true_criteria,15)) ) //or crossover(num_true_criteria, sma(num_true_criteria,5) ) )

