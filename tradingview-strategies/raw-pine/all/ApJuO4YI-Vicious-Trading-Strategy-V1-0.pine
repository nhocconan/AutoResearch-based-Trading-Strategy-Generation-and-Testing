//Color Gradient Definition//

////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

BRIGHT_GREEN = #00FF08  // hex color. For more gradient could be used more colors
DARK_GREEN = #14FF00
MED_DARK_GREEN = #32FF00
MED_GREEN = #4FFF00
MED_LIGHT_GREEN = #6DFF00
LIGHT_GREEN = #8AFF00
WEAK_GREEN = #A8FF00

//

BRIGHT_YELLOW = #C6FF00
MED_YELLOW = #FFFC00
ORANGE_YELLOW = #FFDF00
MED_ORANGE = #FFC100
BRIGHT_ORANGE = #FFA400

//

WEAK_RED = #FF8600
LIGHT_RED = #FF6800
MED_LIGHT_RED = #FF4B00
MED_RED = #FF2D00
MED_DARK_RED = #FF1000
DARK_RED = #FF000D
BRIGHT_RED = #FF002A


//
//GreenShade(value) =>
    //value >= 75 ? #00b300 : // dark green
     //value > 50 ? #00cc00 :
     //value > 30 ? #00e600 :
     //value > 20 ? #00ff00 : // green
     //value > 15 ? #1aff1a :
     //value > 10 ? #33ff33 :
        //#4dff4d             // light green

//RedShade(value) =>
    //value >= 75 ? #b30000 : // dark red
     //value > 50 ? #cc0000 :
     //value > 30 ? #e60000 :
     //value > 20 ? #ff0000 : // red
     //value > 15 ? #ff1a1a :
     //value > 10 ? #ff3333 :
        //#ff4d4d             // light red



getColor(num_criteria) =>
  num_criteria >= 36 ? BRIGHT_GREEN :
  num_criteria >= 34 ? DARK_GREEN :
  num_criteria >= 32 ? MED_DARK_GREEN :
  num_criteria >= 30 ? MED_GREEN :
  num_criteria >= 28 ? MED_LIGHT_GREEN :
  num_criteria >= 26 ? LIGHT_GREEN :
  num_criteria >= 24 ? WEAK_GREEN :
  num_criteria >= 22 ? BRIGHT_YELLOW :
  num_criteria >= 20 ? MED_YELLOW :
  num_criteria >= 18 ? ORANGE_YELLOW :
  num_criteria >= 16 ? MED_ORANGE :
  num_criteria >= 14 ? BRIGHT_ORANGE :
  num_criteria >= 12 ? WEAK_RED :
  num_criteria >= 10 ? LIGHT_RED :
  num_criteria >= 8 ? MED_LIGHT_RED :
  num_criteria >= 6 ? MED_RED :
  num_criteria >= 4 ? MED_DARK_RED :
  num_criteria >= 2 ? DARK_RED :
  BRIGHT_RED


//////////////////////////////////////////////////////////////////
//Positive Factors


num_true_criteria = 16



//////////////////////////////
//Candles and Pattern//
/////////////////////////////


if (close[1]<open[1] and body[1]>cLarge[1] and bodySz[1]>=0.7 and close>open and bodySz>=0.7 and open<=close[1] and close<open[1] and close>((open[1]+close[1])/2))
    num_true_criteria := num_true_criteria + 1
    
if (open[1]>close[1] and body[1]>cLarge[1] and open[1] >= max(close,open) and close[1]<=min(close,open)) and (body<=cSmall and bodySz<pctCDb and (high-max(close,open))>(pctCDw*truerange) and (min(close,open)-low)>(pctCDw*truerange))
    num_true_criteria := num_true_criteria + 1
    
if open<close and atrratio>=szOvr
    num_true_criteria := num_true_criteria + 1
   
if not oversizeBarBu and not oversizeBarBe and (close[1]<open[1] and close>open and open<=close[1] and close>open[1] and body>=cLarge and ratio>=szBg) and (not strictEn or (low<=low[1] and high>=highest(high,ne+1))) 
    num_true_criteria := num_true_criteria + 1
    
if not bullishEngulf and not oversizeBarBe  and not oversizeBarBu and not piecingLine and body>cLarge and (close >= (high - (truerange * pctCs))) and (open <= (low + (truerange * pctCs)))
    num_true_criteria := num_true_criteria + 1
    
if (open<high[1] and close<high[1] and high>high[1]) and (open < (high - (truerange * pctCp)) and close < (high - (truerange * pctCp)))
    num_true_criteria := num_true_criteria + 1
    
if insideBar_ and not pBarUp and not pBarDn and open<close
    num_true_criteria := num_true_criteria + 1
  
if not bullishEngulf and not oversizeBarBu and not oversizeBarBe  and not pBarUp and not pBarDn and outsideBarBu_
    num_true_criteria := num_true_criteria + 1
    
if nc==2? (open[4]>open[3] and open[3]>close[3] and close[1]>close[2] and close>close[1] and pBarDn_[2] and body>cSmall) : nc==1?  (open[2]>close[2] and close>close[1] and pBarDn_[1] and body>cSmall) : false
    num_true_criteria := num_true_criteria + 1

if (close[2] < open[2] and max(open[1],close[1])<=close[2] and close[2]<=low[3] and close > open and body[1]<=cSmall and close>(close[2]+open[2])/2 and body[2]>cLarge[2]) 
    num_true_criteria := num_true_criteria + 1

if (open[1] > close[1] and close > open and close <= open[1] and close[1] <= open and close - open < open[1] - close[1] and open[trend] > open)
    num_true_criteria := num_true_criteria + 1
//plotshape(scndleptrn and data7 ? data7 : na ,  title= "Bullish Harami", location=location.belowbar, color=lime, style=shape.arrowup, text="Bullish\nHarami")

if (open[1] > close[1] and close > open and close >= open[1] and close[1] >= open and close - open > open[1] - close[1] and open[trend] > open)
    num_true_criteria := num_true_criteria + 1
//plotshape(scndleptrn and data9 ? data9 : na , title= "Bullish Engulfing", location=location.belowbar, color=lime, style=shape.arrowup, text="Bullish\nEngulfling")

//upper = highest(10)[1]
if (close[1] < open[1] and  open < low[1] and close > close[1] + ((open[1] - close[1])/2) and close < open[1] and open[trend] > open)
    num_true_criteria := num_true_criteria + 1
//plotshape(scndleptrn and data10 ? data10 : na , title= "Piercing Line", location=location.belowbar, color=lime, style=shape.arrowup, text="Piercing\nLine")

//lower = lowest(10)[1]
if (low == open and  open < lower and open < close and close > ((high[1] - low[1]) / 2) + low[1] and open[trend] > open)
    num_true_criteria := num_true_criteria + 1
//plotshape(scndleptrn and data11 ? data11 : na , title= "Bullish Belt", location=location.belowbar, color=lime, style=shape.arrowup, text="Bullish\nBelt")

if (open[1]>close[1] and open>=open[1] and close>open and open[trend] > open)
    num_true_criteria := num_true_criteria + 1
//plotshape(scndleptrn and data12 ? data12 : na , title= "Bullish Kicker", location=location.belowbar, color=lime, style=shape.arrowup, text="Bullish\nKicker")


/////////////////////////////
//Moving Averages//
////////////////////////////

//
if n1>n2
    num_true_criteria := num_true_criteria + 1

if n1>n2 and ma_up 
    num_true_criteria := num_true_criteria + 1
    
if n1>n2 and ma_up2 
    num_true_criteria := num_true_criteria + 1
    
if n1>n2 and ma_up3 
    num_true_criteria := num_true_criteria + 1
    
if n1>n2 and ma_up4 
    num_true_criteria := num_true_criteria + 1
    
    
///////////////////////////////////
//Moving Average Crosses//
///////////////////////////////////

if crossover(out1, out2)
    num_true_criteria := num_true_criteria + 1

if crossover(out1, out3) 
    num_true_criteria := num_true_criteria + 1

if crossover(out1, out4) 
    num_true_criteria := num_true_criteria + 1

if crossover(out2, out3) 
    num_true_criteria := num_true_criteria + 1

if crossover(out2, out4) 
    num_true_criteria := num_true_criteria + 1

if crossover(out3, out4)
    num_true_criteria := num_true_criteria + 1


//

////////////////////////////
//Bollinger Bands//
///////////////////////////

//

if close <= lowerbb
    num_true_criteria := num_true_criteria + 1
    
    
if buyZoneEnter()
    num_true_criteria := num_true_criteria + 1
    
if trendUpStart()
    num_true_criteria := num_true_criteria + 1



// sigma tollerance bands
//plot(basisDevMult(sigmaMultiply),   title = "Trend Tollerance Upper Band", color = #BBFFDD, style = circles, linewidth = 1, transp = 20)
//plot(basisDevMult(-sigmaMultiply),  title = "Trend Tollerance Lower Band", color = #BBFFDD, style = circles, linewidth = 1, transp = 20)
// percentile deviation bands
//plot(basisDevMult(0.5),     title = "50% Deviation Upper Band", color = #009999, style = line, linewidth = 1, transp = 60)
//plot(basisDevMult(-0.5),    title = "50% Deviation Lower Band", color = #009999, style = line, linewidth = 1, transp = 60)
//plot(basisDevMult(1),       title = "Base Deviation Upper Band", color = #00BBBB, style = line, linewidth = 1, transp = 60)
//plot(basisDevMult(-1),      title = "Base Deviation Lower Band", color = #00BBBB, style = line, linewidth = 1, transp = 60)
//plot(basisDevMult(1.5),     title = "150% Deviation Upper Band", color = #00DDDD, style = line, linewidth = 1, transp = 60)
//plot(basisDevMult(-1.5),    title = "150% Deviation Lower Band", color = #00DDDD, style = line, linewidth = 1, transp = 60)
//plot(basisDevMult(2),       title = "200% Deviation Upper Band", color = #00FFFF, style = line, linewidth = 1, transp = 60)
//plot(basisDevMult(-2),      title = "200% Deviation Lower Band", color = #00FFFF, style = line, linewidth = 1, transp = 60)
// higher resolution extreme bands visual
//plot(MTFcheck ? MTFbasisDevMult(2) : na,    title = "Higher Reference 200% Upper Band", color = silver, style = circles, linewidth = 1, transp = 50)
//plot(MTFcheck ? MTFbasisDevMult(-2) : na,   title = "Higher Reference 200% Lower Band", color = silver, style = circles, linewidth = 1, transp = 50)
