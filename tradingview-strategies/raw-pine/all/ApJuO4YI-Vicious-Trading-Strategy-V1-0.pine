//@version=3
strategy("Vicious Trading Strategy V1.0", shorttitle="Vicious Strat V1.0", overlay=true)

// @version=3
//study("Vicious Trading Suite Trend Number V4", shorttitle="Vicious Trend Number", overlay = true)
