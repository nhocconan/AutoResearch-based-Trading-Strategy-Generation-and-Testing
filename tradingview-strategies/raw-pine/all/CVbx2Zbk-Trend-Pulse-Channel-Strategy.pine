//@version=6
strategy("Trend Pulse Channel Strategy", overlay=true,
     initial_capital=10000, default_qty_type=strategy.percent_of_equity,
     default_qty_value=10,
     commission_type=strategy.commission.percent,
     commission_value=0.1, slippage=1, margin_long=0, margin_short=0,
     fill_orders_on_standard_ohlc=true)

// ── Date Range
startDate   = input.time(timestamp("1 Jan 2018"), "Start Date")
endDate     = input.time(timestamp("31 Dec 2069"), "End Date")
inDateRange = time >= startDate and time <= endDate

// ── Inputs
src      = input(hlc3, "Source")
poles    = input.int(4, "Poles", 1, 9)
period   = input.int(144, "Period", 2)
mult     = input.float(1.414, "Range Multiplier", 0)
lagMode  = input.bool(false, "Reduced Lag")
fastMode = input.bool(false, "Fast Response")

// ── Calculate Alpha
pi    = math.asin(1) * 2
beta  = (1 - math.cos(2 * pi / period)) / (math.pow(1.414, 2 / poles) - 1)
alpha = -beta + math.sqrt(beta * beta + 2 * beta)

// ── Apply lag reduction if enabled
lag     = lagMode ? int((period - 1) / (2 * poles)) : 0
srcData = lagMode ? src + (src - src[lag]) : src
tr      = ta.tr(true)  // true range as a series
trData  = lagMode ? tr + (tr - tr[lag]) : tr

// ── AI Filter (EMA approximation)
AIFilter(data, a, p) =>
    ema1   = ta.ema(data, int(2 / a))
    result = ema1
    if p >= 2
        result := ta.ema(result, int(2 / a))
    if p >= 3
        result := ta.ema(result, int(2 / a))
    if p >= 4
        result := ta.ema(result, int(2 / a))
    result

// ── Apply filter
filt   = AIFilter(srcData, alpha, poles)
filtTR = AIFilter(trData,  alpha, poles)

// ── Fast mode: average with single-pole versions
if fastMode
    filt1   = AIFilter(srcData, alpha, 1)
    filtTR1 = AIFilter(trData,  alpha, 1)
    filt    := (filt + filt1) / 2
    filtTR  := (filtTR + filtTR1) / 2

// ── Bands
upper = filt + filtTR * mult
lower = filt - filtTR * mult

// ── Colors
trendColor = filt > filt[1] ? #0aff68 : filt < filt[1] ? #ff0a5a : #cccccc

// ── Plots
plot(filt,  "Filter",     trendColor, 3,  force_overlay=true)
p1 = plot(upper, "Upper Band", trendColor,      force_overlay=true)
p2 = plot(lower, "Lower Band", trendColor,      force_overlay=true)
fill(p1, p2, color.new(trendColor, 80))

// ── Bar coloring
barCol = src > src[1] and src > filt and src < upper ? #0aff68 :
         src > src[1] and src >= upper              ? #0aff1b :
         src <= src[1] and src >  filt              ? #00752d :
         src <  src[1] and src <  filt and src > lower ? #ff0a5a :
         src <  src[1] and src <= lower             ? #ff0a11 :
         src >= src[1] and src <  filt              ? #990032 : #cccccc
barcolor(barCol)

// ── Strategy logic
if ta.crossover(close, upper) and inDateRange
    strategy.entry("long", strategy.long)
if ta.crossunder(close, upper) and inDateRange
    strategy.close("long")

// ── Equity line
plot(title="Equity Line", series=strategy.equity, trackprice=true,
     display=display.data_window, color=color.black, force_overlay=true)

// ── CAGR / MDD (define cagr so it's usable)
msPerYear = 365.25 * 24 * 60 * 60 * 1000
startTs   = startDate
finalTs   = time[1]
years     = not na(finalTs) ? float(finalTs - startTs) / msPerYear : na
cagr      = years > 0 ? math.pow(strategy.equity / strategy.initial_capital, 1 / years) - 1 : na
cagrByMddRatio = na(strategy.max_drawdown_percent) or strategy.max_drawdown_percent == 0 ? na : (cagr * 100) / strategy.max_drawdown_percent
// plot(cagr * 100, title="CAGR %", color=color.teal, linewidth=2)
// plot(cagrByMddRatio, title="CAGR/MDD Ratio", color=color.red, linewidth=2)

