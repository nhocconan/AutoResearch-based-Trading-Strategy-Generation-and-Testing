T_from = 0 //int(input.time(title="Plz enter the Top line point 1 timestamp", defval=0)) // unixTimestampIn1
T_to   = 0 // int(input.time(title="Plz enter the Top line point 2 timestamp", defval=0)) //unixTimestampIn2

T_from1 = 0 // int(input.time(title="Plz enter the Bottom line point 1 timestamp", defval=0)) // unixTimestampIn1
T_to1   =  0 //int(input.time(title="Plz enter the Bottom line point 2 timestamp", defval=0)) //unixTimestampIn2

if T_from==0
    T_from:=unixTimestampIn1
if T_to==0
    T_to:=unixTimestampIn2
if T_from1==0
    T_from1:=unixTimestampIn3
if T_to1==0
    T_to1:=unixTimestampIn4

bartime = int(ta.change(time))

int count_bars1 = ta.barssince(year(T_from)==year(time) and month(T_from)==month(time) and dayofmonth(T_from)==dayofmonth(time) and hour(T_from)==hour(time) and minute(T_from)==minute(time))//math.floor((timenow - T_from) / bartime)
int count_bars2 = ta.barssince(year(T_to)==year(time) and month(T_to)==month(time) and dayofmonth(T_to)==dayofmonth(time) and hour(T_to)==hour(time) and minute(T_to)==minute(time)) //math.floor((timenow - T_to) / bartime)

int count_bars3 = ta.barssince(year(T_from1)==year(time) and month(T_from1)==month(time) and dayofmonth(T_from1)==dayofmonth(time) and hour(T_from1)==hour(time) and minute(T_from1)==minute(time))//math.floor((timenow - T_from) / bartime)
int count_bars4 = ta.barssince(year(T_to1)==year(time) and month(T_to1)==month(time) and dayofmonth(T_to1)==dayofmonth(time) and hour(T_to1)==hour(time) and minute(T_to1)==minute(time)) //math.floor((timenow - T_to) / bartime)

count_bars3 := math.min(count_bars3, 4999)
count_bars4 := math.min(count_bars4, 4999)

count_bars1 := math.min(count_bars1, 4999)
count_bars2 := math.min(count_bars2, 4999)
// 1 Jan 25 9:48
// 6 jan 25 13:54

trendBottom=line(na)
trendBottom:=tradeLogic!=15?line(na):line.new(x1=bar_index-count_bars1, y1=price1==0.0?high[count_bars1]:price1, x2=bar_index-count_bars2, y2=price2==0.0?high[count_bars2]:price2, xloc=xloc.bar_index ,extend =extend.right, color=#7d69ee, style=line.style_solid, width=1)
line.delete(trendBottom[2])

trendTop=line(na)
trendTop:=tradeLogic!=15?line(na):line.new(x1=bar_index-count_bars3, y1=price3==0.0?low[count_bars3]:price3, x2=bar_index-count_bars4, y2=price4==0.0?low[count_bars4]:price4, xloc=xloc.bar_index ,extend =extend.right, color=#7d69ee, style=line.style_solid, width=1)
line.delete(trendTop[2]) 

hline(price=price5,title='Resistence',color=color.rgb(42, 231, 222), linestyle=hline.style_dashed, linewidth=3)
hline(price=price6,title='Resistence',color=color.rgb(42, 231, 222), linestyle=hline.style_dashed, linewidth=3)
// if(time == unixTimestampIn2 or time == unixTimestampIn4)
//     strategy.exit(id="BS", stop=close) 
if tradeLogic==15
    finalBuySellVal:=0
    isSquaredOffInt:=0
    e201= v_ma1_visible? v_ma1: close
    topLinePrice=line.get_price(trendBottom,bar_index)
    bottomLinePrice=line.get_price(trendTop,bar_index)
    if ta.crossover(e201, topLinePrice[1]) or ta.crossover(e201, bottomLinePrice[1]) or (e201[1] <= topLinePrice[1] and e201>topLinePrice[0] ) or (e201[1] <= bottomLinePrice[1] and e201>bottomLinePrice[0] )
        finalBuySellVal:=50
    else if ta.crossunder(e201, topLinePrice[1]) or ta.crossunder(e201, bottomLinePrice[1]) or (e201[1] >= topLinePrice[1] and e201<topLinePrice[0] ) or (e201[1] >= bottomLinePrice[1] and e201<bottomLinePrice[0] )
        finalBuySellVal:=-50

    if (price5 >0 or price6 > 0) and (ta.crossunder(e201, price5) or ta.crossunder(e201, price6))
        finalBuySellVal:=-50
    else if (price5 >0 or price6 > 0) and (ta.crossover(e201, price5) or ta.crossover(e201, price6))
        finalBuySellVal:=50
                
    if time < math.max(unixTimestampIn2,unixTimestampIn4)
        finalBuySellVal:=0
if tradeLogic==16 // only slope
    finalBuySellVal:=0
    isSquaredOffInt:=0
    if slope50Deried > slope50Deried[1] and slope50Deried[1] > slope50Deried[2] and slope50Deried[2] <= slope50Deried[3] 
        finalBuySellVal:=50
    if slope50Deried < slope50Deried[1] and slope50Deried[1] < slope50Deried[2] and slope50Deried[2] >= slope50Deried[3]
        finalBuySellVal:=-50

if tradeLogic==17 // FRAMA
    finalBuySellVal:=0
    isSquaredOffInt:=0
    topLinePrice=line.get_price(trendBottom,bar_index)
    bottomLinePrice=line.get_price(trendTop,bar_index)
    // Detect if current bar is the first of a new day
    isNewDay = (dayofmonth != dayofmonth[1]) or (month != month[1]) or (year != year[1])

    isFilt1Buy=ta.crossover(Filt1,topLinePrice[0]) or ta.crossover(Filt1,topLinePrice[1]) or ta.crossover(Filt1,bottomLinePrice[0]) or ta.crossover(Filt1,bottomLinePrice[1]) or ta.crossover(Filt1,monthR1[0]) or ta.crossover(Filt1,monthS1[0])  or ta.crossover(Filt1,pdh[0])  or ta.crossover(Filt1,pdl[0]) or ta.crossover(Filt1,price5[0]) or ta.crossover(Filt1,price6[0]) 
    isFilt2Buy=ta.crossover(Filt2,topLinePrice[0]) or ta.crossover(Filt2,topLinePrice[1]) or ta.crossover(Filt2,bottomLinePrice[0]) or ta.crossover(Filt2,bottomLinePrice[1]) or ta.crossover(Filt2,monthR1[0]) or ta.crossover(Filt2,monthS1[0])  or ta.crossover(Filt2,pdh[0])  or ta.crossover(Filt2,pdl[0]) or ta.crossover(Filt2,price5[0]) or ta.crossover(Filt2,price6[0])
    isFilt1Sell=ta.crossunder(Filt1,topLinePrice[0]) or ta.crossunder(Filt1,topLinePrice[1]) or ta.crossunder(Filt1,bottomLinePrice[0]) or ta.crossunder(Filt1,bottomLinePrice[1]) or ta.crossunder(Filt1,monthR1[0]) or ta.crossunder(Filt1,monthS1[0])  or ta.crossunder(Filt1,pdh[0])  or ta.crossunder(Filt1,pdl[0]) or ta.crossunder(Filt1,price5[0]) or ta.crossunder(Filt1,price6[0]) 
    isFilt2Sell=ta.crossunder(Filt2,topLinePrice[0]) or ta.crossunder(Filt2,topLinePrice[1]) or ta.crossunder(Filt2,bottomLinePrice[0]) or ta.crossunder(Filt2,bottomLinePrice[1]) or ta.crossunder(Filt2,monthR1[0]) or ta.crossunder(Filt2,monthS1[0])  or ta.crossunder(Filt2,pdh[0])  or ta.crossunder(Filt2,pdl[0]) or ta.crossunder(Filt2,price5[0]) or ta.crossunder(Filt2,price6[0])

    if isNewDay==false and (isFilt1Buy or isFilt2Buy)
        finalBuySellVal:=50
    else if  isNewDay==false and (isFilt1Sell or isFilt2Sell)
        finalBuySellVal:=-50
//LOGIC here END 
