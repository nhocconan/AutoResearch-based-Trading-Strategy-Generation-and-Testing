plot(pdl , color=color.rgb(185, 178, 77), style=plot.style_cross, linewidth=2, title="open", transp = 5)

ttt=label.new(bar_index+1, pdh, "HighV" + ": " + str.tostring(pdh, format.mintick), color=color.new(color.white, 100), textcolor=color.rgb(238, 27, 27), style=label.style_label_left)
