            mypl:=mypl+ppl
else if isEndDay==false and finalBuySellVal==-50 and (isAlreadyBuyBefore1 or (isAlreadyBuyBefore1==false and isAlreadySellBefore1==false) or (isSquaredOffInt==1) )
    tradeInS:=closepl
