ttt1_mS1=label.new(bar_index+1, monthS1, "Month-S1" + ": " + str.tostring(monthS1, format.mintick), color=color.new(color.white, 100), textcolor=color.yellow, style=label.style_label_left)
label.delete(ttt1_mS1[1])

finalBuySellVal:=0
bool longCondition=false
bool shortCondition=false

isgreen= col==color.green //(bbw60 - bbw60[1] >0)
if not isgreen and (isAlreadyBuyBefore1 or isAlreadySellBefore1)
    if isAlreadyBuyBefore1
        isSquaredOffInt:=1
        finalBuySellVal:=-50
        debugMsg+= str.tostring( int (1))
    else if isAlreadySellBefore1
        isSquaredOffInt:=2
        finalBuySellVal:=50
        debugMsg+= str.tostring( int (2))
if(isgreen and ta.crossover(bbw60, out60))
    if v_ma1 > v_ma1[1]
