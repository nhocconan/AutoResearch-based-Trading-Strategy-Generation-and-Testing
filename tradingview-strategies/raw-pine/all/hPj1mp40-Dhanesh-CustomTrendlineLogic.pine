tradeLogic = input.int(title = "Select \n TradeLogic: 15: For Manual Trendline with ema crossover \n 16: only slope  \n 17: Trade using FRAMAA  ",  defval = 17)
minStochasticPriceDiff = input.float(title = " min span between hh and lll in one side stochstics candle price values ",  defval = 350.0)

dop = request.security(ticker.standard( syminfo.tickerid), 'D', open, lookahead=barmerge.lookahead_on)

