            mypl:=mypl+ppl

qty = input.int(confirm=false, defval = 40, title="Qty to trade for bitcoin")
productType = input.string(confirm=false, defval = "M", options=["M","I"], title="Product Type - Day(M) or Intraday(I)")
instrumentType = input.string(confirm=false, defval = "OPT", options=["OPT","FUT"], title="Is this future or options?")
ecn = input.string(confirm=false, defval = "NSE", options=["NSE","MCX"], title="Exchange Select")
strike_price = input.string(confirm=false, defval = "50000.0", title="Enter Strike Price")
secret = input.string(confirm=false, defval = "N.A.", title="Enter Dhan Secret against the URL Webhook")
real_qty = input.string(confirm=false, defval = "4", title="Enter Dhan Qty Lot to trade")
exp_date = input.string(confirm=false, defval = "2024-05-15", title="Enter Expiry date of the option")

getAlertJsonMessage_DHAN(c,o,h,l,bsVal,isSqrd,t,sym,secret,real_qty,exp_date) =>
    isFuture = instrumentType == "FUT"
    cepe = "CE"
    tranType = "B"
    price = 0.0
    if isFuture
        tranType := bsVal == 50 ? 'B' : 'S'
    else
        if isSqrd==0
            if bsVal == 50
                cepe := "CE"
                tranType:="B"
                price := high + 10
            else if bsVal == -50
                cepe := "PE"
                tranType:="B"
                price := high + 10
        else if isSqrd == 1
            cepe := "CE"
            tranType:="S"
            price := low - 10
        else if isSqrd == 2
            cepe := "PE"
            tranType:="S"
            price := low - 10
    //productType
    json = "{\"secret\":\""++str.tostring(secret)+"\","
    json += "\"alertType\":\"multi_leg_order\",\"order_legs\":["
    
    json += " {\"orderType\":\"MKT\",\"exchange\":\""+str.tostring(ecn)+"\",\"instrument\":\""+str.tostring(instrumentType)+"\",\"sort_order\":\"1\","
    json += "\"symbol\":\""+str.tostring(sym)+"\","
    //json += "\"price\":\""+str.tostring(price)+"\","
    json += "\"price\":\"0\","
    
    json += "\"transactionType\":\""+str.tostring(tranType)+"\","
    json += "\"productType\":\""+str.tostring(productType)+"\","
    json += "\"quantity\":\""+str.tostring(real_qty)+"\""
    if isFuture == false
        json += "\","
        json += "\"option_type\":\""+str.tostring(cepe)+"\","
        json += "\"strike_price\":\""+str.tostring(strike_price)+"\","
        json += "\"expiry_date\":\""+str.tostring(exp_date)+"\""
        json += "},"
    else
        json += "}"
    //Counter order
    if isFuture
        tranType := bsVal == -50 ? 'B' : 'S'
    else
        if isSqrd==0
            if bsVal == 50
                cepe := "PE"
                tranType:="S"
                price := high + 10
            else if bsVal == -50
                cepe := "CE"
                tranType:="S"
                price := high + 10
        else if isSqrd == 1
            cepe := "PE"
            tranType:="B"
            price := low - 10
        else if isSqrd == 2
            cepe := "CE"
            tranType:="B"
            price := low - 10
        
    if isFuture == false
        json += " {\"orderType\":\"MKT\",\"exchange\":\""+str.tostring(ecn)+"\",\"instrument\":\""+str.tostring(instrumentType)+"\",\"sort_order\":\"1\","
        json += "\"symbol\":\""+str.tostring(sym)+"\","
        //json += "\"price\":\""+str.tostring(price)+"\","
        json += "\"price\":\"0\","
        if isFuture
            if tranType =="S"
                tranType:="B"
            else
                tranType:="S"
        json += "\"transactionType\":\""+str.tostring(tranType)+"\","
        json += "\"productType\":\""+str.tostring(productType)+"\","
        json += "\"quantity\":\""+str.tostring(real_qty)+"\""
        if isFuture == false    
            json += "\","
            json += "\"option_type\":\""+str.tostring(cepe)+"\","
            json += "\"strike_price\":\""+str.tostring(strike_price)+"\","
            json += "\"expiry_date\":\""+str.tostring(exp_date)+"\""
        json += "}"

    json += "]}"
    json

getAlertJsonMessage(c,o,h,l,bsVal,isSqrd,t,sym) =>
    json = "{\"stocks\": \""+str.tostring(sym)+"\","
    json +="    \"trigger_prices\":"+str.tostring( int (c) ) +","
    json +="    \"scan_name\":\"positionalmyrnd\","
    json +="    \"triggeredAtInLong\":"+str.tostring(t) +","
    json +="    \"open\":"+str.tostring( int (o) ) +","
    json +="    \"high\":"+str.tostring( int (h) ) +","
    json +="    \"low\":"+str.tostring( int (l) ) +"," 
    json +="    \"close\":"+str.tostring( int (c) ) +","
    json +="    \"minDeviation\": 1.7,"
    json +="    \"conversionLine\":0.0,"
    json +="    \"baseLine\":0.0,"
    json +="    \"isOnBuySellValue\": true,"
    json +="    \"buySellValue\":"+str.tostring( int (bsVal) ) +","
    json +="    \"isSquaredOff\":"+str.tostring( int (isSqrd) ) +","
    json +="    \"version\": 222,"
    json +="    \"sendAlertAsIs\":false}"
    json

xDown=  finalBuySellVal[0] == -50 and  isSquaredOffInt==0 and (noTrade or isAlreadyBuyBefore1) 
xUp=  finalBuySellVal[0] == 50 and  isSquaredOffInt==0 and (noTrade or isAlreadySellBefore1)
xSquareOff=isSquaredOffInt > 0 and ((isAlreadySellBefore1 or isAlreadyBuyBefore1) )


side= xUp ? "buy": xDown ? "sell" : "NA"
if isSquaredOffInt==1
    side:="sell"
else if isSquaredOffInt==2
    side:="buy"

getAlertJsonMessageBitcoin(qty, mm, sym) =>
    json = "{"
    json += "\"symbol\": \""+str.tostring(sym)+"\","
    json += "\"side\":\""+str.tostring(mm)+"\","
    json += "\"qty\": \""+str.tostring(qty)+"\","
    json += "\"trigger_time\": \"{{timenow}}\","
    json += "\"strategy_id\": \"6691cbdf4ed9de5491f9b0a8c9c3858d\""
    json += "}"
    json

alert_msg = alertSymbol=='BTCUSD' ?getAlertJsonMessageBitcoin(qty,side,alertSymbol) : getAlertJsonMessage(close,open,high,low,finalBuySellVal,isSquaredOffInt,time,alertSymbol) 
//alert_msg_target_exit = alertSymbol=='BTCUSD' ?getAlertJsonMessageBitcoin(qty,side_target_exit,alertSymbol) : secret!='N.A.' ? getAlertJsonMessage_DHAN(close,open,high,low,finalBuySellVal==50?-50:finalBuySellVal==-50?50:0,isSquaredOffInt,time_close,alertSymbol,secret,real_qty,exp_date) :getAlertJsonMessage(close,open,high,low,finalBuySellVal==50?-50:finalBuySellVal==-50?50:0,isSquaredOffInt,time,alertSymbol) 






buySellCol =  finalBuySellVal==50 ? color.black :  color.black
plot(finalBuySellVal , color=buySellCol, style=plot.style_line, linewidth=1, title="BuySellValue", transp = 5)
plot(isSquaredOffInt , color=buySellCol, style=plot.style_line, linewidth=1, title="isSquaredOff", transp = 5)

if isEndDay and ndDone and onlyIntradayTrades
    xSquareOff:=true
    if (isAlreadySellBefore1) // earlier sell
        ppl:=tradeInS - closepl - brokerage_pl
        glob_pl:=glob_pl+ppl
        totalPL:=totalPL+ppl
    else if (isAlreadyBuyBefore1) 
        ppl:=closepl - tradeInB - brokerage_pl
        glob_pl:=glob_pl+ppl
        totalPL:=totalPL+ppl
    ndDone:=false
    mypl:=mypl+ppl
    finalPL:=finalPL+(totalPL - mypl)
    isAlreadySellBefore1:=false
    isAlreadyBuyBefore1:=false
else
    if (isAlreadySellBefore1 and tradeInS == 0) 
        tradeInS:=closepl
    if (isAlreadyBuyBefore1 and tradeInB == 0) 
        tradeInB:=closepl
    candleWiseProfit=0.0
    if isAlreadyBuyBefore1 and tradeInB > 0
        candleWiseProfit:=closepl - tradeInB + glob_pl
    else if isAlreadySellBefore1 and tradeInS > 0
        candleWiseProfit:=tradeInS - closepl + glob_pl
    if (isAlreadySellBefore1 and tradeInS > 0) // earlier sell
        ppl:=tradeInS - closepl - brokerage_pl
        totalPL:=totalPL+ppl
    else if (isAlreadyBuyBefore1  and tradeInB > 0) 
        ppl:=closepl - tradeInB - brokerage_pl
        totalPL:=totalPL+ppl
    if candleWiseProfit >= target and target > 0
        isToConsider:=false
        xSquareOff:=true

if ((xDown ) or (xUp ) or (xSquareOff))    
    if (xDown and not xSquareOff)
        tradeInS:=closepl
        
        isAlreadySellBefore1:=true
        isAlreadyBuyBefore1:=false
        strategy.entry("S "+debugMsg, strategy.short, when= (xDown and not xSquareOff)  , alert_message=alert_msg)
        log.warning("sell xSquareOff:"+str.tostring(bool(xSquareOff))+ " xDown:"+str.tostring(bool(xDown)) + " xUp:"+str.tostring(bool(xUp)) )
    else if (xUp and not xSquareOff)
        tradeInB:=closepl
        isAlreadySellBefore1:=false
        isAlreadyBuyBefore1:=true
        strategy.entry("B "+debugMsg, strategy.long, when= (xUp and not xSquareOff), alert_message=alert_msg )
        log.warning("buy xSquareOff:"+str.tostring(bool(xSquareOff))+ " xDown:"+str.tostring(bool(xDown)) + " xUp:"+str.tostring(bool(xUp)) )
    else if  ( xSquareOff)
        isAlreadySellBefore1:=false
        isAlreadyBuyBefore1:=false
        strategy.exit(id="e "+debugMsg, stop=close, alert_message=alert_msg)
        log.warning("exit xSquareOff:"+str.tostring(bool(xSquareOff))+ " xDown:"+str.tostring(bool(xDown)) + " xUp:"+str.tostring(bool(xUp)) )
    //alert(getAlertJsonMessage(close,open,high,low,finalBuySellVal,isSquaredOffInt,time,alertSymbol),alert.freq_once_per_bar)

 
plot(totalPL , color=color.rgb(241, 222, 78), style=plot.style_line, linewidth=1, title="PROFIT", transp = 5)


 
plotchar(xUp and not xSquareOff, 'Go Long', '▲', location.belowbar, color.new(color.lime, 0), size=size.tiny)
plotchar(xDown and not xSquareOff, 'Go Short', '▼', location.abovebar, color.new(color.red, 0), size=size.tiny)
plotchar(xSquareOff, 'Squareoff', '▼', location.abovebar, color.new(#6d45fc, 0), size=size.tiny,text="")

