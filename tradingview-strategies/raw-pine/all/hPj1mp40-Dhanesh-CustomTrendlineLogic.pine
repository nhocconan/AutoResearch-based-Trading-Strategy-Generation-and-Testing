pml = request.security(ticker.standard( syminfo.tickerid), 'M', low[1], lookahead=barmerge.lookahead_on)
pmc = request.security(ticker.standard( syminfo.tickerid), 'M', close[1], lookahead=barmerge.lookahead_on)


monthR1 = (0.0916*(pmh-pml)) + pmc
monthS1 = pmc - (0.0916*(pmh-pml))


