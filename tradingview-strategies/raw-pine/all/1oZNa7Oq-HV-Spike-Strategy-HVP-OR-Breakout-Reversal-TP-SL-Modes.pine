//@version=6
strategy("HV Spike Strategy (HVP + OR Breakout + Reversal + TP/SL Modes)", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=10)

// === Inputs ===
length            = input.int(30, title="STDev Time Period")
percentileLookback = input.int(252, title="Lookback for HV Percentile")
threshold         = input.float(50.0, title="HVP Activation Threshold (%)")
extendBars        = input.int(10, minval=1, title="Extend Lines for N Bars")
atrLen            = input.int(14, title="ATR Length")
atrMultSL         = input.float(1.0, title="Stop Loss ATR Multiplier")
atrMultTP         = input.float(2.0, title="Take Profit ATR Multiplier")
tpMode            = input.string("ATR", title="Take Profit Mode", options=["ATR", "Percentage"])
tpPercent         = input.float(1.0, title="Take Profit % (if using Percentage)", minval=0.1)
slMode            = input.string("ATR", title="Stop Loss Mode", options=["ATR", "Percentage"])
slPercent         = input.float(1.0, title="Stop Loss % (if using Percentage)", minval=0.1)

// === Activation Mode ===
activationMode = input.string("HV Spike", title="Strategy Activation Mode", options=["HV Spike", "Market Sessions"])

// === Session Timing Inputs (UTC-based)
tokyoHour     = input.int(20, title="Tokyo Start Hour (UTC)")
tokyoMinute   = input.int(0,  title="Tokyo Start Minute (UTC)")
londonHour    = input.int(3,  title="London Start Hour (UTC)")
londonMinute  = input.int(30, title="London Start Minute (UTC)")
nyHour        = input.int(9,  title="New York Start Hour (UTC)")
nyMinute      = input.int(30, title="New York Start Minute (UTC)")
sessionOffset = input.int(0,  title="Time Offset (hours)", minval=-12, maxval=12)

// === Adjusted Time
adjustedHour   = (hour - sessionOffset + 24) % 24
adjustedMinute = minute

// === Session Start Detection
isTokyoStart  = adjustedHour == tokyoHour  and adjustedMinute == tokyoMinute
isLondonStart = adjustedHour == londonHour and adjustedMinute == londonMinute
isNYStart     = adjustedHour == nyHour     and adjustedMinute == nyMinute
isSessionStart = isTokyoStart or isLondonStart or isNYStart

// === HV Calculation
annual = 365
per    = timeframe.isintraday or (timeframe.isdaily and timeframe.multiplier == 1) ? 1 : 7
hvRaw  = 100 * ta.stdev(math.log(close / close[1]), length) * math.sqrt(annual / per)

// === Manual Percentile Calculation
hvSeries = array.new_float(percentileLookback, 0.0)
for i = 0 to percentileLookback - 1
    array.set(hvSeries, i, hvRaw[i])

countBelow = 0
for i = 0 to percentileLookback - 1
    countBelow := countBelow + (hvRaw >= array.get(hvSeries, i) ? 1 : 0)

hvPercentile = 100 * countBelow / percentileLookback

// === Activation Trigger
hvPercentileTrigger = hvPercentile > threshold and hvPercentile[1] <= threshold
isStrategyActive = ((activationMode == "HV Spike" and hvPercentileTrigger) or(activationMode == "Market Sessions" and isSessionStart))

// === ATR Calculation
atr = ta.atr(atrLen)

// === Spike Detection
candleRange = high - low
var float spikeHigh     = na
var float spikeLow      = na
var float longTrigger   = na
var float shortTrigger  = na
var float long50        = na
var float short50       = na
var bool  tradeTaken    = true
var bool  longBreakout100 = false
var bool  shortBreakout100 = false
var bool  backInsideORB = false

if isStrategyActive
    spikeHigh    := high
    spikeLow     := low
    longTrigger  := high + candleRange * 1.0
    shortTrigger := low - candleRange * 1.0
    long50       := high + candleRange * 0.5
    short50      := low - candleRange * 0.5
    tradeTaken   := false
    longBreakout100 := false
    shortBreakout100 := false
    backInsideORB := false

    // Draw horizontal lines
    line.new(bar_index, spikeHigh, bar_index + extendBars, spikeHigh, color=color.red, width=2)
    line.new(bar_index, spikeLow, bar_index + extendBars, spikeLow, color=color.red, width=2)
    line.new(bar_index, longTrigger, bar_index + extendBars, longTrigger, color=color.orange, width=1)
    line.new(bar_index, shortTrigger, bar_index + extendBars, shortTrigger, color=color.orange, width=1)
    line.new(bar_index, long50, bar_index + extendBars, long50, color=color.teal, width=1)
    line.new(bar_index, short50, bar_index + extendBars, short50, color=color.teal, width=1)

// === Track 100% Breakout
if not tradeTaken and not longBreakout100 and close > longTrigger
    longBreakout100 := true

if not tradeTaken and not shortBreakout100 and close < shortTrigger
    shortBreakout100 := true

// === Detect return to ORB
backInsideORB := (longBreakout100 or shortBreakout100) and close < spikeHigh and close > spikeLow

// === Entry Logic (both breakout and reversal allowed)
breakoutLong  = not tradeTaken and close > longTrigger
breakoutShort = not tradeTaken and close < shortTrigger

reverseLong   = not tradeTaken and shortBreakout100 and backInsideORB and close > short50
reverseShort  = not tradeTaken and longBreakout100 and backInsideORB and close < long50

// === TP/SL Calculation from entry price
entryPrice = strategy.position_avg_price

tpLong  = tpMode == "ATR" ? entryPrice + atr * atrMultTP : entryPrice * (1 + tpPercent / 100)
slLong  = slMode == "ATR" ? entryPrice - atr * atrMultSL : entryPrice * (1 - slPercent / 100)

tpShort = tpMode == "ATR" ? entryPrice - atr * atrMultTP : entryPrice * (1 - tpPercent / 100)
slShort = slMode == "ATR" ? entryPrice + atr * atrMultSL : entryPrice * (1 + slPercent / 100)

// === Execute Entry
if breakoutLong or reverseLong
    strategy.entry("Long", strategy.long)
    strategy.exit("Exit Long", from_entry="Long", stop=slLong, limit=tpLong)
    tradeTaken := true

if breakoutShort or reverseShort
    strategy.entry("Short", strategy.short)
    strategy.exit("Exit Short", from_entry="Short", stop=slShort, limit=tpShort)
    tradeTaken := true

// === Visual Marker
plotshape(isStrategyActive, location=location.abovebar, style=shape.circle, color=color.green, size=size.small)

