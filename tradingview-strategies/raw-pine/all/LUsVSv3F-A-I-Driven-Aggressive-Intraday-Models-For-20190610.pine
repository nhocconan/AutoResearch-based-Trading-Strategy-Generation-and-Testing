//@version=3
strategy("My Strategy", overlay=true)

// these price levels are derived from our A.I. driven quant models;
// long-entries should have an 8-point trailing stop, 
//and short entries a 6-point trailing stop - still learning this TradingView environment to code this in
longCondition1 = crossover(sma(close, 1), 2895.00)
longCondition2 = crossover(sma(close, 1), 2886.00)
longCondition3 = crossover(sma(close, 1), 2874.00)
if (longCondition1 or longCondition2 or longCondition3)
    strategy.exit("ShortExit123","Short123")
    strategy.entry("Long123", strategy.long)

shortCondition1 = crossunder(sma(close, 1), 2890)
shortCondition2 = crossunder(sma(close, 1), 2882)
shortCondition3 = crossunder(sma(close, 1), 2870)
if (shortCondition1 or shortCondition2 or shortCondition3)
    strategy.exit("LongExit123","Long123")
    strategy.entry("Short123", strategy.short)

