//@version=6
strategy("SPY VWAP + Squeeze Breakout", overlay=true)

// --- Inputs ---
length   = input.int(20, "BB Length") // Add this line
mult     = input.float(2.0, "BB StdDev")
lengthKC = input.int(20, "KC Length")
multKC   = input.float(1.5, "KC Multiplier")

// Bollinger Bands
[basis, upper, lower] = ta.bb(close, length, mult)

// Keltner Channels
ma = ta.sma(close, lengthKC)
rangeKC = ta.tr(true) // Added parentheses
rangema = ta.sma(rangeKC, lengthKC)
upperKC = ma + (rangema * multKC)
lowerKC = ma - (rangema * multKC)

// VWAP Definition (Assuming standard VWAP)
vwapVal = ta.vwap(close)

// --- Squeeze Condition ---
// Changed 'basis - dev' to 'lower' and 'basis + dev' to 'upper'
sqzOn = lower > lowerKC and upper < upperKC
sqzOff = lower < lowerKC or upper > upperKC
sqzFired = sqzOff and (sqzOn[1] == true)

// --- Strategy Execution ---
longCondition = close > vwapVal and sqzFired and close > open
if (longCondition)
    strategy.entry("Long Squeeze", strategy.long)

shortCondition = close < vwapVal and sqzFired and close < open
if (shortCondition)
    strategy.entry("Short Squeeze", strategy.short)

// --- Exit Logic ---
if (strategy.position_size > 0 and close < vwapVal)
    strategy.close("Long Squeeze")

if (strategy.position_size < 0 and close > vwapVal)
    strategy.close("Short Squeeze")

