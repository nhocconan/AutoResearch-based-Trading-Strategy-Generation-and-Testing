//@version=5
// Risk Metric by Oakley Wood (modified by pommesUNDwurst)
// DCA Strategy implementation with 3Commas integration
strategy("BTC DCA Risk Strategy", 
     overlay=false, 
     initial_capital=10000, 
     default_qty_type=strategy.cash, 
     commission_type=strategy.commission.percent, 
     commission_value=0.1,
     pyramiding=1000,
     calc_on_order_fills=false,
     calc_on_every_tick=false,
     process_orders_on_close=true)

// === EXCHANGE SELECTION ===
exchange = input.string("KRAKEN", "Exchange", options=["BINANCE", "COINBASE", "KRAKEN", "GEMINI", "BYBIT"])
quoteSymbol = input.string("USD", "Quote Currency", options=["USD", "USDT", "BUSD"])

// Build tickers
BTC_TICKER = syminfo.tickerid
BTC_TRADE_TICKER = "BTC" + quoteSymbol

// === 3COMMAS CREDENTIALS ===
bot_uuid = input.string("", "3Commas Bot UUID", group="3Commas")
secret_token = input.string("", "3Commas Secret Token", group="3Commas")
use_3commas = input.bool(false, "Enable 3Commas Alerts", group="3Commas")

// === BUY THRESHOLDS & AMOUNTS ===
buyL1_thresh = input.float(0.20, "Buy L1 Threshold", group="Buy Settings", tooltip="Risk metric threshold for first buy tier")
buyL2_thresh = input.float(0.10, "Buy L2 Threshold", group="Buy Settings")
buyL3_thresh = input.float(0.00, "Buy L3 Threshold", group="Buy Settings")
buyL1_amt = input.float(10.0, "Buy L1 $ Amount", group="Buy Settings")
buyL2_amt = input.float(15.0, "Buy L2 $ Amount", group="Buy Settings")
buyL3_amt = input.float(20.0, "Buy L3 $ Amount", group="Buy Settings")

// === SELL THRESHOLDS & PERCENTAGES ===
sellL1_thresh = input.float(1.00, "Sell L1 Threshold", group="Sell Settings")
sellL2_thresh = input.float(1.50, "Sell L2 Threshold", group="Sell Settings")
sellL3_thresh = input.float(2.00, "Sell L3 Threshold", group="Sell Settings")
sellL1_pct = input.float(25.0, "Sell L1 %", group="Sell Settings")
sellL2_pct = input.float(35.0, "Sell L2 %", group="Sell Settings")
sellL3_pct = input.float(40.0, "Sell L3 %", group="Sell Settings")

// === RISK METRIC CALCULATION (Oakley Wood) ===

// METRIC 1: (BTC - 4 year SMA) / StdDev, normalized by time
d1460_sma = request.security(BTC_TICKER, 'D', ta.sma(close, 1460)) 
stdev1 = request.security(BTC_TICKER, 'D', ta.stdev(close, 1460)) 
btc = request.security(BTC_TICKER, 'D', close)
maxRiskOne = -38.12 * math.log(timenow) + 1078.5
riskOne = ((btc - d1460_sma) / stdev1) / maxRiskOne

// METRIC 2: ln(BTC / 20 week MA), normalized by time
w20_sma = request.security(BTC_TICKER, "W", ta.sma(close, 20))
minRiskTwo = -3.719 * math.log(timenow) + 105
maxRiskTwo = -6 * math.pow(10, -12) * timenow + 10.93
riskTwo = (math.log(btc / w20_sma) + minRiskTwo) / maxRiskTwo

// METRIC 3: 50D MA / 50W MA, normalized by time
d50_sma = request.security(BTC_TICKER, 'D', ta.sma(close, 50))
w50_sma = request.security(BTC_TICKER, 'W', ta.sma(close, 50))
maxRiskThree = -12.55 * math.log(timenow) + 355.15
riskThree = (d50_sma / w50_sma) / maxRiskThree

// COMPOUND RISK METRIC (0 = extreme buy, 1 = extreme sell)
riskMetric = (nz(riskOne,0) + nz(riskTwo,0) + nz(riskThree,0)) / 3

// === STATE VARIABLES ===
var bool sellL1_done = false
var bool sellL2_done = false
var bool sellL3_done = false

// === BUY LOGIC ===
var float buyAmount = 0.0
buyTier = "NONE"

if riskMetric <= buyL3_thresh
    buyAmount := buyL1_amt + buyL2_amt + buyL3_amt
    buyTier := "L3"
else if riskMetric <= buyL2_thresh
    buyAmount := buyL1_amt + buyL2_amt
    buyTier := "L2"
else if riskMetric <= buyL1_thresh
    buyAmount := buyL1_amt
    buyTier := "L1"
else
    buyAmount := 0
    buyTier := "NONE"

buyTrigger = buyAmount > 0

// === BUY EXECUTION ===
if buyTrigger
    strategy.entry("BUY", strategy.long, qty=buyAmount/close, comment="BUY " + buyTier)
    label.new(bar_index, riskMetric, "BUY " + buyTier + "\n$" + str.tostring(buyAmount), 
         style=label.style_label_up, color=color.green, textcolor=color.white, size=size.small)
    
    sellL1_done := false
    sellL2_done := false
    sellL3_done := false
    
    if use_3commas
        buyJson = '{"secret":"' + secret_token + '","max_lag":"300","timestamp":"' + str.tostring(timenow) + '","trigger_price":"' + str.tostring(close) + '","tv_exchange":"' + exchange + '","tv_instrument":"' + BTC_TRADE_TICKER + '","action":"enter_long","bot_uuid":"' + bot_uuid + '","order":{"amount":"' + str.tostring(buyAmount) + '","currency_type":"quote","order_type":"market"}}'
        alert(buyJson, alert.freq_once_per_bar_close)

// === SELL LOGIC ===
sell1Cond = strategy.position_size > 0 and riskMetric >= sellL1_thresh and not sellL1_done
sell2Cond = strategy.position_size > 0 and riskMetric >= sellL2_thresh and sellL1_done and not sellL2_done
sell3Cond = strategy.position_size > 0 and riskMetric >= sellL3_thresh and sellL2_done and not sellL3_done

if sell1Cond
    strategy.close("BUY", qty_percent=sellL1_pct, comment="SELL L1")
    label.new(bar_index, riskMetric, "SELL L1\n" + str.tostring(sellL1_pct) + "%", 
         style=label.style_label_down, color=color.orange, textcolor=color.white, size=size.small)
    sellL1_done := true
    
    if use_3commas
        sellJson = '{"secret":"' + secret_token + '","max_lag":"300","timestamp":"' + str.tostring(timenow) + '","trigger_price":"' + str.tostring(close) + '","tv_exchange":"' + exchange + '","tv_instrument":"' + BTC_TRADE_TICKER + '","action":"exit_long","bot_uuid":"' + bot_uuid + '","order":{"amount":"' + str.tostring(sellL1_pct) + '","currency_type":"position_percent","order_type":"market"}}'
        alert(sellJson, alert.freq_once_per_bar_close)

if sell2Cond
    strategy.close("BUY", qty_percent=sellL2_pct, comment="SELL L2")
    label.new(bar_index, riskMetric, "SELL L2\n" + str.tostring(sellL2_pct) + "%", 
         style=label.style_label_down, color=color.red, textcolor=color.white, size=size.small)
    sellL2_done := true
    
    if use_3commas
        sellJson = '{"secret":"' + secret_token + '","max_lag":"300","timestamp":"' + str.tostring(timenow) + '","trigger_price":"' + str.tostring(close) + '","tv_exchange":"' + exchange + '","tv_instrument":"' + BTC_TRADE_TICKER + '","action":"exit_long","bot_uuid":"' + bot_uuid + '","order":{"amount":"' + str.tostring(sellL2_pct) + '","currency_type":"position_percent","order_type":"market"}}'
        alert(sellJson, alert.freq_once_per_bar_close)

if sell3Cond
    strategy.close("BUY", qty_percent=sellL3_pct, comment="SELL L3")
    label.new(bar_index, riskMetric, "SELL L3\n" + str.tostring(sellL3_pct) + "%", 
         style=label.style_label_down, color=color.maroon, textcolor=color.white, size=size.small)
    sellL3_done := true
    
    if use_3commas
        sellJson = '{"secret":"' + secret_token + '","max_lag":"300","timestamp":"' + str.tostring(timenow) + '","trigger_price":"' + str.tostring(close) + '","tv_exchange":"' + exchange + '","tv_instrument":"' + BTC_TRADE_TICKER + '","action":"exit_long","bot_uuid":"' + bot_uuid + '","order":{"amount":"' + str.tostring(sellL3_pct) + '","currency_type":"position_percent","order_type":"market"}}'
        alert(sellJson, alert.freq_once_per_bar_close)

// === COLOR-CODED PLOTTING (matching original) ===
var colorway = color.white

if (riskMetric >= 0.8) 
    colorway := color.white
else if (riskMetric >= 0.65) 
    colorway := color.red
else if (riskMetric >= 0.5) 
    colorway := color.orange
else if (riskMetric >= 0.35) 
    colorway := color.yellow
else if (riskMetric >= 0.2) 
    colorway := color.rgb(21, 255, 0) 
else if (riskMetric >= 0.0) 
    colorway := color.rgb(255, 255, 255)

riskMetricPlot = plot(riskMetric, title="Risk Metric", color=colorway, linewidth=1, display=display.all)

// === HORIZONTAL THRESHOLD PLOTS (hidden by default) ===
i_plot = plot(0.9, color=color.new(color.white, 100), linewidth=1, display=display.none)
h_plot = plot(0.8, color=color.new(color.white, 100), linewidth=1, display=display.none)
g_plot = plot(0.7, color=color.new(color.white, 100), linewidth=1, display=display.none)
f_plot = plot(0.6, color=color.new(color.white, 100), linewidth=1, display=display.none)
neutral_plot = plot(0.5, color=color.new(color.yellow, 100), linewidth=1, display=display.none)
d_plot = plot(0.4, color=color.new(color.white, 100), linewidth=1, display=display.none)
c_plot = plot(0.3, color=color.new(color.white, 100), linewidth=1, display=display.none)
b_plot = plot(0.2, color=color.new(color.green, 100), linewidth=1, display=display.none)
a_plot = plot(0.1, color=color.new(color.white, 100), linewidth=1, display=display.none)
sell_plot = plot(0.8, color=color.new(color.red, 100), linewidth=1, display=display.none)
buy_plot = plot(0.2, color=color.new(color.green, 100), linewidth=1, display=display.none)

// === BACKGROUND FILLS (matching original) ===
allinColor = riskMetric < 0.1 ? color.new(color.green, 0) : na
bullColor = riskMetric < 0.2 ? color.new(color.green, 60) : na
yellow = riskMetric > 0.2 ? color.new(color.yellow, 50) : na
orange = riskMetric < 0.8 ? color.new(color.orange, 50) : na
bearColor = riskMetric > 0.8 ? color.new(color.red, 60) : na
alloutColor = riskMetric > 0.9 ? color.new(color.red, 0) : na

fill(riskMetricPlot, a_plot, color=allinColor)
fill(riskMetricPlot, buy_plot, color=bullColor)
fill(riskMetricPlot, sell_plot, color=bearColor)
fill(riskMetricPlot, i_plot, color=alloutColor)

// Custom buy/sell threshold lines (thinnest, dashed, 100% opacity)
plot(buyL1_thresh, "Buy L1", color=color.new(color.yellow, 0), linewidth=1, style=plot.style_linebr)
plot(buyL2_thresh, "Buy L2", color=color.new(color.lime, 0), linewidth=1, style=plot.style_linebr)
plot(buyL3_thresh, "Buy L3", color=color.new(color.green, 0), linewidth=1, style=plot.style_linebr)
plot(sellL1_thresh, "Sell L1", color=color.new(color.orange, 0), linewidth=1, style=plot.style_linebr)
plot(sellL2_thresh, "Sell L2", color=color.new(color.red, 0), linewidth=1, style=plot.style_linebr)
plot(sellL3_thresh, "Sell L3", color=color.new(color.maroon, 0), linewidth=1, style=plot.style_linebr)

