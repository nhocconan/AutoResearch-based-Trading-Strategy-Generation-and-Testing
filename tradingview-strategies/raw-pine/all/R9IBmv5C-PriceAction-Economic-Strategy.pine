//@version=6
strategy("Price Action & Economic Data Strategy", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=10)

// Basic price action conditions
longCondition = close > open
shortCondition = close < open

// Manage entries and exits
if (longCondition)
    strategy.close("Short")
    strategy.entry("Long", strategy.long)

if (shortCondition)
    strategy.close("Long")
    strategy.entry("Short", strategy.short)

// Request economic data (US GDP) using request.economic()
gdp = request.economic("US", "GDP")

// Plot the economic data in the data window
plot(gdp, title="US GDP", display=display.data_window)

