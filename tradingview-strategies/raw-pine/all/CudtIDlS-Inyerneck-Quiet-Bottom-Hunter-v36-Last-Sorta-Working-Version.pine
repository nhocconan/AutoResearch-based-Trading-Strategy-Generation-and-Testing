//@version=5
strategy("Quiet Bottom Hunter v36 — Last Sorta-Working Version", overlay=true,
         default_qty_type=strategy.percent_of_equity, default_qty_value=10)

// SETTINGS — this is the version that gave you signals
lookback     = input.int(100, "Lookback bars for high")
minDrop      = input.float(-25.0, "Min % drop from high")
volMax       = input.float(0.8, "Max volume vs 50-day avg")
rsiMax       = input.int(38, "RSI max")
greenMin     = input.int(2, "Min green/flat days")

// DROP FROM HIGH
highPrev = ta.highest(high[1], lookback)
drop     = (close - highPrev) / highPrev * 100
isDown   = drop <= minDrop

// VOLUME
volDry   = volume <= ta.sma(volume, 50) * volMax

// RSI
rsiOk    = ta.rsi(close, 14) <= rsiMax

// GREEN STREAK — FIXED
streak = 0
streak := close >= open ? streak[1] + 1 : 0
bottomOk = streak >= greenMin

// TRIGGER
qbLong = isDown and volDry and rsiOk and bottomOk

if (qbLong)
    strategy.entry("QB", strategy.long)

strategy.exit("QB Exit", "QB", profit=40, loss=12)

// TINY ARROW
plotshape(qbLong, location=location.belowbar, color=#00ff9d, style=shape.triangleup, size=size.tiny, text="QB")

alertcondition(qbLong, title="Quiet Bottom", message="{\"content\":\"♻️ QUIET BOTTOM {{ticker}} @ {{close}} | {{interval}}\"}")

