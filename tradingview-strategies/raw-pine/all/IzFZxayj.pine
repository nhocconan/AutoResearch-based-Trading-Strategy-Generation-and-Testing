//@version=5
strategy("Customizable BTC Seasonality Strategy", overlay=true,  precision=2, calc_on_every_tick=true, initial_capital=50000, currency=currency.USD, slippage=1, commission_type=strategy.commission.cash_per_order, commission_value=0.05)

// Entry and Exit times as user inputs
entry_hour = input.int(21, title="Entry Hour (UTC)", minval=0, maxval=23)
exit_hour = input.int(23, title="Exit Hour (UTC)", minval=0, maxval=23)

// Define current hour and minute
current_hour = hour
current_minute = minute

// Trading logic based on user-defined times
enterTrade = (current_hour == entry_hour) and (current_minute == 0)
exitTrade = (current_hour == exit_hour) and (current_minute == 0)

// Open a long position at the specified entry time
if (enterTrade)
    strategy.entry("BTC Long", strategy.long)

// Close the position at the specified exit time
if (exitTrade)
    strategy.close("BTC Long")

