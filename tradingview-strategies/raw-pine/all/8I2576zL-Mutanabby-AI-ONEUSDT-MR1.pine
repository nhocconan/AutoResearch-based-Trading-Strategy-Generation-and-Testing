//@version=5
strategy("ONEUSDT(1)_MR1", overlay=true, initial_capital=100, default_qty_type=strategy.fixed, default_qty_value=100)

// Input Parameters
var float TRAIL_ATR_MULT = 11.0
var int ATR_LENGTH = 14
var float ACCOUNT_SIZE = 100.0


// Tracking Variables
var int profx = 0
var float trailLevel = na
var int barsInTrade = 0

// Calculate Technical Indicators
atr = ta.atr(ATR_LENGTH)

// Position Size Calculation
positionSize = math.floor(ACCOUNT_SIZE / close)

// Calculate Price Changes
percentChange2Bars(offset) =>
    ((close[offset] - close[offset+2]) / close[offset+2]) * 100

// Entry Conditions

priorMove = percentChange2Bars(3) >= -7
currentMove = percentChange2Bars(0) <= 0
threeBarBack = percentChange2Bars(3) <= -5

longCondition =  priorMove and currentMove and threeBarBack

// Exit Conditions
exitCondition = close > high[1] and open[1] <= close[9]

// Track Trade Duration and Profitable Closes
if (strategy.position_size > 0)
    barsInTrade := barsInTrade + 1
    if (close >= strategy.position_avg_price)
        profx := profx + 1
else
    barsInTrade := 0

// Trailing Stop Logic
if (strategy.position_size > 0)
    float newTrail = close - (atr * TRAIL_ATR_MULT)
    trailLevel := na(trailLevel) ? newTrail : math.max(trailLevel, newTrail)
else
    trailLevel := na

// Execute Strategy
if (longCondition)
    strategy.entry("Long", strategy.long, qty=positionSize)
    profx := 0

// Exit Conditions
if (strategy.position_size > 0)
    // Trailing Stop
    strategy.exit("Trail", "Long", stop=trailLevel)
    
    // Signal Exit
    if (exitCondition)
        strategy.close("Long", comment="Signal Exit")
    


// Visualization
plot(strategy.position_size > 0 ? trailLevel : na, "Trailing Stop", color=color.red, style=plot.style_stepline)
plotshape(longCondition, "Entry", location=location.belowbar, color=color.green, style=shape.triangleup, size=size.small)
plotshape(exitCondition and strategy.position_size > 0, "Exit", location=location.abovebar, color=color.red, style=shape.triangledown, size=size.small)

