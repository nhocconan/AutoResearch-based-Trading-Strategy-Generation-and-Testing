//@version=5
strategy("QQQ Momentum Regime Rider (EMA + VWAP + ADX + Vol Pullback)",
     overlay                = true,
     initial_capital        = 100000,
     commission_type        = strategy.commission.percent,
     commission_value       = 0.0,
     pyramiding             = 0,          // one position at a time
     calc_on_every_tick     = true,
     process_orders_on_close= true,
     max_labels_count       = 500)

//========= INPUTS =========//
riskPerTrade   = input.float(1000, "Risk per trade ($)", minval = 100, step = 100)
atrLen         = input.int(14, "ATR length", minval = 5)
pullbackATR    = input.float(0.8, "Max distance from EMA20 (ATR)", minval = 0.1, step = 0.1)

dmiLen         = input.int(14, "DMI / ADX length", minval = 5)
adxTrendThresh = input.float(20.0, "Min ADX for trend regime", minval = 5, step = 1)

volLen         = input.int(20, "Volume MA length", minval = 5)
volDryFactor   = input.float(0.7, "Max vol as % of avg on pullback", minval = 0.1, maxval = 1.0, step = 0.05)

sessionTime    = input.session("0930-1600", "Regular hours (NY)")
useSession     = input.bool(true, "Use RTH only")

tpRR           = input.float(3.0, "Take-profit RR", minval = 1.0, step = 0.1)
slATRmult      = input.float(1.5, "Stop distance (ATR multiples)", minval = 0.5, step = 0.1)

//========= INDICATORS =========//
// 1m EMAs & VWAP
ema20 = ta.ema(close, 20)
ema50 = ta.ema(close, 50)
vwap  = ta.vwap(close)
atr   = ta.atr(atrLen)

// DMI / ADX  —— 注意：TradingView 这里用的是 ta.dmi(length, adxSmoothing)
[posDI, negDI, adx] = ta.dmi(dmiLen, dmiLen)

// Volume regime
volMA  = ta.sma(volume, volLen)
volDry = volume < volMA * volDryFactor  // 缩量条件

// Session filter
inSession = useSession ? not na(time(timeframe.period, sessionTime)) : true

//========= TREND REGIME =========//
bullTrend = ema20 > ema50 and adx > adxTrendThresh and posDI > negDI
bearTrend = ema20 < ema50 and adx > adxTrendThresh and negDI > posDI

//========= PULLBACK 定义（贴 EMA20 + 缩量） =========//
atrSafe   = math.max(atr, syminfo.mintick * 4)

nearEma20 = math.abs(close - ema20) <= pullbackATR * atrSafe

// Long 方向的“健康回调” = 强多头趋势 + 价在 ema50 之上 + 回到 ema20 附近 + 在 VWAP 上方 + 缩量
healthyPullbackLong =
     bullTrend and
     close > ema50 and
     close > vwap and
     nearEma20 and
     volDry

// Short 方向的“健康回调” = 强空头趋势 + 价在 ema50 之下 + 回到 ema20 附近 + 在 VWAP 下方 + 缩量
healthyPullbackShort =
     bearTrend and
     close < ema50 and
     close < vwap and
     nearEma20 and
     volDry

//========= POSITION SIZE =========//
stopDist = atrSafe * slATRmult
qty      = riskPerTrade / stopDist

//========= ENTRY CONDITIONS（单行，防止换行报错） =========//
longCond  = inSession and healthyPullbackLong  and strategy.position_size == 0
shortCond = inSession and healthyPullbackShort and strategy.position_size == 0

//========= EXECUTION =========//
//================= EXECUTION =================//

// 进场逻辑保持不变：只在满足条件 & 无持仓时进场
if longCond and strategy.position_size == 0
    strategy.entry("Long", strategy.long, qty = qty)

if shortCond and strategy.position_size == 0
    strategy.entry("Short", strategy.short, qty = qty)


//================= EXECUTION (BE + EMA20 only) =================//

// -------- Long 出场逻辑（动态止损 + 固定RR止盈） --------
if strategy.position_size > 0 and strategy.position_avg_price > 0
    entryLong   = strategy.position_avg_price
    baseStopL   = entryLong - stopDist                      
    beTriggerL  = entryLong + stopDist                      
    beStopL     = close >= beTriggerL ? entryLong : baseStopL

    trendStopL  = ema20 - atr * 0.2
    finalStopL  = math.max(beStopL, trendStopL)

    tpLong      = entryLong + stopDist * tpRR

    strategy.exit("Long Exit", "Long", stop = finalStopL, limit = tpLong)


// -------- Short 出场逻辑 --------
if strategy.position_size < 0 and strategy.position_avg_price > 0
    entryShort  = strategy.position_avg_price
    baseStopS   = entryShort + stopDist
    beTriggerS  = entryShort - stopDist
    beStopS     = close <= beTriggerS ? entryShort : baseStopS

    trendStopS  = ema20 + atr * 0.2
    finalStopS  = math.min(beStopS, trendStopS)

    tpShort     = entryShort - stopDist * tpRR
    strategy.exit("Short Exit", "Short", stop = finalStopS, limit = tpShort)

//========= PLOTS =========//
plot(ema20, "EMA20", color=color.orange)
plot(ema50, "EMA50", color=color.blue)
plot(vwap, "VWAP", color=color.new(color.purple, 0))

// ADX / Volume 均线默认隐藏，只用来调参
plot(adx,   "ADX",   color=color.new(color.teal,   0), display = display.none)
plot(volMA, "VolMA", color=color.new(color.yellow, 0), display = display.none)

