//@version=6
strategy('Dow Theory Swing Trading-Dexter', overlay = true)

// Swing High and Swing Low Detection
swingLength = 5 // Defines how many bars on each side to confirm a swing
swingHigh = ta.highest(high, swingLength) // Highest high in past 'swingLength' bars
swingLow = ta.lowest(low, swingLength) // Lowest low in past 'swingLength' bars

// Track previous swings
var float prevHigh = na
var float prevLow = na

// Update previous swings
if bool(ta.change(swingHigh))
    prevHigh := swingHigh
    prevHigh

if bool(ta.change(swingLow))
    prevLow := swingLow
    prevLow

// Define Higher Highs (HH) and Higher Lows (HL) for Uptrend
isHH = swingHigh > nz(prevHigh[1])
isHL = swingLow > nz(prevLow[1])

// Define Lower Highs (LH) and Lower Lows (LL) for Downtrend
isLH = swingHigh < nz(prevHigh[1])
isLL = swingLow < nz(prevLow[1])

// Buy and Sell Conditions
buyCondition = isHH and isHL // Uptrend confirmation
sellCondition = isLH and isLL // Downtrend confirmation

// Execute Buy and Sell Signals
if buyCondition
    strategy.entry('Buy', strategy.long)

if sellCondition
    strategy.entry('Sell', strategy.short)

// Plot Swing Points
plotshape(isHH, location = location.abovebar, color = color.green, style = shape.labelup, title = 'HH')
plotshape(isHL, location = location.belowbar, color = color.blue, style = shape.triangleup, title = 'HL')
plotshape(isLH, location = location.abovebar, color = color.red, style = shape.triangledown, title = 'LH')
plotshape(isLL, location = location.belowbar, color = color.orange, style = shape.labeldown, title = 'LL')

// Background highlighting for trends
bgcolor(buyCondition ? color.green : sellCondition ? color.red : na)

