showLondonBox = input.bool(false, "Show Session Box", tooltip="Draw a box around the London session range", group=grpLondon, display=display.none)
showLondonMid = input.bool(false, "Show Midline", group=grpLondon, display=display.none)
extendLondonLines = input.bool(true, "Extend Lines", tooltip="Extend London H/L lines beyond session end", group=grpLondon, display=display.none)
londonExtendUntil = input.string("1130", "Extend Until (HHMM ET)", tooltip="Time to extend lines until when 'Extend Lines' is enabled", group=grpLondon, display=display.none)
londonStartKZ = input.string("0200", "Kill Zone Start (HHMM ET)", group=grpLondon, display=display.none)
