londonLineWidth = input.int(1, "Line Thickness", minval=1, maxval=5, group=grpLondon, display=display.none)
londonColor = input.color(color.new(color.orange, 0), "Color", group=grpLondon, display=display.none)
londonBoxColor = input.color(color.new(color.orange, 90), "Box Fill Color", group=grpLondon, display=display.none)
i_alertLondon = input.bool(false, "Alert on Break", tooltip="Fire alertcondition when price breaks London H/L. Uncheck to see levels without alerts.", group=grpLondon, display=display.none)

