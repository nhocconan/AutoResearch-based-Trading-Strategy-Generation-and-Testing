nyamBoxColor = input.color(color.new(color.blue, 90), "Box Fill Color", group=grpNYAM, display=display.none)
i_alertNYAM = input.bool(false, "Alert on Break", tooltip="Fire alertcondition when price breaks NY AM H/L. Uncheck to see levels without alerts.", group=grpNYAM, display=display.none)

