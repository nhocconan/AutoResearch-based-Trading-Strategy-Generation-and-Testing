//@version=6
strategy(title="Buy-Dip / Sell-Pullback (Loosened v6)", overlay=true, pyramiding=1, calc_on_every_tick=false, default_qty_type=strategy.percent_of_equity, default_qty_value=10)

// ─── Inputs ────────────────────────────────────────────────────────────────────
rsiLen       = input.int(20,  "RSI Length")
rsiBullMin   = input.float(48, "RSI Bull Min (was 50)")
rsiBearMax   = input.float(52, "RSI Bear Max (was 50)")

stochKLen    = input.int(55,  "%K Length")
stochKSmooth = input.int(34,  "%K Smoothing")
stochDSmooth = input.int(21,  "%D Smoothing")
stochEdge    = input.float(0.5, "Stoch Edge (K-D), 0 = loosest")

atrLen       = input.int(5,   "ATR Length (SL/TP)")
stLen        = input.int(10,  "Supertrend ATR Length")
stMult       = input.float(2, "Supertrend Multiplier")

bbLen        = input.int(20,  "BB Length")
bbMult       = input.float(2, "BB Multiplier")

trMult       = input.float(0.8, "Gap Filter TR × (was 0.5)")
slMult       = input.float(1.1, "SL = ATR ×")
tpMult       = input.float(2.2, "TP = ATR ×")

stBufMult    = input.float(0.45, "ST Buffer = ATR × (was 0.30)")
showMarkers  = input.bool(true, "Show Markers")

// ─── Indicators ───────────────────────────────────────────────────────────────
rsi = ta.rsi(close, rsiLen)

ll  = ta.lowest(low, stochKLen)
hh  = ta.highest(high, stochKLen)
den = math.max(hh - ll, syminfo.mintick)
rawK = 100 * (close - ll) / den
k = ta.sma(rawK, stochKSmooth)
d = ta.sma(k, stochDSmooth)

atr = ta.atr(atrLen)

[stLine, stDirF] = ta.supertrend(stMult, stLen)
stUp = stDirF > 0

basis = ta.sma(close, bbLen)
upperBB = basis + bbMult * ta.stdev(close, bbLen)
lowerBB = basis - bbMult * ta.stdev(close, bbLen)

trToday = ta.tr(true)

// ─── Loosened Gates ────────────────────────────────────────────────────────────
// 1) RSI loosened
rsiBull = rsi >= rsiBullMin
rsiBear = rsi <= rsiBearMax

// 2) Stoch loosened with adjustable edge
stochBull = k >= d + stochEdge
stochBear = k <= d - stochEdge

// 3) Supertrend direction still required (keeps “trend only” integrity)
trendBull = stUp
trendBear = not stUp

// 4) Close vs Supertrend buffered (loosened default buffer)
stBuffer = stBufMult * atr
closeOkLong  = close >= (stLine - stBuffer)
closeOkShort = close <= (stLine + stBuffer)

// 5) Replace rare “ST vs BB mid” with simpler “close vs BB basis”
bbOkLong  = close >= basis
bbOkShort = close <= basis

// ─── Final EOD Setups ─────────────────────────────────────────────────────────
bullSetup = rsiBull and stochBull and trendBull and closeOkLong and bbOkLong
bearSetup = rsiBear and stochBear and trendBear and closeOkShort and bbOkShort

// ─── Gap filter modeled via LIMIT (robust in TV backtests) ─────────────────────
longLimit  = close + trMult * trToday
shortLimit = close - trMult * trToday

if bullSetup and strategy.position_size <= 0
    strategy.entry("Long", strategy.long, limit=longLimit)

if bearSetup and strategy.position_size >= 0
    strategy.entry("Short", strategy.short, limit=shortLimit)

// ─── Detect fills ─────────────────────────────────────────────────────────────
newLong  = strategy.position_size > 0 and strategy.position_size[1] <= 0
newShort = strategy.position_size < 0 and strategy.position_size[1] >= 0

// Freeze ATR at entry (use prior bar ATR)
var float atrEntry = na
if newLong or newShort
    atrEntry := atr[1]

// ─── Exits ────────────────────────────────────────────────────────────────────
if strategy.position_size > 0
    ep = strategy.position_avg_price
    strategy.exit("Exit Long", "Long", stop=ep - slMult * atrEntry, limit=ep + tpMult * atrEntry)

if strategy.position_size < 0
    ep = strategy.position_avg_price
    strategy.exit("Exit Short", "Short", stop=ep + slMult * atrEntry, limit=ep - tpMult * atrEntry)

// ─── Markers ───────────────────────────────────────────────────────────────────
plotshape(showMarkers and bullSetup, title="Bull Setup", style=shape.labelup, location=location.belowbar, color=color.yellow, text="SET↑")
plotshape(showMarkers and bearSetup, title="Bear Setup", style=shape.labeldown, location=location.abovebar, color=color.orange, text="SET↓")
plotshape(showMarkers and newLong,   title="BUY", style=shape.triangleup, location=location.belowbar, color=color.green, text="BUY")
plotshape(showMarkers and newShort,  title="SELL", style=shape.triangledown, location=location.abovebar, color=color.red, text="SELL")

