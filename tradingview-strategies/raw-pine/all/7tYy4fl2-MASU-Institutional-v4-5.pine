//@version=6
strategy("MASU+ Institutional v4.5+", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=10, pyramiding=0, calc_on_every_tick=true, max_labels_count=500, max_lines_count=200, max_boxes_count=500)

// ═══════════════════════════════════════════════════════════════════════════
// 1. SETTINGS  
// ═══════════════════════════════════════════════════════════════════════════
symbol_group = input.string("Auto") 
use_adaptive = input.bool(true, "Use Adaptive Parameters", group="Strategy Settings")
base_timeframe = input.string("15", "Base Timeframe", group="Strategy Settings")

// TIME FILTER
use_time_filter = input.bool(true, "Trade Only During Session", group="Time Filter")
trading_session = input.session("0900-2200", "Trading Hours", group="Time Filter")

// TREND FOLLOWING
trend_ema_fast = input.int(21, "Trend EMA Fast", minval=5, group="Trend Following")
trend_ema_slow = input.int(50, "Trend EMA Slow", minval=10, group="Trend Following")
trend_ema_filter = input.int(200, "Trend Filter EMA", minval=50, group="Trend Following")

// MTF FILTER
use_mtf_filter = input.bool(true, "Use MTF Filter", group="MTF Filter")
mtf_timeframe = input.timeframe("240", "Higher Timeframe", group="MTF Filter")
mtf_ema_fast = input.int(21, "MTF EMA Fast", minval=5, group="MTF Filter")
mtf_ema_slow = input.int(55, "MTF EMA Slow", minval=10, group="MTF Filter")

// MA RIBBON
use_ma_ribbon = input.bool(true, "Use MA Ribbon", group="MA Ribbon")
ribbon_type = input.string("EMA", "Ribbon MA Type", options=["EMA", "SMA", "HMA"], group="MA Ribbon")
ribbon_ma1 = input.int(8, "Ribbon MA 1", minval=2, group="MA Ribbon")
ribbon_ma2 = input.int(13, "Ribbon MA 2", minval=2, group="MA Ribbon")
ribbon_ma3 = input.int(21, "Ribbon MA 3", minval=2, group="MA Ribbon")
ribbon_ma4 = input.int(34, "Ribbon MA 4", minval=2, group="MA Ribbon")
ribbon_ma5 = input.int(55, "Ribbon MA 5", minval=2, group="MA Ribbon")
ribbon_ma6 = input.int(89, "Ribbon MA 6", minval=2, group="MA Ribbon")
ribbon_ma7 = input.int(144, "Ribbon MA 7", minval=2, group="MA Ribbon")
ribbon_ma8 = input.int(233, "Ribbon MA 8", minval=2, group="MA Ribbon")
ribbon_threshold = input.int(6, "Ribbon Alignment Threshold", minval=4, maxval=8, group="MA Ribbon")

// ORDER FLOW
use_order_flow = input.bool(true, "Enable Order Flow Analysis", group="Order Flow")
show_vwap = input.bool(true, "Show VWAP Bands", group="Order Flow")
vwap_std_mult1 = input.float(1.0, "VWAP Std 1", minval=0.1, step=0.1, group="Order Flow")
vwap_std_mult2 = input.float(2.0, "VWAP Std 2", minval=0.1, step=0.1, group="Order Flow")
vwap_std_mult3 = input.float(3.0, "VWAP Std 3", minval=0.1, step=0.1, group="Order Flow")
cvd_length = input.int(20, "CVD Period", minval=1, group="Order Flow")
cvd_threshold = input.float(0.6, "CVD Threshold", minval=0.1, maxval=1.0, step=0.1, group="Order Flow")
show_volume_profile = input.bool(true, "Show Volume Profile POC", group="Order Flow")
volume_profile_bins = input.int(20, "VP Bins", minval=10, maxval=50, group="Order Flow")

// SMART MONEY
use_smc = input.bool(true, "Enable Smart Money Concepts", group="Smart Money")
show_order_blocks = input.bool(true, "Show Order Blocks", group="Smart Money")
show_fvg = input.bool(true, "Show Fair Value Gaps", group="Smart Money")
show_liquidity = input.bool(true, "Show Liquidity Sweeps", group="Smart Money")
show_bos = input.bool(true, "Show BOS/CHoCH", group="Smart Money")
show_demand_supply = input.bool(true, "Show Demand/Supply Zones", group="Smart Money")
ob_lookback = input.int(10, "Order Block Lookback", minval=5, group="Smart Money")
fvg_min_size = input.float(0.5, "FVG Min Size (ATR mult)", minval=0.1, step=0.1, group="Smart Money")
liquidity_lookback = input.int(20, "Liquidity Lookback", minval=10, group="Smart Money")
bos_pivot_length = input.int(5, "BOS Pivot Length", minval=3, group="Smart Money")
ds_impulse_mult = input.float(1.5, "D/S Impulse Strength (ATR mult)", minval=0.5, step=0.1, group="Smart Money")
ds_max_zones = input.int(8, "Max D/S Zones Each Side", minval=2, maxval=20, group="Smart Money")

// VOLATILITY
use_vol_regime = input.bool(true, "Enable Volatility Regime", group="Volatility Regime")
bb_vr_length = input.int(20, "BB VR Period", minval=10, group="Volatility Regime")
bb_vr_mult = input.float(2.0, "BB VR Multiplier", minval=1.0, step=0.1, group="Volatility Regime")
atr_percentile_length = input.int(100, "ATR Percentile Period", minval=20, group="Volatility Regime")
vol_expansion_threshold = input.float(1.5, "Expansion Threshold", minval=1.0, step=0.1, group="Volatility Regime")
vol_contraction_threshold = input.float(0.7, "Contraction Threshold", minval=0.1, maxval=1.0, step=0.1, group="Volatility Regime")

// CORRELATION
use_correlation = input.bool(false, "Enable Multi-Asset Correlation", group="Correlation")
corr_symbol1 = input.symbol("OANDA:SPX500USD", "Correlation Symbol 1", group="Correlation")
corr_symbol2 = input.symbol("OANDA:XAUUSD", "Correlation Symbol 2", group="Correlation")
corr_length = input.int(20, "Correlation Period", minval=10, group="Correlation")
corr_threshold = input.float(0.7, "Correlation Threshold", minval=0.5, maxval=1.0, step=0.1, group="Correlation")

// STRATEGY PARAMS
breakout_length = input.int(20, "Breakout Period", minval=5, group="Breakout")
breakout_atr_mult = input.float(1.5, "Breakout ATR Multiplier", minval=0.5, step=0.1, group="Breakout")
bb_length = input.int(20, "Bollinger Bands Period", minval=5, group="Mean Reversion")
bb_mult = input.float(2.0, "BB Std Dev", minval=0.5, step=0.1, group="Mean Reversion")
rsi_length = input.int(14, "RSI Period", minval=2, group="Mean Reversion")
rsi_ob = input.int(70, "RSI Overbought", minval=50, maxval=100, group="Mean Reversion")
rsi_os = input.int(30, "RSI Oversold", minval=0, maxval=50, group="Mean Reversion")

// RISK MANAGEMENT
atr_length = input.int(14, "ATR Period", minval=1, group="Risk Management")
stop_atr_mult = input.float(2.0, "Stop Loss ATR Multiplier", minval=0.5, step=0.1, group="Risk Management")
tp_atr_mult = input.float(3.0, "Take Profit ATR Multiplier", minval=0.5, step=0.1, group="Risk Management")
use_trailing = input.bool(true, "Use Trailing Stop", group="Risk Management")
trailing_atr_mult = input.float(1.5, "Trailing ATR Multiplier", minval=0.5, step=0.1, group="Risk Management")

// FILTERS
adx_length = input.int(14, "ADX Period", minval=1, group="Filters")
adx_threshold = input.int(20, "ADX Threshold", minval=10, maxval=50, group="Filters")
volume_mult = input.float(1.2, "Volume Multiplier", minval=1.0, step=0.1, group="Filters")

// DISPLAY
showDashboard = input.bool(true, "Show Institutional Dashboard", group="Display")
show_support_resistance = input.bool(true, "Show Support/Resistance Lines", group="Display")
show_tp_sl_lines = input.bool(true, "Show TP/SL Lines", group="Display")
sr_lookback = input.int(50, "S/R Lookback Period", minval=20, group="Display")
sr_line_width = input.int(2, "S/R Line Width", minval=1, maxval=5, group="Display")
tp_sl_line_width = input.int(2, "TP/SL Line Width", minval=1, maxval=5, group="Display")
sr_line_style = input.string("Solid", "S/R Line Style", options=["Solid", "Dashed", "Dotted"], group="Display")
tp_sl_line_style = input.string("Dashed", "TP/SL Line Style", options=["Solid", "Dashed", "Dotted"], group="Display")

// ═══════════════════════════════════════════════════════════════════════════
// 2. HELPER FUNCTIONS & INDICATORS
// ═══════════════════════════════════════════════════════════════════════════
hma(src, len) =>
    wma1 = ta.wma(src, len / 2)
    wma2 = ta.wma(src, len)
    ta.wma(2 * wma1 - wma2, math.round(math.sqrt(len)))

calc_ma(src, len, ma_type) =>
    switch ma_type
        "EMA" => ta.ema(src, len)
        "SMA" => ta.sma(src, len)
        "HMA" => hma(src, len)
        => ta.ema(src, len)

// Line style helpers
sr_style = sr_line_style == "Dashed" ? line.style_dashed : sr_line_style == "Dotted" ? line.style_dotted : line.style_solid
tp_sl_style = tp_sl_line_style == "Dashed" ? line.style_dashed : tp_sl_line_style == "Dotted" ? line.style_dotted : line.style_solid

// Indicators
atr = ta.atr(atr_length)
ema_fast = ta.ema(close, trend_ema_fast)
ema_slow = ta.ema(close, trend_ema_slow)
ema_filter = ta.ema(close, trend_ema_filter)
[diPlus, diMinus, adx] = ta.dmi(adx_length, adx_length)

// BB & RSI
bb_basis = ta.sma(close, bb_length)
bb_dev = bb_mult * ta.stdev(close, bb_length)
bb_upper = bb_basis + bb_dev
bb_lower = bb_basis - bb_dev
rsi = ta.rsi(close, rsi_length)

// Volume & Breakout
volume_sma = ta.sma(volume, 20)
volume_spike = volume > volume_sma * volume_mult
highest_high = ta.highest(high, breakout_length)
lowest_low = ta.lowest(low, breakout_length)

// MA Ribbon
r1 = calc_ma(close, ribbon_ma1, ribbon_type)
r2 = calc_ma(close, ribbon_ma2, ribbon_type)
r3 = calc_ma(close, ribbon_ma3, ribbon_type)
r4 = calc_ma(close, ribbon_ma4, ribbon_type)
r5 = calc_ma(close, ribbon_ma5, ribbon_type)
r6 = calc_ma(close, ribbon_ma6, ribbon_type)
r7 = calc_ma(close, ribbon_ma7, ribbon_type)
r8 = calc_ma(close, ribbon_ma8, ribbon_type)

ribbon_bullish_count = (r1 > r2 ? 1 : 0) + (r2 > r3 ? 1 : 0) + (r3 > r4 ? 1 : 0) + (r4 > r5 ? 1 : 0) + (r5 > r6 ? 1 : 0) + (r6 > r7 ? 1 : 0) + (r7 > r8 ? 1 : 0)
ribbon_bearish_count = (r1 < r2 ? 1 : 0) + (r2 < r3 ? 1 : 0) + (r3 < r4 ? 1 : 0) + (r4 < r5 ? 1 : 0) + (r5 < r6 ? 1 : 0) + (r6 < r7 ? 1 : 0) + (r7 < r8 ? 1 : 0)
ribbon_bullish = ribbon_bullish_count >= (ribbon_threshold - 1)
ribbon_bearish = ribbon_bearish_count >= (ribbon_threshold - 1)
ribbon_aligned = ribbon_bullish or ribbon_bearish

// MTF Filter
mtf_ema_fast_val = request.security(syminfo.tickerid, mtf_timeframe, ta.ema(close, mtf_ema_fast), lookahead=barmerge.lookahead_off)
mtf_ema_slow_val = request.security(syminfo.tickerid, mtf_timeframe, ta.ema(close, mtf_ema_slow), lookahead=barmerge.lookahead_off)
mtf_close = request.security(syminfo.tickerid, mtf_timeframe, close, lookahead=barmerge.lookahead_off)
mtf_bullish = mtf_ema_fast_val > mtf_ema_slow_val and mtf_close > mtf_ema_fast_val
mtf_bearish = mtf_ema_fast_val < mtf_ema_slow_val and mtf_close < mtf_ema_fast_val
mtf_filter_long = not use_mtf_filter or mtf_bullish
mtf_filter_short = not use_mtf_filter or mtf_bearish
ribbon_filter_long = not use_ma_ribbon or ribbon_bullish
ribbon_filter_short = not use_ma_ribbon or ribbon_bearish

// VWAP & CVD
var float vwap_sum = 0.0
var float vol_sum = 0.0
var float vwap = 0.0
is_new_day = ta.change(time('D')) != 0
if barstate.isfirst or is_new_day
    vwap_sum := 0.0
    vol_sum := 0.0
vwap_sum += volume * hlc3
vol_sum += volume
vwap := vol_sum > 0 ? vwap_sum / vol_sum : close

vwap_dev = ta.stdev(close, cvd_length)
vwap_upper1 = vwap + vwap_std_mult1 * vwap_dev
vwap_lower1 = vwap - vwap_std_mult1 * vwap_dev
vwap_upper2 = vwap + vwap_std_mult2 * vwap_dev
vwap_lower2 = vwap - vwap_std_mult2 * vwap_dev
vwap_upper3 = vwap + vwap_std_mult3 * vwap_dev
vwap_lower3 = vwap - vwap_std_mult3 * vwap_dev

buy_volume = close > open ? volume : 0
sell_volume = close < open ? volume : 0
delta = buy_volume - sell_volume
cvd = ta.cum(delta)
cvd_sma = ta.sma(cvd, cvd_length)
cvd_bullish = cvd > cvd_sma and close < close[1] and cvd > cvd[1]
cvd_bearish = cvd < cvd_sma and close > close[1] and cvd < cvd[1]
volume_ratio = buy_volume / math.max(sell_volume, 1)
strong_buying = volume_ratio > (1 + cvd_threshold)
strong_selling = volume_ratio < (1 - cvd_threshold)
price_above_vwap = close > vwap
price_below_vwap = close < vwap
vwap_cross_up = ta.crossover(close, vwap)
vwap_cross_down = ta.crossunder(close, vwap)
of_bullish = use_order_flow and ((cvd_bullish or strong_buying) and (vwap_cross_up or price_above_vwap))
of_bearish = use_order_flow and ((cvd_bearish or strong_selling) and (vwap_cross_down or price_below_vwap))

// Volume Profile POC
var float[] volume_levels = array.new_float(volume_profile_bins, 0.0)
var float poc_price = na
vp_highest = ta.highest(high, volume_profile_bins)
vp_lowest = ta.lowest(low, volume_profile_bins)
if barstate.islast and show_volume_profile
    price_range = vp_highest - vp_lowest
    bin_size = price_range / volume_profile_bins
    array.fill(volume_levels, 0.0)
    for i = 0 to volume_profile_bins - 1
        bin_price = vp_lowest + i * bin_size
        for j = 0 to volume_profile_bins - 1
            if low[j] <= bin_price and high[j] >= bin_price
                array.set(volume_levels, i, array.get(volume_levels, i) + volume[j])
    max_volume = array.max(volume_levels)
    max_index = array.indexof(volume_levels, max_volume)
    poc_price := vp_lowest + max_index * bin_size

// ═══════════════════════════════════════════════════════════════════════════
// SMC Logic — Order Blocks (WRAPPED IN ISCONFIRMED)
// ═══════════════════════════════════════════════════════════════════════════
bullish_ob = close > open and close[1] < open[1] and high - close < (high - low) * 0.3
bearish_ob = close < open and close[1] > open[1] and close - low < (high - low) * 0.3
var box[] bullish_ob_boxes = array.new_box()
var box[] bearish_ob_boxes = array.new_box()

// FIX: Added barstate.isconfirmed to prevent flickering
if barstate.isconfirmed
    if bullish_ob and use_smc and show_order_blocks
        new_box = box.new(bar_index - 1, high[1], bar_index + 15, low[1], border_color=color.new(color.green, 100), bgcolor=color.new(color.green, 90), border_width=0)
        array.push(bullish_ob_boxes, new_box)
        if array.size(bullish_ob_boxes) > 8
            box.delete(array.shift(bullish_ob_boxes))
    if bearish_ob and use_smc and show_order_blocks
        new_box = box.new(bar_index - 1, high[1], bar_index + 15, low[1], border_color=color.new(color.red, 100), bgcolor=color.new(color.red, 90), border_width=0)
        array.push(bearish_ob_boxes, new_box)
        if array.size(bearish_ob_boxes) > 8
            box.delete(array.shift(bearish_ob_boxes))

// ═══════════════════════════════════════════════════════════════════════════
// SMC Logic — Demand Zones (BLUE) & Supply Zones (YELLOW)
// ═══════════════════════════════════════════════════════════════════════════
// Detect strong impulse moves
impulse_up = (close - open) > atr * ds_impulse_mult and close > open     // strong bullish candle
impulse_down = (open - close) > atr * ds_impulse_mult and close < open   // strong bearish candle

// Demand zone logic
demand_zone = impulse_up and close[1] < open[1]
supply_zone = impulse_down and close[1] > open[1]

// Arrays to track zone boxes and their price levels for mitigation
var box[] demand_boxes = array.new_box()
var float[] demand_tops = array.new_float()
var float[] demand_bottoms = array.new_float()

var box[] supply_boxes = array.new_box()
var float[] supply_tops = array.new_float()
var float[] supply_bottoms = array.new_float()

// FIX: Added barstate.isconfirmed to prevent flickering
if barstate.isconfirmed
    // Create new demand zones (BLUE)
    if demand_zone and use_smc and show_demand_supply
        zone_top = math.max(open[1], close[1])
        zone_bot = math.min(open[1], close[1])
        new_box = box.new(bar_index - 1, zone_top, bar_index + 200, zone_bot, border_color=color.new(#2196F3, 100), bgcolor=color.new(#2196F3, 85), border_width=0)
        array.push(demand_boxes, new_box)
        array.push(demand_tops, zone_top)
        array.push(demand_bottoms, zone_bot)
        if array.size(demand_boxes) > ds_max_zones
            box.delete(array.shift(demand_boxes))
            array.shift(demand_tops)
            array.shift(demand_bottoms)

    // Create new supply zones (YELLOW)
    if supply_zone and use_smc and show_demand_supply
        zone_top = math.max(open[1], close[1])
        zone_bot = math.min(open[1], close[1])
        new_box = box.new(bar_index - 1, zone_top, bar_index + 200, zone_bot, border_color=color.new(#FF9800, 100), bgcolor=color.new(#FF9800, 85), border_width=0)
        array.push(supply_boxes, new_box)
        array.push(supply_tops, zone_top)
        array.push(supply_bottoms, zone_bot)
        if array.size(supply_boxes) > ds_max_zones
            box.delete(array.shift(supply_boxes))
            array.shift(supply_tops)
            array.shift(supply_bottoms)

// Mitigate demand zones
if array.size(demand_boxes) > 0
    for i = array.size(demand_boxes) - 1 to 0
        if i < array.size(demand_boxes)
            d_top = array.get(demand_tops, i)
            d_bot = array.get(demand_bottoms, i)
            // Mitigated: price has traded through the zone
            if low <= d_top and close < d_bot
                box.delete(array.get(demand_boxes, i))
                array.remove(demand_boxes, i)
                array.remove(demand_tops, i)
                array.remove(demand_bottoms, i)
            else
                // Extend active zone
                box.set_right(array.get(demand_boxes, i), bar_index + 20)

// Mitigate supply zones
if array.size(supply_boxes) > 0
    for i = array.size(supply_boxes) - 1 to 0
        if i < array.size(supply_boxes)
            s_top = array.get(supply_tops, i)
            s_bot = array.get(supply_bottoms, i)
            // Mitigated: price has traded through the zone
            if high >= s_bot and close > s_top
                box.delete(array.get(supply_boxes, i))
                array.remove(supply_boxes, i)
                array.remove(supply_tops, i)
                array.remove(supply_bottoms, i)
            else
                // Extend active zone
                box.set_right(array.get(supply_boxes, i), bar_index + 20)

// ═══════════════════════════════════════════════════════════════════════════
// SMC Logic — FVG, Liquidity, BOS
// ═══════════════════════════════════════════════════════════════════════════
bullish_fvg = low > high[2] and (low - high[2]) > atr * fvg_min_size
bearish_fvg = high < low[2] and (low[2] - high) > atr * fvg_min_size
recent_high = ta.highest(high, liquidity_lookback)
recent_low = ta.lowest(low, liquidity_lookback)
liquidity_grab_high = high > recent_high[1] and close < open and close < recent_high[1]
liquidity_grab_low = low < recent_low[1] and close > open and close > recent_low[1]
swing_high = ta.pivothigh(high, bos_pivot_length, bos_pivot_length)
swing_low = ta.pivotlow(low, bos_pivot_length, bos_pivot_length)
var float last_swing_high = na
var float last_swing_low = na
if not na(swing_high)
    last_swing_high := swing_high
if not na(swing_low)
    last_swing_low := swing_low
bullish_bos = not na(last_swing_high) and close > last_swing_high and close[1] <= last_swing_high
bearish_bos = not na(last_swing_low) and close < last_swing_low and close[1] >= last_swing_low
smc_bullish = use_smc and (bullish_ob or bullish_fvg or liquidity_grab_low or bullish_bos)
smc_bearish = use_smc and (bearish_ob or bearish_fvg or liquidity_grab_high or bearish_bos)

// Volatility & Market Regime
bb_vr_basis = ta.sma(close, bb_vr_length)
bb_vr_dev = bb_vr_mult * ta.stdev(close, bb_vr_length)
bb_vr_width = (bb_vr_basis + bb_vr_dev - (bb_vr_basis - bb_vr_dev)) / bb_vr_basis
atr_percentile = ta.percentrank(atr, atr_percentile_length)
high_volatility = atr_percentile > 70
low_volatility = atr_percentile < 30

bb_vr_width_sma = ta.sma(bb_vr_width, bb_vr_length)
bb_expansion = bb_vr_width > bb_vr_width_sma * vol_expansion_threshold
bb_contraction = bb_vr_width < bb_vr_width_sma * vol_contraction_threshold

vol_regime_trending = use_vol_regime and (bb_expansion or high_volatility)
vol_regime_ranging = use_vol_regime and (bb_contraction or low_volatility)
is_trending = adx > adx_threshold
is_ranging = adx <= adx_threshold
bullish_trend = ema_fast > ema_slow and close > ema_filter
bearish_trend = ema_fast < ema_slow and close < ema_filter

// ═══════════════════════════════════════════════════════════════════════════
// 3. CALCULATION OF VARIABLES FOR DASHBOARD & STRATEGY
// ═══════════════════════════════════════════════════════════════════════════
// Universal S/L & T/P levels
universal_long_sl = close - (atr * stop_atr_mult)
universal_long_tp = close + (atr * tp_atr_mult)
universal_short_sl = close + (atr * stop_atr_mult)
universal_short_tp = close - (atr * tp_atr_mult)

// Dynamic S/R
pivot_high = ta.pivothigh(high, sr_lookback, sr_lookback)
pivot_low = ta.pivotlow(low, sr_lookback, sr_lookback)
var float dynamic_resistance = na
var float dynamic_support = na
highest_price = ta.highest(high, sr_lookback)
lowest_price = ta.lowest(low, sr_lookback)
if not na(pivot_high)
    dynamic_resistance := pivot_high
if not na(pivot_low)
    dynamic_support := pivot_low
dynamic_resistance := na(dynamic_resistance) ? highest_price : dynamic_resistance
dynamic_support := na(dynamic_support) ? lowest_price : dynamic_support

// Kelly & Position
var int total_trades = 0
var int winning_trades = 0
var float total_profit = 0.0
var float total_loss = 0.0
if strategy.closedtrades > total_trades
    total_trades := strategy.closedtrades
    if strategy.closedtrades.profit(strategy.closedtrades - 1) > 0
        winning_trades += 1
        total_profit += strategy.closedtrades.profit(strategy.closedtrades - 1)
    else
        total_loss += math.abs(strategy.closedtrades.profit(strategy.closedtrades - 1))
win_rate = total_trades > 0 ? winning_trades / total_trades : 0.5
avg_win = winning_trades > 0 ? total_profit / winning_trades : tp_atr_mult * atr
avg_loss = (total_trades - winning_trades) > 0 ? total_loss / (total_trades - winning_trades) : stop_atr_mult * atr
win_loss_ratio = avg_loss > 0 ? avg_win / avg_loss : tp_atr_mult / stop_atr_mult
kelly_percentage = math.max(0, math.min(win_rate - ((1 - win_rate) / win_loss_ratio), 0.25))
position_size_pct = kelly_percentage * 100

// Confluence & Signals
of_filter_long = not use_order_flow or of_bullish or price_above_vwap
of_filter_short = not use_order_flow or of_bearish or price_below_vwap
smc_filter_long = not use_smc or smc_bullish or bullish_ob or bullish_fvg
smc_filter_short = not use_smc or smc_bearish or bearish_ob or bearish_fvg
vol_filter_trend = not use_vol_regime or vol_regime_trending
vol_filter_range = not use_vol_regime or vol_regime_ranging

signal_strength_long = (mtf_filter_long ? 1 : 0) + (ribbon_filter_long ? 1 : 0) + (of_filter_long ? 1 : 0) + (smc_filter_long ? 1 : 0) + (adx > adx_threshold ? 1 : 0)
signal_strength_short = (mtf_filter_short ? 1 : 0) + (ribbon_filter_short ? 1 : 0) + (of_filter_short ? 1 : 0) + (smc_filter_short ? 1 : 0) + (adx > adx_threshold ? 1 : 0)
current_signal = signal_strength_long > signal_strength_short ? "LONG" : signal_strength_short > signal_strength_long ? "SHORT" : "WAIT"
signal_color_bg = current_signal == "LONG" ? color.new(color.green, 70) : current_signal == "SHORT" ? color.new(color.red, 70) : color.new(color.gray, 70)
confluence_score = math.max(signal_strength_long, signal_strength_short)
confluence_color = confluence_score >= 4 ? color.green : confluence_score >= 3 ? color.orange : color.red
confluence_status = confluence_score >= 4 ? "STRONG" : confluence_score >= 3 ? "MODERATE" : "WEAK"

universal_sl_display = current_signal == "LONG" ? universal_long_sl : universal_short_sl
universal_tp_display = current_signal == "LONG" ? universal_long_tp : universal_short_tp

// Market Structure String
var float last_bos_level = na
var string last_bos_type = "NONE"
if bullish_bos
    last_bos_level := close
    last_bos_type := "BULLISH"
if bearish_bos
    last_bos_level := close
    last_bos_type := "BEARISH"
market_structure = bullish_bos or bearish_bos ? last_bos_type + " BOS" : "CONSOLIDATION"

// Volume Pressure
var float volume_buy_pct = 50.0
var string volume_pressure = "NEUTRAL"
var color volume_pressure_color = color.gray
if bar_index >= 20 
    float current_buy_vol = 0.0
    float current_sell_vol = 0.0
    for i = 0 to 19
        current_buy_vol += (close[i] > open[i] ? volume[i] : 0)
        current_sell_vol += (close[i] < open[i] ? volume[i] : 0)
    float total_vol = current_buy_vol + current_sell_vol
    volume_buy_pct := total_vol > 0 ? (current_buy_vol / total_vol * 100) : 50.0
    volume_pressure := volume_buy_pct > 60 ? "BUYING" : volume_buy_pct < 40 ? "SELLING" : "NEUTRAL"
    volume_pressure_color := volume_buy_pct > 60 ? color.green : volume_buy_pct < 40 ? color.red : color.gray

// Liquidity String
var float last_liq_sweep_level = na
var string last_liq_sweep_type = "NONE"
if liquidity_grab_high
    last_liq_sweep_level := high
    last_liq_sweep_type := "HIGH"
if liquidity_grab_low
    last_liq_sweep_level := low
    last_liq_sweep_type := "LOW"

// Session detection
london_session = not na(time(timeframe.period, "0800-1600"))
ny_session = not na(time(timeframe.period, "1300-2100"))
asia_session = not na(time(timeframe.period, "0000-0800"))
current_session = london_session and ny_session ? "LON/NY" : london_session ? "LONDON" : ny_session ? "NEW YORK" : asia_session ? "ASIA" : "OFF"

// ═══════════════════════════════════════════════════════════════════════════
// 4. STRATEGY EXECUTION
// ═══════════════════════════════════════════════════════════════════════════
in_session = not use_time_filter or not na(time(timeframe.period, trading_session))

ema_cross_up = ta.crossover(ema_fast, ema_slow)
ema_cross_down = ta.crossunder(ema_fast, ema_slow)
rsi_cross_up = ta.crossover(rsi, rsi_os)
rsi_cross_down = ta.crossunder(rsi, rsi_ob)

trend_long = is_trending and bullish_trend and ema_cross_up and volume_spike
trend_short = is_trending and bearish_trend and ema_cross_down and volume_spike
breakout_long = close > highest_high[1] and volume_spike and close > ema_filter
breakout_short = close < lowest_low[1] and volume_spike and close < ema_filter
mean_reversion_long = is_ranging and close < bb_lower and rsi < rsi_os and rsi_cross_up
mean_reversion_short = is_ranging and close > bb_upper and rsi > rsi_ob and rsi_cross_down

long_condition = (trend_long or breakout_long or mean_reversion_long) and mtf_filter_long and ribbon_filter_long and of_filter_long and smc_filter_long and in_session
short_condition = (trend_short or breakout_short or mean_reversion_short) and mtf_filter_short and ribbon_filter_short and of_filter_short and smc_filter_short and in_session

// Execution
if long_condition and strategy.position_size == 0
    stop_loss = close - (atr * stop_atr_mult)
    take_profit = close + (atr * tp_atr_mult)
    strategy.entry("Long", strategy.long)
    alert("🟢 BUY Signal | Price: " + str.tostring(close), alert.freq_once_per_bar_close)
    if use_trailing
        strategy.exit("Exit Long", "Long", stop=stop_loss, trail_offset=atr * trailing_atr_mult, trail_points=atr * trailing_atr_mult)
    else
        strategy.exit("Exit Long", "Long", stop=stop_loss, limit=take_profit)

if short_condition and strategy.position_size == 0
    stop_loss = close + (atr * stop_atr_mult)
    take_profit = close - (atr * tp_atr_mult)
    strategy.entry("Short", strategy.short)
    alert("🔴 SELL Signal | Price: " + str.tostring(close), alert.freq_once_per_bar_close)
    if use_trailing
        strategy.exit("Exit Short", "Short", stop=stop_loss, trail_offset=atr * trailing_atr_mult, trail_points=atr * trailing_atr_mult)
    else
        strategy.exit("Exit Short", "Short", stop=stop_loss, limit=take_profit)

// ═══════════════════════════════════════════════════════════════════════════
// 5. VISUALIZATION — Layered to avoid overlaps (FIXED: barstate.isconfirmed)
// ═══════════════════════════════════════════════════════════════════════════
plot(ema_fast, "EMA Fast", color=color.blue)
plot(ema_slow, "EMA Slow", color=color.orange)
plot(ema_filter, "EMA Filter", color=color.red)

// VWAP bands
plot(show_vwap ? vwap : na, "VWAP", color=color.purple, linewidth=2)
plot(show_vwap ? vwap_upper1 : na, "VWAP +1σ", color=color.new(color.purple, 60))
plot(show_vwap ? vwap_lower1 : na, "VWAP -1σ", color=color.new(color.purple, 60))
plot(show_vwap ? vwap_upper2 : na, "VWAP +2σ", color=color.new(color.purple, 75))
plot(show_vwap ? vwap_lower2 : na, "VWAP -2σ", color=color.new(color.purple, 75))
plot(show_vwap ? vwap_upper3 : na, "VWAP +3σ", color=color.new(color.purple, 85))
plot(show_vwap ? vwap_lower3 : na, "VWAP -3σ", color=color.new(color.purple, 85))

// FIX: Added 'and barstate.isconfirmed' to plotshape conditions to prevent repainting/flickering
// === LAYER 3: BUY / SELL signal labels (furthest from candles) ===
plotshape(long_condition and barstate.isconfirmed, "Long", shape.triangleup, location.belowbar, color.green, size=size.small)
plotshape(short_condition and barstate.isconfirmed, "Short", shape.triangledown, location.abovebar, color.red, size=size.small)

if long_condition and barstate.isconfirmed
    label.new(bar_index, low - atr * 0.6, "▲ BUY", color=color.new(color.green, 60), textcolor=color.white, style=label.style_label_up, size=size.small)
if short_condition and barstate.isconfirmed
    label.new(bar_index, high + atr * 0.6, "▼ SELL", color=color.new(color.red, 60), textcolor=color.white, style=label.style_label_down, size=size.small)

// === LAYER 2: Liquidity sweep labels ===
if show_liquidity and use_smc and barstate.isconfirmed
    if liquidity_grab_high
        label.new(bar_index, high + atr * 0.35, "LIQ ✕", color=color.new(color.orange, 70), textcolor=color.orange, style=label.style_label_down, size=size.tiny)
    if liquidity_grab_low
        label.new(bar_index, low - atr * 0.35, "LIQ ✕", color=color.new(color.orange, 70), textcolor=color.orange, style=label.style_label_up, size=size.tiny)

// === LAYER 1: BOS labels (closest to candles among labels) ===
if show_bos and use_smc and barstate.isconfirmed
    if bullish_bos
        label.new(bar_index, low - atr * 0.15, "BOS ▲", color=color.new(color.green, 85), textcolor=color.green, style=label.style_label_up, size=size.tiny)
        alert("🟢 BOS BUY | " + syminfo.ticker + " | Price: " + str.tostring(close), alert.freq_once_per_bar_close)
    if bearish_bos
        label.new(bar_index, high + atr * 0.15, "BOS ▼", color=color.new(color.red, 85), textcolor=color.red, style=label.style_label_down, size=size.tiny)
        alert("🔴 BOS SELL | " + syminfo.ticker + " | Price: " + str.tostring(close), alert.freq_once_per_bar_close)

// === LAYER 0: FVG boxes (at price level, no offset) ===
var box[] fvg_bull_boxes = array.new_box()
var box[] fvg_bear_boxes = array.new_box()
if show_fvg and use_smc and barstate.isconfirmed
    if bullish_fvg
        new_fvg = box.new(bar_index - 2, low, bar_index + 10, high[2], border_color=color.new(color.teal, 100), bgcolor=color.new(color.teal, 90), border_width=0)
        array.push(fvg_bull_boxes, new_fvg)
        if array.size(fvg_bull_boxes) > 6
            box.delete(array.shift(fvg_bull_boxes))
    if bearish_fvg
        new_fvg = box.new(bar_index - 2, low[2], bar_index + 10, high, border_color=color.new(color.maroon, 100), bgcolor=color.new(color.maroon, 90), border_width=0)
        array.push(fvg_bear_boxes, new_fvg)
        if array.size(fvg_bear_boxes) > 6
            box.delete(array.shift(fvg_bear_boxes))

// === Support / Resistance lines ===
var line resistance_line = na
var line support_line = na
var label resistance_label = na
var label support_label = na

var line tp_line = na
var line sl_line = na
var label tp_label = na
var label sl_label = na

if show_support_resistance
    if barstate.islast
        if not na(resistance_line)
            line.delete(resistance_line)
        if not na(support_line)
            line.delete(support_line)
        if not na(resistance_label)
            label.delete(resistance_label)
        if not na(support_label)
            label.delete(support_label)
        resistance_line := line.new(bar_index - 50, dynamic_resistance, bar_index + 10, dynamic_resistance, color=color.new(color.red, 20), width=sr_line_width, style=sr_style, extend=extend.right)
        support_line := line.new(bar_index - 50, dynamic_support, bar_index + 10, dynamic_support, color=color.new(color.green, 20), width=sr_line_width, style=sr_style, extend=extend.right)
        resistance_label := label.new(bar_index - 45, dynamic_resistance, "RESISTANCE: " + str.tostring(dynamic_resistance, format.mintick), color=color.new(color.red, 80), textcolor=color.red, style=label.style_label_down, size=size.small)
        support_label := label.new(bar_index - 45, dynamic_support, "SUPPORT: " + str.tostring(dynamic_support, format.mintick), color=color.new(color.green, 80), textcolor=color.green, style=label.style_label_up, size=size.small)

// === TP/SL Lines ===
if show_tp_sl_lines and strategy.position_size != 0
    if barstate.islast
        if not na(tp_line)
            line.delete(tp_line)
        if not na(sl_line)
            line.delete(sl_line)
        if not na(tp_label)
            label.delete(tp_label)
        if not na(sl_label)
            label.delete(sl_label)
        float display_tp = strategy.position_size > 0 ? universal_long_tp : universal_short_tp
        float display_sl = strategy.position_size > 0 ? universal_long_sl : universal_short_sl
        tp_line := line.new(bar_index - 10, display_tp, bar_index + 10, display_tp, color=color.new(color.green, 30), width=tp_sl_line_width, style=tp_sl_style)
        sl_line := line.new(bar_index - 10, display_sl, bar_index + 10, display_sl, color=color.new(color.red, 30), width=tp_sl_line_width, style=tp_sl_style)
        tp_label := label.new(bar_index + 11, display_tp, "TP: " + str.tostring(display_tp, format.mintick), color=color.new(color.green, 80), textcolor=color.green, style=label.style_label_left, size=size.tiny)
        sl_label := label.new(bar_index + 11, display_sl, "SL: " + str.tostring(display_sl, format.mintick), color=color.new(color.red, 80), textcolor=color.red, style=label.style_label_left, size=size.tiny)

// ═══════════════════════════════════════════════════════════════════════════
// VISUAL: GRADIENT TREND CANDLES
// ═══════════════════════════════════════════════════════════════════════════
use_gradient = input(true, "Use Gradient Candle Colors")

// Logic: Mix RSI momentum + Trend direction
// 0 = Super Bear, 50 = Neutral, 100 = Super Bull
grad_rsi = ta.rsi(close, 14)
grad_trend_strength = (close - ta.ema(close, 50)) / ta.ema(close, 50) * 1000 // Normalized strength

// Base Colors
c_strong_bull = color.new(#00E676, 0)   // Bright Green
c_weak_bull   = color.new(#1B5E20, 0)   // Dark Green
c_neutral     = color.new(#78909C, 0)   // Grey
c_weak_bear   = color.new(#B71C1C, 0)   // Dark Red
c_strong_bear = color.new(#FF1744, 0)   // Bright Red

// Dynamic Color Selection
get_candle_color() =>
    if grad_rsi > 60 and close > open
        color.from_gradient(grad_rsi, 60, 80, c_weak_bull, c_strong_bull)
    else if grad_rsi < 40 and close < open
        color.from_gradient(grad_rsi, 20, 40, c_strong_bear, c_weak_bear)
    else
        c_neutral

barcolor(use_gradient ? get_candle_color() : na)

// ═══════════════════════════════════════════════════════════════════════════
// 6. DASHBOARD
// ═══════════════════════════════════════════════════════════════════════════
mtf_15m_trend = request.security(syminfo.tickerid, "15", ta.ema(close, 21) > ta.ema(close, 50), lookahead=barmerge.lookahead_off)
mtf_15m_neutral = request.security(syminfo.tickerid, "15", math.abs(ta.ema(close, 21) - ta.ema(close, 50)) < atr * 0.5, lookahead=barmerge.lookahead_off)
mtf_15m_status = mtf_15m_neutral ? "NEUTRAL" : (mtf_15m_trend ? "UP" : "DOWN")
mtf_1h_trend = request.security(syminfo.tickerid, "60", ta.ema(close, 21) > ta.ema(close, 50), lookahead=barmerge.lookahead_off)
mtf_1h_neutral = request.security(syminfo.tickerid, "60", math.abs(ta.ema(close, 21) - ta.ema(close, 50)) < atr * 0.5, lookahead=barmerge.lookahead_off)
mtf_1h_status = mtf_1h_neutral ? "NEUTRAL" : (mtf_1h_trend ? "UP" : "DOWN")
mtf_4h_trend = request.security(syminfo.tickerid, "240", ta.ema(close, 21) > ta.ema(close, 50), lookahead=barmerge.lookahead_off)
mtf_4h_neutral = request.security(syminfo.tickerid, "240", math.abs(ta.ema(close, 21) - ta.ema(close, 50)) < atr * 0.5, lookahead=barmerge.lookahead_off)
mtf_4h_status = mtf_4h_neutral ? "NEUTRAL" : (mtf_4h_trend ? "UP" : "DOWN")

trend_15m_aligned = mtf_15m_status == "UP" ? 1 : mtf_15m_status == "DOWN" ? -1 : 0
trend_1h_aligned = mtf_1h_status == "UP" ? 1 : mtf_1h_status == "DOWN" ? -1 : 0
trend_4h_aligned = mtf_4h_status == "UP" ? 1 : mtf_4h_status == "DOWN" ? -1 : 0
trend_alignment_score = math.abs(trend_15m_aligned) + math.abs(trend_1h_aligned) + math.abs(trend_4h_aligned)
trend_alignment_direction = (trend_15m_aligned + trend_1h_aligned + trend_4h_aligned) > 0 ? "UP" : (trend_15m_aligned + trend_1h_aligned + trend_4h_aligned) < 0 ? "DOWN" : "MIXED"
trend_alignment_text = str.tostring(trend_alignment_score) + "/3 " + trend_alignment_direction
trend_alignment_color = trend_alignment_score == 3 ? color.green : trend_alignment_score == 2 ? color.orange : color.red

rr_ratio = current_signal == "LONG" ? (universal_long_tp > universal_long_sl ? (universal_long_tp - close) / math.max(close - universal_long_sl, syminfo.mintick) : 0) : (universal_short_sl > universal_short_tp ? (close - universal_short_tp) / math.max(universal_short_sl - close, syminfo.mintick) : 0)
rr_text = "1:" + str.tostring(math.round(rr_ratio, 2))
rr_color = rr_ratio >= 2 ? color.green : rr_ratio >= 1.5 ? color.orange : color.red

day_close_time = request.security(syminfo.tickerid, "D", time_close, lookahead=barmerge.lookahead_on)
ms_per_bar = timeframe.in_seconds(timeframe.period) * 1000
bars_to_day_close = (not na(day_close_time) and ms_per_bar > 0) ? math.floor(math.max(0, day_close_time - time_close) / ms_per_bar) : 0
time_to_close = str.tostring(bars_to_day_close) + " bars"

// Demand/Supply zone status for dashboard
active_demand = array.size(demand_boxes)
active_supply = array.size(supply_boxes)
ds_status = "D:" + str.tostring(active_demand) + " S:" + str.tostring(active_supply)
ds_color = active_demand > 0 and active_supply > 0 ? color.orange : active_demand > 0 ? #2196F3 : active_supply > 0 ? #FF9800 : color.gray

if showDashboard
    var table dashboard = table.new(position.bottom_right, 2, 29, border_width=1, border_color=color.new(color.gray, 80), frame_width=1, frame_color=color.new(color.gray, 80))
    if barstate.islast
        bg_row = color.new(color.gray, 90)
        txt_size = size.small
        
        table.cell(dashboard, 0, 0, "INSTITUTIONAL", text_color=color.white, bgcolor=color.new(color.navy, 10), text_size=txt_size, text_halign=text.align_left)
        table.cell(dashboard, 1, 0, "ANALYTICS", text_color=color.white, bgcolor=color.new(color.navy, 10), text_size=txt_size, text_halign=text.align_right)

        table.cell(dashboard, 0, 1, "Trend 15M", text_color=color.black, bgcolor=bg_row, text_size=txt_size, text_halign=text.align_left)
        table.cell(dashboard, 1, 1, mtf_15m_status, text_color=color.white, bgcolor=mtf_15m_status == "UP" ? color.green : mtf_15m_status == "DOWN" ? color.red : color.gray, text_size=txt_size, text_halign=text.align_right)
        
        table.cell(dashboard, 0, 2, "Trend 1H", text_color=color.black, bgcolor=bg_row, text_size=txt_size, text_halign=text.align_left)
        table.cell(dashboard, 1, 2, mtf_1h_status, text_color=color.white, bgcolor=mtf_1h_status == "UP" ? color.green : mtf_1h_status == "DOWN" ? color.red : color.gray, text_size=txt_size, text_halign=text.align_right)
        
        table.cell(dashboard, 0, 3, "Trend 4H", text_color=color.black, bgcolor=bg_row, text_size=txt_size, text_halign=text.align_left)
        table.cell(dashboard, 1, 3, mtf_4h_status, text_color=color.white, bgcolor=mtf_4h_status == "UP" ? color.green : mtf_4h_status == "DOWN" ? color.red : color.gray, text_size=txt_size, text_halign=text.align_right)
        
        table.cell(dashboard, 0, 4, "Ribbon", text_color=color.black, bgcolor=bg_row, text_size=txt_size, text_halign=text.align_left)
        table.cell(dashboard, 1, 4, ribbon_bullish ? "BULL" : ribbon_bearish ? "BEAR" : "NEUTRAL", text_color=color.white, bgcolor=ribbon_bullish ? color.green : ribbon_bearish ? color.red : color.gray, text_size=txt_size, text_halign=text.align_right)

        table.cell(dashboard, 0, 5, "ADX", text_color=color.black, bgcolor=bg_row, text_size=txt_size, text_halign=text.align_left)
        table.cell(dashboard, 1, 5, str.tostring(math.round(adx, 1)), text_color=color.white, bgcolor=adx > adx_threshold ? color.green : color.gray, text_size=txt_size, text_halign=text.align_right)
        
        table.cell(dashboard, 0, 6, "Order Flow", text_color=color.black, bgcolor=bg_row, text_size=txt_size, text_halign=text.align_left)
        table.cell(dashboard, 1, 6, of_bullish ? "BUY" : of_bearish ? "SELL" : "WAIT", text_color=color.white, bgcolor=of_bullish ? color.green : of_bearish ? color.red : color.gray, text_size=txt_size, text_halign=text.align_right)

        table.cell(dashboard, 0, 7, "Smart Money", text_color=color.black, bgcolor=bg_row, text_size=txt_size, text_halign=text.align_left)
        table.cell(dashboard, 1, 7, smc_bullish ? "BULL" : smc_bearish ? "BEAR" : "WAIT", text_color=color.white, bgcolor=smc_bullish ? color.green : smc_bearish ? color.red : color.gray, text_size=txt_size, text_halign=text.align_right)

        table.cell(dashboard, 0, 8, "Volatility", text_color=color.black, bgcolor=bg_row, text_size=txt_size, text_halign=text.align_left)
        table.cell(dashboard, 1, 8, str.tostring(math.round(atr_percentile, 0)) + "%", text_color=color.white, bgcolor=high_volatility ? color.orange : low_volatility ? color.blue : color.gray, text_size=txt_size, text_halign=text.align_right)

        table.cell(dashboard, 0, 9, "Asset", text_color=color.black, bgcolor=bg_row, text_size=txt_size, text_halign=text.align_left)
        table.cell(dashboard, 1, 9, syminfo.ticker, text_color=color.black, bgcolor=bg_row, text_size=txt_size, text_halign=text.align_right)

        table.cell(dashboard, 0, 10, "Resistance", text_color=color.black, bgcolor=bg_row, text_size=txt_size, text_halign=text.align_left)
        table.cell(dashboard, 1, 10, str.tostring(dynamic_resistance, format.mintick), text_color=color.red, bgcolor=bg_row, text_size=txt_size, text_halign=text.align_right)

        table.cell(dashboard, 0, 11, "Support", text_color=color.black, bgcolor=bg_row, text_size=txt_size, text_halign=text.align_left)
        table.cell(dashboard, 1, 11, str.tostring(dynamic_support, format.mintick), text_color=color.green, bgcolor=bg_row, text_size=txt_size, text_halign=text.align_right)

        table.cell(dashboard, 0, 12, "Stop Loss", text_color=color.black, bgcolor=bg_row, text_size=txt_size, text_halign=text.align_left)
        table.cell(dashboard, 1, 12, str.tostring(universal_sl_display, format.mintick), text_color=color.red, bgcolor=bg_row, text_size=txt_size, text_halign=text.align_right)

        table.cell(dashboard, 0, 13, "Take Profit", text_color=color.black, bgcolor=bg_row, text_size=txt_size, text_halign=text.align_left)
        table.cell(dashboard, 1, 13, str.tostring(universal_tp_display, format.mintick), text_color=color.green, bgcolor=bg_row, text_size=txt_size, text_halign=text.align_right)

        table.cell(dashboard, 0, 14, "Risk % (Kelly)", text_color=color.black, bgcolor=bg_row, text_size=txt_size, text_halign=text.align_left)
        table.cell(dashboard, 1, 14, str.tostring(math.round(kelly_percentage * 100, 2)) + "%", text_color=color.black, bgcolor=bg_row, text_size=txt_size, text_halign=text.align_right)

        table.cell(dashboard, 0, 15, "Position Size", text_color=color.black, bgcolor=bg_row, text_size=txt_size, text_halign=text.align_left)
        table.cell(dashboard, 1, 15, str.tostring(math.round(position_size_pct, 2)) + "%", text_color=color.blue, bgcolor=bg_row, text_size=txt_size, text_halign=text.align_right)

        table.cell(dashboard, 0, 16, "Price", text_color=color.black, bgcolor=bg_row, text_size=txt_size, text_halign=text.align_left)
        table.cell(dashboard, 1, 16, str.tostring(close, format.mintick), text_color=color.black, bgcolor=bg_row, text_size=txt_size, text_halign=text.align_right)

        table.cell(dashboard, 0, 17, "Confluence", text_color=color.black, bgcolor=bg_row, text_size=txt_size, text_halign=text.align_left)
        table.cell(dashboard, 1, 17, str.tostring(confluence_score) + "/5 " + confluence_status, text_color=color.white, bgcolor=confluence_color, text_size=txt_size, text_halign=text.align_right)

        table.cell(dashboard, 0, 18, "Market Structure", text_color=color.black, bgcolor=bg_row, text_size=txt_size, text_halign=text.align_left)
        table.cell(dashboard, 1, 18, market_structure, text_color=color.black, bgcolor=bg_row, text_size=size.tiny, text_halign=text.align_right)

        table.cell(dashboard, 0, 19, "Volume Pressure", text_color=color.black, bgcolor=bg_row, text_size=txt_size, text_halign=text.align_left)
        table.cell(dashboard, 1, 19, volume_pressure + " " + str.tostring(math.round(volume_buy_pct, 1)) + "%", text_color=color.white, bgcolor=volume_pressure_color, text_size=txt_size, text_halign=text.align_right)

        table.cell(dashboard, 0, 20, "Last Liq Sweep", text_color=color.black, bgcolor=bg_row, text_size=txt_size, text_halign=text.align_left)
        table.cell(dashboard, 1, 20, last_liq_sweep_type + (not na(last_liq_sweep_level) ? " @ " + str.tostring(last_liq_sweep_level, format.mintick) : ""), text_color=color.white, bgcolor=color.new(color.gray, 70), text_size=txt_size, text_halign=text.align_right)

        table.cell(dashboard, 0, 21, "Trend Alignment", text_color=color.black, bgcolor=bg_row, text_size=txt_size, text_halign=text.align_left)
        table.cell(dashboard, 1, 21, trend_alignment_text, text_color=color.white, bgcolor=trend_alignment_color, text_size=txt_size, text_halign=text.align_right)

        table.cell(dashboard, 0, 22, "Session", text_color=color.black, bgcolor=bg_row, text_size=txt_size, text_halign=text.align_left)
        table.cell(dashboard, 1, 22, current_session, text_color=color.white, bgcolor=color.new(color.blue, 50), text_size=txt_size, text_halign=text.align_right)

        table.cell(dashboard, 0, 23, "Risk/Reward", text_color=color.black, bgcolor=bg_row, text_size=txt_size, text_halign=text.align_left)
        table.cell(dashboard, 1, 23, rr_text, text_color=color.white, bgcolor=rr_color, text_size=txt_size, text_halign=text.align_right)

        table.cell(dashboard, 0, 24, "Bars to D Close", text_color=color.black, bgcolor=bg_row, text_size=txt_size, text_halign=text.align_left)
        table.cell(dashboard, 1, 24, time_to_close, text_color=color.white, bgcolor=color.new(color.gray, 70), text_size=txt_size, text_halign=text.align_right)

        table.cell(dashboard, 0, 25, "D/S Zones", text_color=color.black, bgcolor=bg_row, text_size=txt_size, text_halign=text.align_left)
        table.cell(dashboard, 1, 25, ds_status, text_color=color.white, bgcolor=ds_color, text_size=txt_size, text_halign=text.align_right)

        table.cell(dashboard, 0, 26, "SIGNAL", text_color=color.white, bgcolor=color.black, text_size=txt_size, text_halign=text.align_left)
        table.cell(dashboard, 1, 26, current_signal, text_color=color.white, bgcolor=signal_color_bg, text_size=size.normal, text_halign=text.align_right)

