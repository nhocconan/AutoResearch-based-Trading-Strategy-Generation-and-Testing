//@version=6
// ╔══════════════════════════════════════════════════════════════════════╗
// ║  ALERT SETUP: Create ONE alert → Order fills only                  ║
// ║  Clear the Message box and paste ONLY this:                        ║
// ║  {{strategy.order.alert_message}}                                  ║
// ║  Add your TradersPost / Ghost webhook URL → Done                   ║
// ╚══════════════════════════════════════════════════════════════════════╝
strategy(
     "ORB SESSIONS STRAT",
     overlay                         = true,
     initial_capital                 = 50000,
     currency                        = currency.USD,
     default_qty_type                = strategy.fixed,
     default_qty_value               = 1,
     pyramiding                      = 1,
     commission_type                 = strategy.commission.cash_per_contract,
     commission_value                = 1.2,
     slippage                        = 2,
     margin_long                     = 1,
     margin_short                    = 1,
     calc_on_every_tick              = true,
     calc_on_order_fills             = false,
     use_bar_magnifier               = true,
     process_orders_on_close         = true,
     backtest_fill_limits_assumption = 0,
     fill_orders_on_standard_ohlc    = false,
     max_lines_count                 = 500,
     max_labels_count                = 500,
     max_boxes_count                 = 500
)

// ════════════════════════════════════════════════════════════════════════════════
// GLOBAL SETTINGS
// ════════════════════════════════════════════════════════════════════════════════
grpGlobal = "Global Settings"
i_daysToShow  = input.int(10, "Days to Show", minval=1, maxval=50, group=grpGlobal, tooltip="Number of historical days of ORB levels, SL/TP lines, and trade events to display on the chart.")
i_timezone = input.string("America/Los_Angeles", "Timezone", options=["America/New_York", "America/Chicago", "America/Los_Angeles", "Europe/London", "Asia/Tokyo", "Asia/Hong_Kong", "Asia/Singapore", "Australia/Sydney", "UTC"], tooltip="All session times are interpreted in this timezone.", group=grpGlobal)

// ── Helpers ──
f_dayKey(_t, _tz) => year(_t, _tz) * 10000 + month(_t, _tz) * 100 + dayofmonth(_t, _tz)

// ── TP Quantity Split Helper (prevents 0-qty TPs when trading small size) ──
f_tpQty(_total, _p1, _p2, _p3) =>
    int total = math.max(0, int(math.round(_total)))
    float p1 = math.max(0.0, _p1)
    float p2 = math.max(0.0, _p2)
    float p3 = math.max(0.0, _p3)
    bool a1 = p1 > 0
    bool a2 = p2 > 0
    bool a3 = p3 > 0
    int active = (a1 ? 1 : 0) + (a2 ? 1 : 0) + (a3 ? 1 : 0)
    if total == 0
        [0, 0, 0]
    else if active == 0
        [total, 0, 0]
    else
        // Base allocation (floors)
        int q1 = a1 ? int(math.floor(total * (p1 / 100.0))) : 0
        int q2 = a2 ? int(math.floor(total * (p2 / 100.0))) : 0
        int q3 = a3 ? int(math.floor(total * (p3 / 100.0))) : 0

        // If we have enough contracts to give at least 1 to each active TP, do it.
        if total >= active
            if a1 and q1 == 0
                q1 := 1
            if a2 and q2 == 0
                q2 := 1
            if a3 and q3 == 0
                q3 := 1
        else
            // Not enough contracts to split: prioritize TP1 then TP2 then TP3
            q1 := a1 ? 1 : 0
            q2 := 0
            q3 := 0
            if q1 == 0 and a2
                q2 := 1
            if q1 == 0 and q2 == 0 and a3
                q3 := 1

        int sumQ = q1 + q2 + q3

        // If we over-allocated (can happen after min-1 forcing), trim from later TPs first.
        while sumQ > total
            if q3 > 0
                q3 -= 1
            else if q2 > 0
                q2 -= 1
            else if q1 > 0
                q1 -= 1
            sumQ := q1 + q2 + q3

        // Distribute remainder to earlier TPs by priority and pct weight.
        int rem = total - sumQ
        while rem > 0
            if a1
                q1 += 1
                rem -= 1
            if rem > 0 and a2
                q2 += 1
                rem -= 1
            if rem > 0 and a3
                q3 += 1
                rem -= 1

        [q1, q2, q3]

// ── Shared Trade Settings ──

// ── Day & Time Filters (Global) ──
grpFlat = "Prop Firm Flat Window"
i_flatWindowEnable = input.bool(true, "Enable Flat Window", tooltip="Flatten all positions and block new entries during this time window.", group=grpFlat)
i_flatWindowStart  = input.string("1300", "Flat Start (HHMM)", group=grpFlat, inline="flat", tooltip="Start of the flat window.")
i_flatWindowEnd    = input.string("1500", "Flat End (HHMM)", group=grpFlat, inline="flat", tooltip="End of the flat window.")

// Day filter check
f_dayAllowed(_sun, _mon, _tue, _wed, _thu, _fri, _sat) =>
    int dow = dayofweek(time, i_timezone)
    dow == dayofweek.sunday    ? _sun :
     dow == dayofweek.monday    ? _mon :
     dow == dayofweek.tuesday   ? _tue :
     dow == dayofweek.wednesday ? _wed :
     dow == dayofweek.thursday  ? _thu :
     dow == dayofweek.friday    ? _fri :
     dow == dayofweek.saturday  ? _sat : false


// Prop firm flat window check
_flatStartH = math.floor(str.tonumber(i_flatWindowStart) / 100)
_flatStartM = str.tonumber(i_flatWindowStart) % 100
_flatEndH   = math.floor(str.tonumber(i_flatWindowEnd) / 100)
_flatEndM   = str.tonumber(i_flatWindowEnd) % 100
_curH = hour(time, i_timezone)
_curM = minute(time, i_timezone)
_curTime = _curH * 60 + _curM
_flatStart = _flatStartH * 60 + _flatStartM
_flatEnd   = _flatEndH * 60 + _flatEndM
inFlatWindow = i_flatWindowEnable and (_flatStart < _flatEnd ? (_curTime >= _flatStart and _curTime < _flatEnd) : (_curTime >= _flatStart or _curTime < _flatEnd))
flatWindowJustStarted = inFlatWindow and not inFlatWindow[1]

// ── Trailing Stop Settings ──

// ── Re-Arm Settings ──
// ════════════════════════════════════════════════════════════════════════════════
// EMA TREND FILTER
// ════════════════════════════════════════════════════════════════════════════════
grpEMA = "EMA Trend Filter"
i_emaEnable      = input.bool(false, "Enable EMA Filter", group=grpEMA, tooltip="When enabled, only take longs above EMA and shorts below EMA.")
i_emaLength      = input.int(9, "EMA Length", minval=1, maxval=200, group=grpEMA, tooltip="Period for the EMA calculation.")
i_emaTF          = input.string("Chart", "EMA Timeframe", options=["Chart", "5 Min", "15 Min", "1 Hour", "4 Hour", "Daily"], group=grpEMA, tooltip="Timeframe to calculate the EMA on. Chart = current chart timeframe.")
i_emaSource      = input.source(close, "EMA Source", group=grpEMA, tooltip="Price source for EMA calculation.")
i_emaScope       = input.string("All Entries", "Filter Scope", options=["First Entry Only", "All Entries"], group=grpEMA, tooltip="First Entry Only: filter the initial breakout, re-arms ignore EMA.\nAll Entries: every entry must agree with EMA direction.")
i_nyEMAFilter    = input.bool(true, "NY: Use EMA Filter", group=grpEMA, inline="ema_sess", tooltip="Apply EMA filter to NY session entries.")
i_asEMAFilter    = input.bool(true, "AS: Use EMA Filter", group=grpEMA, inline="ema_sess", tooltip="Apply EMA filter to Asia session entries.")
i_lnEMAFilter    = input.bool(true, "LN: Use EMA Filter", group=grpEMA, inline="ema_sess", tooltip="Apply EMA filter to London session entries.")

// EMA visual settings
i_emaColorSmooth = input.int(3, "Color Smoothing", minval=1, maxval=20, group=grpEMA, display=display.none, tooltip="Smoothing period for EMA color gradient transition.")
i_emaShowGlow    = input.bool(true, "Show EMA Glow", group=grpEMA, display=display.none, tooltip="Display glowing halo effect around the EMA line.")
i_emaShowBG      = input.bool(false, "Show Trend Background", group=grpEMA, display=display.none, tooltip="Tint chart background based on EMA trend direction.")
i_emaBullBG      = input.color(color.new(#00ff88, 96), "Bull BG", group=grpEMA, display=display.none, inline="emabg")
i_emaBearBG      = input.color(color.new(#ff3366, 96), "Bear BG", group=grpEMA, display=display.none, inline="emabg")



// ════════════════════════════════════════════════════════════════════════════════
// EMA CALCULATION & VISUAL
// ════════════════════════════════════════════════════════════════════════════════

// Resolve timeframe string
f_emaTF() =>
    switch i_emaTF
        "Chart"  => timeframe.period
        "5 Min"  => "5"
        "15 Min" => "15"
        "1 Hour" => "60"
        "4 Hour" => "240"
        "Daily"  => "D"

// Calculate EMA (supports MTF via request.security)
_emaTFStr = f_emaTF()
_emaRaw = i_emaTF == "Chart" ? ta.ema(i_emaSource, i_emaLength) : request.security(syminfo.tickerid, _emaTFStr, ta.ema(close, i_emaLength), barmerge.gaps_off, barmerge.lookahead_off)
emaValue = _emaRaw

// EMA trend state
emaBullish = close > emaValue
emaBearish = close < emaValue

// EMA filter function — returns true if entry is allowed
f_emaAllowLong(_sessionUsesEMA, _isRearm) =>
    if not i_emaEnable or not _sessionUsesEMA
        true
    else if i_emaScope == "First Entry Only" and _isRearm
        true
    else
        emaBullish

f_emaAllowShort(_sessionUsesEMA, _isRearm) =>
    if not i_emaEnable or not _sessionUsesEMA
        true
    else if i_emaScope == "First Entry Only" and _isRearm
        true
    else
        emaBearish

// ── EMA Color Gradient (from BOSWaves style) ──
_emaChange = emaValue - nz(emaValue[1])
_emaAccel  = ta.ema(_emaChange, i_emaColorSmooth)

// Normalized tanh for color mapping
f_tanh(_x) =>
    _ex = math.exp(2 * _x)
    (_ex - 1) / (_ex + 1)

_accelNorm = f_tanh(_emaAccel / (ta.atr(14) * 0.01))
_hueRaw = 60 + _accelNorm * 60
_hue = na(_hueRaw[1]) ? _hueRaw : (_hueRaw + _hueRaw[1]) / 2

// HSV to RGB
f_hsv(_h, _s, _v) =>
    _c = _v * _s
    _x = _c * (1 - math.abs((_h / 60) % 2 - 1))
    _m = _v - _c
    _r = 0.0, _g = 0.0, _b = 0.0
    if _h < 60
        _r := _c, _g := _x
    else if _h < 120
        _r := _x, _g := _c
    else if _h < 180
        _g := _c, _b := _x
    else if _h < 240
        _g := _x, _b := _c
    else if _h < 300
        _r := _x, _b := _c
    else
        _r := _c, _b := _x
    color.rgb(int((_r + _m) * 255), int((_g + _m) * 255), int((_b + _m) * 255))

_emaColor = i_emaEnable ? f_hsv(_hue, 1.0, 1.0) : na

// ── EMA Glow Effect ──
_glowOff = ta.atr(14) * 0.25

_emaShow = i_emaEnable

_showGlow = _emaShow and i_emaShowGlow
_eg6p = plot(_showGlow ? emaValue + _glowOff * 6 : na, "EG6+", color.new(_emaColor, 97), 1, display=display.none, editable=false)
_eg5p = plot(_showGlow ? emaValue + _glowOff * 5 : na, "EG5+", color.new(_emaColor, 95), 1, display=display.none, editable=false)
_eg4p = plot(_showGlow ? emaValue + _glowOff * 4 : na, "EG4+", color.new(_emaColor, 92), 1, display=display.none, editable=false)
_eg3p = plot(_showGlow ? emaValue + _glowOff * 3 : na, "EG3+", color.new(_emaColor, 88), 1, display=display.none, editable=false)
_eg2p = plot(_showGlow ? emaValue + _glowOff * 2 : na, "EG2+", color.new(_emaColor, 83), 1, display=display.none, editable=false)
_eg1p = plot(_showGlow ? emaValue + _glowOff * 1 : na, "EG1+", color.new(_emaColor, 75), 1, display=display.none, editable=false)
_pEmaCore = plot(_emaShow ? emaValue : na, "EMA", _emaColor, 3, editable=false)
_eg1m = plot(_showGlow ? emaValue - _glowOff * 1 : na, "EG1-", color.new(_emaColor, 75), 1, display=display.none, editable=false)
_eg2m = plot(_showGlow ? emaValue - _glowOff * 2 : na, "EG2-", color.new(_emaColor, 83), 1, display=display.none, editable=false)
_eg3m = plot(_showGlow ? emaValue - _glowOff * 3 : na, "EG3-", color.new(_emaColor, 88), 1, display=display.none, editable=false)
_eg4m = plot(_showGlow ? emaValue - _glowOff * 4 : na, "EG4-", color.new(_emaColor, 92), 1, display=display.none, editable=false)
_eg5m = plot(_showGlow ? emaValue - _glowOff * 5 : na, "EG5-", color.new(_emaColor, 95), 1, display=display.none, editable=false)
_eg6m = plot(_showGlow ? emaValue - _glowOff * 6 : na, "EG6-", color.new(_emaColor, 97), 1, display=display.none, editable=false)

// Glow fills
fill(_eg6p, _eg5p, _showGlow ? color.new(_emaColor, 97) : na)
fill(_eg5p, _eg4p, _showGlow ? color.new(_emaColor, 95) : na)
fill(_eg4p, _eg3p, _showGlow ? color.new(_emaColor, 93) : na)
fill(_eg3p, _eg2p, _showGlow ? color.new(_emaColor, 90) : na)
fill(_eg2p, _eg1p, _showGlow ? color.new(_emaColor, 87) : na)
fill(_eg1p, _pEmaCore, _showGlow ? color.new(_emaColor, 80) : na)
fill(_pEmaCore, _eg1m, _showGlow ? color.new(_emaColor, 80) : na)
fill(_eg1m, _eg2m, _showGlow ? color.new(_emaColor, 87) : na)
fill(_eg2m, _eg3m, _showGlow ? color.new(_emaColor, 90) : na)
fill(_eg3m, _eg4m, _showGlow ? color.new(_emaColor, 93) : na)
fill(_eg4m, _eg5m, _showGlow ? color.new(_emaColor, 95) : na)
fill(_eg5m, _eg6m, _showGlow ? color.new(_emaColor, 97) : na)

// Background
bgcolor(i_emaEnable and i_emaShowBG and emaBullish ? i_emaBullBG : i_emaEnable and i_emaShowBG and emaBearish ? i_emaBearBG : na, title="EMA Trend BG")

// ════════════════════════════════════════════════════════════════════════════════
// SESSION 1: NEW YORK
// ════════════════════════════════════════════════════════════════════════════════
grpNY = "Session 1: New York ORB"
i_nyEnable     = input.bool(true, "Enable NY Session", group=grpNY, tooltip="Enable trading during the New York session.")
i_nyContracts      = input.int(3, "Contracts", minval=1, maxval=100, group=grpNY, tooltip="Contracts per trade entry.")
i_nyDirection  = input.string("Both", "Direction", options=["Long Only", "Short Only", "Both"], group=grpNY, tooltip="Only take long, short, or both directions for NY session entries.")
i_nyORBStart   = input.string("0630", "ORB Start (HHMM)", group=grpNY, tooltip="Time the Opening Range begins building (24h format, in your selected timezone).")
i_nyORBDur     = input.string("15 Min", "ORB Duration", options=["5 Min", "15 Min", "30 Min", "1 Hour", "Custom"], group=grpNY, tooltip="How long the Opening Range builds before completing. Candles during this window define the high/low of the ORB.")
i_nyORBEnd     = input.string("0645", "ORB Custom End (HHMM)", tooltip="Only used when Duration = Custom", group=grpNY, display=display.none)
i_nySessEnd    = input.string("1300", "Session End (HHMM)", tooltip="Go flat and reset at this time.", group=grpNY)
i_nyFlattenEOD = input.bool(true, "Flatten at Session End", group=grpNY, tooltip="Force close all positions when this session ends using a hard market order (EOS).")
i_nyEntryMode      = input.string("Breakout", "Entry Mode", options=["Breakout", "Retest Zone", "Retest Midpoint"], group=grpNY, tooltip="Breakout: enter on candle close through level.\nRetest Zone: wait for wick back to broken level.\nRetest Midpoint: wait for wick back to ORB midpoint.")
i_nyEntryBuffer    = input.int(0, "Entry Buffer (ticks)", minval=0, maxval=50, group=grpNY, tooltip="Ticks beyond ORB level for entry trigger.")
i_nyRetestTimeout  = input.int(20, "Retest Timeout (bars)", minval=3, maxval=100, group=grpNY, display=display.none, tooltip="Bars to wait for retest before signal expires.")
i_nySLMethod   = input.string("Opposite Side", "Stop Loss", options=["Midpoint", "Opposite Side", "Fixed Points"], group=grpNY, tooltip="Where to place the stop loss. Midpoint = ORB mid. Opposite Side = other ORB boundary. Fixed Points = custom distance.")
i_nySLPoints   = input.float(20.0, "SL Fixed Points", minval=0.25, step=0.25, group=grpNY, display=display.none, tooltip="Distance in points for stop loss when using Fixed Points mode.")
i_nyTP1RR      = input.float(1.0, "TP1 R:R", minval=0.1, step=0.1, group=grpNY, inline="nytp1", tooltip="Take Profit 1 as a multiple of the risk (distance to stop loss).")
i_nyTP1Qty     = input.int(1, "Qty", minval=1, maxval=100, group=grpNY, inline="nytp1", tooltip="Contracts to exit at TP1.")
i_nyTP2RR      = input.float(2.0, "TP2 R:R", minval=0.1, step=0.1, group=grpNY, inline="nytp2", tooltip="Take Profit 2 as a multiple of the risk. Set Qty to 0 to disable.")
i_nyTP2Qty     = input.int(1, "Qty", minval=0, maxval=100, group=grpNY, inline="nytp2", tooltip="Contracts to exit at TP2. 0 = disabled, remainder goes to TP3.")
i_nyTP3RR      = input.float(3.0, "TP3 R:R", minval=0.1, step=0.1, group=grpNY, inline="nytp3", tooltip="Take Profit 3 as a multiple of the risk. Set Qty to 0 to disable.")
i_nyTP3Qty     = input.int(1, "Qty", minval=0, maxval=100, group=grpNY, inline="nytp3", tooltip="Contracts to exit at TP3. 0 = auto-assign remaining contracts.")
i_nyTrailEnable    = input.bool(true, "Enable Staircase Stop", group=grpNY, tooltip="Staircase SL: TP1->entry, TP2->TP1, TP3->TP2.")
i_nyTrailShowLine  = input.bool(true, "Show Staircase Line", group=grpNY, display=display.none, tooltip="Display staircase stop line on chart.")
