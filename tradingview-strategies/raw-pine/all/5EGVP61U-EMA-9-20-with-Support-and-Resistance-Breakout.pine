//@version=5
strategy("EMA 9,20 with Support and Resistance Breakout v5", overlay=true,
     default_qty_type=strategy.percent_of_equity,
     default_qty_value=10,
     calc_on_every_tick=false,
     process_orders_on_close=true)

// ─── INPUTS ───────────────────────────────────────────────────────────────────
ema9_len    = input.int(9,      "EMA Fast")
ema20_len   = input.int(20,     "EMA Slow")
sr_lookback = input.int(20,     "S/R Lookback Bars")
target_pct  = input.float(12.0, "Target %",    step=0.5) / 100
sl_pct      = input.float(6.0,  "Stop Loss %", step=0.5) / 100

// ─── EMA ──────────────────────────────────────────────────────────────────────
ema9  = ta.ema(close, ema9_len)
ema20 = ta.ema(close, ema20_len)

plot(ema9,  "EMA 9",  color=color.orange, linewidth=2)
plot(ema20, "EMA 20", color=color.blue,   linewidth=2)

// ─── S/R PIVOT SEGMENTS ───────────────────────────────────────────────────────
ph = ta.pivothigh(high, sr_lookback, sr_lookback)
pl = ta.pivotlow(low,   sr_lookback, sr_lookback)

if not na(ph)
    line.new(bar_index[sr_lookback] - 4, ph,
             bar_index[sr_lookback] + 4, ph,
             color=color.red, style=line.style_dotted, width=2)

if not na(pl)
    line.new(bar_index[sr_lookback] - 4, pl,
             bar_index[sr_lookback] + 4, pl,
             color=color.green, style=line.style_dotted, width=2)

// ─── CANDLE BODY FILTER (relaxed to 0.3) ─────────────────────────────────────
candle_range  = high - low
candle_body   = math.abs(close - open)
strong_candle = candle_range > 0 and (candle_body / candle_range) >= 0.3

// ─── CORE CONDITIONS ──────────────────────────────────────────────────────────
// BUY  : EMA9 crosses above EMA20  +  close above EMA9  +  strong candle
// SELL : EMA9 crosses below EMA20  +  close below EMA9  +  strong candle

ema_cross_up   = ta.crossover(ema9, ema20)
ema_cross_down = ta.crossunder(ema9, ema20)

buy_condition  = ema_cross_up   and close > ema9 and strong_candle
sell_condition = ema_cross_down and close < ema9 and strong_candle

// ─── POSITION STATE ───────────────────────────────────────────────────────────
flat     = strategy.position_size == 0
in_long  = strategy.position_size > 0
in_short = strategy.position_size < 0

// ─── ENTRIES ──────────────────────────────────────────────────────────────────
if buy_condition and flat
    strategy.entry("Long", strategy.long)

if sell_condition and flat
    strategy.entry("Short", strategy.short)

// ─── EXITS ────────────────────────────────────────────────────────────────────
if in_long
    strategy.exit("Long Exit", "Long",
         limit          = strategy.position_avg_price * (1 + target_pct),
         stop           = strategy.position_avg_price * (1 - sl_pct),
         comment_profit = "TP +12%",
         comment_loss   = "SL -6%")

if in_short
    strategy.exit("Short Exit", "Short",
         limit          = strategy.position_avg_price * (1 - target_pct),
         stop           = strategy.position_avg_price * (1 + sl_pct),
         comment_profit = "TP +12%",
         comment_loss   = "SL -6%")

// ─── ENTRY ARROWS ─────────────────────────────────────────────────────────────
plotshape(buy_condition  and flat, title="BUY",
     location=location.belowbar, style=shape.triangleup,
     color=color.green, size=size.normal, text="BUY")

plotshape(sell_condition and flat, title="SELL",
     location=location.abovebar, style=shape.triangledown,
     color=color.red, size=size.normal, text="SELL")

