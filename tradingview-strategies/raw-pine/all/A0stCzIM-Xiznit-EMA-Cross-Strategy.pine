//@version=6
// This source code is subject to the terms of the Mozilla Public License 2.0 at https://mozilla.org/MPL/2.0/
// This strategy has been created for illustration purposes only and should not be relied upon as a basis for buying, selling, or holding any asset or security.
// © kirilov (enhanced by Grok) — Xiznit EMA Cross Strategy

strategy(
     "Xiznit EMA Cross Strategy",
     overlay=true,
     calc_on_every_tick=true,
     currency=currency.USD
     )

// INPUTS:

// EMA Inputs
emaFast = input.int(title="Fast EMA", defval=10, minval=1, maxval=9999)
emaSlow = input.int(title="Slow EMA", defval=20, minval=1, maxval=9999)

// Trade Direction
tradeDirection = input.string(title="Trade Direction", options=["Long", "Short", "Both"], defval="Both")

// ADX/DMI Inputs
adxLen = input.int(title="ADX/DMI Length", defval=14, minval=1)
adxThresh = input.float(title="ADX Threshold", defval=25.0, minval=0.0, step=0.1)

// Volume Surge Inputs
volLen = input.int(title="Volume SMA Length", defval=20, minval=1)
volMult = input.float(title="Volume Multiplier", defval=1.5, minval=1.0, step=0.1)

// Trailing Stop and Risk Management Inputs
atrLen = input.int(title="ATR Length", defval=14, minval=1)
trailMult = input.float(title="Trailing ATR Multiplier (Chandelier)", defval=3.0, minval=0.1, step=0.1)
slMult = input.float(title="Initial SL ATR Multiplier", defval=1.5, minval=0.1, step=0.1)
rr = input.float(title="RR for BE Move", defval=1.0, minval=0.1, step=0.1)

// CALCULATIONS:

// EMAs
fastEMA = ta.ema(close, emaFast)
slowEMA = ta.ema(close, emaSlow)

// ADX and DMI (same length for DI and ADX smoothing)
[diplus, diminus, adxVal] = ta.dmi(adxLen, adxLen)

// Volume SMA
volSMA = ta.sma(volume, volLen)

// ATR
atrVal = ta.atr(atrLen)

// CONDITIONS:

// Trade Direction Permissions
longOK  = (tradeDirection == "Long") or (tradeDirection == "Both")
shortOK = (tradeDirection == "Short") or (tradeDirection == "Both")

// Raw EMA Cross Conditions
longCross = ta.crossover(fastEMA, slowEMA)
shortCross = ta.crossunder(fastEMA, slowEMA)

// Enhanced Filters
longFilter = (adxVal > adxThresh) and (diplus > diminus) and (volume > volSMA * volMult)
shortFilter = (adxVal > adxThresh) and (diminus > diplus) and (volume > volSMA * volMult)

// Full entry conditions
longEntry = longCross and longFilter and longOK
shortEntry = shortCross and shortFilter and shortOK

// POSITION TRACKING VARIABLES
var float entryPrice = na
var float initialSL = na
var float trailStop = na
var bool beTriggered = false
var line trailLine = na
var line initialSLLine = na
var int slLineBars = 10  // Display initial SL for 10 bars
var int slLineCounter = 0

// ENTRY LOGIC

if (longEntry)
    strategy.entry(id="long", direction=strategy.long)
    entryPrice := close
    initialSL := close - atrVal * slMult
    trailStop := high - atrVal * trailMult  // Initial Chandelier for long
    beTriggered := false
    
    // Reset Trail Line
    if not na(trailLine)
        line.delete(trailLine)
    trailLine := line.new(bar_index - 1, trailStop, bar_index, trailStop, color=color.new(color.green, 50), width=2, style=line.style_dashed)
    
    // Initial SL Line
    if not na(initialSLLine)
        line.delete(initialSLLine)
    initialSLLine := line.new(bar_index, initialSL, bar_index + slLineBars, initialSL, color=color.red, width=1, style=line.style_dashed)
    slLineCounter := slLineBars

if (shortEntry)
    strategy.entry(id="short", direction=strategy.short)
    entryPrice := close
    initialSL := close + atrVal * slMult
    trailStop := low + atrVal * trailMult  // Initial Chandelier for short
    beTriggered := false
    
    // Reset Trail Line
    if not na(trailLine)
        line.delete(trailLine)
    trailLine := line.new(bar_index - 1, trailStop, bar_index, trailStop, color=color.new(color.red, 50), width=2, style=line.style_dashed)
    
    // Initial SL Line
    if not na(initialSLLine)
        line.delete(initialSLLine)
    initialSLLine := line.new(bar_index, initialSL, bar_index + slLineBars, initialSL, color=color.red, width=1, style=line.style_dashed)
    slLineCounter := slLineBars

// POSITION MANAGEMENT (Trailing Stop, BE Move, Exit)

if (strategy.position_size > 0)  // In Long Position
    // Update Chandelier Trail (move up only)
    trailStop := math.max(trailStop, high - atrVal * trailMult)
    
    // Check for BE Move (to exact entry price)
    float risk = entryPrice - initialSL
    float profit = close - entryPrice
    if (not beTriggered and profit >= risk * rr)
        initialSL := entryPrice
        trailStop := math.max(trailStop, initialSL)
        beTriggered := true
        // No label here anymore
        line.set_color(trailLine, color.new(color.lime, 30))  // Brighter post-BE
        line.set_width(trailLine, 3)  // Thicker post-BE
        line.set_style(trailLine, line.style_solid)  // Solid post-BE
    
    // Update Trail Line
    line.set_xy2(trailLine, bar_index, trailStop)
    line.set_xy1(trailLine, bar_index - 1, line.get_y2(trailLine[1]))
    
    // Exit if Breached
    if (close < trailStop)
        strategy.close(id="long")
        line.delete(trailLine)
        trailLine := na
        if not na(initialSLLine)
            line.delete(initialSLLine)
            initialSLLine := na
    
    // Manage Initial SL Line Duration
    if (slLineCounter > 0)
        slLineCounter -= 1
        line.set_x2(initialSLLine, bar_index + slLineCounter)
    else if not na(initialSLLine)
        line.delete(initialSLLine)
        initialSLLine := na

if (strategy.position_size < 0)  // In Short Position
    // Update Chandelier Trail (move down only)
    trailStop := math.min(trailStop, low + atrVal * trailMult)
    
    // Check for BE Move (to exact entry price)
    float risk = initialSL - entryPrice
    float profit = entryPrice - close
    if (not beTriggered and profit >= risk * rr)
        initialSL := entryPrice
        trailStop := math.min(trailStop, initialSL)
        beTriggered := true
        // No label here anymore
        line.set_color(trailLine, color.new(color.fuchsia, 30))  // Brighter post-BE
        line.set_width(trailLine, 3)  // Thicker post-BE
        line.set_style(trailLine, line.style_solid)  // Solid post-BE
    
    // Update Trail Line
    line.set_xy2(trailLine, bar_index, trailStop)
    line.set_xy1(trailLine, bar_index - 1, line.get_y2(trailLine[1]))
    
    // Exit if Breached
    if (close > trailStop)
        strategy.close(id="short")
        line.delete(trailLine)
        trailLine := na
        if not na(initialSLLine)
            line.delete(initialSLLine)
            initialSLLine := na
    
    // Manage Initial SL Line Duration
    if (slLineCounter > 0)
        slLineCounter -= 1
        line.set_x2(initialSLLine, bar_index + slLineCounter)
    else if not na(initialSLLine)
        line.delete(initialSLLine)
        initialSLLine := na

// PLOTS & VISUALS

// EMAs on Chart
plot(fastEMA, title="Fast EMA", color=color.orange, linewidth=2)
plot(slowEMA, title="Slow EMA", color=color.blue, linewidth=2)

// ADX/DMI Overlaid
plot(adxVal, title="ADX", color=color.purple, linewidth=1)
plot(diplus, title="+DI", color=color.green, linewidth=1)
plot(diminus, title="-DI", color=color.red, linewidth=1)
hline(adxThresh, title="ADX Threshold", color=color.red, linestyle=hline.style_dashed)

// DI Cross Markers
plotshape(ta.crossover(diplus, diminus), title="+DI > -DI Cross", style=shape.diamond, location=location.absolute, color=color.green, size=size.tiny)
plotshape(ta.crossunder(diplus, diminus), title="-DI > +DI Cross", style=shape.diamond, location=location.absolute, color=color.red, size=size.tiny)

// Entry Shapes
plotshape(longEntry, title="Long Entry", style=shape.triangleup, location=location.belowbar, color=color.green, size=size.small)
plotshape(shortEntry, title="Short Entry", style=shape.triangledown, location=location.abovebar, color=color.red, size=size.small)

// Background Fill for ADX Condition
bgcolor(adxVal > adxThresh ? color.new(color.green, 90) : color.new(color.gray, 90), title="ADX Trend Background")

View in Pine Editor・214 lines
