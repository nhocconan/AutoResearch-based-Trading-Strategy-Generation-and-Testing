//@version=4
strategy("Swing Parabolic SAR Strategy", overlay=true)
start = input(0.02)
increment = input(0.02)
maximum = input(0.2)
var bool uptrend = na
var float EP = na
var float SAR = na
var float AF = start
var float nextBarSAR = na

//MONEY MANAGEMENT--------------------------------------------------------------
balance = strategy.netprofit + strategy.initial_capital //current balance
floating = strategy.openprofit          //floating profit/loss
risk = input(1,type=input.float,title="Risk %")/100           //risk % per trade

if bar_index > 0
    firstTrendBar = false
    SAR := nextBarSAR
    if bar_index == 1
        float prevSAR = na
        float prevEP = na
        lowPrev = low[1]
        highPrev = high[1]
        closeCur = close
        closePrev = close[1]
        if closeCur > closePrev
            uptrend := true
            EP := high
            prevSAR := lowPrev
            prevEP := high
        else
            uptrend := false
            EP := low
            prevSAR := highPrev
            prevEP := low
        firstTrendBar := true
        SAR := prevSAR + start * (prevEP - prevSAR)
    if uptrend
        if SAR > low
            firstTrendBar := true
            uptrend := false
            SAR := max(EP, high)
            EP := low
            AF := start
    else
        if SAR < high
            firstTrendBar := true
            uptrend := true
            SAR := min(EP, low)
            EP := high
            AF := start
    if not firstTrendBar
        if uptrend
            if high > EP
                EP := high
                AF := min(AF + increment, maximum)
        else
            if low < EP
                EP := low
                AF := min(AF + increment, maximum)
    if uptrend
        SAR := min(SAR, low[1])
        if bar_index > 1
            SAR := min(SAR, low[2])
    else
        SAR := max(SAR, high[1])
        if bar_index > 1
            SAR := max(SAR, high[2])
    nextBarSAR := SAR + AF * (EP - SAR)
    if barstate.isconfirmed
        if uptrend
            //dataL = (close-SAR)*100000
            dataS = (SAR-close)*1000
            
                //Calculate the size of the next trade
            temp01 = balance * risk     //Risk in USD
            temp02 = temp01/dataS        //Risk in lots
            temp03 = temp02*100000      //Convert to contracts
            size = temp03 - temp03%1000 //Normalize to 1000s (Trade size)
            if(size < 1000)
                size := 1000           //Set min. lot size
            strategy.entry("short", strategy.short,size, stop=nextBarSAR, comment="short")
            //strategy.exit("tp/sl short","short",stop=dataS)
            strategy.cancel("long")
        else
            dataL = (close-SAR)*1000
            //dataS = (SAR-close)*100000
            
                //Calculate the size of the next trade
            temp01 = balance * risk     //Risk in USD
            temp02 = temp01/dataL        //Risk in lots
            temp03 = temp02*100000      //Convert to contracts
            size = temp03 - temp03%1000 //Normalize to 1000s (Trade size)
            if(size < 1000)
                size := 1000           //Set min. lot size
            strategy.entry("long", strategy.long,size, stop=nextBarSAR, comment="long")
            //strategy.exit("tp/sl LONG","long",stop=dataL)
            strategy.cancel("short")
            
plot(SAR, style=plot.style_cross, linewidth=3, color=color.orange)
plot(nextBarSAR, style=plot.style_cross, linewidth=3, color=color.aqua)

