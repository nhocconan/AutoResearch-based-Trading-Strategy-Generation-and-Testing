//@version=6
strategy(
    "gen_kama_direction_awesome_osc_keltner_squeeze_1d_v1 [Independent Conversion]",
    overlay = true,
    initial_capital = 10000,
    pyramiding = 0,
    calc_on_every_tick = false,
    process_orders_on_close = false,
    commission_type = strategy.commission.percent,
    commission_value = 0.05,
    default_qty_type = strategy.fixed,
    default_qty_value = 0,
    margin_long = 100,
    margin_short = 100
)

float sizeFraction = input.float(0.25, "Position Size Fraction", minval = 0.0, maxval = 1.0, step = 0.01)
int atrLength = input.int(14, "ATR Stop Length", minval = 1)
float atrStopMultiplier = input.float(2.5, "ATR Stop Multiplier", minval = 0.1, step = 0.1)
int warmupBars = input.int(100, "Warmup Bars", minval = 1)
int kamaLookback = input.int(10, "KAMA Efficiency Length", minval = 1)
float kamaFastAlpha = input.float(2.0 / 3.0, "KAMA Fast Alpha", minval = 0.0001, step = 0.0001)
float kamaSlowAlpha = input.float(2.0 / 31.0, "KAMA Slow Alpha", minval = 0.0001, step = 0.0001)
int aoFastLength = input.int(5, "AO Fast Length", minval = 1)
int aoSlowLength = input.int(34, "AO Slow Length", minval = 1)
int kcLength = input.int(20, "Keltner Length", minval = 1)
float kcMultiplier = input.float(1.5, "Keltner Multiplier", minval = 0.1, step = 0.1)
int bbLength = input.int(20, "Bollinger Length", minval = 1)
float bbMultiplier = input.float(2.0, "Bollinger Multiplier", minval = 0.1, step = 0.1)

if barstate.isfirst and (not timeframe.isdaily or timeframe.multiplier != 1)
    runtime.error("Use this script on a 1D chart. It is a direct conversion of gen_kama_direction_awesome_osc_keltner_squeeze_1d_v1.")

f_round_qty(_qty) =>
    float step = syminfo.mincontract > 0 ? syminfo.mincontract : 0.000001
    float rounded = math.floor(_qty / step) * step
    rounded >= step ? rounded : step

float tr = bar_index == 0 ? 0.0 : math.max(high - low, math.max(math.abs(high - close[1]), math.abs(low - close[1])))
float atrStopRaw = ta.sma(tr, atrLength)
float atrStop = bar_index >= atrLength - 1 ? atrStopRaw : na

float volatilityK = 0.0
if bar_index >= kamaLookback
    for j = 0 to kamaLookback - 1
        volatilityK += math.abs(close[j] - close[j + 1])
float directionK = bar_index >= kamaLookback ? math.abs(close - close[kamaLookback]) : 0.0
float er = volatilityK > 0 ? directionK / volatilityK : 0.0
float sc = math.pow(er * (kamaFastAlpha - kamaSlowAlpha) + kamaSlowAlpha, 2)
var float kama = na
if bar_index == kamaLookback
    kama := close
else if bar_index > kamaLookback
    float prevKama = nz(kama[1], close)
    kama := prevKama + sc * (close - prevKama)
else
    kama := na
float trend = 0.0
if bar_index >= kamaLookback + 2 and not na(kama) and not na(kama[1])
    if close > kama and kama > kama[1]
        trend := 1.0
    else if close < kama and kama < kama[1]
        trend := -1.0

float aoBasis = (high + low) / 2.0
float aoFast = ta.sma(aoBasis, aoFastLength)
float aoSlow = ta.sma(aoBasis, aoSlowLength)
float aoValue = aoFast - aoSlow
bool entryOkLong = not na(aoValue) and aoValue > 0 and (bar_index < 1 or aoValue > aoValue[1])
bool entryOkShort = not na(aoValue) and aoValue < 0 and (bar_index < 1 or aoValue < aoValue[1])

float kcMidRaw = ta.ema(close, kcLength)
float kcMid = bar_index >= kcLength - 1 ? kcMidRaw : na
float kcAtr = ta.sma(tr, kcLength)
float kcUpper = not na(kcMid) and not na(kcAtr) ? kcMid + kcMultiplier * kcAtr : na
float bbMid = ta.sma(close, bbLength)
float bbStd = ta.stdev(close, bbLength)
float bbUpper = not na(bbMid) and not na(bbStd) ? bbMid + bbMultiplier * bbStd : na
bool regimeOk = not na(kcUpper) and not na(bbUpper) and bbUpper < kcUpper

// Keep an internal entry reference at the signal bar close to mirror the Python state machine.
var int modelState = 0
var float modelEntryPrice = na

float activeSignal = sizeFraction * modelState
float stopLineLong = modelState == 1 and not na(modelEntryPrice) and not na(atrStop) ? modelEntryPrice - atrStopMultiplier * atrStop : na
float stopLineShort = modelState == -1 and not na(modelEntryPrice) and not na(atrStop) ? modelEntryPrice + atrStopMultiplier * atrStop : na

if barstate.isconfirmed
    int prevState = modelState
    float nextEntryPrice = modelEntryPrice
    int nextState = prevState

    if bar_index < warmupBars or na(atrStop) or atrStop == 0
        nextState := 0
        nextEntryPrice := na
    else if prevState != 0
        bool longStopHit = prevState == 1 and close < modelEntryPrice - atrStopMultiplier * atrStop
        bool shortStopHit = prevState == -1 and close > modelEntryPrice + atrStopMultiplier * atrStop
        bool longTrendExit = prevState == 1 and trend < 0
        bool shortTrendExit = prevState == -1 and trend > 0
        if longStopHit or shortStopHit or longTrendExit or shortTrendExit
            nextState := 0
            nextEntryPrice := na
    else
        if regimeOk and trend > 0 and entryOkLong
            nextState := 1
            nextEntryPrice := close
        else if regimeOk and trend < 0 and entryOkShort
            nextState := -1
            nextEntryPrice := close

    bool signalChanged = nextState != prevState
    float rawQty = close > 0 ? (strategy.equity * sizeFraction) / close : 0.0
    float entryQty = rawQty > 0 ? f_round_qty(rawQty) : 0.0

    if signalChanged
        if prevState == 1
            strategy.close("Long", comment = "Long Exit")
        if prevState == -1
            strategy.close("Short", comment = "Short Exit")
        if nextState == 1 and entryQty > 0
            strategy.entry("Long", strategy.long, qty = entryQty, comment = "Long Entry")
        if nextState == -1 and entryQty > 0
            strategy.entry("Short", strategy.short, qty = entryQty, comment = "Short Entry")

    modelState := nextState
    modelEntryPrice := nextEntryPrice
    activeSignal := sizeFraction * modelState
    stopLineLong := modelState == 1 and not na(modelEntryPrice) and not na(atrStop) ? modelEntryPrice - atrStopMultiplier * atrStop : na
    stopLineShort := modelState == -1 and not na(modelEntryPrice) and not na(atrStop) ? modelEntryPrice + atrStopMultiplier * atrStop : na

plot(stopLineLong, "Long Stop", color = color.new(color.red, 0), style = plot.style_linebr)
plot(stopLineShort, "Short Stop", color = color.new(color.green, 0), style = plot.style_linebr)
plotchar(activeSignal > 0, "Long Bias", "L", location.top, color = color.lime)
plotchar(activeSignal < 0, "Short Bias", "S", location.bottom, color = color.red)
